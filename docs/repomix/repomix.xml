566:     def estimate_cost_for_files(self, file_count: int, features: Optional[List[str]] = None) -> Dict[str, Any]:
567:         """
568:         Estimate cost for processing a given number of files.
569: 
570:         Args:
571:             file_count: Number of files to estimate
572:             features: List of features to use (None for all)
573: 
574:         Returns:
575:             Cost estimate breakdown
576:         """
577:         features = features or list(self.cost_configs.keys())
578:         estimates = {}
579:         total_cost = 0.0
580:         total_time = 0.0
581:         total_value = 0.0
582: 
583:         for feature_name in features:
584:             config = self.cost_configs.get(feature_name)
585:             if not config:
586:                 continue
587: 
588:             # Estimate cost
589:             cost = file_count * config.cost_per_unit
590:             time_sec = file_count * config.avg_processing_time_sec
591: 
592:             # Estimate value
593:             files_classified = file_count * config.files_correctly_classified * config.success_rate
594:             value = (files_classified * config.manual_time_saved_sec / 3600) * self.MANUAL_HOURLY_RATE
595: 
596:             estimates[feature_name] = {
597:                 'estimated_cost': cost,
598:                 'estimated_time_sec': time_sec,
599:                 'estimated_time_human': self._format_duration(time_sec),
600:                 'estimated_value': value,
601:                 'estimated_roi': ((value - cost) / cost * 100) if cost > 0 else float('inf')
602:             }
603: 
604:             total_cost += cost
605:             total_time += time_sec
606:             total_value += value
607: 
608:         return {
609:             'file_count': file_count,
610:             'total_estimated_cost': total_cost,
611:             'total_estimated_time_sec': total_time,
612:             'total_estimated_time_human': self._format_duration(total_time),
613:             'total_estimated_value': total_value,
614:             'estimated_roi': ((total_value - total_cost) / total_cost * 100) if total_cost > 0 else float('inf'),
615:             'feature_estimates': estimates
616:         }
