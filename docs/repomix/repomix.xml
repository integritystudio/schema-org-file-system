3368:     def get_destination_path(self, file_path: Path, category: str, subcategory: str, company_name: Optional[str] = None, image_metadata: Optional[Dict] = None, people_names: Optional[List[str]] = None) -> Path:
3369:         """
3370:         Get the destination path for a file based on content category.
3371: 
3372:         Args:
3373:             file_path: Path to the file
3374:             category: Main category
3375:             subcategory: Subcategory
3376:             company_name: Optional company name for business/organization files
3377:             image_metadata: Optional metadata for images (datetime, location)
3378:             people_names: Optional list of people names for person-classified files
3379: 
3380:         Returns:
3381:             Destination path for the file
3382:         """
3383:         # Special handling for filepath-based classification
3384:         if category == 'filepath':
3385:             # subcategory contains the full path (e.g., "Technical/Python/MyProject")
3386:             relative_path = subcategory
3387:         # Special handling for media files with nested structure
3388:         elif category == 'media' and '_' in subcategory:
3389:             # subcategory format: "media_type_subcategory" (e.g., "photos_screenshots")
3390:             parts = subcategory.split('_', 1)  # Split into at most 2 parts
3391:             if len(parts) == 2:
3392:                 media_type, media_subcat = parts
3393:                 if media_type in self.category_paths['media']:
3394:                     media_dict = self.category_paths['media'][media_type]
3395:                     if isinstance(media_dict, dict):
3396:                         relative_path = media_dict.get(media_subcat, media_dict.get('other', f'Media/{media_type.capitalize()}/Other'))
3397:                     else:
3398:                         relative_path = media_dict
3399:                 else:
3400:                     relative_path = 'Media/Other'
3401:             else:
3402:                 relative_path = 'Media/Other'
3403:         elif category in self.category_paths:
3404:             if isinstance(self.category_paths[category], dict):
3405:                 if subcategory in self.category_paths[category]:
3406:                     relative_path = self.category_paths[category][subcategory]
3407:                 else:
3408:                     relative_path = self.category_paths[category].get('other', f'{category.capitalize()}/Other')
3409:             else:
3410:                 relative_path = self.category_paths[category]
3411:         else:
3412:             relative_path = 'Uncategorized'
3413: 
3414:         # Organization: Create entity-named subfolders under Organization/
3415:         # Structure: Organization/{OrgName}/ for most types
3416:         # Exception: Organization/Clients/{OrgName}/ for clients (nested subfolders)
3417:         if category == 'organization' and company_name:
3418:             sanitized_company = self.classifier.sanitize_company_name(company_name)
3419:             # Only create company subfolder if name is valid (not a sentence fragment)
3420:             if sanitized_company:
3421:                 if subcategory == 'clients':
3422:                     # Clients get nested: Organization/Clients/{OrgName}/
3423:                     relative_path = f"{relative_path}/{sanitized_company}"
3424:                 elif subcategory == 'meeting_notes':
3425:                     # Meeting notes get nested: Organization/{OrgName}/Meeting Notes/
3426:                     relative_path = f"{relative_path}/{sanitized_company}/Meeting Notes"
3427:                 else:
3428:                     # All other org types: Organization/{OrgName}/
3429:                     relative_path = f"{relative_path}/{sanitized_company}"
3430: 
3431:         # Person: Create person-named subfolders under Person/
3432:         # Structure: Person/{PersonName}/ for all types
3433:         if category == 'person' and people_names:
3434:             # Use first person name as the folder name
3435:             person_name = people_names[0] if people_names else 'Unknown'
3436:             sanitized_person = self.classifier.sanitize_company_name(person_name)
3437:             # Only create person subfolder if name is valid
3438:             if sanitized_person:
3439:                 relative_path = f"{relative_path}/{sanitized_person}"
3440:             else:
3441:                 relative_path = f"{relative_path}/Unknown"
3442:         elif category == 'person' and not people_names:
3443:             # Fallback for person category without extracted names
3444:             relative_path = f"{relative_path}/Unknown"
3445: 
3446:         # Legacy: client files from business category with company name
3447:         if category == 'business' and subcategory == 'clients' and company_name:
3448:             sanitized_company = self.classifier.sanitize_company_name(company_name)
3449:             # Only create company subfolder if name is valid
3450:             if sanitized_company:
3451:                 relative_path = f"{relative_path}/{sanitized_company}"
3452: 
3453:         # Date-based organization for images (if enabled and metadata available)
3454:         if self.organize_by_date and image_metadata and image_metadata.get('year'):
3455:             year = image_metadata['year']
3456:             month = image_metadata['month']
3457:             relative_path = f"Photos/{year}/{month:02d}"
3458: 
3459:         # Location-based organization for images (if enabled and location available)
3460:         elif self.organize_by_location and image_metadata and image_metadata.get('location_name'):
3461:             # Clean location name for folder
3462:             location = image_metadata['location_name']
3463:             # Take first part (usually city)
3464:             city = location.split(',')[0].strip()
3465:             # Sanitize for folder name
3466:             safe_city = re.sub(r'[<>:"/\\|?*]', '', city)
3467:             relative_path = f"Photos/Locations/{safe_city}"
3468: 
3469:         dest_dir = self.base_path / relative_path
3470:         dest_dir.mkdir(parents=True, exist_ok=True)
3471: 
3472:         # Handle duplicate filenames
3473:         dest_path = dest_dir / file_path.name
3474:         if dest_path.exists() and dest_path != file_path:
3475:             stem = file_path.stem
3476:             suffix = file_path.suffix
3477:             timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
3478:             dest_path = dest_dir / f"{stem}_{timestamp}{suffix}"
3479: 
3480:         return dest_path
3481: 
3482:     def should_skip_file(self, file_path: Path) -> bool:
3483:         """Check if file should be skipped."""
3484:         skip_files = {'.DS_Store', '.localized', 'Thumbs.db', 'desktop.ini'}
3485:         skip_dirs = {'__pycache__', '.git', 'node_modules', '.venv', 'venv'}
3486: 
3487:         if file_path.name.startswith('.') and file_path.name not in {'.gitignore', '.env.example'}:
3488:             return True
3489: 
3490:         if file_path.name in skip_files:
3491:             return True
3492: 
3493:         if any(skip_dir in file_path.parts for skip_dir in skip_dirs):
3494:             return True
3495: 
3496:         return False
