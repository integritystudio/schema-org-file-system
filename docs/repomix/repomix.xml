 257:     def get_or_create_category(
 258:         self,
 259:         name: str,
 260:         parent_name: str = None,
 261:         session: Session = None
 262:     ) -> Optional[Category]:
 263:         """
 264:         Get or create a category.
 265: 
 266:         Args:
 267:             name: Category name
 268:             parent_name: Parent category name (for hierarchy)
 269:             session: Optional existing session
 270: 
 271:         Returns:
 272:             Category object or None if creation fails
 273:         """
 274:         close_session = session is None
 275:         session = session or self.get_session()
 276: 
 277:         try:
 278:             # Build full path
 279:             if parent_name:
 280:                 full_path = f"{parent_name}/{name}"
 281:             else:
 282:                 full_path = name
 283: 
 284:             # Check if exists
 285:             category = session.query(Category).filter(Category.full_path == full_path).first()
 286:             if category:
 287:                 return category
 288: 
 289:             # Get parent if specified
 290:             parent = None
 291:             level = 0
 292:             if parent_name:
 293:                 parent = session.query(Category).filter(Category.name == parent_name).first()
 294:                 if parent:
 295:                     level = parent.level + 1
 296: 
 297:             # Create new category with canonical ID
 298:             category = Category(
 299:                 name=name,
 300:                 canonical_id=Category.generate_canonical_id(full_path),
 301:                 parent_id=parent.id if parent else None,
 302:                 level=level,
 303:                 full_path=full_path
 304:             )
 305:             session.add(category)
 306:             # Only commit if we own the session
 307:             if close_session:
 308:                 session.commit()
 309:             else:
 310:                 session.flush()  # Ensure ID is generated but don't commit
 311:             return category
 312: 
 313:         except IntegrityError:
 314:             session.rollback()
 315:             # Race condition - return existing
 316:             return session.query(Category).filter(Category.full_path == full_path).first()
 317:         finally:
 318:             if close_session:
 319:                 session.close()
