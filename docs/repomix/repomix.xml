308:     def _classify_game_asset(self, file_path: Path, file_name: str, file_ext: str) -> Optional[Tuple[str, str, str]]:
309:         """
310:         Classify file as a game asset based on filename patterns.
311: 
312:         Returns:
313:             Tuple of (category, subcategory, schema_type) or None if not a game asset
314:         """
315:         import re
316: 
317:         # Only check image and audio files
318:         if file_ext not in ['.png', '.jpg', '.jpeg', '.bmp', '.tga', '.dds',
319:                            '.wav', '.ogg', '.mp3', '.flac', '.aac']:
320:             return None
321: 
322:         stem = file_path.stem.lower()
323: 
324:         # Remove timestamp suffixes for pattern matching (e.g., _20251120_164506)
325:         clean_stem = re.sub(r'_\d{8}_\d{6}$', '', stem)
326: 
327:         # Check for image files that are game sprites/textures
328:         if file_ext in ['.png', '.jpg', '.jpeg', '.bmp', '.tga', '.dds']:
329:             # Check for game font sprite sheets first
330:             for keyword in self.game_font_keywords:
331:                 if keyword in stem or keyword in clean_stem:
332:                     return ('game_assets', 'fonts', 'ImageObject')
333: 
334:             # Check regex patterns for numbered sprites and variants
335:             for pattern in self.game_sprite_patterns:
336:                 if pattern.match(clean_stem):
337:                     return ('game_assets', 'sprites', 'ImageObject')
338: 
339:             # Check for sprite/texture keyword patterns
340:             for keyword in self.game_sprite_keywords:
341:                 if keyword in stem or keyword in clean_stem:
342:                     # Distinguish between sprites and textures
343:                     sprite_keywords = [
344:                         'frame', 'sprite', 'leg', 'arm', 'head', 'torso', 'body',
345:                         'wing', 'hair', 'face', 'mouth', '_grey', '_gray',
346:                         'assassins', 'atonement', 'arrow_v', 'arrow_h', 'add',
347:                         '2h_', '1h_', 'dagger', 'sword', 'axe', 'hammer', 'mace'
348:                     ]
349:                     if any(kw in stem or kw in clean_stem for kw in sprite_keywords):
350:                         return ('game_assets', 'sprites', 'ImageObject')
351:                     else:
352:                         return ('game_assets', 'textures', 'ImageObject')
353: 
354:         return None
