288: class ScreenshotOrganizer:
289:     """Organizes screenshots by renaming and categorizing them."""
290: 
291:     def __init__(self, source_dir: Path, output_dir: Path = None, dry_run: bool = True):
292:         self.source_dir = Path(source_dir)
293:         self.output_dir = output_dir or self.source_dir
294:         self.dry_run = dry_run
295:         self.analyzer = ScreenshotAnalyzer()
296:         self.results = []
297:         self.stats = defaultdict(int)
298: 
299:     def find_images(self) -> List[Path]:
300:         """Find all image files in source directory."""
301:         extensions = {'.png', '.jpg', '.jpeg', '.webp', '.gif'}
302:         images = []
303: 
304:         for ext in extensions:
305:             images.extend(self.source_dir.glob(f'*{ext}'))
306:             images.extend(self.source_dir.glob(f'*{ext.upper()}'))
307: 
308:         return sorted(images)
309: 
310:     def process_image(self, image_path: Path) -> Dict:
311:         """Process a single image."""
312:         result = self.analyzer.analyze_image(image_path)
313: 
314:         # Determine destination
315:         dest_folder = self.output_dir / result['folder']
316:         dest_path = dest_folder / result['new_name']
317: 
318:         # Handle name collisions
319:         dest_path = resolve_collision(dest_path)
320: 
321:         result['dest_folder'] = str(dest_folder)
322:         result['dest_path'] = str(dest_path)
323: 
324:         return result
325: 
326:     def organize(self, limit: int = None, min_confidence: float = 0.1) -> List[Dict]:
327:         """
328:         Organize all images in source directory.
329: 
330:         Args:
331:             limit: Maximum number of images to process
332:             min_confidence: Minimum confidence to accept classification
333: 
334:         Returns:
335:             List of processing results
336:         """
337:         images = self.find_images()
338: 
339:         if limit:
340:             images = images[:limit]
341: 
342:         total = len(images)
343:         print(f"\n{'='*60}")
344:         print(f"Screenshot Renamer & Organizer")
345:         print(f"{'='*60}")
346:         print(f"Source: {self.source_dir}")
347:         print(f"Output: {self.output_dir}")
348:         print(f"Images: {total}")
349:         print(f"Mode: {'DRY RUN' if self.dry_run else 'LIVE'}")
350:         print(f"{'='*60}\n")
351: 
352:         for i, image_path in enumerate(images, 1):
353:             print(f"[{i}/{total}] Processing: {image_path.name}")
354: 
355:             try:
356:                 result = self.process_image(image_path)
357:                 self.results.append(result)
358: 
359:                 # Update stats
360:                 self.stats['processed'] += 1
361:                 self.stats[result['folder']] += 1
362: 
363:                 # Show result
364:                 conf_str = f"{result['confidence']*100:.1f}%"
365:                 print(f"  → {result['folder']}/{result['new_name']} ({conf_str})")
366: 
367:                 # Actually move/rename if not dry run
368:                 if not self.dry_run:
369:                     dest_folder = Path(result['dest_folder'])
370:                     dest_path = Path(result['dest_path'])
371: 
372:                     # Create destination folder
373:                     dest_folder.mkdir(parents=True, exist_ok=True)
374: 
375:                     # Copy or move file
376:                     shutil.copy2(image_path, dest_path)
377:                     self.stats['moved'] += 1
378: 
379:             except Exception as e:
380:                 print(f"  ✗ Error: {e}")
381:                 self.stats['errors'] += 1
382:                 if ERROR_TRACKING_AVAILABLE:
383:                     capture_error(e, context={'file': str(image_path)})
384: 
385:         self.print_summary()
386:         return self.results
387: 
388:     def print_summary(self):
389:         """Print organization summary."""
390:         print(f"\n{'='*60}")
391:         print("SUMMARY")
392:         print(f"{'='*60}")
393:         print(f"Total processed: {self.stats['processed']}")
394: 
395:         if not self.dry_run:
396:             print(f"Files moved: {self.stats['moved']}")
397: 
398:         print(f"Errors: {self.stats['errors']}")
399: 
400:         print(f"\nBy Category:")
401:         for key, count in sorted(self.stats.items()):
402:             if key not in ('processed', 'moved', 'errors') and '/' in key:
403:                 print(f"  {key}: {count}")
404: 
405:     def save_results(self, output_file: Path = None):
406:         """Save results to JSON file."""
407:         if output_file is None:
408:             output_file = self.output_dir / 'organization_results.json'
409: 
410:         with open(output_file, 'w') as f:
411:             json.dump({
412:                 'timestamp': datetime.now().isoformat(),
413:                 'source_dir': str(self.source_dir),
414:                 'output_dir': str(self.output_dir),
415:                 'dry_run': self.dry_run,
416:                 'stats': dict(self.stats),
417:                 'results': self.results
418:             }, f, indent=2)
419: 
420:         print(f"\nResults saved to: {output_file}")
421: 
422: 
423: def main():
424:     import argparse
425: 
426:     parser = argparse.ArgumentParser(
427:         description='Rename and categorize screenshot images using AI vision'
428:     )
429:     parser.add_argument(
430:         'source',
431:         nargs='?',
432:         default='~/Documents/ImageObject/Screenshot',
433:         help='Source directory containing screenshots'
434:     )
435:     parser.add_argument(
436:         '--output', '-o',
