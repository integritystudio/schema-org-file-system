496:     def get_optimization_recommendations(self) -> List[Dict[str, Any]]:
497:         """
498:         Analyze usage and provide cost optimization recommendations.
499: 
500:         Returns:
501:             List of recommendations
502:         """
503:         recommendations = []
504: 
505:         for feature_name in self.cost_configs.keys():
506:             summary = self.calculate_feature_cost(feature_name)
507:             roi = self.calculate_roi(feature_name)
508:             config = self.cost_configs[feature_name]
509: 
510:             if summary.total_invocations == 0:
511:                 continue
512: 
513:             # Check for low success rate
514:             if summary.success_rate < 0.7:
515:                 recommendations.append({
516:                     'feature': feature_name,
517:                     'type': 'low_success_rate',
518:                     'severity': 'high',
519:                     'message': f"{config.name} has a {summary.success_rate:.1%} success rate. "
520:                               f"Consider improving error handling or fallback mechanisms.",
521:                     'potential_savings': summary.total_cost * (1 - summary.success_rate)
522:                 })
523: 
524:             # Check for negative ROI
525:             if roi.roi_percentage < 0:
526:                 recommendations.append({
527:                     'feature': feature_name,
528:                     'type': 'negative_roi',
529:                     'severity': 'critical',
530:                     'message': f"{config.name} has negative ROI ({roi.roi_percentage:.1f}%). "
531:                               f"Cost (${roi.total_cost:.4f}) exceeds value (${roi.total_value:.4f}).",
532:                     'potential_savings': roi.total_cost - roi.total_value
533:                 })
534: 
535:             # Check for high processing time
536:             avg_time = summary.total_processing_time_sec / summary.total_invocations
537:             if avg_time > config.avg_processing_time_sec * 2:
538:                 recommendations.append({
539:                     'feature': feature_name,
540:                     'type': 'slow_processing',
541:                     'severity': 'medium',
542:                     'message': f"{config.name} is taking {avg_time:.2f}s per invocation "
543:                               f"(expected {config.avg_processing_time_sec:.2f}s). Consider optimization.",
544:                     'potential_savings': 0.0  # Time savings, not cost
545:                 })
546: 
547:             # Check if feature is underutilized
548:             total_files = sum(r.files_processed for r in self.usage_records)
549:             feature_files = summary.total_files_processed
550:             if total_files > 100 and feature_files / total_files < 0.05 and roi.roi_percentage > 100:
551:                 recommendations.append({
552:                     'feature': feature_name,
553:                     'type': 'underutilized',
554:                     'severity': 'low',
555:                     'message': f"{config.name} is only used for {feature_files/total_files:.1%} of files "
556:                               f"but has {roi.roi_percentage:.0f}% ROI. Consider expanding usage.",
557:                     'potential_savings': 0.0  # Opportunity cost
558:                 })
559: 
560:         # Sort by severity and potential savings
561:         severity_order = {'critical': 0, 'high': 1, 'medium': 2, 'low': 3}
562:         recommendations.sort(key=lambda x: (severity_order.get(x['severity'], 4), -x['potential_savings']))
563: 
564:         return recommendations
