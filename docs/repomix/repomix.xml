227:     def _check_document_processing(self) -> None:
228:         """Check document processing libraries."""
229:         available_libs = []
230:         missing_libs = []
231: 
232:         # Check python-docx
233:         try:
234:             import docx
235:             available_libs.append("docx")
236:         except ImportError:
237:             missing_libs.append("python-docx")
238: 
239:         # Check pypdf
240:         try:
241:             import pypdf
242:             available_libs.append("pypdf")
243:         except ImportError:
244:             missing_libs.append("pypdf")
245: 
246:         # Check openpyxl
247:         try:
248:             import openpyxl
249:             available_libs.append("openpyxl")
250:         except ImportError:
251:             missing_libs.append("openpyxl")
252: 
253:         if available_libs:
254:             self.features['documents'] = FeatureStatus(
255:                 name="Document Processing",
256:                 available=True,
257:                 version=", ".join(available_libs),
258:                 impact=f"PDF/Word/Excel parsing ({len(available_libs)}/3 libs)"
259:             )
