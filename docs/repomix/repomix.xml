578:     def column_exists(conn: sqlite3.Connection, table: str, column: str) -> bool:
579:         """Check if a column exists in a table."""
580:         cursor = conn.execute(f"PRAGMA table_info({table})")
581:         columns = [row[1] for row in cursor.fetchall()]
582:         return column in columns
583: 
584:     def table_exists(conn: sqlite3.Connection, table: str) -> bool:
585:         """Check if a table exists."""
586:         cursor = conn.execute(
587:             "SELECT name FROM sqlite_master WHERE type='table' AND name=?",
588:             (table,)
589:         )
590:         return cursor.fetchone() is not None
591: 
