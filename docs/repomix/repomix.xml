324: **Interaction**:
325: ```javascript
326: // Open modal
327: document.getElementById('modalId').classList.add('active');
328: 
329: // Close modal
330: document.getElementById('modalId').classList.remove('active');
331: 
332: // Close on overlay click
333: modal.addEventListener('click', (e) => {
