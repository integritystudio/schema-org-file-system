  1: #!/usr/bin/env python3
  2: """
  3: Timeline API - Provides session data for timeline visualization.
  4: 
  5: Fetches organization session data from SQLite database and serves it
  6: as JSON for the timeline interface.
  7: """
  8: 
  9: import json
 10: import sqlite3
 11: from datetime import datetime
 12: from typing import List, Dict, Any, Optional
 13: from pathlib import Path
 14: from collections import defaultdict
 15: 
 16: from constants import COST_DECIMAL_PLACES
 17: 
 18: 
 19: class TimelineAPI:
 20:     """API for fetching and formatting timeline data."""
 21: 
 22:     def __init__(self, db_path: str = "results/file_organization.db"):
 23:         """
 24:         Initialize the Timeline API.
 25: 
 26:         Args:
 27:             db_path: Path to SQLite database
 28:         """
 29:         self.db_path = Path(db_path)
 30:         if not self.db_path.exists():
 31:             raise FileNotFoundError(f"Database not found: {db_path}")
 32: 
 33:     def get_all_sessions(self) -> List[Dict[str, Any]]:
 34:         """
 35:         Fetch all organization sessions with aggregated statistics.
 36: 
 37:         Returns:
 38:             List of session dictionaries with enriched data
 39:         """
 40:         conn = sqlite3.connect(self.db_path)
 41:         conn.row_factory = sqlite3.Row
 42:         cursor = conn.cursor()
 43: 
 44:         # Fetch sessions with category distributions
 45:         sessions = []
 46: 
 47:         try:
 48:             # Get all sessions
 49:             cursor.execute("""
 50:                 SELECT
 51:                     id,
 52:                     started_at,
 53:                     completed_at,
 54:                     dry_run,
 55:                     total_files,
 56:                     organized_count,
 57:                     skipped_count,
 58:                     error_count,
 59:                     total_cost,
 60:                     total_processing_time_sec as processing_time,
 61:                     source_directories,
 62:                     base_path
 63:                 FROM organization_sessions
 64:                 ORDER BY started_at DESC
 65:             """)
 66: 
 67:             session_rows = cursor.fetchall()
 68: 
 69:             for row in session_rows:
 70:                 session_data = dict(row)
 71: 
 72:                 # Parse JSON fields
 73:                 if session_data['source_directories']:
 74:                     try:
 75:                         session_data['source_directories'] = json.loads(
 76:                             session_data['source_directories']
 77:                         )
 78:                     except json.JSONDecodeError:
 79:                         session_data['source_directories'] = []
 80: 
 81:                 # Get category distribution for this session
 82:                 session_data['categories'] = self._get_category_distribution(
 83:                     cursor, session_data['id']
 84:                 )
 85: 
 86:                 # Calculate derived metrics
 87:                 session_data['success_rate'] = self._calculate_success_rate(session_data)
 88:                 session_data['files_per_second'] = self._calculate_files_per_second(
 89:                     session_data
 90:                 )
 91:                 session_data['cost_per_file'] = self._calculate_cost_per_file(session_data)
 92: 
 93:                 # Get top schema types
 94:                 session_data['schema_types'] = self._get_schema_type_distribution(
 95:                     cursor, session_data['id']
 96:                 )
 97: 
 98:                 sessions.append(session_data)
 99: 
100:         finally:
101:             conn.close()
102: 
103:         return sessions
104: 
105:     def get_session_by_id(self, session_id: str) -> Optional[Dict[str, Any]]:
106:         """
107:         Fetch a single session by ID.
108: 
109:         Args:
110:             session_id: Session ID to fetch
111: 
112:         Returns:
113:             Session dictionary or None if not found
114:         """
115:         sessions = self.get_all_sessions()
116:         for session in sessions:
117:             if session['id'] == session_id:
118:                 return session
119:         return None
120: 
121:     def get_session_comparison(
122:         self, session_id_1: str, session_id_2: str
123:     ) -> Dict[str, Any]:
124:         """
125:         Compare two sessions and calculate differences.
126: 
127:         Args:
128:             session_id_1: First session ID
129:             session_id_2: Second session ID
130: 
131:         Returns:
132:             Comparison dictionary with deltas
133:         """
134:         session1 = self.get_session_by_id(session_id_1)
135:         session2 = self.get_session_by_id(session_id_2)
136: 
137:         if not session1 or not session2:
138:             raise ValueError("One or both sessions not found")
139: 
140:         comparison = {
141:             'session1': session1,
142:             'session2': session2,
143:             'deltas': {
144:                 'total_files': session2['total_files'] - session1['total_files'],
145:                 'organized_count': session2['organized_count'] - session1['organized_count'],
146:                 'error_count': session2['error_count'] - session1['error_count'],
147:                 'total_cost': round(
148:                     session2['total_cost'] - session1['total_cost'], 2
149:                 ),
150:                 'success_rate': round(
151:                     session2['success_rate'] - session1['success_rate'], 2
152:                 ),
153:             }
154:         }
155: 
156:         return comparison
157: 
158:     def get_latest_sessions(self, limit: int = 2) -> List[Dict[str, Any]]:
159:         """
160:         Get the most recent sessions.
161: 
162:         Args:
163:             limit: Number of sessions to return
164: 
165:         Returns:
166:             List of recent sessions
167:         """
168:         sessions = self.get_all_sessions()
169:         return sessions[:limit]
170: 
171:     def get_aggregate_stats(self) -> Dict[str, Any]:
172:         """
173:         Calculate aggregate statistics across all sessions.
174: 
175:         Returns:
176:             Dictionary of aggregate metrics
177:         """
178:         sessions = self.get_all_sessions()
179: 
180:         if not sessions:
181:             return {
182:                 'total_sessions': 0,
183:                 'total_files_processed': 0,
184:                 'total_organized': 0,
185:                 'total_errors': 0,
186:                 'total_cost': 0.0,
187:                 'average_success_rate': 0.0,
188:                 'total_processing_time': 0.0,
189:             }
190: 
191:         total_files = sum(s['total_files'] for s in sessions)
192:         total_organized = sum(s['organized_count'] for s in sessions)
193:         total_errors = sum(s['error_count'] for s in sessions)
194:         total_cost = sum(s['total_cost'] for s in sessions)
195:         avg_success_rate = sum(s['success_rate'] for s in sessions) / len(sessions)
196:         total_processing_time = sum(s['processing_time'] or 0 for s in sessions)
197: 
198:         # Category breakdown across all sessions
199:         all_categories = defaultdict(int)
200:         for session in sessions:
201:             for cat, count in session['categories'].items():
202:                 all_categories[cat] += count
203: 
204:         return {
205:             'total_sessions': len(sessions),
206:             'total_files_processed': total_files,
207:             'total_organized': total_organized,
208:             'total_errors': total_errors,
209:             'total_cost': round(total_cost, 2),
210:             'average_success_rate': round(avg_success_rate, 2),
211:             'total_processing_time': round(total_processing_time, 2),
212:             'category_breakdown': dict(all_categories),
213:             'dry_run_count': sum(1 for s in sessions if s['dry_run']),
214:             'live_run_count': sum(1 for s in sessions if not s['dry_run']),
215:         }
216: 
217:     def _get_category_distribution(
218:         self, cursor: sqlite3.Cursor, session_id: str
219:     ) -> Dict[str, int]:
220:         """
221:         Get category distribution for a session.
222: 
223:         Args:
224:             cursor: Database cursor
225:             session_id: Session ID
226: 
227:         Returns:
228:             Dictionary mapping category names to file counts
229:         """
230:         cursor.execute("""
231:             SELECT c.name, COUNT(DISTINCT f.id) as count
232:             FROM files f
233:             JOIN file_categories fc ON f.id = fc.file_id
234:             JOIN categories c ON fc.category_id = c.id
235:             WHERE f.session_id = ?
236:             GROUP BY c.name
237:             ORDER BY count DESC
238:         """, (session_id,))
239: 
240:         rows = cursor.fetchall()
241:         distribution = {row['name']: row['count'] for row in rows}
242: 
243:         return distribution
244: 
245:     def _get_schema_type_distribution(
246:         self, cursor: sqlite3.Cursor, session_id: str
247:     ) -> Dict[str, int]:
248:         """
249:         Get schema type distribution for a session.
250: 
251:         Args:
252:             cursor: Database cursor
253:             session_id: Session ID
254: 
255:         Returns:
256:             Dictionary mapping schema types to counts
257:         """
258:         cursor.execute("""
259:             SELECT schema_type, COUNT(*) as count
260:             FROM files
261:             WHERE session_id = ? AND schema_type IS NOT NULL
262:             GROUP BY schema_type
263:             ORDER BY count DESC
264:             LIMIT 10
265:         """, (session_id,))
266: 
267:         rows = cursor.fetchall()
268:         distribution = {row['schema_type']: row['count'] for row in rows}
269: 
270:         return distribution
271: 
272:     @staticmethod
273:     def _calculate_success_rate(session: Dict[str, Any]) -> float:
274:         """Calculate success rate percentage."""
275:         if session['total_files'] == 0:
276:             return 0.0
277:         return round(
278:             (session['organized_count'] / session['total_files']) * 100, 2
279:         )
280: 
281:     @staticmethod
282:     def _calculate_files_per_second(session: Dict[str, Any]) -> float:
283:         """Calculate processing throughput."""
284:         if not session.get('processing_time') or session['processing_time'] == 0:
285:             return 0.0
286:         return round(session['total_files'] / session['processing_time'], 2)
287: 
288:     @staticmethod
289:     def _calculate_cost_per_file(session: Dict[str, Any]) -> float:
290:         """Calculate cost per file."""
291:         if session['total_files'] == 0:
292:             return 0.0
293:         return round(session['total_cost'] / session['total_files'], COST_DECIMAL_PLACES)
294: 
295:     def export_to_json(self, output_path: str = "_site/timeline_data.json"):
296:         """
297:         Export all session data to JSON file for static serving.
298: 
299:         Args:
300:             output_path: Path to write JSON file
301:         """
302:         data = {
303:             'sessions': self.get_all_sessions(),
304:             'aggregate_stats': self.get_aggregate_stats(),
305:             'generated_at': datetime.utcnow().isoformat(),
306:         }
307: 
308:         output_file = Path(output_path)
309:         output_file.parent.mkdir(parents=True, exist_ok=True)
310: 
311:         with open(output_file, 'w') as f:
312:             json.dump(data, f, indent=2, default=str)
313: 
314:         print(f"Timeline data exported to {output_path}")
315:         return output_path
316: 
