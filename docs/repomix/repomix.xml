<file path="scripts/regenerate_schemas.py">
  1: #!/usr/bin/env python3
  2: """
  3: Regenerate Schema.org metadata for all files in the database.
  4: 
  5: This script updates all schema_data in the files table to include the new @id field
  6: based on the file's canonical_id. It uses the updated generators from src/base.py.
  7: 
  8: Usage:
  9:     python scripts/regenerate_schemas.py --db-path results/file_organization.db
 10:     python scripts/regenerate_schemas.py --dry-run  # Show what would be done
 11:     python scripts/regenerate_schemas.py --limit 100  # Process only first 100
 12: """
 13: 
 14: import argparse
 15: import sqlite3
 16: import json
 17: import sys
 18: from pathlib import Path
 19: from datetime import datetime
 20: from typing import Dict, Any, Optional
 21: from urllib.parse import quote
 22: 
 23: # Add src directory to path
 24: sys.path.insert(0, str(Path(__file__).parent.parent / 'src'))
 25: 
 26: from generators import (
 27:     DocumentGenerator,
 28:     ImageGenerator,
 29:     VideoGenerator,
 30:     AudioGenerator,
 31:     CodeGenerator,
 32:     DatasetGenerator,
 33:     ArchiveGenerator
 34: )
 35: from base import PropertyType
 36: from enrichment import MetadataEnricher
 37: 
 38: 
 39: def get_generator_for_type(schema_type: str, entity_id: str):
 40:     """Get the appropriate generator for a schema type with @id."""
 41:     # Generators that take schema_type as first argument
 42:     type_generators = {
 43:         'ImageObject': lambda: ImageGenerator('ImageObject', entity_id=entity_id),
 44:         'Photograph': lambda: ImageGenerator('Photograph', entity_id=entity_id),
 45:         'DigitalDocument': lambda: DocumentGenerator('DigitalDocument', entity_id=entity_id),
 46:         'Article': lambda: DocumentGenerator('Article', entity_id=entity_id),
 47:         'Report': lambda: DocumentGenerator('Report', entity_id=entity_id),
 48:         'VideoObject': lambda: VideoGenerator('VideoObject', entity_id=entity_id),
 49:         'MovieClip': lambda: VideoGenerator('MovieClip', entity_id=entity_id),
 50:         'AudioObject': lambda: AudioGenerator('AudioObject', entity_id=entity_id),
 51:         'MusicRecording': lambda: AudioGenerator('MusicRecording', entity_id=entity_id),
 52:         'PodcastEpisode': lambda: AudioGenerator('PodcastEpisode', entity_id=entity_id),
 53:         # These generators don't take schema_type
 54:         'SoftwareSourceCode': lambda: CodeGenerator(entity_id=entity_id),
 55:         'Dataset': lambda: DatasetGenerator(entity_id=entity_id),
 56:         'Archive': lambda: ArchiveGenerator(entity_id=entity_id),
 57:     }
 58: 
 59:     generator_factory = type_generators.get(
 60:         schema_type,
 61:         lambda: DocumentGenerator('DigitalDocument', entity_id=entity_id)
 62:     )
 63:     return generator_factory()
 64: 
 65: 
 66: def regenerate_schema(
 67:     file_id: str,
 68:     canonical_id: str,
 69:     current_path: str,
 70:     schema_type: str,
 71:     existing_schema: Dict[str, Any],
 72:     enricher: MetadataEnricher
 73: ) -> Dict[str, Any]:
 74:     """
 75:     Regenerate Schema.org metadata for a file with @id.
 76: 
 77:     Args:
 78:         file_id: Internal file ID (SHA-256 hash)
 79:         canonical_id: Public canonical ID for @id
 80:         current_path: Current file path
 81:         schema_type: Schema.org type (e.g., 'ImageObject')
 82:         existing_schema: Existing schema data to preserve
 83:         enricher: MetadataEnricher instance
 84: 
 85:     Returns:
 86:         Updated schema dictionary with @id
 87:     """
 88:     # Use canonical_id as entity_id (it's already in urn:sha256:... format)
 89:     entity_id = canonical_id if canonical_id else f"urn:sha256:{file_id}"
 90: 
 91:     # Create generator with @id
 92:     generator = get_generator_for_type(schema_type or 'DigitalDocument', entity_id)
 93: 
 94:     # Try to get file stats if file exists
 95:     file_path = Path(current_path) if current_path else None
 96:     if file_path and file_path.exists():
 97:         try:
 98:             stats = file_path.stat()
 99:             mime_type = enricher.detect_mime_type(str(file_path))
100:             file_url = f"https://localhost/files/{quote(file_path.name)}"
101: 
102:             # Set basic info based on type
103:             if schema_type == 'ImageObject':
104:                 generator.set_basic_info(
105:                     name=file_path.name,
106:                     content_url=file_url,
107:                     encoding_format=mime_type or 'image/png',
108:                     description=existing_schema.get('description', file_path.name)
109:                 )
110:             else:
111:                 generator.set_basic_info(
112:                     name=file_path.name,
113:                     description=existing_schema.get('description', file_path.name)
114:                 )
115:                 if hasattr(generator, 'set_file_info'):
116:                     generator.set_file_info(
117:                         encoding_format=mime_type or 'application/octet-stream',
118:                         url=file_url,
119:                         content_size=stats.st_size
120:                     )
121: 
122:             # Set dates
123:             generator.set_dates(
124:                 created=datetime.fromtimestamp(stats.st_ctime),
125:                 modified=datetime.fromtimestamp(stats.st_mtime)
126:             )
127: 
128:             # Add file path
129:             generator.set_property('filePath', str(file_path.absolute()), PropertyType.TEXT)
130: 
131:         except Exception as e:
132:             # If we can't access the file, use existing schema data
133:             pass
134: 
135:     # Preserve existing properties that we don't regenerate
136:     schema = generator.to_dict()
137: 
138:     # Preserve these properties from existing schema if present
139:     preserve_keys = ['abstract', 'text', 'keywords', 'author', 'creator',
140:                      'width', 'height', 'duration', 'bitrate']
141:     for key in preserve_keys:
142:         if key in existing_schema and key not in schema:
143:             schema[key] = existing_schema[key]
144: 
145:     return schema
146: 
147: 
148: def process_files(
149:     conn: sqlite3.Connection,
150:     dry_run: bool = False,
151:     limit: Optional[int] = None,
152:     batch_size: int = 1000
153: ) -> int:
154:     """Process all files and regenerate their schemas."""
155:     enricher = MetadataEnricher()
156: 
157:     # Get total count
158:     cursor = conn.execute("SELECT COUNT(*) FROM files")
159:     total_count = cursor.fetchone()[0]
160: 
161:     if limit:
162:         total_count = min(total_count, limit)
163: 
164:     print(f"Processing {total_count} files...")
165: 
166:     # Process in batches
167:     processed = 0
168:     errors = 0
169:     offset = 0
170: 
171:     while processed < total_count:
172:         # Fetch batch
173:         query = """
174:             SELECT id, canonical_id, current_path, schema_type, schema_data
175:             FROM files
176:             ORDER BY id
177:             LIMIT ? OFFSET ?
178:         """
179:         cursor = conn.execute(query, (batch_size, offset))
180:         rows = cursor.fetchall()
181: 
182:         if not rows:
183:             break
184: 
185:         for file_id, canonical_id, current_path, schema_type, schema_data_json in rows:
186:             if limit and processed >= limit:
187:                 break
188: 
189:             try:
190:                 # Parse existing schema
191:                 existing_schema = {}
192:                 if schema_data_json:
193:                     try:
194:                         existing_schema = json.loads(schema_data_json)
195:                     except json.JSONDecodeError:
196:                         pass
197: 
198:                 # Regenerate schema with @id
199:                 new_schema = regenerate_schema(
200:                     file_id=file_id,
201:                     canonical_id=canonical_id,
202:                     current_path=current_path or '',
203:                     schema_type=schema_type or 'DigitalDocument',
204:                     existing_schema=existing_schema,
205:                     enricher=enricher
206:                 )
207: 
208:                 if dry_run:
209:                     if processed < 3:  # Show first 3 examples
210:                         print(f"\n  Example {processed + 1}:")
211:                         print(f"    File: {current_path or file_id[:16]}...")
212:                         print(f"    @id: {new_schema.get('@id', 'MISSING')}")
213:                 else:
214:                     # Update database
215:                     conn.execute(
216:                         "UPDATE files SET schema_data = ? WHERE id = ?",
217:                         (json.dumps(new_schema), file_id)
218:                     )
219: 
220:                 processed += 1
221: 
222:             except Exception as e:
223:                 errors += 1
224:                 if errors <= 5:  # Show first 5 errors
225:                     print(f"  Error processing {file_id[:16]}...: {e}")
226: 
227:         offset += batch_size
228: 
229:         # Commit batch
230:         if not dry_run:
231:             conn.commit()
232: 
233:         # Progress update
234:         pct = (processed / total_count) * 100
235:         print(f"  Progress: {processed}/{total_count} ({pct:.1f}%) - Errors: {errors}")
236: 
237:     return processed
238: 
239: 
240: def verify_schemas(conn: sqlite3.Connection) -> bool:
241:     """Verify that schemas have @id field."""
242:     print("\n=== Verification ===\n")
243: 
244:     # Check a sample of schemas
245:     cursor = conn.execute("""
246:         SELECT schema_data FROM files
247:         WHERE schema_data IS NOT NULL
248:         LIMIT 100
249:     """)
250: 
251:     has_id = 0
252:     missing_id = 0
253: 
254:     for (schema_data_json,) in cursor.fetchall():
255:         try:
256:             schema = json.loads(schema_data_json)
257:             if '@id' in schema:
258:                 has_id += 1
259:             else:
260:                 missing_id += 1
261:         except Exception:
262:             missing_id += 1
263: 
264:     total = has_id + missing_id
265:     if total == 0:
266:         print("  No schemas found to verify")
267:         return False
268: 
269:     pct = (has_id / total) * 100
270:     print(f"  Sample of 100 schemas:")
271:     print(f"    With @id: {has_id} ({pct:.1f}%)")
272:     print(f"    Missing @id: {missing_id}")
273: 
274:     if missing_id > 0:
275:         # Show an example of missing @id
276:         cursor = conn.execute("""
277:             SELECT id, schema_data FROM files
278:             WHERE schema_data IS NOT NULL
279:             AND schema_data NOT LIKE '%"@id"%'
280:             LIMIT 1
281:         """)
282:         row = cursor.fetchone()
283:         if row:
284:             print(f"\n  Example missing @id: {row[0][:16]}...")
285: 
286:     return missing_id == 0
287: 
288: 
289: def main():
290:     parser = argparse.ArgumentParser(
291:         description="Regenerate Schema.org metadata with @id for all files"
292:     )
293:     parser.add_argument(
294:         '--db-path',
295:         default='results/file_organization.db',
296:         help='Path to SQLite database'
297:     )
298:     parser.add_argument(
299:         '--dry-run',
300:         action='store_true',
301:         help='Show what would be done without making changes'
302:     )
303:     parser.add_argument(
304:         '--limit',
305:         type=int,
306:         default=None,
307:         help='Limit number of files to process'
308:     )
309:     parser.add_argument(
310:         '--batch-size',
311:         type=int,
312:         default=1000,
313:         help='Batch size for processing'
314:     )
315: 
316:     args = parser.parse_args()
317: 
318:     db_path = Path(args.db_path)
319:     if not db_path.exists():
320:         print(f"Error: Database not found at {db_path}")
321:         sys.exit(1)
322: 
323:     print(f"Schema Regeneration Script")
324:     print(f"==========================")
325:     print(f"Database: {db_path}")
326:     print(f"Dry run: {args.dry_run}")
327:     print(f"Limit: {args.limit or 'None'}")
328:     print(f"Started: {datetime.now().isoformat()}")
329: 
330:     conn = sqlite3.connect(str(db_path))
331: 
332:     try:
333:         print("\n=== Regenerating Schemas ===\n")
334: 
335:         processed = process_files(
336:             conn,
337:             dry_run=args.dry_run,
338:             limit=args.limit,
339:             batch_size=args.batch_size
340:         )
341: 
342:         if not args.dry_run:
343:             success = verify_schemas(conn)
344:         else:
345:             print("\n=== Dry Run Complete ===")
346:             print("Run without --dry-run to apply changes")
347:             success = True
348: 
349:         print(f"\n=== Summary ===")
350:         print(f"Files processed: {processed}")
351:         print(f"Status: {'SUCCESS' if success else 'INCOMPLETE - run again'}")
352:         print(f"Completed: {datetime.now().isoformat()}")
353: 
354:     finally:
355:         conn.close()
356: 
357: 
358: if __name__ == '__main__':
359:     main()
