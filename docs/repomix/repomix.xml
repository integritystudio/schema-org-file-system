 59: def add_column_if_not_exists(
 60:     conn: sqlite3.Connection,
 61:     table: str,
 62:     column: str,
 63:     column_type: str,
 64:     dry_run: bool = False
 65: ) -> bool:
 66:     """Add a column to a table if it doesn't exist.
 67: 
 68:     Note: SQLite doesn't support adding UNIQUE columns directly via ALTER TABLE.
 69:     We add the column without UNIQUE constraint, then create a unique index.
 70:     """
 71:     if column_exists(conn, table, column):
 72:         print(f"  Column {table}.{column} already exists")
 73:         return False
 74: 
 75:     # Remove UNIQUE from column type (SQLite limitation)
 76:     # We'll add a unique index separately
 77:     base_type = column_type.replace(' UNIQUE', '').replace('UNIQUE ', '')
 78: 
 79:     sql = f"ALTER TABLE {table} ADD COLUMN {column} {base_type}"
 80:     if dry_run:
 81:         print(f"  [DRY RUN] Would execute: {sql}")
 82:     else:
 83:         conn.execute(sql)
 84:         print(f"  Added column {table}.{column}")
 85: 
 86:     # Create unique index if UNIQUE was specified
 87:     if 'UNIQUE' in column_type:
 88:         index_name = f"uq_{table}_{column}"
 89:         if dry_run:
 90:             print(f"  [DRY RUN] Would create unique index: {index_name}")
 91:         else:
 92:             try:
 93:                 conn.execute(f"CREATE UNIQUE INDEX {index_name} ON {table}({column})")
 94:                 print(f"  Created unique index {index_name}")
 95:             except sqlite3.OperationalError as e:
 96:                 if "already exists" in str(e):
 97:                     print(f"  Unique index {index_name} already exists")
 98:                 else:
 99:                     raise
100: 
101:     return True
