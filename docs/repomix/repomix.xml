3593:     def organize_file(self, file_path: Path, dry_run: bool = False, force: bool = False) -> Dict:
3594:         """
3595:         Organize a single file based on content.
3596: 
3597:         Args:
3598:             file_path: Path to the file
3599:             dry_run: If True, don't actually move files
3600:             force: If True, re-organize even if already in correct location
3601: 
3602:         Returns:
3603:             Dictionary with organization details
3604:         """
3605:         result = {
3606:             'source': str(file_path),
3607:             'status': 'skipped',
3608:             'reason': None,
3609:             'destination': None,
3610:             'schema': None,
3611:             'extracted_text_length': 0
3612:         }
3613: 
3614:         if self.should_skip_file(file_path):
3615:             result['reason'] = 'system_file'
3616:             self.stats['skipped'] += 1
3617:             return result
3618: 
3619:         if not file_path.is_file():
3620:             result['reason'] = 'not_file'
3621:             self.stats['skipped'] += 1
3622:             return result
3623: 
3624:         try:
3625:             # Detect category based on content
3626:             category, subcategory, schema_type, extracted_text, company_name, people_names, image_metadata = self.detect_file_category(file_path)
3627:             result['extracted_text_length'] = len(extracted_text)
3628:             result['company_name'] = company_name
3629:             result['people_names'] = people_names
3630:             result['image_metadata'] = image_metadata
3631: 
3632:             # Handle skip category (duplicates, etc.)
3633:             if category == 'skip':
3634:                 result['status'] = 'skipped'
3635:                 result['reason'] = subcategory  # e.g., 'duplicate'
3636:                 self.stats['skipped'] += 1
3637:                 return result
3638: 
3639:             # Generate schema with extracted content
3640:             schema = self.generate_schema(file_path, schema_type, extracted_text)
3641: 
3642:             # Validate schema
3643:             validation_report = self.validator.validate(schema)
3644: 
3645:             # Get destination path (with optional date/location organization for images)
3646:             dest_path = self.get_destination_path(file_path, category, subcategory, company_name, image_metadata, people_names)
3647: 
3648:             # Skip if already in the right place (unless force=True)
3649:             if file_path == dest_path and not force:
3650:                 result['status'] = 'already_organized'
3651:                 result['destination'] = str(dest_path)
3652:                 result['schema'] = schema
3653:                 result['category'] = category
3654:                 result['subcategory'] = subcategory
3655:                 self.stats['already_organized'] += 1
3656:                 return result
3657: 
3658:             # Move file if not dry run
3659:             if not dry_run:
3660:                 shutil.move(str(file_path), str(dest_path))
3661: 
3662:                 # Register schema
3663:                 schema['url'] = f"file://{dest_path.absolute()}"
3664:                 metadata = {
3665:                     'category': category,
3666:                     'subcategory': subcategory,
3667:                     'organized_date': datetime.now().isoformat(),
3668:                     'is_valid': validation_report.is_valid(),
3669:                     'has_extracted_text': bool(extracted_text)
3670:                 }
3671:                 if company_name:
3672:                     metadata['company_name'] = company_name
3673: 
3674:                 self.registry.register(
3675:                     str(dest_path),
3676:                     schema,
3677:                     metadata=metadata
3678:                 )
3679: 
3680:                 # Persist to database with canonical IDs
3681:                 if self.graph_store:
3682:                     self._persist_to_graph_store(
3683:                         file_path=file_path,
3684:                         dest_path=dest_path,
3685:                         category=category,
3686:                         subcategory=subcategory,
3687:                         schema=schema,
3688:                         extracted_text=extracted_text,
3689:                         company_name=company_name,
3690:                         people_names=people_names,
3691:                         image_metadata=image_metadata
3692:                     )
3693: 
3694:             result['status'] = 'organized' if not dry_run else 'would_organize'
3695:             result['destination'] = str(dest_path)
3696:             result['schema'] = schema
3697:             result['category'] = category
3698:             result['subcategory'] = subcategory
3699:             result['is_valid'] = validation_report.is_valid()
3700: 
3701:             self.stats['organized'] += 1
3702:             self.stats[f'{category}_{subcategory}'] += 1
3703: 
3704:         except Exception as e:
3705:             result['status'] = 'error'
3706:             result['reason'] = str(e)
3707:             self.stats['errors'] += 1
3708:             print(f"  ✗ Error: {e}")
3709: 
3710:         return result
