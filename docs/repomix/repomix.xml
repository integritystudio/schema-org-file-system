3103:     def detect_file_category(self, file_path: Path) -> Tuple[str, str, str, str, Optional[str], List[str], Dict[str, Any]]:
3104:         """
3105:         Detect file category based on content.
3106: 
3107:         Priority order:
3108:         0. Filename pattern detection (fastest - no content extraction needed)
3109:         1. Organization entity detection (for documents with content)
3110:         2. Person entity detection
3111:         3. Game asset detection (audio, sprites, textures)
3112:         4. Filepath-based classification (file extensions, filenames)
3113:         5. Image content analysis (for home interiors)
3114:         6. OCR and text-based classification
3115: 
3116:         Returns:
3117:             Tuple of (main_category, subcategory, schema_type, extracted_text, company_name, people_names, image_metadata)
3118:         """
3119:         # Determine schema type and MIME type early (needed for multiple paths)
3120:         mime_type = self.enricher.detect_mime_type(str(file_path))
3121:         if mime_type:
3122:             if mime_type.startswith('image/'):
3123:                 schema_type = 'ImageObject'
3124:             elif mime_type == 'application/pdf':
3125:                 schema_type = 'DigitalDocument'
3126:             elif mime_type.startswith('video/'):
3127:                 schema_type = 'VideoObject'
3128:             elif mime_type.startswith('audio/'):
3129:                 schema_type = 'AudioObject'
3130:             else:
3131:                 schema_type = 'DigitalDocument'
3132:         else:
3133:             schema_type = 'DigitalDocument'
3134: 
3135:         # PRIORITY 0: Filename pattern detection (fastest - no content extraction needed)
3136:         # Handles: Google invoices, resumes, technical files, legal docs, business docs, entity files
3137:         filename_result = self.classify_by_filename_patterns(file_path)
3138:         if filename_result:
3139:             category, subcategory, company_name, people_names = filename_result
3140:             # Handle skip category for duplicates
3141:             if category == 'skip':
3142:                 return ('skip', subcategory, schema_type, '', None, [], {})
3143:             # Point A: enhance weak photos_other from filename patterns for images
3144:             if subcategory == 'photos_other' and schema_type == 'ImageObject':
3145:                 enhanced = self.enhance_weak_image_classification(file_path)
3146:                 if enhanced:
3147:                     return (enhanced[0], enhanced[1], schema_type, '', None, [], {})
3148:             return (category, subcategory, schema_type, '', company_name, people_names, {})
3149: 
3150:         # PRIORITY 1: Organization and Person detection for document-type files
3151:         # Only apply to document/PDF types (not images, audio, video)
3152:         if schema_type == 'DigitalDocument' or mime_type == 'application/pdf':
3153:             print(f"  Checking for Organization/Person entities...")
3154:             extracted_text = self.extract_text(file_path)
3155: 
3156:             if extracted_text and len(extracted_text) >= 50:
3157:                 # Try Organization detection first
3158:                 org_result = self.classify_by_organization(extracted_text, file_path.name)
3159:                 if org_result:
3160:                     category, subcategory, org_name = org_result
3161:                     print(f"  ✓ Organization detected: {org_name} ({subcategory})")
3162:                     return (category, subcategory, schema_type, extracted_text, org_name, [], {})
3163: 
3164:                 # Try Person detection second
3165:                 person_result = self.classify_by_person(extracted_text, file_path.name)
3166:                 if person_result:
3167:                     category, subcategory, people_names = person_result
3168:                     print(f"  ✓ Person detected: {', '.join(people_names[:3]) if people_names else 'Unknown'} ({subcategory})")
3169:                     return (category, subcategory, schema_type, extracted_text, None, people_names, {})
3170: 
3171:         # PRIORITY 3: Check for game assets (before filepath patterns)
3172:         game_asset = self.classify_game_asset(file_path)
3173:         if game_asset:
3174:             category, subcategory = game_asset
3175:             print(f"  ✓ Game asset detected: {subcategory}")
3176:             return (category, subcategory, schema_type, '', None, [], {})
3177: 
3178:         # PRIORITY 3: Check filepath patterns (most efficient and accurate for code files)
3179:         filepath_category = self.classify_by_filepath(file_path)
3180:         if filepath_category:
3181:             print(f"  ✓ Filepath match: {filepath_category}")
3182:             # Return filepath-based category as a special marker
3183:             # We'll handle this in get_destination_path
3184:             return ('filepath', filepath_category, schema_type, '', None, [], {})
3185: 
3186:         # Extract metadata for images
3187:         image_metadata = {}
3188:         if schema_type == 'ImageObject' and self.metadata_parser.metadata_available:
3189:             print(f"  Extracting image metadata...")
3190:             image_metadata = self.metadata_parser.get_metadata_summary(file_path)
3191: 
3192:             if image_metadata.get('datetime'):
3193:                 dt = image_metadata['datetime']
3194:                 print(f"  ✓ Photo taken: {dt.strftime('%Y-%m-%d %H:%M:%S')}")
3195: 
3196:             if image_metadata.get('gps_coordinates'):
3197:                 coords = image_metadata['gps_coordinates']
