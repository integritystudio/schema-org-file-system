  1: #!/usr/bin/env python3
  2: """
  3: Organize content-described files into existing Schema.org folder structure.
  4: Maps content types to existing folders in ~/Documents.
  5: """
  6: 
  7: import json
  8: import shutil
  9: from pathlib import Path
 10: from collections import defaultdict
 11: 
 12: from shared.constants import CONTENT_TO_EXISTING_FOLDER, CONTENT_ABBREVIATIONS, IMAGE_EXTENSIONS
 13: from shared.file_ops import resolve_collision
 14: 
 15: # Reverse lookup: "_abbrev_" substring → canonical content type label.
 16: # CONTENT_ABBREVIATIONS maps content_type → abbrev, so we invert it here.
 17: # Derived from shared constants so it stays in sync automatically.
 18: _ABBREV_TO_CONTENT = {f"_{abbrev}_": ctype for ctype, abbrev in CONTENT_ABBREVIATIONS.items()}
 19: 
 20: 
 21: def organize_files(base_path: str = "~/Documents", dry_run: bool = False) -> dict:
 22:     """Organize files from ~/Documents root into existing subfolders."""
 23: 
 24:     base_path = Path(base_path).expanduser()
 25: 
 26:     print(f"\n{'='*60}")
 27:     print(f"Organizing Files to Existing Folders {'(DRY RUN)' if dry_run else ''}")
 28:     print(f"{'='*60}\n")
 29:     print(f"Base path: {base_path}")
 30: 
 31:     # Find all files in ~/Documents root that match our renamed files
 32:     root_files = [f for f in base_path.iterdir() if f.is_file() and f.suffix.lower() in IMAGE_EXTENSIONS]
 33: 
 34:     # Filter to only files we renamed (have content descriptions)
 35:     files_to_organize = []
 36:     for f in root_files:
 37:         if any(abbrev in f.name.lower() for abbrev in _ABBREV_TO_CONTENT):
 38:             files_to_organize.append(f)
 39: 
 40:     print(f"Files to organize: {len(files_to_organize)}\n")
 41: 
 42:     stats = defaultdict(int)
 43:     organization_log = []
 44: 
 45:     for i, file_path in enumerate(files_to_organize, 1):
 46:         # Determine content type from filename abbreviation
 47:         content_type = None
 48:         fname_lower = file_path.name.lower()
 49: 
 50:         for abbrev_key, ctype in _ABBREV_TO_CONTENT.items():
 51:             if abbrev_key in fname_lower:
 52:                 content_type = ctype
 53:                 break
 54: 
 55:         if not content_type:
 56:             stats['no_content_type'] += 1
 57:             continue
 58: 
 59:         # Get destination folder
 60:         dest_folder = CONTENT_TO_EXISTING_FOLDER.get(content_type)
 61:         if not dest_folder:
 62:             stats['no_mapping'] += 1
 63:             continue
 64: 
 65:         dest_dir = base_path / dest_folder
 66:         dest_path = dest_dir / file_path.name
 67: 
 68:         # Create directory if needed
 69:         if not dry_run:
 70:             dest_dir.mkdir(parents=True, exist_ok=True)
 71: 
 72:         # Handle collisions
 73:         dest_path = resolve_collision(dest_path)
 74: 
 75:         # Move file
 76:         try:
 77:             if not dry_run:
 78:                 shutil.move(str(file_path), str(dest_path))
 79: 
 80:             stats['organized'] += 1
 81:             organization_log.append({
 82:                 'source': str(file_path),
 83:                 'destination': str(dest_path),
 84:                 'content_type': content_type,
 85:                 'folder': dest_folder
 86:             })
 87: 
 88:             if i <= 30 or i % 100 == 0:
 89:                 action = "Would move" if dry_run else "Moved"
 90:                 print(f"  {action}: {file_path.name}")
 91:                 print(f"       → {dest_folder}/")
 92: 
 93:         except Exception as e:
 94:             stats['errors'] += 1
 95:             print(f"  Error: {file_path.name}: {e}")
 96: 
 97:     # Print summary
 98:     print(f"\n{'='*60}")
 99:     print("Organization Summary")
100:     print(f"{'='*60}\n")
101:     print(f"Total files found: {len(files_to_organize)}")
102:     print(f"Organized: {stats['organized']}")
103:     print(f"No content type: {stats['no_content_type']}")
104:     print(f"No folder mapping: {stats['no_mapping']}")
105:     print(f"Errors: {stats['errors']}")
106: 
107:     if dry_run:
108:         print(f"\n⚠️  This was a DRY RUN - no files were moved")
109: 
110:     # Show breakdown by folder
111:     if organization_log:
112:         print(f"\nFiles by Destination Folder:")
113:         print("-" * 40)
114:         folder_counts = defaultdict(int)
115:         for item in organization_log:
116:             folder_counts[item['folder']] += 1
117: 
118:         for folder, count in sorted(folder_counts.items(), key=lambda x: x[1], reverse=True):
119:             print(f"  {folder}: {count}")
120: 
121:     return {
122:         'stats': dict(stats),
123:         'log': organization_log
124:     }
125: 
126: 
127: def main():
128:     import argparse
129: 
130:     parser = argparse.ArgumentParser(
131:         description='Organize files into existing folder structure'
132:     )
133:     parser.add_argument(
134:         '--dry-run',
135:         action='store_true',
136:         help='Preview changes without moving files'
137:     )
138:     parser.add_argument(
139:         '--output-log',
140:         help='Save organization log to JSON file'
141:     )
142: 
143:     args = parser.parse_args()
144: 
145:     result = organize_files(dry_run=args.dry_run)
146: 
147:     if args.output_log:
148:         with open(args.output_log, 'w') as f:
149:             json.dump(result, f, indent=2)
150:         print(f"\nOrganization log saved to: {args.output_log}")
151: 
152: 
153: if __name__ == '__main__':
154:     main()
</file>

<file path="README.md">
  1: # Schema.org File Organization System
  2: 
  3: AI-powered file organization using CLIP vision, OCR, Schema.org metadata, and entity detection.
  4: 
  5: **Version:** 1.4.0 | **Python:** 3.8 - 3.14 | **Files Processed:** 265,000+
  6: 
  7: ## Quick Start
  8: 
  9: ```bash
 10: # Setup
 11: git clone https://github.com/aledlie/schema-org-file-system.git
 12: cd schema-org-file-system
 13: python3 -m venv venv && source venv/bin/activate
 14: pip install -e ".[all]"
 15: brew install tesseract poppler
 16: 
 17: # Run
 18: organize-files content --source ~/Downloads --dry-run --limit 100
 19: organize-files health  # Check dependencies
 20: ```
 21: 
 22: ## CLI Commands
 23: 
 24: | Command | Description |
 25: |---------|-------------|
 26: | `organize-files content` | AI-powered organization (CLIP, OCR) |
 27: | `organize-files name` | Filename pattern organization |
 28: | `organize-files type` | Extension-based organization |
 29: | `organize-files health` | Check system dependencies |
 30: | `organize-files migrate-ids` | Run database migration |
 31: | `organize-files update-site` | Update dashboard data |
 32: 
 33: ## Architecture
 34: 
 35: ```mermaid
 36: flowchart LR
 37:     A[Source Files] --> B[CLI]
 38:     B --> C{Organizer}
 39:     C --> D[CLIP Vision]
 40:     C --> E[OCR]
 41:     C --> F[Entity Detection]
 42:     D & E & F --> G[Category Assignment]
 43:     G --> H[GraphStore]
 44:     H --> I[(SQLite)]
 45:     H --> J[Schema.org JSON-LD]
 46:     I & J --> K[Dashboard]
 47: ```
 48: 
 49: ## Classification Priority
 50: 
 51: 1. **Organization** - client, vendor, invoice, company names
 52: 2. **Person** - resume, contact, signatures (OCR-enhanced)
 53: 3. **Legal/Contract** - contracts, agreements, terms
 54: 4. **E-commerce** - product listings, shopping carts
 55: 5. **Software UI** - app interfaces, dashboards
 56: 6. **Game Assets** - 200+ patterns, sprites, textures, audio
 57: 7. **Filepath** - directory structure patterns
 58: 8. **Content Analysis** - OCR text + CLIP vision
 59: 9. **MIME Type** - file extension fallback
 60: 
 61: ## Project Structure
 62: 
 63: ```
 64: ├── src/                    # Core library
 65: │   ├── cli.py              # CLI entry point
 66: │   ├── generators.py       # Schema.org generators
 67: │   └── storage/            # GraphStore, models
 68: ├── scripts/                # Organizer scripts
 69: ├── tests/                  # Unit, integration, e2e
 70: ├── _site/                  # Web dashboard
 71: └── results/                # Database & reports
 72: ```
 73: 
 74: ## Output Folders
 75: 
 76: ```
 77: ~/Documents/
 78: ├── Organization/{Company}/    # Vendor/partner files
 79: ├── Person/{Name}/             # Person-related files
 80: ├── GameAssets/                # Sprites, textures, models
 81: ├── Financial/                 # Invoices, receipts
 82: ├── Technical/                 # Code, configs
 83: └── Media/                     # Photos, videos, audio
 84: ```
 85: 
 86: ## Key Features
 87: 
 88: - **Entity Detection** - Prioritizes Organization and Person identification
 89: - **Canonical IDs** - UUID v5 + SHA256 for persistent identification
 90: - **Schema.org Metadata** - Full JSON-LD generation
 91: - **Cost Tracking** - ROI calculation with manual time savings
 92: - **E2E Testing** - Playwright with OpenTelemetry instrumentation
 93: 
 94: ## Tech Stack
 95: 
 96: | Layer | Technology |
 97: |-------|------------|
 98: | AI/ML | PyTorch, CLIP, OpenCV |
 99: | OCR | Tesseract |
100: | Database | SQLite + SQLAlchemy |
101: | Monitoring | Sentry SDK |
102: | Testing | pytest, Playwright |
103: 
104: ## Documentation
105: 
106: - [CHANGELOG](docs/CHANGELOG.md) - Version history
107: - [DEPENDENCIES](docs/DEPENDENCIES.md) - Installation guide
108: - [ARCHITECTURE_REFACTOR](docs/ARCHITECTURE_REFACTOR.md) - Design decisions
109: 
110: ## Environment Variables
111: 
112: | Variable | Description |
113: |----------|-------------|
114: | `FILE_SYSTEM_SENTRY_DSN` | Sentry error tracking (Doppler) |
115: | `--sentry-dsn` | CLI override |
116: 
117: ## Troubleshooting
118: 
119: | Issue | Solution |
120: |-------|----------|
121: | HEIC fails | `pip install pillow-heif` |
122: | No OCR | `brew install tesseract` |
123: | No AI | `pip install torch transformers` |
124: | Check deps | `organize-files health` |
125: 
126: ## Visual Architecture
127: 
128: ### System Overview
129: 
130: ```mermaid
