<file path="tests/e2e/global-setup.ts">
  1: import { FullConfig } from '@playwright/test';
  2: import { NodeSDK } from '@opentelemetry/sdk-node';
  3: import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';
  4: import { Resource } from '@opentelemetry/resources';
  5: import { ATTR_SERVICE_NAME, ATTR_SERVICE_VERSION } from '@opentelemetry/semantic-conventions';
  6: import { v4 as uuidv4 } from 'uuid';
  7: import fs from 'fs';
  8: import path from 'path';
  9: 
 10: const TELEMETRY_DIR = 'test-results/telemetry';
 11: const METADATA_FILE = 'test-run-metadata.json';
 12: 
 13: interface TestRunMetadata {
 14:   runId: string;
 15:   correlationId: string;
 16:   startTime: string;
 17:   playwright: {
 18:     version: string;
 19:     projects: string[];
 20:   };
 21:   otel: {
 22:     enabled: boolean;
 23:     endpoint: string | null;
 24:   };
 25:   environment: {
 26:     nodeVersion: string;
 27:     platform: string;
 28:     ci: boolean;
 29:   };
 30: }
 31: 
 32: let sdk: NodeSDK | null = null;
 33: 
 34: async function globalSetup(config: FullConfig): Promise<void> {
 35:   const runId = uuidv4();
 36:   const correlationId = uuidv4();
 37: 
 38:   // Set correlation ID for all tests
 39:   process.env.TEST_RUN_ID = runId;
 40:   process.env.TEST_CORRELATION_ID = correlationId;
 41: 
 42:   // Ensure telemetry directory exists
 43:   const telemetryDir = path.join(process.cwd(), TELEMETRY_DIR);
 44:   if (!fs.existsSync(telemetryDir)) {
 45:     fs.mkdirSync(telemetryDir, { recursive: true });
 46:   }
 47: 
 48:   // Initialize OpenTelemetry if endpoint is configured
 49:   const otelEndpoint = process.env.OTEL_EXPORTER_OTLP_ENDPOINT;
 50:   const otelEnabled = !!otelEndpoint;
 51: 
 52:   if (otelEnabled) {
 53:     try {
 54:       const exporter = new OTLPTraceExporter({
 55:         url: `${otelEndpoint}/v1/traces`,
 56:       });
 57: 
 58:       sdk = new NodeSDK({
 59:         resource: new Resource({
 60:           [ATTR_SERVICE_NAME]: 'playwright-e2e',
 61:           [ATTR_SERVICE_VERSION]: '1.0.0',
 62:           'test.run_id': runId,
 63:           'test.correlation_id': correlationId,
 64:         }),
 65:         traceExporter: exporter,
 66:       });
 67: 
 68:       await sdk.start();
 69: 
 70:       if (process.env.OTEL_DEBUG) {
 71:         console.log('[OTEL] SDK initialized successfully');
 72:         console.log(`[OTEL] Exporting to: ${otelEndpoint}`);
 73:       }
 74:     } catch (error) {
 75:       console.error('[OTEL] Failed to initialize SDK:', error);
 76:     }
 77:   }
 78: 
 79:   // Create test run metadata
 80:   const metadata: TestRunMetadata = {
 81:     runId,
 82:     correlationId,
 83:     startTime: new Date().toISOString(),
 84:     playwright: {
 85:       version: require('@playwright/test/package.json').version,
 86:       projects: config.projects.map(p => p.name),
 87:     },
 88:     otel: {
 89:       enabled: otelEnabled,
 90:       endpoint: otelEndpoint || null,
 91:     },
 92:     environment: {
 93:       nodeVersion: process.version,
 94:       platform: process.platform,
 95:       ci: !!process.env.CI,
 96:     },
 97:   };
 98: 
 99:   // Write metadata file
100:   const metadataPath = path.join(telemetryDir, METADATA_FILE);
101:   fs.writeFileSync(metadataPath, JSON.stringify(metadata, null, 2));
102: 
103:   console.log(`\n[E2E Setup] Test run started`);
104:   console.log(`  Run ID: ${runId}`);
105:   console.log(`  Correlation ID: ${correlationId}`);
106:   console.log(`  OTEL: ${otelEnabled ? 'enabled' : 'disabled'}`);
107:   console.log(`  Metadata: ${metadataPath}\n`);
108: }
109: 
110: export default globalSetup;
111: 
112: // Export SDK for teardown
113: export { sdk };
</file>

<file path="tests/e2e/global-teardown.ts">
 1: import { FullConfig } from '@playwright/test';
 2: import fs from 'fs';
 3: import path from 'path';
 4: 
 5: const TELEMETRY_DIR = 'test-results/telemetry';
 6: const METADATA_FILE = 'test-run-metadata.json';
 7: 
 8: interface TestRunMetadata {
 9:   runId: string;
10:   correlationId: string;
11:   startTime: string;
12:   endTime?: string;
13:   duration?: number;
14:   playwright: {
15:     version: string;
16:     projects: string[];
17:   };
18:   otel: {
19:     enabled: boolean;
20:     endpoint: string | null;
21:   };
22:   environment: {
23:     nodeVersion: string;
24:     platform: string;
25:     ci: boolean;
26:   };
27: }
28: 
29: async function globalTeardown(config: FullConfig): Promise<void> {
30:   const endTime = new Date();
31: 
32:   // Flush OpenTelemetry spans
33:   try {
34:     // Dynamic import to avoid issues if SDK wasn't initialized
35:     const { sdk } = await import('./global-setup.js');
36: 
37:     if (sdk) {
38:       await sdk.shutdown();
39: 
40:       if (process.env.OTEL_DEBUG) {
41:         console.log('[OTEL] SDK shutdown complete, spans flushed');
42:       }
43:     }
44:   } catch (error) {
45:     // SDK wasn't initialized or shutdown failed
46:     if (process.env.OTEL_DEBUG) {
47:       console.log('[OTEL] Shutdown skipped:', error);
48:     }
49:   }
50: 
51:   // Update metadata with end time and duration
52:   const telemetryDir = path.join(process.cwd(), TELEMETRY_DIR);
53:   const metadataPath = path.join(telemetryDir, METADATA_FILE);
54: 
55:   try {
56:     if (fs.existsSync(metadataPath)) {
57:       const metadata: TestRunMetadata = JSON.parse(fs.readFileSync(metadataPath, 'utf-8'));
58: 
59:       metadata.endTime = endTime.toISOString();
60:       metadata.duration = endTime.getTime() - new Date(metadata.startTime).getTime();
61: 
62:       fs.writeFileSync(metadataPath, JSON.stringify(metadata, null, 2));
63: 
64:       const durationSec = (metadata.duration / 1000).toFixed(2);
65:       console.log(`\n[E2E Teardown] Test run completed`);
66:       console.log(`  Duration: ${durationSec}s`);
67:       console.log(`  Run ID: ${metadata.runId}`);
68:     }
69:   } catch (error) {
70:     console.error('[E2E Teardown] Failed to update metadata:', error);
71:   }
72: 
73:   // Log HAR files summary
74:   const harDir = path.join(process.cwd(), 'test-results/har');
75:   if (fs.existsSync(harDir)) {
76:     const harFiles = fs.readdirSync(harDir).filter(f => f.endsWith('.har'));
77:     if (harFiles.length > 0) {
78:       console.log(`  HAR files: ${harFiles.length} recorded`);
79:     }
80:   }
81: 
82:   console.log('');
83: }
84: 
85: export default globalTeardown;
</file>

