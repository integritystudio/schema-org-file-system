618:     def _format_duration(self, seconds: float) -> str:
619:         """Format seconds into human-readable duration."""
620:         if seconds < 60:
621:             return f"{seconds:.1f} seconds"
622:         elif seconds < 3600:
623:             return f"{seconds/60:.1f} minutes"
624:         else:
625:             return f"{seconds/3600:.1f} hours"
