<file path="scripts/shared/db_utils.py">
 1: """Shared database connection utilities."""
 2: from __future__ import annotations
 3: import sqlite3
 4: from contextlib import contextmanager
 5: from pathlib import Path
 6: from typing import Generator
 7: 
 8: DEFAULT_DB_PATH = Path(__file__).parent.parent.parent / "results" / "file_organization.db"
 9: 
10: 
11: def get_db_connection(
12:   db_path: Path | str | None = None,
13:   row_factory: bool = True,
14: ) -> sqlite3.Connection:
15:   """Get a SQLite connection.
16: 
17:   Caller is responsible for calling conn.close().
18:   Prefer db_connection() context manager to avoid leaks.
19: 
20:   Args:
21:     db_path: Path to database. Defaults to results/file_organization.db
22:     row_factory: If True, set row_factory to sqlite3.Row
23:   """
24:   path = Path(db_path) if db_path else DEFAULT_DB_PATH
25:   conn = sqlite3.connect(path)
26:   if row_factory:
27:     conn.row_factory = sqlite3.Row
28:   return conn
29: 
30: 
31: @contextmanager
32: def db_connection(
33:   db_path: Path | str | None = None,
34:   row_factory: bool = True,
35: ) -> Generator[sqlite3.Connection, None, None]:
36:   """Context manager that opens and closes a SQLite connection.
37: 
38:   Usage:
39:     with db_connection() as conn:
40:         conn.execute(...)
41:   """
42:   conn = get_db_connection(db_path, row_factory)
43:   try:
44:     yield conn
45:   finally:
46:     conn.close()
</file>

