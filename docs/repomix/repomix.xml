 321:     def add_file_to_category(
 322:         self,
 323:         file_id: str,
 324:         category_name: str,
 325:         subcategory_name: str = None,
 326:         confidence: float = 1.0,
 327:         session: Session = None
 328:     ) -> bool:
 329:         """
 330:         Associate a file with a category.
 331: 
 332:         Args:
 333:             file_id: File ID
 334:             category_name: Main category
 335:             subcategory_name: Optional subcategory
 336:             confidence: Classification confidence
 337:             session: Optional existing session
 338: 
 339:         Returns:
 340:             True if successful
 341:         """
 342:         close_session = session is None
 343:         session = session or self.get_session()
 344: 
 345:         try:
 346:             file = session.query(File).filter(File.id == file_id).first()
 347:             if not file:
 348:                 return False
 349: 
 350:             # Get or create category
 351:             if subcategory_name:
 352:                 # Create parent first
 353:                 parent = self.get_or_create_category(category_name, session=session)
 354:                 category = self.get_or_create_category(subcategory_name, category_name, session=session)
 355:             else:
 356:                 category = self.get_or_create_category(category_name, session=session)
 357: 
 358:             # Guard against None category
 359:             if category is None:
 360:                 return False
 361: 
 362:             # Add relationship if not exists
 363:             if category not in file.categories:
 364:                 file.categories.append(category)
 365:                 category.file_count += 1
 366:                 # Only commit if we own the session
 367:                 if close_session:
 368:                     session.commit()
 369: 
 370:             return True
 371: 
 372:         except Exception as e:
 373:             session.rollback()
 374:             raise e
 375:         finally:
 376:             if close_session:
 377:                 session.close()
