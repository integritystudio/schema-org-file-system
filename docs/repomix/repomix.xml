268:     def is_available(self, feature: str) -> bool:
269:         """Check if a specific feature is available."""
270:         if not self._checked:
271:             self.run_all_checks()
272:         return self.features.get(feature, FeatureStatus("unknown", False)).available
273: 
274:     def get_status(self, feature: str) -> Optional[FeatureStatus]:
275:         """Get detailed status for a feature."""
276:         if not self._checked:
277:             self.run_all_checks()
278:         return self.features.get(feature)
279: 
280:     def print_status(self, verbose: bool = False) -> None:
281:         """Print feature availability status."""
282:         if not self._checked:
283:             self.run_all_checks()
284: 
285:         available_count = sum(1 for f in self.features.values() if f.available)
286:         total_count = len(self.features)
287: 
288:         print("\n" + "=" * SEPARATOR_WIDTH_MEDIUM)
289:         print("SYSTEM HEALTH CHECK")
290:         print("=" * SEPARATOR_WIDTH_MEDIUM)
291: 
292:         for feature in self.features.values():
293:             status = "\033[92m[OK]\033[0m" if feature.available else "\033[91m[--]\033[0m"
294:             version = f" v{feature.version}" if feature.version and feature.available else ""
295:             print(f"  {status} {feature.name}{version}")
296: 
297:             if verbose or not feature.available:
298:                 if feature.error:
299:                     print(f"       Error: {feature.error}")
300:                 if not feature.available:
301:                     print(f"       Impact: {feature.impact}")
302: 
303:         print("-" * SEPARATOR_WIDTH_MEDIUM)
304:         print(f"Features available: {available_count}/{total_count}")
305: 
306:         if available_count == total_count:
307:             print("\033[92mAll features operational!\033[0m")
308:         else:
309:             missing = total_count - available_count
310:             print(f"\033[93m{missing} feature(s) unavailable - see above for install commands\033[0m")
311: 
312:         print("=" * SEPARATOR_WIDTH_MEDIUM + "\n")
313: 
314:     def to_dict(self) -> dict:
315:         """Export status as dictionary."""
316:         if not self._checked:
317:             self.run_all_checks()
318:         return {
319:             name: {
320:                 "available": f.available,
321:                 "version": f.version,
322:                 "error": f.error,
323:                 "impact": f.impact
324:             }
325:             for name, f in self.features.items()
326:         }
327: 
328: 
329: # Singleton instance for easy access
330: _checker: Optional[SystemHealthChecker] = None
331: 
332: 
333: def get_health_checker() -> SystemHealthChecker:
334:     """Get or create the singleton health checker instance."""
335:     global _checker
336:     if _checker is None:
337:         _checker = SystemHealthChecker()
338:     return _checker
339: 
340: 
341: def check_system(verbose: bool = False) -> SystemHealthChecker:
342:     """Run health check and print status."""
343:     checker = get_health_checker()
344:     checker.run_all_checks()
345:     checker.print_status(verbose=verbose)
346:     return checker
347: 
348: 
349: def require_feature(feature: str) -> bool:
350:     """
351:     Check if a feature is available, print warning if not.
352: 
353:     Usage:
354:         if require_feature('clip_vision'):
355:             # Use CLIP model
356:         else:
357:             # Fallback behavior
358:     """
359:     checker = get_health_checker()
360:     if not checker._checked:
361:         checker.run_all_checks()
362: 
363:     status = checker.get_status(feature)
364:     if status and not status.available:
365:         print(f"\033[93mWarning: {status.name} unavailable - {status.impact}\033[0m")
366:         return False
367:     return status.available if status else False
368: 
369: 
370: if __name__ == "__main__":
371:     # Run standalone health check
372:     import argparse
373:     parser = argparse.ArgumentParser(description="Check system dependencies")
374:     parser.add_argument("-v", "--verbose", action="store_true", help="Show detailed output")
375:     args = parser.parse_args()
376: 
377:     check_system(verbose=args.verbose)
