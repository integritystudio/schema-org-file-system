412:     def export_rules(self) -> Dict:
413:         """Export learned rules for integration with the file organizer.
414: 
415:         Returns:
416:             Dictionary of rules that can be applied to improve categorization
417:         """
418:         rules = {
419:             "pattern_rules": [],
420:             "content_rules": [],
421:             "extension_rules": {}
422:         }
423: 
424:         # Extract high-confidence pattern rules
425:         for pattern, data in self.data["learned_patterns"].items():
426:             if data["categories"]:
427:                 total = sum(data["categories"].values())
428:                 best_cat = max(data["categories"].items(), key=lambda x: x[1])
429:                 confidence = best_cat[1] / total
430: 
431:                 if total >= 3 and confidence >= 0.7:
432:                     best_subcat = None
433:                     if data["subcategories"]:
434:                         best_subcat = max(data["subcategories"].items(), key=lambda x: x[1])[0]
435: 
436:                     rules["pattern_rules"].append({
437:                         "pattern": pattern,
438:                         "category": best_cat[0],
439:                         "subcategory": best_subcat,
440:                         "confidence": round(confidence, 3),
441:                         "sample_count": total
442:                     })
443: 
444:         # Sort by sample count
445:         rules["pattern_rules"].sort(key=lambda x: -x["sample_count"])
446: 
447:         # Extract content hint rules
448:         content_hints = defaultdict(lambda: defaultdict(int))
449:         for correction in self.data["corrections"].values():
450:             for hint in correction.get("content_hints", []):
451:                 content_hints[hint][correction["correct_category"]] += 1
452: 
453:         for hint, categories in content_hints.items():
454:             total = sum(categories.values())
455:             best_cat = max(categories.items(), key=lambda x: x[1])
456:             confidence = best_cat[1] / total
457: 
458:             if total >= 2 and confidence >= 0.7:
459:                 rules["content_rules"].append({
460:                     "hint": hint,
461:                     "category": best_cat[0],
462:                     "confidence": round(confidence, 3),
463:                     "sample_count": total
464:                 })
465: 
466:         rules["content_rules"].sort(key=lambda x: -x["sample_count"])
467: 
468:         return rules
