276:     metrics = evaluation['overall_metrics']
277:     print(f"  Category Accuracy:    {metrics['accuracy']:.2%}")
278:     print(f"  Subcategory Accuracy: {metrics['subcategory_accuracy']:.2%}")
279:     print(f"  Avg Confidence:       {metrics['avg_confidence']:.2%}")
280:     print(f"  Correct Predictions:  {metrics['total_correct']:,}")
281:     print(f"  Incorrect Predictions:{metrics['total_incorrect']:,}")
282: 
283:     print("\n" + "-" * 40)
