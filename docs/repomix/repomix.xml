 1: """Shared OCR text extraction."""
 2: from __future__ import annotations
 3: from pathlib import Path
 4: 
 5: OCR_AVAILABLE = False
 6: try:
 7:   import pytesseract
 8:   from PIL import Image
 9:   OCR_AVAILABLE = True
10: except ImportError:
11:   pass
12: 
13: # HEIC support
14: try:
15:   from pillow_heif import register_heif_opener
16:   register_heif_opener()
17: except ImportError:
18:   pass
19: 
20: 
21: def is_ocr_available() -> bool:
22:   return OCR_AVAILABLE
23: 
24: 
25: def extract_ocr_text(
26:   image_path: Path,
27:   max_chars: int = 500,
28:   config: str = "",
29:   timeout: int = 10,
30: ) -> str | None:
31:   """Extract text from image using OCR.
32: 
33:   Handles RGB conversion, text cleanup, and truncation.
34:   Returns None if OCR unavailable or no text found.
35:   """
36:   if not OCR_AVAILABLE:
37:     return None
38:   try:
39:     with Image.open(image_path) as img:
40:       if img.mode != 'RGB':
41:         img = img.convert('RGB')
42:       text = pytesseract.image_to_string(img, timeout=timeout, config=config)
43:     text = ' '.join(text.split())
44:     if max_chars and len(text) > max_chars:
45:       text = text[:max_chars] + "..."
46:     return text if text.strip() else None
47:   except Exception:
48:     return None
