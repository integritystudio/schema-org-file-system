797:         Index('ix_merge_performed_at', 'performed_at'),
798:     )
799: 
800:     def generate_jsonld(self) -> dict:
801:         """
802:         Generate JSON-LD with owl:sameAs for this merge event.
803: 
804:         Returns:
805:             JSON-LD dict representing the merge
806:         """
807:         target_iri = f"urn:uuid:{self.target_canonical_id}" if self.target_canonical_id else None
808:         source_iris = [f"urn:uuid:{cid}" for cid in (self.source_canonical_ids or [])]
809: 
810:         return {
811:             "@context": {
812:                 "@vocab": "https://schema.org/",
813:                 "owl": "http://www.w3.org/2002/07/owl#"
814:             },
815:             "@type": "MergeAction",
816:             "@id": f"urn:uuid:{self.id}",
817:             "targetEntity": {
818:                 "@id": target_iri,
819:                 "owl:sameAs": source_iris if len(source_iris) > 1 else source_iris[0] if source_iris else None
820:             },
821:             "description": self.merge_reason,
822:             "confidence": self.confidence,
823:             "agent": self.performed_by,
824:             "startTime": self.performed_at.isoformat() if self.performed_at else None
825:         }
826: 
827:     def to_dict(self) -> Dict[str, Any]:
828:         return {
829:             'id': self.id,
830:             'target_entity_type': self.target_entity_type.value if self.target_entity_type else None,
831:             'target_entity_id': self.target_entity_id,
832:             'target_canonical_id': self.target_canonical_id,
833:             'source_entity_ids': self.source_entity_ids,
834:             'source_canonical_ids': self.source_canonical_ids,
835:             'merge_reason': self.merge_reason,
836:             'confidence': self.confidence,
837:             'performed_by': self.performed_by,
838:             'performed_at': self.performed_at.isoformat() if self.performed_at else None,
839:             'is_rolled_back': self.is_rolled_back,
840:         }
841: 
842: 
843: def init_db(db_path: str = 'file_organization.db') -> Session:
844:     """
845:     Initialize the database and return a session.
846: 
847:     Args:
848:         db_path: Path to SQLite database file
849: 
850:     Returns:
851:         SQLAlchemy Session
852:     """
853:     engine = create_engine(f'sqlite:///{db_path}', echo=False)
854: 
855:     # Enable foreign keys for SQLite
856:     @event.listens_for(engine, "connect")
857:     def set_sqlite_pragma(dbapi_connection, connection_record):
858:         cursor = dbapi_connection.cursor()
859:         cursor.execute("PRAGMA foreign_keys=ON")
860:         cursor.execute("PRAGMA journal_mode=WAL")  # Better concurrency
861:         cursor.close()
862: 
863:     # Create all tables
864:     Base.metadata.create_all(engine)
865: 
866:     # Create session factory
867:     SessionLocal = sessionmaker(bind=engine)
868: 
869:     return SessionLocal()
870: 
871: 
872: def get_session(db_path: str = 'file_organization.db') -> Session:
873:     """Get a database session."""
874:     return init_db(db_path)
