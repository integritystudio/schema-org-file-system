3041:     def enhance_weak_image_classification(
3042:         self, file_path: Path, image_metadata: Dict = None
3043:     ) -> Optional[Tuple[str, str]]:
3044:         """Run full 20-category CLIP + OCR fallback for weakly classified images.
3045: 
3046:         Only called for images that would otherwise land in photos_other or uncategorized.
3047:         Returns (category, subcategory) or None to keep original classification.
3048:         """
3049:         if not ENHANCED_CLIP_AVAILABLE or not self.image_analyzer.vision_available:
3050:             return None
3051:         if not self.image_analyzer.model or not self.image_analyzer.processor:
3052:             return None
3053: 
3054:         try:
3055:             image = Image.open(file_path)
3056:         except Exception as e:
3057:             print(f"  CLIP enhance: cannot open image: {e}")
3058:             return None
3059: 
3060:         # Run full 20-category CLIP classification
3061:         try:
3062:             inputs = self.image_analyzer.processor(
3063:                 text=CLIP_CATEGORY_PROMPTS, images=image,
3064:                 return_tensors="pt", padding=True,
3065:             )
3066:             with torch.no_grad():
3067:                 probs = self.image_analyzer.model(**inputs).logits_per_image.softmax(dim=1)
3068:             scores = {label: float(probs[0][i]) for i, label in enumerate(CLIP_CONTENT_LABELS)}
3069:             best_label = max(scores, key=scores.get)
3070:             best_score = scores[best_label]
3071:             print(f"  CLIP enhance: {best_label} ({best_score:.1%})")
3072:         except Exception as e:
3073:             print(f"  CLIP enhance error: {e}")
3074:             return None
3075: 
3076:         if best_score < CLIP_ENHANCE_THRESHOLD:
3077:             return None
3078: 
3079:         # High confidence — map directly, skip OCR
3080:         if best_score >= CLIP_ENHANCE_HIGH_THRESHOLD:
3081:             result = self._map_clip_label(best_label, image_metadata)
3082:             if result:
3083:                 print(f"  CLIP enhance → {result[0]}/{result[1]} (high confidence)")
3084:                 return result
3085: 
3086:         # Medium confidence — try OCR first, fall back to CLIP mapping
3087:         if self.ocr_available:
3088:             try:
3089:                 ocr_text = self.extract_text_from_image(file_path)
3090:                 if ocr_text and len(ocr_text) >= 30:
3091:                     text_cat, text_subcat, _, _ = self.classifier.classify_content(ocr_text, file_path.name)
3092:                     if text_cat != "uncategorized":
3093:                         print(f"  CLIP enhance → {text_cat}/{text_subcat} (OCR fallback)")
3094:                         return (text_cat, text_subcat)
3095:             except Exception as e:
3096:                 print(f"  CLIP enhance OCR error: {e}")
3097: 
3098:         result = self._map_clip_label(best_label, image_metadata)
3099:         if result:
3100:             print(f"  CLIP enhance → {result[0]}/{result[1]} (medium confidence)")
3101:         return result
