  1: #!/usr/bin/env python3
  2: """
  3: Simple file organizer based on file extensions and naming patterns.
  4: Organizes files by type without OCR.
  5: """
  6: 
  7: import os
  8: import shutil
  9: from pathlib import Path
 10: from collections import defaultdict
 11: from datetime import datetime
 12: 
 13: 
 14: class FileTypeOrganizer:
 15:     """Organize files based on file type and naming patterns."""
 16: 
 17:     def __init__(self, base_path: str = None):
 18:         """Initialize the organizer."""
 19:         self.base_path = Path(base_path or "~/Documents").expanduser()
 20:         self.stats = defaultdict(int)
 21: 
 22:         # File type to category mapping
 23:         self.type_mapping = {
 24:             # Images
 25:             'Images/Photos': ['.jpg', '.jpeg', '.png', '.heic', '.gif', '.bmp', '.webp', '.svg'],
 26: 
 27:             # Documents
 28:             'Documents/PDFs': ['.pdf'],
 29:             'Documents/Word': ['.doc', '.docx'],
 30:             'Documents/Excel': ['.xls', '.xlsx', '.csv'],
 31:             'Documents/PowerPoint': ['.ppt', '.pptx'],
 32:             'Documents/Text': ['.txt', '.md', '.rtf'],
 33: 
 34:             # Code
 35:             'Code/Python': ['.py'],
 36:             'Code/JavaScript': ['.js', '.jsx', '.mjs'],
 37:             'Code/TypeScript': ['.ts', '.tsx'],
 38:             'Code/Shell': ['.sh', '.bash', '.zsh'],
 39:             'Code/Web': ['.html', '.css', '.scss', '.sass'],
 40: 
 41:             # Data/Config
 42:             'Data/YAML': ['.yaml', '.yml'],
 43:             'Data/JSON': ['.json'],
 44:             'Data/XML': ['.xml'],
 45:             'Data/Config': ['.conf', '.config', '.ini', '.env', '.toml'],
 46: 
 47:             # Media
 48:             'Media/Audio': ['.mp3', '.wav', '.ogg', '.flac', '.m4a', '.aac'],
 49:             'Media/Video': ['.mp4', '.mov', '.avi', '.mkv', '.webm'],
 50: 
 51:             # Archives
 52:             'Archives': ['.zip', '.tar', '.gz', '.rar', '.7z', '.bz2'],
 53: 
 54:             # Fonts
 55:             'Fonts': ['.ttf', '.otf', '.woff', '.woff2'],
 56: 
 57:             # Other
 58:             'Other/Executables': ['.exe', '.app', '.pkg', '.dmg'],
 59:             'Other/Misc': ['.noe', '.tpl', '.lark', '.proto', '.rst'],
 60:         }
 61: 
 62:     def get_category_for_file(self, file_path: Path) -> str:
 63:         """Determine category based on file extension."""
 64:         ext = file_path.suffix.lower()
 65:         name_lower = file_path.name.lower()
 66: 
 67:         # Check for special naming patterns BEFORE general type mapping
 68:         # Screenshots - check first so they don't get categorized as generic images
 69:         if name_lower.startswith('screenshot'):
 70:             return 'Images/Photos/Screenshots'
 71: 
 72:         # Game assets (lots of numbered/timestamped files)
 73:         if any(pattern in name_lower for pattern in ['frame', 'item', 'segment', 'wing', 'arm', 'leg', 'head', 'torso']):
 74:             return 'Images/Photos/GameAssets'
 75: 
 76:         # Check file type mappings
 77:         for category, extensions in self.type_mapping.items():
 78:             if ext in extensions:
 79:                 return category
 80: 
 81:         # Timezone files
 82:         if file_path.suffix == '' and len(file_path.name.split('_')) == 1:
 83:             # Could be timezone file
 84:             return 'Data/Timezones'
 85: 
 86:         return 'Uncategorized'
 87: 
 88:     def should_skip_file(self, file_path: Path) -> bool:
 89:         """Check if file should be skipped."""
 90:         skip_files = {'.DS_Store', '.localized', 'Thumbs.db', 'desktop.ini'}
 91:         skip_dirs = {'__pycache__', '.git', 'node_modules', '.venv', 'venv'}
 92: 
 93:         if file_path.name.startswith('.') and file_path.name not in {'.gitignore', '.env.example'}:
 94:             return True
 95: 
 96:         if file_path.name in skip_files:
 97:             return True
 98: 
 99:         if any(skip_dir in file_path.parts for skip_dir in skip_dirs):
100:             return True
101: 
102:         return False
103: 
104:     def organize_file(self, file_path: Path, dry_run: bool = False) -> dict:
105:         """Organize a single file based on type."""
106:         result = {
107:             'source': str(file_path),
108:             'status': 'skipped',
109:             'destination': None,
110:             'category': None
111:         }
112: 
113:         if self.should_skip_file(file_path):
114:             self.stats['skipped'] += 1
115:             return result
116: 
117:         if not file_path.is_file():
118:             self.stats['skipped'] += 1
119:             return result
120: 
121:         try:
122:             # Get category
123:             category = self.get_category_for_file(file_path)
124:             result['category'] = category
125: 
126:             # Create destination path
127:             dest_dir = self.base_path / category
128:             dest_dir.mkdir(parents=True, exist_ok=True)
129: 
130:             # Handle duplicate filenames
131:             dest_path = dest_dir / file_path.name
132:             if dest_path.exists() and dest_path != file_path:
133:                 stem = file_path.stem
134:                 suffix = file_path.suffix
135:                 timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
136:                 dest_path = dest_dir / f"{stem}_{timestamp}{suffix}"
137: 
138:             # Skip if already in right place
139:             if file_path.parent == dest_dir:
140:                 result['status'] = 'already_organized'
141:                 result['destination'] = str(dest_path)
142:                 self.stats['already_organized'] += 1
143:                 return result
144: 
145:             # Move file if not dry run
146:             if not dry_run:
147:                 shutil.move(str(file_path), str(dest_path))
148:                 result['status'] = 'organized'
149:             else:
150:                 result['status'] = 'would_organize'
151: 
152:             result['destination'] = str(dest_path)
153:             self.stats['organized'] += 1
154:             self.stats[f'category_{category}'] += 1
155: 
156:         except Exception as e:
157:             result['status'] = 'error'
158:             result['error'] = str(e)
159:             self.stats['errors'] += 1
160:             print(f"  Error: {e}")
161: 
162:         return result
163: 
164:     def organize_directory(self, source_dir: str, dry_run: bool = False) -> dict:
165:         """Organize files from source directory."""
166:         results = []
167:         source_path = Path(source_dir).expanduser()
168: 
169:         print(f"\n{'='*60}")
170:         print(f"File Type Organization {'(DRY RUN)' if dry_run else ''}")
171:         print(f"{'='*60}\n")
172:         print(f"Source: {source_path}")
173:         print(f"Base: {self.base_path}\n")
174: 
175:         # Collect all files
176:         all_files = []
177:         for item in source_path.rglob('*'):
178:             if item.is_file() and not self.should_skip_file(item):
179:                 all_files.append(item)
180: 
181:         print(f"Total files to process: {len(all_files)}\n")
182: 
183:         # Process each file
184:         for i, file_path in enumerate(all_files, 1):
185:             if i % 100 == 0:
186:                 print(f"[{i}/{len(all_files)}] Processing...")
187: 
188:             result = self.organize_file(file_path, dry_run=dry_run)
189:             results.append(result)
190: 
191:         # Generate summary
192:         summary = {
193:             'total_files': len(all_files),
194:             'organized': self.stats['organized'],
195:             'already_organized': self.stats['already_organized'],
196:             'skipped': self.stats['skipped'],
197:             'errors': self.stats['errors'],
198:             'dry_run': dry_run,
199:             'results': results
200:         }
201: 
202:         return summary
203: 
204:     def print_summary(self, summary: dict):
205:         """Print organization summary."""
206:         print(f"\n{'='*60}")
207:         print("Organization Summary")
208:         print(f"{'='*60}\n")
209: 
210:         print(f"Total files processed: {summary['total_files']}")
211:         print(f"Successfully organized: {summary['organized']}")
212:         print(f"Already organized: {summary['already_organized']}")
213:         print(f"Skipped: {summary['skipped']}")
214:         print(f"Errors: {summary['errors']}")
215: 
216:         if summary['dry_run']:
217:             print("\n⚠️  This was a DRY RUN - no files were moved")
218: 
219:         # Category breakdown
220:         print(f"\n{'='*60}")
221:         print("Category Breakdown")
222:         print(f"{'='*60}\n")
223: 
224:         category_stats = defaultdict(int)
225:         for result in summary['results']:
226:             if result.get('category'):
227:                 category_stats[result['category']] += 1
228: 
229:         for category, count in sorted(category_stats.items(), key=lambda x: x[1], reverse=True):
230:             print(f"{category}: {count} files")
231: 
232: 
233: def main():
234:     """Main entry point."""
235:     import argparse
236: 
237:     parser = argparse.ArgumentParser(
238:         description='Organize files by type based on extensions'
239:     )
240:     parser.add_argument(
241:         '--dry-run',
242:         action='store_true',
243:         help='Simulate organization without moving files'
244:     )
245:     parser.add_argument(
246:         '--base-path',
247:         default='~/Documents',
248:         help='Base path for organized files (default: ~/Documents)'
249:     )
250:     parser.add_argument(
251:         '--source',
252:         default='~/Documents/Uncategorized',
253:         help='Source directory to organize (default: ~/Documents/Uncategorized)'
254:     )
255: 
256:     args = parser.parse_args()
257: 
258:     # Create organizer
259:     organizer = FileTypeOrganizer(base_path=args.base_path)
260: 
261:     # Organize directory
262:     summary = organizer.organize_directory(
263:         source_dir=args.source,
264:         dry_run=args.dry_run
265:     )
266: 
267:     # Print summary
268:     organizer.print_summary(summary)
269: 
270: 
271: if __name__ == '__main__':
272:     main()
