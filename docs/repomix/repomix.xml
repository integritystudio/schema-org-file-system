214:     `  FCP: ${metrics.fcp !== null ? `${metrics.fcp.toFixed(0)}ms` : 'N/A'}`,
215:     `  CLS: ${metrics.cls !== null ? metrics.cls.toFixed(3) : 'N/A'}`,
216:     `  TTFB: ${metrics.ttfb !== null ? `${metrics.ttfb.toFixed(0)}ms` : 'N/A'}`,
217:     `Page Load:`,
218:     `  DOMContentLoaded: ${metrics.domContentLoaded !== null ? `${metrics.domContentLoaded.toFixed(0)}ms` : 'N/A'}`,
219:     `  Load Complete: ${metrics.loadComplete !== null ? `${metrics.loadComplete.toFixed(0)}ms` : 'N/A'}`,
220:     `Resources:`,
