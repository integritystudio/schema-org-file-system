598:     def _seconds_to_iso_duration(self, seconds: Union[int, float]) -> str:
599:         """
600:         Convert seconds to ISO 8601 duration format.
601: 
602:         Args:
603:             seconds: Duration in seconds
604: 
605:         Returns:
606:             ISO 8601 duration string (e.g., 'PT1H30M')
607:         """
608:         hours = int(seconds // SECONDS_PER_HOUR)
609:         minutes = int((seconds % SECONDS_PER_HOUR) // SECONDS_PER_MINUTE)
610:         secs = int(seconds % SECONDS_PER_MINUTE)
611: 
612:         parts = ['PT']
613:         if hours > 0:
614:             parts.append(f'{hours}H')
615:         if minutes > 0:
616:             parts.append(f'{minutes}M')
617:         if secs > 0 or (hours == 0 and minutes == 0):
618:             parts.append(f'{secs}S')
619: 
620:         return ''.join(parts)
