  1: """
  2: Sentry Error Tracking Module
  3: 
  4: Provides comprehensive error tracking and performance monitoring
  5: for the Schema.org File Organization System using Sentry SDK v2.
  6: 
  7: Usage:
  8:     from error_tracking import init_sentry, capture_error, track_operation
  9: 
 10:     # Initialize at app startup
 11:     init_sentry()
 12: 
 13:     # Capture errors
 14:     try:
 15:         process_file(path)
 16:     except Exception as e:
 17:         capture_error(e, context={'file_path': path})
 18: 
 19:     # Track performance
 20:     with track_operation('classify_image', file_path=path):
 21:         result = classifier.classify(image)
 22: """
 23: 
 24: import os
 25: import functools
 26: from typing import Optional, Dict, Any, Callable
 27: from contextlib import contextmanager
 28: 
 29: from constants import DEFAULT_TRACES_SAMPLE_RATE, DEFAULT_PROFILES_SAMPLE_RATE
 30: 
 31: # Sentry SDK import with graceful degradation
 32: try:
 33:     import sentry_sdk
 34:     from sentry_sdk import capture_exception, capture_message, set_tag, set_context
 35:     SENTRY_AVAILABLE = True
 36: except ImportError:
 37:     SENTRY_AVAILABLE = False
 38:     # Stub implementations
 39:     def capture_exception(*args, **kwargs): pass
 40:     def capture_message(*args, **kwargs): pass
 41:     def set_tag(*args, **kwargs): pass
 42:     def set_context(*args, **kwargs): pass
 43: 
 44: 
 45: # Error severity levels
 46: class ErrorLevel:
 47:     FATAL = 'fatal'      # System unusable
 48:     ERROR = 'error'      # Operation failed
 49:     WARNING = 'warning'  # Recoverable issue
 50:     INFO = 'info'        # Informational
 51:     DEBUG = 'debug'      # Debug only
 52: 
 53: 
 54: def init_sentry(
 55:     dsn: Optional[str] = None,
 56:     environment: Optional[str] = None,
 57:     traces_sample_rate: float = DEFAULT_TRACES_SAMPLE_RATE,
 58:     profiles_sample_rate: float = DEFAULT_PROFILES_SAMPLE_RATE,
 59:     enable_logs: bool = True
 60: ) -> bool:
 61:     """
 62:     Initialize Sentry error tracking.
 63: 
 64:     Args:
 65:         dsn: Sentry DSN (defaults to SENTRY_DSN env var)
 66:         environment: Environment name (defaults to NODE_ENV or 'development')
 67:         traces_sample_rate: Percentage of transactions to trace (0.0-1.0)
 68:         profiles_sample_rate: Percentage of transactions to profile (0.0-1.0)
 69:         enable_logs: Whether to enable Sentry logs
 70: 
 71:     Returns:
 72:         True if Sentry initialized successfully, False otherwise
 73:     """
 74:     if not SENTRY_AVAILABLE:
 75:         print("Warning: sentry-sdk not installed. Error tracking disabled.")
 76:         print("Install with: pip install sentry-sdk")
 77:         return False
 78: 
 79:     dsn = dsn or os.environ.get('SENTRY_DSN')
 80:     if not dsn:
 81:         print("Warning: SENTRY_DSN not set. Error tracking disabled.")
 82:         return False
 83: 
 84:     environment = environment or os.environ.get('NODE_ENV', 'development')
 85: 
 86:     try:
 87:         sentry_sdk.init(
 88:             dsn=dsn,
 89:             environment=environment,
 90:             traces_sample_rate=traces_sample_rate,
 91:             profiles_sample_rate=profiles_sample_rate,
 92:             send_default_pii=False,  # Don't send PII by default
 93:             attach_stacktrace=True,
 94:             # Release tracking
 95:             release=os.environ.get('APP_VERSION', '1.2.0'),
 96:         )
 97: 
 98:         # Set default tags
 99:         set_tag('service', 'schema-org-file-system')
100:         set_tag('python_version', os.sys.version.split()[0])
101: 
102:         print(f"Sentry initialized for environment: {environment}")
103:         return True
104: 
105:     except Exception as e:
106:         print(f"Warning: Failed to initialize Sentry: {e}")
107:         return False
