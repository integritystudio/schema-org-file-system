  1: #!/usr/bin/env python3
  2: """
  3: Key-Value storage for flexible, schema-less data.
  4: 
  5: Provides a Redis-like interface using SQLite for persistence.
  6: Supports namespacing, TTL, and JSON values.
  7: 
  8: Design allows easy migration to Redis/Memcached in the future.
  9: """
 10: 
 11: import json
 12: import hashlib
 13: from datetime import datetime, timedelta
 14: from typing import Any, Dict, List, Optional, Union
 15: from contextlib import contextmanager
 16: 
 17: from sqlalchemy import create_engine, event, func, and_
 18: from sqlalchemy.orm import Session, sessionmaker
 19: 
 20: from .models import Base, KeyValueStore
 21: 
 22: 
 23: class KeyValueStorage:
 24:     """
 25:     Key-Value storage with namespace support.
 26: 
 27:     Features:
 28:     - Namespace isolation (like Redis databases)
 29:     - TTL support for automatic expiration
 30:     - JSON value serialization
 31:     - Atomic increment/decrement operations
 32:     - Pattern-based key scanning
 33: 
 34:     Can be swapped with Redis by implementing the same interface.
 35:     """
 36: 
 37:     # Default namespaces
 38:     NAMESPACE_CACHE = 'cache'           # Temporary cached data
 39:     NAMESPACE_CONFIG = 'config'         # Configuration values
 40:     NAMESPACE_METADATA = 'metadata'     # File metadata overflow
 41:     NAMESPACE_STATS = 'stats'           # Statistics and counters
 42:     NAMESPACE_SESSION = 'session'       # Session-specific data
 43:     NAMESPACE_FEATURE = 'feature'       # Feature flags
 44: 
 45:     def __init__(self, db_path: str = 'results/file_organization.db'):
 46:         """
 47:         Initialize key-value storage.
 48: 
 49:         Args:
 50:             db_path: Path to SQLite database (shared with graph store)
 51:         """
 52:         self.db_path = db_path
 53:         self.engine = create_engine(f'sqlite:///{db_path}', echo=False)
 54: 
 55:         # SQLite optimizations
 56:         @event.listens_for(self.engine, "connect")
 57:         def set_sqlite_pragma(dbapi_connection, connection_record):
 58:             cursor = dbapi_connection.cursor()
 59:             cursor.execute("PRAGMA foreign_keys=ON")
 60:             cursor.execute("PRAGMA journal_mode=WAL")
 61:             cursor.close()
 62: 
 63:         # Create tables
 64:         Base.metadata.create_all(self.engine)
 65: 
 66:         self.SessionLocal = sessionmaker(bind=self.engine)
 67: 
 68:     def get_session(self) -> Session:
 69:         """Get a database session."""
 70:         return self.SessionLocal()
 71: 
 72:     @contextmanager
 73:     def session_scope(self):
 74:         """Provide a transactional scope around a series of operations."""
 75:         session = self.get_session()
 76:         try:
 77:             yield session
 78:             session.commit()
 79:         except Exception:
 80:             session.rollback()
 81:             raise
 82:         finally:
 83:             session.close()
 84: 
 85:     # =========================================================================
 86:     # Basic Operations
 87:     # =========================================================================
 88: 
 89:     def get(
 90:         self,
 91:         key: str,
 92:         namespace: str = NAMESPACE_CACHE,
 93:         default: Any = None
 94:     ) -> Any:
 95:         """
 96:         Get a value by key.
 97: 
 98:         Args:
 99:             key: The key to retrieve
100:             namespace: Namespace for the key
101:             default: Default value if key doesn't exist
102: 
103:         Returns:
104:             The value or default
105:         """
106:         with self.session_scope() as session:
107:             record = session.query(KeyValueStore).filter(
108:                 and_(
109:                     KeyValueStore.namespace == namespace,
110:                     KeyValueStore.key == key
111:                 )
112:             ).first()
113: 
114:             if not record:
115:                 return default
116: 
117:             # Check TTL
118:             if record.expires_at and record.expires_at < datetime.utcnow():
119:                 session.delete(record)
120:                 return default
121: 
122:             return record.value
123: 
124:     def set(
125:         self,
126:         key: str,
127:         value: Any,
128:         namespace: str = NAMESPACE_CACHE,
129:         ttl_seconds: int = None,
130:         file_id: str = None
131:     ) -> bool:
132:         """
133:         Set a value.
134: 
135:         Args:
136:             key: The key to set
137:             value: The value (will be JSON serialized)
138:             namespace: Namespace for the key
139:             ttl_seconds: Time-to-live in seconds (None for permanent)
140:             file_id: Optional file association
141: 
142:         Returns:
143:             True if successful
144:         """
145:         with self.session_scope() as session:
146:             # Calculate expiration
147:             expires_at = None
148:             if ttl_seconds:
149:                 expires_at = datetime.utcnow() + timedelta(seconds=ttl_seconds)
150: 
151:             # Determine value type
152:             value_type = self._get_value_type(value)
153: 
154:             # Check if exists
155:             record = session.query(KeyValueStore).filter(
156:                 and_(
157:                     KeyValueStore.namespace == namespace,
158:                     KeyValueStore.key == key
159:                 )
160:             ).first()
161: 
162:             if record:
163:                 record.value = value
164:                 record.value_type = value_type
165:                 record.expires_at = expires_at
166:                 record.file_id = file_id
167:                 record.updated_at = datetime.utcnow()
168:             else:
169:                 record = KeyValueStore(
170:                     namespace=namespace,
171:                     key=key,
172:                     value=value,
173:                     value_type=value_type,
174:                     expires_at=expires_at,
175:                     file_id=file_id
176:                 )
177:                 session.add(record)
178: 
179:             return True
180: 
181:     def delete(self, key: str, namespace: str = NAMESPACE_CACHE) -> bool:
182:         """
183:         Delete a key.
184: 
185:         Args:
186:             key: The key to delete
187:             namespace: Namespace for the key
188: 
189:         Returns:
190:             True if key existed and was deleted
191:         """
192:         with self.session_scope() as session:
193:             result = session.query(KeyValueStore).filter(
194:                 and_(
195:                     KeyValueStore.namespace == namespace,
196:                     KeyValueStore.key == key
197:                 )
198:             ).delete()
199:             return result > 0
200: 
201:     def exists(self, key: str, namespace: str = NAMESPACE_CACHE) -> bool:
202:         """
203:         Check if a key exists.
204: 
205:         Args:
206:             key: The key to check
207:             namespace: Namespace for the key
208: 
209:         Returns:
210:             True if key exists and hasn't expired
211:         """
212:         with self.session_scope() as session:
213:             record = session.query(KeyValueStore).filter(
214:                 and_(
215:                     KeyValueStore.namespace == namespace,
216:                     KeyValueStore.key == key
217:                 )
218:             ).first()
219: 
220:             if not record:
221:                 return False
222: 
223:             # Check TTL
224:             if record.expires_at and record.expires_at < datetime.utcnow():
225:                 session.delete(record)
226:                 return False
227: 
228:             return True
229: 
230:     # =========================================================================
231:     # Batch Operations
232:     # =========================================================================
233: 
234:     def mget(
235:         self,
236:         keys: List[str],
237:         namespace: str = NAMESPACE_CACHE
238:     ) -> Dict[str, Any]:
239:         """
240:         Get multiple values at once.
241: 
242:         Args:
243:             keys: List of keys to retrieve
244:             namespace: Namespace for the keys
245: 
246:         Returns:
247:             Dictionary of key -> value (missing keys omitted)
248:         """
249:         with self.session_scope() as session:
250:             records = session.query(KeyValueStore).filter(
251:                 and_(
252:                     KeyValueStore.namespace == namespace,
253:                     KeyValueStore.key.in_(keys)
254:                 )
255:             ).all()
256: 
257:             now = datetime.utcnow()
258:             result = {}
259: 
260:             for record in records:
261:                 if record.expires_at and record.expires_at < now:
262:                     session.delete(record)
263:                     continue
264:                 result[record.key] = record.value
265: 
266:             return result
267: 
268:     def mset(
269:         self,
270:         mapping: Dict[str, Any],
271:         namespace: str = NAMESPACE_CACHE,
272:         ttl_seconds: int = None
273:     ) -> bool:
274:         """
275:         Set multiple values at once.
276: 
277:         Args:
278:             mapping: Dictionary of key -> value
279:             namespace: Namespace for the keys
280:             ttl_seconds: Optional TTL for all keys
281: 
282:         Returns:
283:             True if successful
284:         """
285:         for key, value in mapping.items():
286:             self.set(key, value, namespace, ttl_seconds)
287:         return True
288: 
289:     # =========================================================================
290:     # Counter Operations
291:     # =========================================================================
292: 
293:     def incr(
294:         self,
295:         key: str,
296:         amount: int = 1,
297:         namespace: str = NAMESPACE_STATS
298:     ) -> int:
299:         """
300:         Increment a counter.
301: 
302:         Args:
303:             key: The counter key
304:             amount: Amount to increment by
305:             namespace: Namespace for the counter
306: 
307:         Returns:
308:             New counter value
309:         """
310:         with self.session_scope() as session:
311:             record = session.query(KeyValueStore).filter(
312:                 and_(
313:                     KeyValueStore.namespace == namespace,
314:                     KeyValueStore.key == key
315:                 )
316:             ).first()
317: 
318:             if record:
319:                 current = record.value or 0
320:                 record.value = current + amount
321:                 record.updated_at = datetime.utcnow()
322:                 return record.value
323:             else:
324:                 record = KeyValueStore(
325:                     namespace=namespace,
326:                     key=key,
327:                     value=amount,
328:                     value_type='int'
329:                 )
330:                 session.add(record)
331:                 return amount
332: 
333:     def decr(
334:         self,
335:         key: str,
336:         amount: int = 1,
337:         namespace: str = NAMESPACE_STATS
338:     ) -> int:
339:         """
340:         Decrement a counter.
341: 
342:         Args:
343:             key: The counter key
344:             amount: Amount to decrement by
345:             namespace: Namespace for the counter
346: 
347:         Returns:
348:             New counter value
349:         """
350:         return self.incr(key, -amount, namespace)
351: 
352:     def incrby_float(
353:         self,
354:         key: str,
355:         amount: float,
356:         namespace: str = NAMESPACE_STATS
357:     ) -> float:
358:         """
359:         Increment a float counter.
360: 
361:         Args:
362:             key: The counter key
363:             amount: Amount to increment by
364:             namespace: Namespace for the counter
365: 
366:         Returns:
367:             New counter value
368:         """
369:         with self.session_scope() as session:
370:             record = session.query(KeyValueStore).filter(
371:                 and_(
372:                     KeyValueStore.namespace == namespace,
373:                     KeyValueStore.key == key
374:                 )
375:             ).first()
376: 
377:             if record:
378:                 current = float(record.value or 0)
379:                 record.value = current + amount
380:                 record.value_type = 'float'
381:                 record.updated_at = datetime.utcnow()
382:                 return record.value
383:             else:
384:                 record = KeyValueStore(
385:                     namespace=namespace,
386:                     key=key,
387:                     value=amount,
388:                     value_type='float'
389:                 )
390:                 session.add(record)
391:                 return amount
392: 
393:     # =========================================================================
394:     # Scan and Pattern Matching
395:     # =========================================================================
396: 
397:     def keys(
398:         self,
399:         pattern: str = '*',
400:         namespace: str = NAMESPACE_CACHE
401:     ) -> List[str]:
402:         """
403:         Get all keys matching a pattern.
404: 
405:         Args:
406:             pattern: Glob-style pattern (* for wildcard)
407:             namespace: Namespace to search
408: 
409:         Returns:
410:             List of matching keys
411:         """
412:         with self.session_scope() as session:
413:             query = session.query(KeyValueStore.key).filter(
414:                 KeyValueStore.namespace == namespace
415:             )
416: 
417:             if pattern != '*':
418:                 # Convert glob to SQL LIKE
419:                 sql_pattern = pattern.replace('*', '%').replace('?', '_')
420:                 query = query.filter(KeyValueStore.key.like(sql_pattern))
421: 
422:             return [row[0] for row in query.all()]
423: 
424:     def scan(
425:         self,
426:         namespace: str = NAMESPACE_CACHE,
427:         match: str = None,
428:         count: int = 100,
429:         cursor: int = 0
430:     ) -> tuple:
431:         """
432:         Incrementally iterate over keys.
433: 
434:         Args:
435:             namespace: Namespace to scan
436:             match: Optional pattern to match
437:             count: Number of keys to return
438:             cursor: Position to start from
439: 
440:         Returns:
441:             Tuple of (next_cursor, list of keys)
442:         """
443:         with self.session_scope() as session:
444:             query = session.query(KeyValueStore.key, KeyValueStore.id).filter(
445:                 KeyValueStore.namespace == namespace
446:             )
447: 
448:             if match:
449:                 sql_pattern = match.replace('*', '%').replace('?', '_')
450:                 query = query.filter(KeyValueStore.key.like(sql_pattern))
451: 
452:             query = query.filter(KeyValueStore.id > cursor)\
453:                 .order_by(KeyValueStore.id)\
454:                 .limit(count)
455: 
456:             results = query.all()
457: 
458:             if not results:
459:                 return (0, [])
460: 
461:             keys = [row[0] for row in results]
462:             next_cursor = results[-1][1]
463: 
464:             # Check if there are more
465:             more = session.query(KeyValueStore.id).filter(
466:                 and_(
467:                     KeyValueStore.namespace == namespace,
468:                     KeyValueStore.id > next_cursor
469:                 )
470:             ).first()
471: 
472:             if not more:
473:                 next_cursor = 0
474: 
475:             return (next_cursor, keys)
476: 
477:     # =========================================================================
478:     # Hash Operations (nested dictionaries)
479:     # =========================================================================
480: 
481:     def hget(
482:         self,
483:         name: str,
484:         key: str,
485:         namespace: str = NAMESPACE_METADATA
486:     ) -> Any:
487:         """
488:         Get a field from a hash.
489: 
490:         Args:
491:             name: Hash name
492:             key: Field key
493:             namespace: Namespace
494: 
495:         Returns:
496:             Field value or None
497:         """
498:         hash_key = f"{name}:{key}"
499:         return self.get(hash_key, namespace)
500: 
501:     def hset(
502:         self,
503:         name: str,
504:         key: str,
505:         value: Any,
506:         namespace: str = NAMESPACE_METADATA
507:     ) -> bool:
508:         """
509:         Set a field in a hash.
510: 
511:         Args:
512:             name: Hash name
513:             key: Field key
514:             value: Field value
515:             namespace: Namespace
516: 
517:         Returns:
518:             True if successful
519:         """
520:         hash_key = f"{name}:{key}"
521:         return self.set(hash_key, value, namespace)
522: 
523:     def hgetall(
524:         self,
525:         name: str,
526:         namespace: str = NAMESPACE_METADATA
527:     ) -> Dict[str, Any]:
528:         """
529:         Get all fields from a hash.
530: 
531:         Args:
532:             name: Hash name
533:             namespace: Namespace
534: 
535:         Returns:
536:             Dictionary of field -> value
537:         """
538:         pattern = f"{name}:*"
539:         keys = self.keys(pattern, namespace)
540: 
541:         result = {}
542:         for key in keys:
543:             field = key[len(name) + 1:]  # Remove "name:" prefix
544:             result[field] = self.get(key, namespace)
545: 
546:         return result
547: 
548:     def hdel(
549:         self,
550:         name: str,
551:         *keys: str,
552:         namespace: str = NAMESPACE_METADATA
553:     ) -> int:
554:         """
555:         Delete fields from a hash.
556: 
557:         Args:
558:             name: Hash name
559:             *keys: Field keys to delete
560:             namespace: Namespace
561: 
562:         Returns:
563:             Number of fields deleted
564:         """
565:         count = 0
566:         for key in keys:
567:             hash_key = f"{name}:{key}"
568:             if self.delete(hash_key, namespace):
569:                 count += 1
570:         return count
571: 
572:     # =========================================================================
573:     # TTL Operations
574:     # =========================================================================
575: 
576:     def ttl(self, key: str, namespace: str = NAMESPACE_CACHE) -> Optional[int]:
577:         """
578:         Get remaining TTL for a key.
579: 
580:         Args:
581:             key: The key
582:             namespace: Namespace
583: 
584:         Returns:
585:             Seconds remaining, -1 if no TTL, None if key doesn't exist
586:         """
587:         with self.session_scope() as session:
588:             record = session.query(KeyValueStore).filter(
589:                 and_(
590:                     KeyValueStore.namespace == namespace,
591:                     KeyValueStore.key == key
592:                 )
593:             ).first()
594: 
595:             if not record:
596:                 return None
597: 
598:             if not record.expires_at:
599:                 return -1
600: 
601:             remaining = (record.expires_at - datetime.utcnow()).total_seconds()
602:             return max(0, int(remaining))
603: 
604:     def expire(
605:         self,
606:         key: str,
607:         seconds: int,
608:         namespace: str = NAMESPACE_CACHE
609:     ) -> bool:
610:         """
611:         Set TTL on an existing key.
612: 
613:         Args:
614:             key: The key
615:             seconds: TTL in seconds
616:             namespace: Namespace
617: 
618:         Returns:
619:             True if key exists and TTL was set
620:         """
621:         with self.session_scope() as session:
622:             record = session.query(KeyValueStore).filter(
623:                 and_(
624:                     KeyValueStore.namespace == namespace,
625:                     KeyValueStore.key == key
626:                 )
627:             ).first()
628: 
629:             if not record:
630:                 return False
631: 
632:             record.expires_at = datetime.utcnow() + timedelta(seconds=seconds)
633:             return True
634: 
635:     def persist(self, key: str, namespace: str = NAMESPACE_CACHE) -> bool:
636:         """
637:         Remove TTL from a key, making it permanent.
638: 
639:         Args:
640:             key: The key
641:             namespace: Namespace
642: 
643:         Returns:
644:             True if key exists and TTL was removed
645:         """
646:         with self.session_scope() as session:
647:             record = session.query(KeyValueStore).filter(
648:                 and_(
649:                     KeyValueStore.namespace == namespace,
650:                     KeyValueStore.key == key
651:                 )
652:             ).first()
653: 
654:             if not record:
655:                 return False
656: 
657:             record.expires_at = None
658:             return True
659: 
660:     # =========================================================================
661:     # Cleanup Operations
662:     # =========================================================================
663: 
664:     def cleanup_expired(self) -> int:
665:         """
666:         Remove all expired keys.
667: 
668:         Returns:
669:             Number of keys removed
670:         """
671:         with self.session_scope() as session:
672:             result = session.query(KeyValueStore).filter(
673:                 and_(
674:                     KeyValueStore.expires_at.isnot(None),
675:                     KeyValueStore.expires_at < datetime.utcnow()
676:                 )
677:             ).delete()
678:             return result
679: 
680:     def flush_namespace(self, namespace: str) -> int:
681:         """
682:         Delete all keys in a namespace.
683: 
684:         Args:
685:             namespace: Namespace to flush
686: 
687:         Returns:
688:             Number of keys deleted
689:         """
690:         with self.session_scope() as session:
691:             result = session.query(KeyValueStore).filter(
692:                 KeyValueStore.namespace == namespace
693:             ).delete()
694:             return result
695: 
696:     def flush_all(self) -> int:
697:         """
698:         Delete all keys in all namespaces.
699: 
700:         Returns:
701:             Number of keys deleted
702:         """
703:         with self.session_scope() as session:
704:             result = session.query(KeyValueStore).delete()
705:             return result
706: 
707:     # =========================================================================
708:     # Utility Methods
709:     # =========================================================================
710: 
711:     def _get_value_type(self, value: Any) -> str:
712:         """Determine the type of a value."""
713:         if isinstance(value, bool):
714:             return 'bool'
715:         elif isinstance(value, int):
716:             return 'int'
717:         elif isinstance(value, float):
718:             return 'float'
719:         elif isinstance(value, str):
720:             return 'string'
721:         elif isinstance(value, (dict, list)):
722:             return 'json'
723:         else:
724:             return 'json'
725: 
726:     def info(self) -> Dict[str, Any]:
727:         """
728:         Get storage statistics.
729: 
730:         Returns:
731:             Dictionary with stats
732:         """
733:         with self.session_scope() as session:
734:             total = session.query(func.count(KeyValueStore.id)).scalar()
735: 
736:             by_namespace = session.query(
737:                 KeyValueStore.namespace,
738:                 func.count(KeyValueStore.id)
739:             ).group_by(KeyValueStore.namespace).all()
740: 
741:             expired = session.query(func.count(KeyValueStore.id)).filter(
742:                 and_(
743:                     KeyValueStore.expires_at.isnot(None),
744:                     KeyValueStore.expires_at < datetime.utcnow()
745:                 )
746:             ).scalar()
747: 
748:             return {
749:                 'total_keys': total,
750:                 'by_namespace': {ns: count for ns, count in by_namespace},
751:                 'expired_keys': expired
752:             }
753: 
754: 
