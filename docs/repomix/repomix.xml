1843:     def classify_media_file(self, file_path: Path, image_metadata: Dict = None) -> Optional[Tuple[str, str, str]]:
1844:         """
1845:         Classify media files (photos, videos, audio) into subcategories.
1846: 
1847:         Returns:
1848:             Tuple of (category, media_type, subcategory) or None if not a media file
1849:             Example: ('media', 'photos', 'screenshots') or ('media', 'videos', 'recordings')
1850:         """
1851:         filename = file_path.name.lower()
1852:         stem = file_path.stem.lower()
1853:         ext = file_path.suffix.lower()
1854: 
1855:         # Videos - .mp4, .mov, .avi, .mkv, .webm, .m4v
1856:         if ext in ['.mp4', '.mov', '.avi', '.mkv', '.webm', '.m4v', '.flv', '.wmv']:
1857:             # Screen recordings
1858:             if 'screen' in stem or 'recording' in stem or 'capture' in stem:
1859:                 return ('media', 'videos', 'screencasts')
1860:             # Exports (from video editors)
1861:             elif 'export' in stem or 'render' in stem or 'final' in stem or 'cut' in stem:
1862:                 return ('media', 'videos', 'exports')
1863:             # Default to recordings
1864:             else:
1865:                 return ('media', 'videos', 'recordings')
1866: 
1867:         # Audio - .mp3, .wav, .m4a, .aac, .flac, .ogg (but not game music)
1868:         if ext in ['.mp3', '.m4a', '.aac', '.flac', '.wma']:
1869:             # Podcasts
1870:             if 'podcast' in stem or 'episode' in stem or 'interview' in stem:
1871:                 return ('media', 'audio', 'podcasts')
1872:             # Music
1873:             elif 'song' in stem or 'album' in stem or 'track' in stem or 'music' in stem:
1874:                 return ('media', 'audio', 'music')
1875:             # Voice recordings
1876:             elif 'recording' in stem or 'voice' in stem or 'memo' in stem or 'audio' in stem:
1877:                 return ('media', 'audio', 'recordings')
1878:             # Default to recordings
1879:             else:
1880:                 return ('media', 'audio', 'recordings')
1881: 
1882:         # Photos - .jpg, .jpeg, .png, .heic, .gif, .webp, .bmp
1883:         if ext in ['.jpg', '.jpeg', '.png', '.heic', '.gif', '.webp', '.bmp', '.tiff', '.tif']:
1884:             # Screenshots (highest priority for photos)
1885:             if filename.startswith('screenshot') or 'screen shot' in filename:
1886:                 return ('media', 'photos', 'screenshots')
1887: 
1888:             # Scanned documents/receipts (OCR will detect text)
1889:             if 'scan' in stem or 'receipt' in stem or 'document' in stem or 'invoice' in stem:
1890:                 return ('media', 'photos', 'documents')
1891: 
1892:             # Travel photos (has GPS metadata)
1893:             if image_metadata and image_metadata.get('gps_coordinates'):
1894:                 # If we have GPS coordinates, it's likely a travel photo
1895:                 return ('media', 'photos', 'travel')
1896: 
1897:             # Photos with datetime (camera photos) - organize by type
1898:             if image_metadata and image_metadata.get('datetime'):
1899:                 # Photos with camera EXIF data are likely personal photos
1900:                 # Default to 'other' category for general photos
1901:                 return ('media', 'photos', 'other')
1902: 
1903:             # Photos without metadata - still categorize as media if they're actual photos
1904:             # (as opposed to game sprites which would be caught earlier)
1905:             if ext in ['.jpg', '.jpeg', '.heic']:
1906:                 return ('media', 'photos', 'other')
1907: 
1908:             # PNG files without clear classification fall through
1909:             # (could be screenshots, documents, or game assets that weren't caught)
1910:             return None
1911: 
1912:         return None
