  1: """
  2: System Health Check Module
  3: 
  4: Validates dependencies and reports feature availability at startup.
  5: """
  6: 
  7: import sys
  8: import shutil
  9: from dataclasses import dataclass
 10: from typing import Optional
 11: 
 12: from constants import SEPARATOR_WIDTH_MEDIUM
 13: 
 14: 
 15: @dataclass
 16: class FeatureStatus:
 17:     """Status of a single feature."""
 18:     name: str
 19:     available: bool
 20:     version: Optional[str] = None
 21:     error: Optional[str] = None
 22:     impact: str = ""
 23: 
 24: 
 25: class SystemHealthChecker:
 26:     """
 27:     Validates system dependencies and reports feature availability.
 28: 
 29:     Usage:
 30:         checker = SystemHealthChecker()
 31:         checker.run_all_checks()
 32:         checker.print_status()
 33: 
 34:         # Or check specific feature
 35:         if checker.is_available('clip_vision'):
 36:             # Use CLIP model
 37:     """
 38: 
 39:     def __init__(self):
 40:         self.features: dict[str, FeatureStatus] = {}
 41:         self._checked = False
 42: 
 43:     def run_all_checks(self) -> 'SystemHealthChecker':
 44:         """Run all dependency checks."""
 45:         self._check_python_version()
 46:         self._check_pillow()
 47:         self._check_heic_support()
 48:         self._check_ocr()
 49:         self._check_clip_vision()
 50:         self._check_database()
 51:         self._check_geocoding()
 52:         self._check_error_tracking()
 53:         self._check_document_processing()
 54:         self._checked = True
 55:         return self
 56: 
 57:     def _check_python_version(self) -> None:
 58:         """Check Python version."""
 59:         version = f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}"
 60:         min_version = (3, 8)
 61:         available = sys.version_info >= min_version
 62:         self.features['python'] = FeatureStatus(
 63:             name="Python",
 64:             available=available,
 65:             version=version,
 66:             error=None if available else f"Requires Python {min_version[0]}.{min_version[1]}+",
 67:             impact="Core functionality"
 68:         )
 69: 
 70:     def _check_pillow(self) -> None:
 71:         """Check PIL/Pillow for image processing."""
 72:         try:
 73:             from PIL import Image
 74:             import PIL
 75:             self.features['pillow'] = FeatureStatus(
 76:                 name="Pillow (Image Processing)",
 77:                 available=True,
 78:                 version=PIL.__version__,
 79:                 impact="JPEG/PNG image loading, EXIF extraction"
 80:             )
 81:         except ImportError as e:
 82:             self.features['pillow'] = FeatureStatus(
 83:                 name="Pillow (Image Processing)",
 84:                 available=False,
 85:                 error=str(e),
 86:                 impact="Cannot process images - pip install Pillow"
 87:             )
 88: 
 89:     def _check_heic_support(self) -> None:
 90:         """Check HEIC/HEIF image support."""
 91:         try:
 92:             import pillow_heif
 93:             self.features['heic'] = FeatureStatus(
 94:                 name="HEIC Support",
 95:                 available=True,
 96:                 version=pillow_heif.__version__,
 97:                 impact="iPhone HEIC photos supported"
 98:             )
 99:         except ImportError:
100:             self.features['heic'] = FeatureStatus(
101:                 name="HEIC Support",
102:                 available=False,
103:                 error="pillow-heif not installed",
104:                 impact="HEIC files skipped - pip install pillow-heif"
105:             )
106: 
107:     def _check_ocr(self) -> None:
108:         """Check Tesseract OCR availability."""
109:         try:
110:             import pytesseract
111:             # Check if tesseract binary is available
112:             tesseract_path = shutil.which('tesseract')
113:             if tesseract_path:
114:                 try:
115:                     version = pytesseract.get_tesseract_version()
116:                     self.features['ocr'] = FeatureStatus(
117:                         name="OCR (Tesseract)",
118:                         available=True,
119:                         version=str(version),
120:                         impact="Text extraction from images/screenshots"
121:                     )
122:                 except Exception:
123:                     self.features['ocr'] = FeatureStatus(
124:                         name="OCR (Tesseract)",
125:                         available=True,
126:                         version="unknown",
127:                         impact="Text extraction from images/screenshots"
128:                     )
129:             else:
130:                 self.features['ocr'] = FeatureStatus(
131:                     name="OCR (Tesseract)",
132:                     available=False,
133:                     error="tesseract binary not found",
134:                     impact="No OCR - brew install tesseract"
135:                 )
136:         except ImportError:
137:             self.features['ocr'] = FeatureStatus(
138:                 name="OCR (Tesseract)",
139:                 available=False,
140:                 error="pytesseract not installed",
141:                 impact="No OCR - pip install pytesseract"
142:             )
