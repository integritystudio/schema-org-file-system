 198:     def set_basic_info(self, name: str, description: Optional[str] = None,
 199:                       abstract: Optional[str] = None) -> 'DocumentGenerator':
 200:         """
 201:         Set basic document information.
 202: 
 203:         Args:
 204:             name: Document name/title
 205:             description: Document description
 206:             abstract: Document abstract/summary
 207: 
 208:         Returns:
 209:             Self for method chaining
 210:         """
 211:         self.set_property("name", name, PropertyType.TEXT)
 212:         if description:
 213:             self.set_property("description", description, PropertyType.TEXT)
 214:         if abstract:
 215:             self.set_property("abstract", abstract, PropertyType.TEXT)
