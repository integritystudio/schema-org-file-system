<file path="scripts/update_site_data.py">
  1: #!/usr/bin/env python3
  2: """
  3: Update _site data files from the latest organization report.
  4: 
  5: Generates:
  6: - metadata.json: File metadata for the metadata viewer
  7: - Updates timeline_data.json with latest session
  8: - Updates index.html stats
  9: """
 10: 
 11: import json
 12: from datetime import datetime
 13: from pathlib import Path
 14: from collections import Counter
 15: 
 16: 
 17: def find_latest_report(results_dir: Path) -> Path:
 18:     """Find the most recent labeled/merged organization report."""
 19:     # Look for labeled reports first, then merged, then regular
 20:     patterns = [
 21:         "content_organization_report_labeled_*.json",
 22:         "content_organization_report_merged_*.json",
 23:         "content_organization_report_*.json"
 24:     ]
 25: 
 26:     for pattern in patterns:
 27:         files = sorted(results_dir.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
 28:         if files:
 29:             return files[0]
 30: 
 31:     raise FileNotFoundError("No organization report found")
 32: 
 33: 
 34: def extract_metadata(report_path: Path) -> list[dict]:
 35:     """Extract metadata array from organization report."""
 36:     print(f"Loading report: {report_path}")
 37: 
 38:     with open(report_path) as f:
 39:         report = json.load(f)
 40: 
 41:     results = report.get('results', [])
 42: 
 43:     # Transform results to metadata format
 44:     metadata = []
 45:     for r in results:
 46:         item = {
 47:             'source': r.get('source'),
 48:             'destination': r.get('destination'),
 49:             'status': r.get('status'),
 50:             'category': r.get('category'),
 51:             'subcategory': r.get('subcategory'),
 52:             'schema': r.get('schema', {}),
 53:             'extracted_text_length': r.get('extracted_text_length', 0),
 54:             'company_name': r.get('company_name'),
 55:             'image_metadata': r.get('image_metadata', {})
 56:         }
 57:         metadata.append(item)
 58: 
 59:     return metadata
 60: 
 61: 
 62: def calculate_stats(metadata: list[dict]) -> dict:
 63:     """Calculate statistics from metadata."""
 64:     total = len(metadata)
 65:     organized = sum(1 for m in metadata if m.get('status') == 'organized')
 66:     already = sum(1 for m in metadata if m.get('status') == 'already_organized')
 67: 
 68:     categories = Counter(m.get('category') for m in metadata if m.get('category'))
 69: 
 70:     return {
 71:         'total_files': total,
 72:         'organized': organized,
 73:         'already_organized': already,
 74:         'success_rate': round(((organized + already) / total * 100) if total > 0 else 0, 1),
 75:         'category_count': len(categories),
 76:         'top_categories': categories.most_common(5)
 77:     }
 78: 
 79: 
 80: def update_index_html(site_dir: Path, stats: dict):
 81:     """Update the landing page with latest stats."""
 82:     index_path = site_dir / "index.html"
 83: 
 84:     if not index_path.exists():
 85:         print(f"Warning: {index_path} not found, skipping")
 86:         return
 87: 
 88:     content = index_path.read_text()
 89: 
 90:     # Update stats values
 91:     replacements = [
 92:         # Files Processed
 93:         (r'<div class="stat-value">[\d,]+</div>\s*<div class="stat-label">Files Processed</div>',
 94:          f'<div class="stat-value">{stats["total_files"]:,}</div>\n                <div class="stat-label">Files Processed</div>'),
 95:         # Success Rate
 96:         (r'<div class="stat-value">[\d.]+%</div>\s*<div class="stat-label">Success Rate</div>',
 97:          f'<div class="stat-value">{stats["success_rate"]}%</div>\n                <div class="stat-label">Success Rate</div>'),
 98:         # Categories
 99:         (r'<div class="stat-value">\d+</div>\s*<div class="stat-label">Categories</div>',
100:          f'<div class="stat-value">{stats["category_count"]}</div>\n                <div class="stat-label">Categories</div>'),
101:         # Last Updated date
102:         (r'Last Updated: \w+ \d+, \d+',
103:          f'Last Updated: {datetime.now().strftime("%B %d, %Y")}'),
104:     ]
105: 
106:     import re
107:     for pattern, replacement in replacements:
108:         content = re.sub(pattern, replacement, content)
109: 
110:     index_path.write_text(content)
111:     print(f"Updated {index_path}")
112: 
113: 
114: def main():
115:     import argparse
116: 
117:     parser = argparse.ArgumentParser(description='Update _site data from latest report')
118:     parser.add_argument('--results-dir', '-r',
119:                         default='results',
120:                         help='Results directory')
121:     parser.add_argument('--site-dir', '-s',
122:                         default='_site',
123:                         help='Site directory')
124:     parser.add_argument('--report',
125:                         help='Specific report file to use')
126: 
127:     args = parser.parse_args()
128: 
129:     base_dir = Path(__file__).parent.parent
130:     results_dir = base_dir / args.results_dir
131:     site_dir = base_dir / args.site_dir
132: 
133:     print("=" * 60)
134:     print("UPDATE SITE DATA")
135:     print("=" * 60)
136: 
137:     # Find latest report
138:     if args.report:
139:         report_path = Path(args.report)
140:     else:
141:         report_path = find_latest_report(results_dir)
142: 
143:     print(f"\nUsing report: {report_path.name}")
144: 
145:     # Extract metadata
146:     metadata = extract_metadata(report_path)
147:     print(f"Extracted {len(metadata):,} file records")
148: 
149:     # Calculate stats
150:     stats = calculate_stats(metadata)
151:     print(f"\nStats:")
152:     print(f"  Total files: {stats['total_files']:,}")
153:     print(f"  Success rate: {stats['success_rate']}%")
154:     print(f"  Categories: {stats['category_count']}")
155: 
156:     # Save metadata.json
157:     metadata_path = site_dir / "metadata.json"
158:     print(f"\nSaving {metadata_path}...")
159:     with open(metadata_path, 'w') as f:
160:         json.dump(metadata, f)
161:     print(f"  Size: {metadata_path.stat().st_size / 1024 / 1024:.1f} MB")
162: 
163:     # Update index.html
164:     print("\nUpdating index.html...")
165:     update_index_html(site_dir, stats)
166: 
167:     # Regenerate timeline data
168:     print("\nRegenerating timeline data...")
169:     import subprocess
170:     result = subprocess.run(
171:         ['python3', 'scripts/generate_timeline_data.py'],
172:         cwd=base_dir,
173:         capture_output=True,
174:         text=True
175:     )
176:     if result.returncode == 0:
177:         print("  Timeline data regenerated")
178:     else:
179:         print(f"  Warning: {result.stderr}")
180: 
181:     print("\n" + "=" * 60)
182:     print("SITE DATA UPDATED")
183:     print("=" * 60)
184:     print(f"  metadata.json: {len(metadata):,} files")
185:     print(f"  index.html: Stats updated")
186:     print(f"  timeline_data.json: Regenerated")
