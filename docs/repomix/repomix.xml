294:             )
295:             self.stats['companies'] += 1
296: 
297:         # Add people relationships
298:         people_names = result.get('people_names', [])
299:         for person_name in people_names:
300:             if person_name:
301:                 self._add_person_to_file(file_id, person_name, db_session)
302:                 self.stats['people'] += 1
