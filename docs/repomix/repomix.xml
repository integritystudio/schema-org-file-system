 350:     def extract_company_names(self, text: str) -> List[str]:
 351:         """
 352:         Extract company names from text using regex patterns.
 353: 
 354:         Returns:
 355:             List of detected company names
 356:         """
 357:         companies = []
 358:         for pattern in self.company_patterns:
 359:             matches = re.findall(pattern, text)
 360:             companies.extend(matches)
 361: 
 362:         # Remove duplicates and clean up
 363:         unique_companies = []
 364:         seen = set()
 365:         for company in companies:
 366:             # Clean up whitespace
 367:             clean = ' '.join(company.split())
 368:             # Skip if too short or already seen
 369:             if len(clean) > 2 and clean.lower() not in seen:
 370:                 seen.add(clean.lower())
 371:                 unique_companies.append(clean)
 372: 
 373:         return unique_companies
 374: 
 375:     def _collapse_spaced_text(self, text: str) -> str:
 376:         """
 377:         Collapse spaced-out text like "I S A B E L  B U D E N Z" to "ISABEL BUDENZ".
 378:         Common in stylized resume/CV templates.
 379:         """
 380:         # Pattern: single letters separated by spaces (at least 3 in a row)
 381:         # Match sequences like "I S A B E L" (single chars with single spaces)
 382:         def collapse_match(match):
 383:             spaced = match.group(0)
 384:             # Remove single spaces between single characters
 385:             collapsed = re.sub(r'(?<=\b[A-Z]) (?=[A-Z]\b)', '', spaced)
 386:             return collapsed
 387: 
 388:         # Find sequences of spaced single uppercase letters
 389:         # Pattern matches: capital letter, space, capital letter (repeated)
 390:         result = re.sub(r'\b([A-Z] ){2,}[A-Z]\b', collapse_match, text)
 391:         return result
 392: 
 393:     def extract_people_names(self, text: str) -> List[str]:
 394:         """
 395:         Extract people names from text using regex patterns.
 396: 
 397:         Returns:
 398:             List of detected people names
 399:         """
 400:         # Preprocess: collapse spaced-out text (common in stylized resumes)
 401:         text = self._collapse_spaced_text(text)
 402: 
 403:         people = []
 404:         for pattern in self.people_patterns:
 405:             matches = re.findall(pattern, text)
 406:             # Pattern can return tuples (first, last) or single strings
 407:             for match in matches:
 408:                 if isinstance(match, tuple):
 409:                     # Join tuple elements (e.g., first name + last name)
 410:                     full_name = ' '.join([m for m in match if m])
 411:                 else:
 412:                     full_name = match
 413:                 people.append(full_name)
 414: 
 415:         # Remove duplicates and clean up
 416:         unique_people = []
 417:         seen = set()
 418:         for person in people:
 419:             # Clean up whitespace
 420:             clean = ' '.join(person.split())
 421:             # Convert ALL-CAPS to Title Case (common in resume headers)
 422:             if clean.isupper():
 423:                 clean = clean.title()
 424:             # Skip if too short or already seen
 425:             if len(clean) > 2 and clean.lower() not in seen:
 426:                 seen.add(clean.lower())
 427:                 unique_people.append(clean)
 428: 
 429:         return unique_people
