620:     def organize_directory(self, source_dir: str, recursive: bool = False, limit: int = None):
621:         """Organize files in a directory."""
622:         source_path = Path(source_dir).expanduser()
623: 
624:         if not source_path.exists():
625:             print(f"Error: Source directory does not exist: {source_path}")
626:             return
627: 
628:         print("=" * 60)
629:         print("File Organization by Name and Path")
630:         print("=" * 60)
631:         print()
632:         print(f"Source: {source_path}")
633:         print(f"Base path: {self.base_path}")
634:         print(f"Recursive: {recursive}")
635:         print(f"Dry run: {self.dry_run}")
636:         if limit:
637:             print(f"Limit: {limit} files")
638:         print()
639: 
640:         # Collect files
641:         if recursive:
642:             files = list(source_path.rglob('*'))
643:         else:
644:             files = list(source_path.glob('*'))
645: 
646:         # Filter to files only
647:         files = [f for f in files if f.is_file()]
648: 
649:         # Apply limit
650:         if limit:
651:             files = files[:limit]
652: 
653:         self.stats['total_files'] = len(files)
654: 
655:         print(f"Found {len(files)} files to process")
656:         print()
657: 
658:         # Process files
659:         for i, file_path in enumerate(files, 1):
660:             print(f"[{i}/{len(files)}] {file_path.name}")
661: 
662:             try:
663:                 # Categorize
664:                 category, subcategory = self.categorize_file(file_path)
665: 
666:                 # Get destination
667:                 destination = self.get_destination_path(category, subcategory, file_path.name)
668: 
669:                 print(f"  Category: {category}/{subcategory}")
670: 
671:                 # Skip if already in correct location
672:                 if file_path.parent == destination.parent:
673:                     print(f"  → Already in correct location")
674:                     self.stats['skipped_files'] += 1
675:                     continue
676: 
677:                 # Move file
678:                 if self.move_file(file_path, destination):
679:                     self.stats['moved_files'] += 1
680: 
681:                     # Update category stats
682:                     cat_key = f"{category}/{subcategory}"
683:                     self.stats['by_category'][cat_key] = self.stats['by_category'].get(cat_key, 0) + 1
684:                 else:
685:                     self.stats['errors'] += 1
686: 
687:             except Exception as e:
688:                 print(f"  ✗ Error processing file: {e}")
689:                 self.stats['errors'] += 1
690: 
691:             print()
692: 
693:         # Print summary
694:         self.print_summary()
695: 
696:     def print_summary(self):
697:         """Print organization summary."""
698:         print()
699:         print("=" * 60)
700:         print("SUMMARY")
701:         print("=" * 60)
702:         print()
703:         print(f"Total files: {self.stats['total_files']}")
704:         print(f"Moved: {self.stats['moved_files']}")
705:         print(f"Skipped (already in place): {self.stats['skipped_files']}")
706:         print(f"Errors: {self.stats['errors']}")
707:         print()
708: 
709:         if self.stats['by_category']:
710:             print("Files by category:")
711:             for category, count in sorted(self.stats['by_category'].items()):
712:                 print(f"  {category}: {count}")
713: 
714:         # Save report
715:         if not self.dry_run and self.stats['moved_files'] > 0:
716:             self.save_report()
717: 
718:     def save_report(self):
719:         """Save organization report to JSON."""
720:         results_dir = Path(__file__).parent / 'results'
721:         results_dir.mkdir(exist_ok=True)
722: 
723:         timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
724:         report_file = results_dir / f'name_organization_report_{timestamp}.json'
725: 
726:         report = {
727:             'timestamp': timestamp,
728:             'base_path': str(self.base_path),
729:             'stats': self.stats,
730:         }
731: 
732:         with open(report_file, 'w') as f:
733:             json.dump(report, f, indent=2)
734: 
735:         print()
736:         print(f"Report saved: {report_file}")
737: 
738: 
739: def main():
740:     parser = argparse.ArgumentParser(
741:         description='Organize files by name and path patterns only',
742:         formatter_class=argparse.RawDescriptionHelpFormatter,
743:         epilog='''
744: Examples:
745:   # Dry run (preview only)
746:   python3 file_organizer_by_name.py --dry-run --source ~/Documents/Uncategorized
747: 
748:   # Organize files
749:   python3 file_organizer_by_name.py --source ~/Documents/Uncategorized
750: 
751:   # Recursive with limit
752:   python3 file_organizer_by_name.py --source ~/Documents --recursive --limit 500
753: 
754:   # Custom base path
755:   python3 file_organizer_by_name.py --base-path ~/MyFiles --source ~/Downloads
756:         '''
757:     )
758: 
759:     parser.add_argument(
760:         '--source',
761:         required=True,
762:         help='Source directory to organize'
763:     )
764: 
765:     parser.add_argument(
766:         '--base-path',
767:         default='~/Documents',
768:         help='Base directory for organized files (default: ~/Documents)'
769:     )
770: 
771:     parser.add_argument(
772:         '--recursive',
773:         action='store_true',
774:         help='Process subdirectories recursively'
775:     )
776: 
777:     parser.add_argument(
778:         '--dry-run',
779:         action='store_true',
780:         help='Preview changes without moving files'
781:     )
782: 
783:     parser.add_argument(
784:         '--limit',
785:         type=int,
786:         help='Limit number of files to process'
787:     )
788: 
789:     args = parser.parse_args()
790: 
791:     # Create organizer
792:     organizer = FileNameOrganizer(
