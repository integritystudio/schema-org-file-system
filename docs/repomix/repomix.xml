 379:     def get_category_tree(self, session: Session = None) -> List[Dict[str, Any]]:
 380:         """
 381:         Get the full category hierarchy as a tree.
 382: 
 383:         Returns:
 384:             List of root categories with nested subcategories
 385:         """
 386:         close_session = session is None
 387:         session = session or self.get_session()
 388: 
 389:         try:
 390:             categories = session.query(Category).order_by(Category.level, Category.name).all()
 391: 
 392:             # Build tree structure
 393:             tree = []
 394:             category_map = {c.id: c for c in categories}
 395: 
 396:             for category in categories:
 397:                 if category.parent_id is None:
 398:                     tree.append(self._build_category_node(category, category_map))
 399: 
 400:             return tree
 401: 
 402:         finally:
 403:             if close_session:
 404:                 session.close()
 405: 
 406:     def _build_category_node(self, category: Category, category_map: Dict) -> Dict[str, Any]:
 407:         """Build a category tree node recursively."""
 408:         node = category.to_dict()
 409:         node['subcategories'] = []
 410: 
 411:         for sub in category.subcategories:
 412:             node['subcategories'].append(self._build_category_node(sub, category_map))
 413: 
 414:         return node
