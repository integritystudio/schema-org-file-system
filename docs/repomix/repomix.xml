1569:     def classify_by_filepath(self, file_path: Path) -> Optional[str]:
1570:         """
1571:         Classify file based on filepath patterns (extension, filename).
1572: 
1573:         Returns:
1574:             Category path string if matched, None otherwise
1575:         """
1576:         # Check exact filename matches first (e.g., Makefile, Dockerfile)
1577:         filename = file_path.name
1578:         if filename in self.filepath_patterns:
1579:             return self.filepath_patterns[filename]
1580: 
1581:         # Check file extension
1582:         ext = file_path.suffix.lower()
1583:         if ext in self.filepath_patterns:
1584:             base_path = self.filepath_patterns[ext]
1585: 
1586:             # Try to extract project name from path
1587:             project_name = self.extract_project_name(file_path)
1588:             if project_name:
1589:                 # Add project subdirectory (e.g., Technical/Python/MyProject)
1590:                 return f"{base_path}/{project_name}"
1591: 
1592:             return base_path
1593: 
1594:         # Check double extensions (e.g., .log.gz)
1595:         if len(file_path.suffixes) >= 2:
1596:             double_ext = ''.join(file_path.suffixes[-2:]).lower()
1597:             if double_ext in self.filepath_patterns:
1598:                 return self.filepath_patterns[double_ext]
1599: 
1600:         return None
1601: 
1602:     def extract_project_name(self, file_path: Path) -> Optional[str]:
1603:         """
1604:         Extract project name from file path.
1605: 
1606:         Looks for common project indicators in path:
1607:         - Directory names like 'myproject', 'my-app', etc.
1608:         - Skips common non-project directories
1609: 
1610:         Returns:
1611:             Project name if found, None otherwise
1612:         """
1613:         skip_dirs = {
1614:             'src', 'lib', 'bin', 'dist', 'build', 'out', 'target',
1615:             'node_modules', 'venv', '.venv', 'env', '__pycache__',
1616:             'scripts', 'tests', 'test', 'docs', 'doc', 'examples',
1617:             'static', 'public', 'assets', 'resources', 'config',
1618:             'home', 'users', 'documents', 'downloads', 'desktop',
1619:             'code', 'projects', 'dev', 'work', 'repos', 'git'
1620:         }
1621: 
1622:         # Get all parent directories
1623:         parts = file_path.parts
1624: 
1625:         # Look backwards from the file for a likely project directory
1626:         for i in range(len(parts) - 2, -1, -1):  # Skip the filename itself
1627:             dir_name = parts[i].lower()
1628: 
1629:             # Skip common non-project directories
1630:             if dir_name in skip_dirs:
1631:                 continue
1632: 
1633:             # Skip hidden directories
1634:             if dir_name.startswith('.'):
1635:                 continue
1636: 
1637:             # Found a likely project directory
1638:             # Return with original case preserved
1639:             return parts[i]
1640: 
1641:         return None
1642: 
1643:     def classify_game_asset(self, file_path: Path) -> Optional[Tuple[str, str]]:
1644:         """
1645:         Classify file as a game asset based on filename patterns.
1646: 
1647:         Returns:
1648:             Tuple of (category, subcategory) or None if not a game asset
1649:         """
1650:         filename = file_path.name.lower()
1651:         stem = file_path.stem.lower()
1652:         ext = file_path.suffix.lower()
1653: 
1654:         # Remove timestamp suffixes for pattern matching (e.g., _20251120_164506)
1655:         import re
1656:         clean_stem = re.sub(r'_\d{8}_\d{6}$', '', stem)
1657: 
1658:         # Check for audio files (.wav, .ogg, .mp3)
1659:         if ext in ['.wav', '.ogg', '.mp3', '.flac', '.aac']:
1660:             # Check for game music patterns (usually .ogg files with specific names)
1661:             if ext == '.ogg':
1662:                 for keyword in self.game_music_keywords:
1663:                     if keyword in stem:
1664:                         return ('game_assets', 'music')
1665: 
1666:             # Check for game sound effects
1667:             for keyword in self.game_audio_keywords:
1668:                 if keyword in stem:
1669:                     return ('game_assets', 'audio')
1670: 
1671:         # Check for image files that are game sprites/textures
1672:         if ext in ['.png', '.jpg', '.jpeg', '.bmp', '.tga', '.dds']:
1673:             # Check for game font sprite sheets first
1674:             for keyword in self.game_font_keywords:
1675:                 if keyword in stem or keyword in clean_stem:
1676:                     return ('game_assets', 'fonts')
1677: 
1678:             # Check regex patterns for numbered sprites and variants
1679:             for pattern in self.game_sprite_patterns:
1680:                 if pattern.match(clean_stem):
1681:                     return ('game_assets', 'sprites')
1682: 
1683:             # Check for sprite/texture keyword patterns
1684:             for keyword in self.game_sprite_keywords:
1685:                 if keyword in stem or keyword in clean_stem:
1686:                     # Distinguish between sprites and textures
1687:                     sprite_keywords = [
1688:                         'frame', 'sprite', 'leg', 'arm', 'head', 'torso', 'body',
1689:                         'wing', 'hair', 'face', 'mouth', '_grey', '_gray',
1690:                         'assassins', 'atonement', 'arrow_v', 'arrow_h', 'add',
1691:                         '2h_', '1h_', 'dagger', 'sword', 'axe', 'hammer', 'mace',
1692:                         # Character customization
1693:                         'beard', 'bling', 'hiero', 'mustache', 'scar', 'tattoo',
1694:                         'earring', 'necklace', 'bracelet', 'glasses', 'mask', 'hood'
1695:                     ]
1696:                     if any(kw in stem or kw in clean_stem for kw in sprite_keywords):
1697:                         return ('game_assets', 'sprites')
1698:                     else:
1699:                         return ('game_assets', 'textures')
1700: 
1701:         # Check for font files
1702:         if ext in ['.ttf', '.otf', '.woff', '.woff2', '.eot', '.fon', '.fnt']:
1703:             if ext == '.ttf':
1704:                 return ('fonts', 'truetype')
1705:             elif ext == '.otf':
1706:                 return ('fonts', 'opentype')
1707:             elif ext in ['.woff', '.woff2', '.eot']:
1708:                 return ('fonts', 'web')
1709:             else:
1710:                 return ('fonts', 'other')
1711: 
1712:         return None
