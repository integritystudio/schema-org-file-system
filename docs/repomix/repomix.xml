 44: /**
 45:  * Measure Core Web Vitals and other performance metrics for a page
 46:  */
 47: export async function measurePagePerformance(page: Page): Promise<PerformanceMetrics> {
 48:   // Inject performance observer for CLS
 49:   await page.evaluate(() => {
 50:     (window as any).__clsValue = 0;
 51:     (window as any).__lcpValue = 0;
 52:     (window as any).__fcpValue = 0;
 53: 
 54:     // CLS observer
 55:     const clsObserver = new PerformanceObserver((list) => {
 56:       for (const entry of list.getEntries()) {
 57:         if (!(entry as any).hadRecentInput) {
 58:           (window as any).__clsValue += (entry as any).value;
 59:         }
 60:       }
 61:     });
 62:     clsObserver.observe({ type: 'layout-shift', buffered: true });
 63: 
 64:     // LCP observer
 65:     const lcpObserver = new PerformanceObserver((list) => {
 66:       const entries = list.getEntries();
 67:       if (entries.length > 0) {
 68:         (window as any).__lcpValue = entries[entries.length - 1].startTime;
 69:       }
 70:     });
 71:     lcpObserver.observe({ type: 'largest-contentful-paint', buffered: true });
 72: 
 73:     // FCP from paint entries
 74:     const paintObserver = new PerformanceObserver((list) => {
 75:       for (const entry of list.getEntries()) {
 76:         if (entry.name === 'first-contentful-paint') {
 77:           (window as any).__fcpValue = entry.startTime;
 78:         }
 79:       }
 80:     });
 81:     paintObserver.observe({ type: 'paint', buffered: true });
 82:   });
 83: 
 84:   // Wait a bit for metrics to be collected
 85:   await page.waitForTimeout(100);
 86: 
 87:   // Collect all metrics
 88:   const metrics = await page.evaluate((): PerformanceMetrics => {
 89:     const navigation = performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming;
 90:     const resources = performance.getEntriesByType('resource') as PerformanceResourceTiming[];
 91: 
 92:     // Calculate TTFB
 93:     const ttfb = navigation ? navigation.responseStart - navigation.requestStart : null;
 94: 
 95:     // Calculate total transfer size
 96:     let totalTransferSize = 0;
 97:     for (const resource of resources) {
 98:       totalTransferSize += resource.transferSize || 0;
 99:     }
100: 
101:     // Get JS heap size if available
102:     const memory = (performance as any).memory;
103:     const jsHeapSize = memory ? memory.usedJSHeapSize : null;
104: 
105:     return {
106:       lcp: (window as any).__lcpValue || null,
107:       fcp: (window as any).__fcpValue || null,
108:       cls: (window as any).__clsValue || null,
109:       ttfb,
110:       fid: null, // Requires user interaction
111:       inp: null, // Requires user interaction
112:       domContentLoaded: navigation ? navigation.domContentLoadedEventEnd - navigation.startTime : null,
113:       loadComplete: navigation ? navigation.loadEventEnd - navigation.startTime : null,
114:       resourceCount: resources.length,
115:       totalTransferSize,
116:       jsHeapSize,
117:     };
118:   });
119: 
120:   return metrics;
121: }
