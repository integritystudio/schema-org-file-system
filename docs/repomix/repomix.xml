324:     def get_vocabulary(self, min_freq: int = 5) -> Dict[str, int]:
325:         """Build vocabulary from filename tokens.
326: 
327:         Args:
328:             min_freq: Minimum frequency for a token to be included
329: 
330:         Returns:
331:             Dictionary mapping tokens to indices
332:         """
333:         if not self.features:
334:             raise ValueError("No features extracted. Call extract_all_features() first.")
