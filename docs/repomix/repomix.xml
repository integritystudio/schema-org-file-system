144:     def _check_clip_vision(self) -> None:
145:         """Check CLIP model for AI vision classification."""
146:         try:
147:             import torch
148:             import transformers
149:             self.features['clip_vision'] = FeatureStatus(
150:                 name="AI Vision (CLIP)",
151:                 available=True,
152:                 version=f"torch {torch.__version__}, transformers {transformers.__version__}",
153:                 impact="AI-powered image content classification"
154:             )
155:         except ImportError as e:
156:             missing = []
