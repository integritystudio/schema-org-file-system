  1: #!/usr/bin/env python3
  2: """
  3: Correction Feedback System for File Organizer
  4: 
  5: Stores user corrections for miscategorized files in a persistent hashmap.
  6: Uses file hashes to identify files and tracks correction patterns to improve
  7: future categorization accuracy.
  8: 
  9: Structure:
 10: {
 11:     "corrections": {
 12:         "<file_hash>": {
 13:             "original_path": "/path/to/original/file.ext",
 14:             "assigned_destination": "/path/to/wrong/destination/file.ext",
 15:             "correct_destination": "/path/to/correct/destination/file.ext",
 16:             "assigned_category": "wrong_category",
 17:             "correct_category": "correct_category",
 18:             "assigned_subcategory": "wrong_subcategory",
 19:             "correct_subcategory": "correct_subcategory",
 20:             "filename": "file.ext",
 21:             "file_extension": ".ext",
 22:             "correction_date": "2025-12-09T10:00:00",
 23:             "correction_reason": "user description of why this was wrong",
 24:             "filename_patterns": ["pattern1", "pattern2"],
 25:             "content_hints": ["hint1", "hint2"]
 26:         }
 27:     },
 28:     "category_rules": {
 29:         "pattern -> category": count
 30:     },
 31:     "learned_patterns": {
 32:         "filename_pattern": {
 33:             "correct_category": "category",
 34:             "correct_subcategory": "subcategory",
 35:             "confidence": 0.95,
 36:             "sample_count": 10
 37:         }
 38:     },
 39:     "statistics": {
 40:         "total_corrections": 100,
 41:         "corrections_by_category": {"category": count},
 42:         "most_common_mistakes": [{"from": "cat1", "to": "cat2", "count": 5}]
 43:     }
 44: }
 45: """
 46: 
 47: import hashlib
 48: import json
 49: import os
 50: import re
 51: from datetime import datetime
 52: from pathlib import Path
 53: from typing import Optional, Dict, List, Any, Tuple
 54: from collections import defaultdict
 55: 
 56: 
 57: class CorrectionFeedbackSystem:
 58:     """Manages correction feedback for file categorization improvements."""
 59: 
 60:     def __init__(self, feedback_file: str = None):
 61:         """Initialize the feedback system.
 62: 
 63:         Args:
 64:             feedback_file: Path to the JSON file storing corrections.
 65:                           Defaults to ~/.schema-org-file-system/corrections.json
 66:         """
 67:         if feedback_file is None:
 68:             home = Path.home()
 69:             config_dir = home / ".schema-org-file-system"
 70:             config_dir.mkdir(exist_ok=True)
 71:             feedback_file = str(config_dir / "corrections.json")
 72: 
 73:         self.feedback_file = feedback_file
 74:         self.data = self._load_data()
 75: 
 76:     def _load_data(self) -> Dict:
 77:         """Load existing corrections from file."""
 78:         if os.path.exists(self.feedback_file):
 79:             try:
 80:                 with open(self.feedback_file, 'r') as f:
 81:                     return json.load(f)
 82:             except (json.JSONDecodeError, IOError):
 83:                 pass
 84: 
 85:         return {
 86:             "corrections": {},
 87:             "category_rules": {},
 88:             "learned_patterns": {},
 89:             "statistics": {
 90:                 "total_corrections": 0,
 91:                 "corrections_by_category": {},
 92:                 "most_common_mistakes": []
 93:             },
 94:             "metadata": {
 95:                 "created": datetime.now().isoformat(),
 96:                 "last_updated": datetime.now().isoformat(),
 97:                 "version": "1.0"
 98:             }
 99:         }
100: 
101:     def _save_data(self) -> None:
102:         """Save corrections to file."""
103:         self.data["metadata"]["last_updated"] = datetime.now().isoformat()
104:         with open(self.feedback_file, 'w') as f:
105:             json.dump(self.data, f, indent=2)
106: 
107:     @staticmethod
108:     def compute_file_hash(file_path: str) -> str:
109:         """Compute SHA-256 hash of a file.
110: 
111:         Args:
112:             file_path: Path to the file
113: 
114:         Returns:
115:             Hexadecimal hash string
116:         """
117:         sha256_hash = hashlib.sha256()
118:         try:
119:             with open(file_path, "rb") as f:
120:                 # Read in chunks for large files
121:                 for chunk in iter(lambda: f.read(8192), b""):
122:                     sha256_hash.update(chunk)
123:             return sha256_hash.hexdigest()
124:         except (IOError, OSError):
125:             # Fallback to path-based hash if file can't be read
126:             return hashlib.sha256(file_path.encode()).hexdigest()
127: 
128:     @staticmethod
129:     def extract_filename_patterns(filename: str) -> List[str]:
130:         """Extract categorizable patterns from a filename.
131: 
132:         Args:
133:             filename: The filename to analyze
134: 
135:         Returns:
136:             List of patterns found
137:         """
138:         patterns = []
139:         name_lower = filename.lower()
140: 
141:         # Common patterns
142:         pattern_checks = [
143:             (r'^screenshot', 'screenshot_prefix'),
144:             (r'^img_', 'img_prefix'),
145:             (r'^pxl_', 'pixel_prefix'),
146:             (r'^dsc_', 'dsc_prefix'),
147:             (r'frame\d*', 'frame_pattern'),
148:             (r'sprite', 'sprite_keyword'),
149:             (r'texture', 'texture_keyword'),
150:             (r'audio|sound|sfx', 'audio_keyword'),
151:             (r'music|bgm|ost', 'music_keyword'),
152:             (r'icon', 'icon_keyword'),
153:             (r'button', 'button_keyword'),
154:             (r'tile', 'tile_keyword'),
155:             (r'wall|floor|door', 'environment_keyword'),
156:             (r'character|player|enemy', 'character_keyword'),
157:             (r'weapon|sword|bow|axe', 'weapon_keyword'),
158:             (r'item|potion|scroll', 'item_keyword'),
159:             (r'ui_|gui_|hud_', 'ui_prefix'),
160:             (r'\d{8}_\d{6}', 'timestamp_pattern'),
161:             (r'whatsapp', 'whatsapp_keyword'),
162:             (r'chatgpt', 'chatgpt_keyword'),
163:             (r'invoice|receipt', 'financial_keyword'),
164:             (r'contract|agreement', 'legal_keyword'),
165:             (r'resume|cv', 'employment_keyword'),
166:         ]
167: 
168:         for pattern, label in pattern_checks:
169:             if re.search(pattern, name_lower):
170:                 patterns.append(label)
171: 
172:         # Extract file extension
173:         ext = Path(filename).suffix.lower()
174:         if ext:
175:             patterns.append(f"ext:{ext}")
176: 
177:         return patterns
178: 
179:     def add_correction(
180:         self,
181:         file_path: str,
182:         assigned_destination: str,
183:         correct_destination: str,
184:         assigned_category: str,
185:         correct_category: str,
186:         assigned_subcategory: str = None,
187:         correct_subcategory: str = None,
188:         correction_reason: str = None,
189:         content_hints: List[str] = None
190:     ) -> str:
191:         """Add a correction for a miscategorized file.
192: 
193:         Args:
194:             file_path: Original path of the file
195:             assigned_destination: Where the organizer put the file
196:             correct_destination: Where the file should have gone
197:             assigned_category: Category assigned by organizer
198:             correct_category: Correct category
199:             assigned_subcategory: Subcategory assigned by organizer
200:             correct_subcategory: Correct subcategory
201:             correction_reason: User's explanation of why this was wrong
202:             content_hints: Keywords from file content that should indicate correct category
203: 
204:         Returns:
205:             The file hash used as the key
206:         """
207:         # Compute file hash (use destination if original doesn't exist)
208:         if os.path.exists(assigned_destination):
209:             file_hash = self.compute_file_hash(assigned_destination)
210:         elif os.path.exists(file_path):
211:             file_hash = self.compute_file_hash(file_path)
212:         else:
213:             file_hash = hashlib.sha256(file_path.encode()).hexdigest()
214: 
215:         filename = os.path.basename(file_path)
216:         filename_patterns = self.extract_filename_patterns(filename)
217: 
218:         correction = {
219:             "original_path": file_path,
220:             "assigned_destination": assigned_destination,
221:             "correct_destination": correct_destination,
222:             "assigned_category": assigned_category,
223:             "correct_category": correct_category,
224:             "assigned_subcategory": assigned_subcategory,
225:             "correct_subcategory": correct_subcategory,
226:             "filename": filename,
227:             "file_extension": Path(filename).suffix.lower(),
228:             "correction_date": datetime.now().isoformat(),
229:             "correction_reason": correction_reason,
230:             "filename_patterns": filename_patterns,
231:             "content_hints": content_hints or []
232:         }
233: 
234:         self.data["corrections"][file_hash] = correction
235: 
236:         # Update statistics
237:         self._update_statistics(assigned_category, correct_category)
238: 
239:         # Update learned patterns
240:         self._update_learned_patterns(filename_patterns, correct_category, correct_subcategory)
241: 
242:         self._save_data()
243: 
244:         return file_hash
245: 
246:     def _update_statistics(self, assigned_category: str, correct_category: str) -> None:
247:         """Update correction statistics."""
248:         stats = self.data["statistics"]
249:         stats["total_corrections"] += 1
250: 
251:         # Track corrections by category
252:         if correct_category not in stats["corrections_by_category"]:
253:             stats["corrections_by_category"][correct_category] = 0
254:         stats["corrections_by_category"][correct_category] += 1
255: 
256:         # Track common mistakes
257:         mistake_key = f"{assigned_category} -> {correct_category}"
258:         found = False
259:         for mistake in stats["most_common_mistakes"]:
260:             if mistake["from"] == assigned_category and mistake["to"] == correct_category:
261:                 mistake["count"] += 1
262:                 found = True
263:                 break
264: 
265:         if not found:
266:             stats["most_common_mistakes"].append({
267:                 "from": assigned_category,
268:                 "to": correct_category,
269:                 "count": 1
270:             })
271: 
272:         # Sort by count
273:         stats["most_common_mistakes"].sort(key=lambda x: -x["count"])
274:         # Keep top 20
275:         stats["most_common_mistakes"] = stats["most_common_mistakes"][:20]
