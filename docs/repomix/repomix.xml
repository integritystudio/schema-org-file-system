340:         # Filter by frequency and create vocabulary
341:         vocab = {'<PAD>': 0, '<UNK>': 1}
342:         idx = 2
343:         for token, count in token_counts.most_common():
344:             if count >= min_freq:
345:                 vocab[token] = idx
346:                 idx += 1
