672:         # Phase 2: Data Backfill
673:         print("\nPhase 2: Data Backfill")
674:         print("-" * SEPARATOR_WIDTH_SMALL)
675: 
676:         # Backfill files (use urn:sha256:{id} format)
677:         if table_exists(conn, 'files'):
678:             cursor = conn.execute("SELECT id, original_path FROM files WHERE canonical_id IS NULL")
679:             rows = cursor.fetchall()
680:             if rows:
681:                 print(f"  Backfilling {len(rows)} files...")
682:                 for file_id, _ in rows:
683:                     canonical_id = f"urn:sha256:{file_id}"
684:                     if not dry_run:
685:                         conn.execute("UPDATE files SET canonical_id = ? WHERE id = ?", (canonical_id, file_id))
686:                     stats['files_backfilled'] += 1
687:                 if not dry_run:
688:                     conn.commit()
689:             else:
690:                 print("  No files need backfilling")
691: 
692:         # Backfill categories (use full_path for deterministic ID)
693:         if table_exists(conn, 'categories'):
694:             cursor = conn.execute("SELECT id, full_path, name FROM categories WHERE canonical_id IS NULL")
695:             rows = cursor.fetchall()
696:             if rows:
697:                 print(f"  Backfilling {len(rows)} categories...")
698:                 for cat_id, full_path, name in rows:
699:                     canonical_id = generate_canonical_id('category', full_path or name)
700:                     if not dry_run:
701:                         conn.execute("UPDATE categories SET canonical_id = ? WHERE id = ?", (canonical_id, cat_id))
702:                     stats['categories_backfilled'] += 1
703:                 if not dry_run:
704:                     conn.commit()
705:             else:
706:                 print("  No categories need backfilling")
707: 
708:         # Backfill companies
709:         if table_exists(conn, 'companies'):
710:             cursor = conn.execute("SELECT id, name FROM companies WHERE canonical_id IS NULL")
711:             rows = cursor.fetchall()
712:             if rows:
713:                 print(f"  Backfilling {len(rows)} companies...")
714:                 for comp_id, name in rows:
715:                     canonical_id = generate_canonical_id('company', name)
716:                     if not dry_run:
717:                         conn.execute("UPDATE companies SET canonical_id = ? WHERE id = ?", (canonical_id, comp_id))
718:                     stats['companies_backfilled'] += 1
719:                 if not dry_run:
720:                     conn.commit()
721:             else:
722:                 print("  No companies need backfilling")
723: 
724:         # Backfill people
725:         if table_exists(conn, 'people'):
726:             cursor = conn.execute("SELECT id, name FROM people WHERE canonical_id IS NULL")
727:             rows = cursor.fetchall()
728:             if rows:
729:                 print(f"  Backfilling {len(rows)} people...")
730:                 for person_id, name in rows:
731:                     canonical_id = generate_canonical_id('person', name)
732:                     if not dry_run:
733:                         conn.execute("UPDATE people SET canonical_id = ? WHERE id = ?", (canonical_id, person_id))
734:                     stats['people_backfilled'] += 1
735:                 if not dry_run:
736:                     conn.commit()
737:             else:
738:                 print("  No people need backfilling")
739: 
740:         # Backfill locations
741:         if table_exists(conn, 'locations'):
742:             cursor = conn.execute("SELECT id, name FROM locations WHERE canonical_id IS NULL")
743:             rows = cursor.fetchall()
744:             if rows:
745:                 print(f"  Backfilling {len(rows)} locations...")
746:                 for loc_id, name in rows:
747:                     canonical_id = generate_canonical_id('location', name)
748:                     if not dry_run:
749:                         conn.execute("UPDATE locations SET canonical_id = ? WHERE id = ?", (canonical_id, loc_id))
750:                     stats['locations_backfilled'] += 1
751:                 if not dry_run:
752:                     conn.commit()
753:             else:
754:                 print("  No locations need backfilling")
755: 
756:         # Phase 3: Create Indexes
757:         print("\nPhase 3: Create Indexes")
758:         print("-" * SEPARATOR_WIDTH_SMALL)
759: 
760:         indexes = [
761:             ("ix_files_canonical_id", "files", "canonical_id"),
762:             ("ix_categories_canonical_id", "categories", "canonical_id"),
763:             ("ix_companies_canonical_id", "companies", "canonical_id"),
764:             ("ix_people_canonical_id", "people", "canonical_id"),
765:             ("ix_locations_canonical_id", "locations", "canonical_id"),
766:         ]
767: 
768:         for index_name, table, column in indexes:
769:             if not table_exists(conn, table):
770:                 continue
771:             # Check if index exists
772:             cursor = conn.execute(
773:                 "SELECT name FROM sqlite_master WHERE type='index' AND name=?",
774:                 (index_name,)
775:             )
776:             if cursor.fetchone():
777:                 print(f"  Index {index_name} already exists")
778:                 continue
779: 
780:             if dry_run:
781:                 print(f"  [DRY RUN] Would create index {index_name}")
782:             else:
783:                 try:
784:                     conn.execute(f"CREATE INDEX IF NOT EXISTS {index_name} ON {table}({column})")
785:                     print(f"  Created index {index_name}")
786:                     stats['indexes_created'] += 1
787:                 except sqlite3.OperationalError as e:
788:                     print(f"  Warning creating index {index_name}: {e}")
789: 
790:         if not dry_run:
791:             conn.commit()
792: 
793:         # Summary
