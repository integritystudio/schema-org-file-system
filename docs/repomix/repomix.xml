588:     def get_destination_path(self, category: str, subcategory: str, filename: str) -> Path:
589:         """Get the full destination path for a file."""
590:         return self.base_path / category / subcategory / filename
591: 
592:     def move_file(self, source: Path, destination: Path) -> bool:
593:         """Move a file to its destination."""
594:         try:
595:             # Create destination directory
596:             destination.parent.mkdir(parents=True, exist_ok=True)
597: 
598:             # Handle duplicates
599:             if destination.exists():
600:                 # Add suffix to filename
601:                 stem = destination.stem
602:                 suffix = destination.suffix
603:                 counter = 1
604:                 while destination.exists():
605:                     new_name = f"{stem}_{counter}{suffix}"
606:                     destination = destination.parent / new_name
607:                     counter += 1
608: 
609:             if self.dry_run:
610:                 print(f"  [DRY RUN] Would move to: {destination}")
611:             else:
612:                 shutil.move(str(source), str(destination))
613:                 print(f"  ✓ Moved to: {destination}")
614: 
615:             return True
616:         except Exception as e:
617:             print(f"  ✗ Error moving file: {e}")
618:             return False
