 668:     def classify_content(self, text: str, filename: str = "") -> Tuple[str, str, Optional[str], List[str]]:
 669:         """
 670:         Classify content based on extracted text.
 671:         Uses Schema.org person-company relationships to improve categorization.
 672: 
 673:         Returns:
 674:             Tuple of (category, subcategory, company_name, people_names)
 675:         """
 676:         if not text:
 677:             return ('uncategorized', 'other', None, [])
 678: 
 679:         text_lower = text.lower()
 680:         filename_lower = filename.lower()
 681:         combined = f"{text_lower} {filename_lower}"
 682: 
 683:         # Extract company names and people names
 684:         company_names = self.extract_company_names(text)
 685:         primary_company = company_names[0] if company_names else None
 686: 
 687:         people_names = self.extract_people_names(text)
 688: 
 689:         # Extract person-company relationships (Schema.org connections)
 690:         person_company_relationships = self.extract_person_company_relationships(text)
 691: 
 692:         # Prioritize company from person-company relationships over direct extraction
 693:         # Relationships tend to be more accurate as they include context
 694:         if person_company_relationships:
 695:             # Get the first relationship's company
 696:             relationship_company = next(iter(person_company_relationships.values()))
 697: 
 698:             # Check if relationship company has proper legal suffix
 699:             has_legal_suffix = any(relationship_company.endswith(suffix)
 700:                                   for suffix in ['LLC', 'Inc.', 'Inc', 'Corp.', 'Corp',
 701:                                                 'Ltd.', 'Ltd', 'LLP', 'L.L.C.', 'L.L.P.'])
 702: 
 703:             # Prefer relationship company if it has legal suffix or we don't have a primary company
 704:             if has_legal_suffix or not primary_company:
 705:                 primary_company = relationship_company
 706:             # Or if the relationship company is much cleaner (shorter and no weird prefixes)
 707:             elif primary_company and 'CEO' not in relationship_company and 'at' not in relationship_company:
 708:                 if len(relationship_company) < len(primary_company) * 0.8:
 709:                     primary_company = relationship_company
 710: 
 711:         # Fallback: If we found people but no company, check relationships again
 712:         if people_names and not primary_company and person_company_relationships:
 713:             # Try to find a company for the first person mentioned
 714:             for person in people_names:
 715:                 if person in person_company_relationships:
 716:                     primary_company = person_company_relationships[person]
 717:                     break
 718: 
 719:         # Score each category
 720:         scores = defaultdict(int)
 721:         category_subcats = {}
 722: 
 723:         for category, data in self.patterns.items():
 724:             for keyword in data['keywords']:
 725:                 count = combined.count(keyword.lower())
 726:                 if count > 0:
 727:                     scores[category] += count
 728: 
 729:                     # Track which subcategory keywords matched
 730:                     for subcat, subcat_keywords in data['subcategories'].items():
 731:                         if any(sk.lower() in combined for sk in subcat_keywords):
 732:                             if category not in category_subcats:
 733:                                 category_subcats[category] = defaultdict(int)
 734:                             category_subcats[category][subcat] += count
 735: 
 736:         if not scores:
 737:             return ('uncategorized', 'other', primary_company, people_names)
 738: 
 739:         # Get category with highest score
 740:         best_category = max(scores.items(), key=lambda x: x[1])[0]
 741: 
 742:         # Get subcategory with highest score for this category
 743:         if best_category in category_subcats:
 744:             subcat_scores = category_subcats[best_category]
 745:             if subcat_scores:
 746:                 best_subcategory = max(subcat_scores.items(), key=lambda x: x[1])[0]
 747:             else:
 748:                 best_subcategory = 'other'
 749:         else:
 750:             best_subcategory = 'other'
 751: 
 752:         # If we detected a company (either directly or via person relationship)
 753:         # and it's business-related, use clients subcategory
 754:         if primary_company and best_category == 'business':
 755:             best_subcategory = 'clients'
 756: 
 757:         return (best_category, best_subcategory, primary_company, people_names)
