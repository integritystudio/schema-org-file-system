1056:     def classify_image_content(self, image_path: Path) -> Dict[str, float]:
1057:         """
1058:         Classify image content using CLIP zero-shot classification.
1059: 
1060:         Returns:
1061:             Dictionary of category -> confidence score
1062:         """
1063:         if not self.vision_available or self.model is None:
1064:             return {}
1065: 
1066:         with CostTracker(self.cost_calculator, 'clip_vision') if self.cost_calculator else nullcontext():
1067:             try:
1068:                 # Open image
1069:                 image = Image.open(image_path)
1070: 
1071:                 # Define categories to check
1072:                 categories = [
1073:                     "a photo of a home interior room",
1074:                     "a photo of a living room",
1075:                     "a photo of a bedroom",
1076:                     "a photo of a kitchen",
1077:                     "a photo of a bathroom",
1078:                     "a photo of furniture",
1079:                     "a photo of a house exterior",
1080:                     "a photo of people",
1081:                     "a screenshot",
1082:                     "a photo of outdoors",
1083:                     "a photo of nature"
1084:                 ]
1085: 
1086:                 # Prepare inputs
1087:                 inputs = self.processor(
1088:                     text=categories,
1089:                     images=image,
1090:                     return_tensors="pt",
1091:                     padding=True
1092:                 )
1093: 
1094:                 # Get predictions
1095:                 with torch.no_grad():
1096:                     outputs = self.model(**inputs)
1097:                     logits_per_image = outputs.logits_per_image
1098:                     probs = logits_per_image.softmax(dim=1)
1099: 
1100:                 # Convert to dictionary
1101:                 scores = {}
1102:                 for i, category in enumerate(categories):
1103:                     scores[category] = float(probs[0][i])
1104: 
1105:                 return scores
1106: 
1107:             except Exception as e:
1108:                 print(f"  Image classification error: {e}")
1109:             return {}
