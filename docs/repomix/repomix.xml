1035:                 img = cv2.imread(str(image_path))
1036:                 if img is None:
1037:                     return False
1038: 
1039:                 # Convert to grayscale for face detection
1040:                 gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
1041: 
1042:                 # Detect faces
1043:                 faces = self.face_cascade.detectMultiScale(
1044:                     gray,
1045:                     scaleFactor=1.1,
1046:                     minNeighbors=5,
1047:                     minSize=(30, 30)
1048:                 )
1049: 
1050:                 return len(faces) > 0
1051: 
1052:             except Exception as e:
1053:                 print(f"  Face detection error: {e}")
1054:                 return False
