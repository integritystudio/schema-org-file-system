  1: #!/usr/bin/env python3
  2: """
  3: Database migration script for ID generation improvements.
  4: 
  5: This script:
  6: 1. Adds new columns (canonical_id, source_ids, merged_into_id) to entity tables
  7: 2. Backfills canonical_id with deterministic UUIDs from names/paths
  8: 3. Creates the merge_events table
  9: 
 10: Safe to run multiple times (idempotent).
 11: 
 12: Usage:
 13:     python scripts/migrate_ids.py --db-path results/file_organization.db
 14:     python scripts/migrate_ids.py --dry-run  # Show what would be done
 15: """
 16: 
 17: import argparse
 18: import sqlite3
 19: import uuid
 20: import sys
 21: from pathlib import Path
 22: from datetime import datetime
 23: 
 24: 
 25: # Namespace UUIDs for deterministic ID generation (must match models.py)
 26: NAMESPACES = {
 27:     'file': uuid.UUID('f4e8a9c0-1234-5678-9abc-def012345678'),
 28:     'category': uuid.UUID('c4e8a9c0-2345-6789-abcd-ef0123456789'),
 29:     'company': uuid.UUID('c0e1a2b3-4567-89ab-cdef-012345678901'),
 30:     'person': uuid.UUID('d1e2a3b4-5678-9abc-def0-123456789012'),
 31:     'location': uuid.UUID('e2e3a4b5-6789-abcd-ef01-234567890123'),
 32: }
 33: 
 34: 
 35: def generate_canonical_id(namespace: str, name: str) -> str:
 36:     """Generate deterministic UUID v5 from name."""
 37:     ns_uuid = NAMESPACES.get(namespace)
 38:     if not ns_uuid:
 39:         raise ValueError(f"Unknown namespace: {namespace}")
 40:     return str(uuid.uuid5(ns_uuid, name.lower().strip()))
 41: 
 42: 
 43: def column_exists(conn: sqlite3.Connection, table: str, column: str) -> bool:
 44:     """Check if a column exists in a table."""
 45:     cursor = conn.execute(f"PRAGMA table_info({table})")
 46:     columns = [row[1] for row in cursor.fetchall()]
 47:     return column in columns
