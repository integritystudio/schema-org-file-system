564:     def categorize_file(self, file_path: Path) -> Tuple[str, str]:
565:         """
566:         Categorize a file using filename and path patterns.
567:         Returns (category, subcategory).
568:         Priority: filename patterns > extension > filepath > uncategorized
569:         """
570:         # Priority 1: Filename patterns (most specific)
571:         result = self.categorize_by_filename(file_path)
572:         if result:
573:             return result
574: 
575:         # Priority 2: Extension
576:         result = self.categorize_by_extension(file_path)
577:         if result:
578:             return result
579: 
580:         # Priority 3: Filepath
581:         result = self.categorize_by_filepath(file_path)
582:         if result:
583:             return result
584: 
585:         # Default: Uncategorized
586:         return ('Uncategorized', 'Other')
