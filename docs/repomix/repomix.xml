  1: #!/usr/bin/env python3
  2: """
  3: Merge Labeled Data from Database Sessions into Organization Report
  4: 
  5: This script combines:
  6: 1. Existing report data (from the main ML run)
  7: 2. Additional labeled data from labeling sessions (manual corrections)
  8: 
  9: The result is an enriched dataset with more diverse labeled examples.
 10: """
 11: 
 12: import json
 13: from datetime import datetime
 14: from pathlib import Path
 15: from typing import Dict, List
 16: 
 17: from shared.db_utils import db_connection
 18: 
 19: 
 20: def get_labeling_session_data(db_path: str, ml_session: str) -> List[Dict]:
 21:     """
 22:     Get labeled file data from labeling sessions (non-ML sessions).
 23: 
 24:     Args:
 25:         db_path: Path to SQLite database
 26:         ml_session: Session ID to exclude (the main ML run)
 27: 
 28:     Returns:
 29:         List of file records with labels
 30:     """
 31:     records = []
 32:     with db_connection(db_path) as conn:
 33:         cursor = conn.cursor()
 34: 
 35:         query = """
 36:         SELECT
 37:             f.original_path,
 38:             f.filename,
 39:             f.file_extension,
 40:             f.mime_type,
 41:             f.file_size,
 42:             f.schema_type,
 43:             f.extracted_text,
 44:             f.extracted_text_length,
 45:             c.name as subcategory,
 46:             c.full_path as full_category_path,
 47:             f.session_id
 48:         FROM files f
 49:         JOIN file_categories fc ON f.id = fc.file_id
 50:         JOIN categories c ON fc.category_id = c.id
 51:         WHERE f.session_id <> ?
 52:         """
 53: 
 54:         cursor.execute(query, (ml_session,))
 55: 
 56:         for row in cursor.fetchall():
 57:             full_path = row['full_category_path'] or ''
 58:             parts = full_path.split('/') if full_path else []
 59:             parent_category = parts[0] if parts else row['subcategory']
 60: 
 61:             records.append({
 62:                 'source': row['original_path'],
 63:                 'status': 'organized',
 64:                 'reason': None,
 65:                 'destination': row['original_path'],  # Use original path as destination
 66:                 'schema': {
 67:                     '@context': 'https://schema.org',
 68:                     '@type': row['schema_type'] or 'DigitalDocument',
 69:                     'name': row['filename'],
 70:                     'description': row['filename'],
 71:                     'filePath': row['original_path']
 72:                 },
 73:                 'extracted_text_length': row['extracted_text_length'] or 0,
 74:                 'company_name': None,
 75:                 'people_names': [],
 76:                 'image_metadata': {},
 77:                 'category': parent_category,
 78:                 'subcategory': row['subcategory'],
 79:                 'is_valid': True,
 80:                 'label_source': 'manual_labeling',
 81:                 'session_id': row['session_id']
 82:             })
 83: 
 84:     return records
 85: 
 86: 
 87: def merge_reports(report_path: str, labeling_data: List[Dict], output_path: str) -> Dict:
 88:     """
 89:     Merge labeling session data into the organization report.
 90: 
 91:     Args:
 92:         report_path: Path to original report JSON
 93:         labeling_data: List of labeled file records
 94:         output_path: Path to save merged report
 95: 
 96:     Returns:
 97:         Statistics about the merge
 98:     """
 99:     print(f"Loading report from: {report_path}")
100:     with open(report_path, 'r') as f:
101:         report = json.load(f)
102: 
103:     results = report.get('results', [])
104: 
105:     # Build set of existing sources to avoid duplicates
106:     existing_sources = set(r.get('source', '') for r in results)
107:     existing_filenames = set(Path(r.get('source', '')).name for r in results if r.get('source'))
108: 
109:     stats = {
110:         'original_count': len(results),
111:         'labeling_records': len(labeling_data),
112:         'added': 0,
113:         'skipped_duplicate_path': 0,
114:         'skipped_duplicate_filename': 0,
115:         'categories_added': {}
116:     }
117: 
118:     # Add labeling session records that aren't already in the report
119:     for record in labeling_data:
120:         source = record.get('source', '')
121:         filename = Path(source).name if source else ''
122: 
123:         if source in existing_sources:
124:             stats['skipped_duplicate_path'] += 1
125:             continue
126: 
127:         if filename in existing_filenames:
128:             stats['skipped_duplicate_filename'] += 1
129:             continue
130: 
131:         # Add the record
132:         results.append(record)
133:         existing_sources.add(source)
134:         existing_filenames.add(filename)
135:         stats['added'] += 1
136: 
137:         # Track category distribution
138:         cat_key = f"{record['category']}/{record['subcategory']}"
139:         stats['categories_added'][cat_key] = stats['categories_added'].get(cat_key, 0) + 1
140: 
141:     # Update report metadata
142:     report['results'] = results
143:     report['total_files'] = len(results)
144:     report['merge_timestamp'] = datetime.now().isoformat()
145:     report['labeling_records_added'] = stats['added']
146: 
147:     # Save merged report
148:     print(f"Saving merged report to: {output_path}")
149:     with open(output_path, 'w') as f:
150:         json.dump(report, f, indent=2)
151: 
152:     return stats
153: 
154: 
155: def main():
156:     import argparse
157: 
158:     parser = argparse.ArgumentParser(description='Merge labeled data from database into report')
159:     parser.add_argument('--report', '-r',
160:                         default='results/content_organization_report_20251209_104237.json',
161:                         help='Path to original organization report')
162:     parser.add_argument('--database', '-d',
163:                         default='results/file_organization.db',
164:                         help='Path to SQLite database')
165:     parser.add_argument('--output', '-o',
166:                         help='Output path (default: timestamped in results/)')
167:     parser.add_argument('--ml-session',
168:                         default='a6b07a390a11312d8306bcd3589c20572c146747338809c1d0ad5af53edd40bb',
169:                         help='Session ID to exclude (main ML run)')
170: 
171:     args = parser.parse_args()
172: 
173:     # Generate output path with timestamp
174:     if args.output:
175:         output_path = args.output
176:     else:
177:         timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
178:         output_path = f'results/content_organization_report_merged_{timestamp}.json'
179: 
180:     print("=" * 60)
181:     print("MERGE LABELED DATA INTO ORGANIZATION REPORT")
182:     print("=" * 60)
183: 
184:     # Get labeling session data
185:     print("\nFetching labeled data from database...")
186:     labeling_data = get_labeling_session_data(args.database, args.ml_session)
187:     print(f"Found {len(labeling_data)} labeled records from labeling sessions")
188: 
189:     # Merge the data
190:     print("\nMerging data...")
191:     stats = merge_reports(args.report, labeling_data, output_path)
192: 
193:     # Print summary
194:     print("\n" + "-" * 40)
195:     print("MERGE SUMMARY")
196:     print("-" * 40)
197:     print(f"Original report files: {stats['original_count']:,}")
198:     print(f"Labeling session records: {stats['labeling_records']:,}")
199:     print(f"Records added: {stats['added']:,}")
200:     print(f"Skipped (duplicate path): {stats['skipped_duplicate_path']:,}")
201:     print(f"Skipped (duplicate filename): {stats['skipped_duplicate_filename']:,}")
202:     print(f"Final total files: {stats['original_count'] + stats['added']:,}")
203: 
204:     if stats['categories_added']:
205:         print("\n" + "-" * 40)
206:         print("CATEGORIES ADDED")
207:         print("-" * 40)
208:         for cat, count in sorted(stats['categories_added'].items(), key=lambda x: -x[1]):
209:             print(f"  {cat}: {count} files")
210: 
211:     print("\n" + "-" * 40)
212:     print(f"Merged report saved to: {output_path}")
213:     print("=" * 60)
214: 
215:     return output_path
216: 
217: 
218: if __name__ == "__main__":
219:     main()
