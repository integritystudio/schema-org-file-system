290:     def _classify_font(self, file_ext: str) -> Optional[Tuple[str, str, str]]:
291:         """
292:         Classify font files based on extension.
293: 
294:         Returns:
295:             Tuple of (category, subcategory, schema_type) or None if not a font
296:         """
297:         font_extensions = {
298:             '.ttf': ('fonts', 'truetype', 'DigitalDocument'),
299:             '.otf': ('fonts', 'opentype', 'DigitalDocument'),
300:             '.woff': ('fonts', 'web', 'DigitalDocument'),
301:             '.woff2': ('fonts', 'web', 'DigitalDocument'),
302:             '.eot': ('fonts', 'web', 'DigitalDocument'),
303:             '.fon': ('fonts', 'other', 'DigitalDocument'),
304:             '.fnt': ('fonts', 'other', 'DigitalDocument'),
305:         }
306:         return font_extensions.get(file_ext.lower())
