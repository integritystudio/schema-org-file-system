3307:     def generate_schema(self, file_path: Path, schema_type: str, extracted_text: str = "") -> Dict:
3308:         """Generate Schema.org metadata for a file with extracted content."""
3309:         stats = file_path.stat()
3310:         mime_type = self.enricher.detect_mime_type(str(file_path))
3311:         file_url = f"https://localhost/files/{quote(file_path.name)}"
3312:         actual_path = str(file_path.absolute())
3313: 
3314:         # Create generator based on type
3315:         if schema_type == 'ImageObject':
3316:             generator = ImageGenerator(schema_type)
3317:             generator.set_basic_info(
3318:                 name=file_path.name,
3319:                 content_url=file_url,
3320:                 encoding_format=mime_type or 'image/png',
3321:                 description=f"{file_path.name}"
3322:             )
3323:         elif schema_type in ['DigitalDocument', 'Article']:
3324:             generator = DocumentGenerator(schema_type)
3325:             generator.set_basic_info(
3326:                 name=file_path.name,
3327:                 description=f"{file_path.name}"
3328:             )
3329:             generator.set_file_info(
3330:                 encoding_format=mime_type or 'application/octet-stream',
3331:                 url=file_url,
3332:                 content_size=stats.st_size
3333:             )
3334:         else:
3335:             generator = DocumentGenerator()
3336:             generator.set_basic_info(
3337:                 name=file_path.name,
3338:                 description=f"{file_path.name}"
3339:             )
3340: 
3341:         # Set dates
3342:         try:
3343:             generator.set_dates(
3344:                 created=datetime.fromtimestamp(stats.st_ctime),
3345:                 modified=datetime.fromtimestamp(stats.st_mtime)
3346:             )
3347:         except Exception:
3348:             pass
3349: 
3350:         # Add extracted text as abstract/text property
3351:         if extracted_text:
3352:             try:
3353:                 # Truncate to reasonable length for schema
3354:                 text_preview = extracted_text[:1000] + ('...' if len(extracted_text) > 1000 else '')
3355:                 generator.set_property('abstract', text_preview, PropertyType.TEXT)
3356:                 generator.set_property('text', extracted_text[:5000], PropertyType.TEXT)
3357:             except Exception:
3358:                 pass
3359: 
3360:         # Add file path
3361:         try:
3362:             generator.set_property('filePath', actual_path, PropertyType.TEXT)
3363:         except Exception:
3364:             pass
3365: 
3366:         return generator.to_dict()
