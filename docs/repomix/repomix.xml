110: def capture_error(
111:     error: Exception,
112:     level: str = ErrorLevel.ERROR,
113:     context: Optional[Dict[str, Any]] = None,
114:     tags: Optional[Dict[str, str]] = None,
115:     user_id: Optional[str] = None
116: ) -> Optional[str]:
117:     """
118:     Capture an error to Sentry with full context.
119: 
120:     Args:
121:         error: The exception to capture
122:         level: Error severity level
123:         context: Additional context data
124:         tags: Additional tags for filtering
125:         user_id: User identifier if available
126: 
127:     Returns:
128:         Sentry event ID if captured, None otherwise
129:     """
130:     if not SENTRY_AVAILABLE:
131:         # Fallback to console logging
132:         print(f"[{level.upper()}] {type(error).__name__}: {error}")
133:         if context:
134:             print(f"  Context: {context}")
135:         return None
136: 
137:     with sentry_sdk.push_scope() as scope:
138:         # Set severity level
139:         scope.level = level
140: 
141:         # Set user if provided
142:         if user_id:
143:             scope.set_user({'id': user_id})
144: 
145:         # Add tags
146:         if tags:
147:             for key, value in tags.items():
148:                 scope.set_tag(key, value)
149: 
150:         # Add context
151:         if context:
152:             scope.set_context('error_context', context)
153: 
154:         # Capture the exception
155:         event_id = sentry_sdk.capture_exception(error)
156:         return event_id
157: 
