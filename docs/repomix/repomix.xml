249:         """Convert to dictionary for JSON serialization."""
250:         return {
251:             'id': self.id,
252:             '@id': self.get_iri(),
253:             'canonical_id': self.canonical_id,
254:             'filename': self.filename,
255:             'original_path': self.original_path,
