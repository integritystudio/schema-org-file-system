 688:         target_file_id: str,
 689:         relationship_type: RelationshipType,
 690:         confidence: float = 1.0,
 691:         metadata: Dict = None,
 692:         session: Session = None
 693:     ) -> FileRelationship:
 694:         """
 695:         Add a relationship between two files.
 696: 
 697:         Args:
 698:             source_file_id: Source file ID
 699:             target_file_id: Target file ID
 700:             relationship_type: Type of relationship
 701:             confidence: Relationship confidence
 702:             metadata: Additional metadata
 703: 
 704:         Returns:
 705:             Created relationship
 706:         """
 707:         close_session = session is None
 708:         session = session or self.get_session()
 709: 
 710:         try:
 711:             # Check if relationship already exists
 712:             existing = session.query(FileRelationship).filter(
 713:                 and_(
 714:                     FileRelationship.source_file_id == source_file_id,
 715:                     FileRelationship.target_file_id == target_file_id,
 716:                     FileRelationship.relationship_type == relationship_type
 717:                 )
 718:             ).first()
 719: 
 720:             if existing:
 721:                 existing.confidence = confidence
 722:                 existing.metadata = metadata
 723:                 session.commit()
 724:                 return existing
 725: 
 726:             relationship = FileRelationship(
 727:                 source_file_id=source_file_id,
 728:                 target_file_id=target_file_id,
 729:                 relationship_type=relationship_type,
 730:                 confidence=confidence,
 731:                 metadata=metadata
 732:             )
 733:             session.add(relationship)
 734:             session.commit()
 735:             return relationship
 736: 
