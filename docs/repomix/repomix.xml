496:     def validate_required_properties(self) -> List[str]:
497:         """
498:         Validate that all required properties are present.
499: 
500:         Returns:
501:             List of missing required properties
502:         """
503:         required = self.get_required_properties()
504:         missing = []
505:         for prop in required:
506:             if prop not in self.data:
507:                 missing.append(prop)
508:         return missing
509: 
510:     def get_completion_score(self) -> float:
511:         """
512:         Calculate completion score based on required and recommended properties.
513: 
514:         Returns:
515:             Completion score (0.0 to 1.0)
516:         """
517:         required = self.get_required_properties()
518:         recommended = self.get_recommended_properties()
519:         total = len(required) + len(recommended)
520: 
521:         if total == 0:
522:             return 1.0
523: 
524:         present = 0
525:         for prop in required:
526:             if prop in self.data:
527:                 present += 1
528:         for prop in recommended:
529:             if prop in self.data:
530:                 present += 0.5  # Recommended properties count as half
531: 
532:         return min(present / len(required) if required else 1.0, 1.0)
533: 
534:     def __str__(self) -> str:
535:         """String representation."""
536:         return self.to_json_ld()
537: 
538:     def __repr__(self) -> str:
539:         """Representation."""
