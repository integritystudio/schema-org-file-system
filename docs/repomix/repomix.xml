1108:     def search_by_location(
1109:         self,
1110:         latitude: float,
1111:         longitude: float,
1112:         radius_km: float = 10,
1113:         limit: int = DEFAULT_SEARCH_LIMIT,
1114:         session: Session = None
1115:     ) -> List[File]:
1116:         """
1117:         Find files near a geographic location.
1118: 
1119:         Uses a simple bounding box approximation for SQLite compatibility.
1120: 
1121:         Args:
1122:             latitude: Center latitude
1123:             longitude: Center longitude
1124:             radius_km: Search radius in kilometers
1125:             limit: Maximum results
1126:             session: Optional existing session
1127: 
1128:         Returns:
1129:             List of files with GPS data near the location
1130:         """
1131:         close_session = session is None
1132:         session = session or self.get_session()
1133: 
1134:         try:
1135:             # Approximate degrees per km (varies by latitude)
1136:             lat_delta = radius_km / KM_PER_DEGREE_LATITUDE
1137:             lon_delta = radius_km / (KM_PER_DEGREE_LATITUDE * abs(latitude) if latitude else KM_PER_DEGREE_LATITUDE)
1138: 
1139:             return session.query(File)\
1140:                 .filter(
1141:                     and_(
1142:                         File.gps_latitude.isnot(None),
1143:                         File.gps_latitude.between(latitude - lat_delta, latitude + lat_delta),
1144:                         File.gps_longitude.between(longitude - lon_delta, longitude + lon_delta)
1145:                     )
1146:                 )\
1147:                 .limit(limit)\
1148:                 .all()
1149: 
1150:         finally:
1151:             if close_session:
