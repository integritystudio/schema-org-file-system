143:     def _migrate_organization_report(self, file_path: Path, verbose: bool = True):
144:         """
145:         Migrate a content organization report.
146: 
147:         Args:
148:             file_path: Path to JSON file
149:             verbose: Print progress
150:         """
151:         if verbose:
152:             print(f"\n  Processing: {file_path.name}")
153: 
154:         with open(file_path, 'r') as f:
155:             data = json.load(f)
156: 
157:         # Extract timestamp from filename
158:         timestamp_str = file_path.stem.replace('content_organization_report_', '')
159:         try:
160:             session_timestamp = datetime.strptime(timestamp_str, '%Y%m%d_%H%M%S')
161:         except ValueError:
162:             session_timestamp = datetime.utcnow()
163: 
164:         # Create organization session
165:         session = self.graph_store.get_session()
166: 
167:         try:
168:             org_session = OrganizationSession(
169:                 id=hashlib.sha256(str(file_path).encode()).hexdigest()[:SHA256_HEX_LENGTH],
170:                 started_at=session_timestamp,
171:                 completed_at=session_timestamp,
172:                 dry_run=data.get('dry_run', False),
173:                 total_files=data.get('total_files', 0),
174:                 organized_count=data.get('organized', 0),
175:                 skipped_count=data.get('skipped', 0),
176:                 error_count=data.get('errors', 0)
177:             )
178:             session.merge(org_session)
179:             session.commit()
180:             self.stats['sessions'] += 1
181: 
182:             # Migrate individual file results in batches
183:             results = data.get('results', [])
184:             batch_size = 100
185:             for i, result in enumerate(results):
186:                 with session.no_autoflush:
187:                     self._migrate_file_result(result, org_session.id, session)
188: 
189:                 # Commit in batches to avoid large transactions
190:                 if (i + 1) % batch_size == 0:
191:                     session.commit()
192: 
193:             # Final commit for remaining items
194:             session.commit()
195: 
196:             if verbose:
197:                 print(f"    - Migrated {len(results)} file records")
198:                 print(f"    - Session ID: {org_session.id[:16]}...")
199: 
200:         except Exception as e:
201:             session.rollback()
202:             raise e
203:         finally:
204:             session.close()
