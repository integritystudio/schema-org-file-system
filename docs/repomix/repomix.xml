375:     def validate_data_quality(self) -> Dict[str, Any]:
376:         """Validate data quality and identify issues."""
377:         if not self.features:
378:             raise ValueError("No features extracted. Call extract_all_features() first.")
379: 
380:         issues = {
381:             'missing_category': [],
382:             'empty_filename': [],
383:             'duplicate_filenames': [],
384:             'suspicious_extensions': [],
385:         }
386: 
387:         filename_counts = Counter(f['filename'] for f in self.features)
388: 
389:         for f in self.features:
