257:             'file_extension': self.file_extension,
258:             'mime_type': self.mime_type,
259:             'file_size': self.file_size,
260:             'status': self.status.value if self.status else None,
261:             'categories': [c.name for c in self.categories],
262:             'companies': [c.name for c in self.companies],
263:             'people': [p.name for p in self.people],
264:             'schema_type': self.schema_type,
265:             'organized_at': self.organized_at.isoformat() if self.organized_at else None,
266:         }
