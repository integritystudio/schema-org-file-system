607:             ('categories', 'VARCHAR(36)'),
608:             ('companies', 'VARCHAR(36)'),
609:             ('people', 'VARCHAR(36)'),
610:             ('locations', 'VARCHAR(36)'),
611:         ]
612: 
613:         for table, col_type in tables_to_migrate:
614:             if not table_exists(conn, table):
615:                 print(f"  Table {table} does not exist, skipping")
616:                 continue
617: 
618:             if not column_exists(conn, table, 'canonical_id'):
619:                 if dry_run:
620:                     print(f"  [DRY RUN] Would add canonical_id to {table}")
621:                 else:
622:                     conn.execute(f"ALTER TABLE {table} ADD COLUMN canonical_id {col_type}")
623:                     print(f"  Added canonical_id to {table}")
624:                 stats['columns_added'] += 1
625:             else:
626:                 print(f"  canonical_id already exists in {table}")
627: 
628:             # Add source_ids column if not exists
629:             if not column_exists(conn, table, 'source_ids'):
630:                 if dry_run:
631:                     print(f"  [DRY RUN] Would add source_ids to {table}")
632:                 else:
633:                     conn.execute(f"ALTER TABLE {table} ADD COLUMN source_ids JSON DEFAULT '[]'")
634:                     print(f"  Added source_ids to {table}")
635: 
636:             # Add merged_into_id for entity tables (not files)
637:             if table != 'files' and not column_exists(conn, table, 'merged_into_id'):
638:                 if dry_run:
639:                     print(f"  [DRY RUN] Would add merged_into_id to {table}")
640:                 else:
641:                     conn.execute(f"ALTER TABLE {table} ADD COLUMN merged_into_id INTEGER REFERENCES {table}(id)")
642:                     print(f"  Added merged_into_id to {table}")
643: 
644:         # Create merge_events table if not exists
645:         if not table_exists(conn, 'merge_events'):
646:             if dry_run:
647:                 print("  [DRY RUN] Would create merge_events table")
648:             else:
649:                 conn.execute(f"""
650:                     CREATE TABLE merge_events (
651:                         id VARCHAR({UUID_STRING_LENGTH}) PRIMARY KEY,
652:                         target_entity_type VARCHAR({SHORT_FIELD_LENGTH}) NOT NULL,
653:                         target_entity_id INTEGER NOT NULL,
654:                         target_canonical_id VARCHAR({UUID_STRING_LENGTH}),
655:                         source_entity_ids JSON NOT NULL,
656:                         source_canonical_ids JSON,
657:                         merge_reason TEXT,
658:                         confidence FLOAT DEFAULT 1.0,
659:                         performed_by VARCHAR(100),
660:                         performed_at DATETIME DEFAULT CURRENT_TIMESTAMP,
661:                         jsonld JSON,
662:                         is_rolled_back BOOLEAN DEFAULT FALSE,
663:                         rolled_back_at DATETIME,
664:                         rolled_back_by VARCHAR(100)
665:                     )
666:                 """)
667:                 print("  Created merge_events table")
668: 
669:         if not dry_run:
670:             conn.commit()
