<file path="scripts/add_content_descriptions.py">
  1: #!/usr/bin/env python3
  2: """
  3: Add content descriptions to renamed image filenames.
  4: Uses the analysis results from analyze_renamed_files.py to add meaningful descriptions.
  5: """
  6: 
  7: import os
  8: import sys
  9: import json
 10: import re
 11: from pathlib import Path
 12: from collections import defaultdict
 13: 
 14: from shared.constants import CONTENT_ABBREVIATIONS
 15: from shared.file_ops import resolve_collision
 16: 
 17: 
 18: def sanitize_for_filename(text: str, max_length: int = 30) -> str:
 19:     """Sanitize text for use in filename."""
 20:     if not text:
 21:         return ""
 22: 
 23:     # Remove special characters, keep alphanumeric and spaces
 24:     clean = re.sub(r'[^\w\s-]', '', text)
 25:     # Replace spaces with underscores
 26:     clean = re.sub(r'\s+', '_', clean.strip())
 27:     # Remove multiple underscores
 28:     clean = re.sub(r'_+', '_', clean)
 29:     # Truncate
 30:     if len(clean) > max_length:
 31:         clean = clean[:max_length].rstrip('_')
 32:     return clean
 33: 
 34: 
 35: def extract_ocr_keywords(ocr_text: str, max_words: int = 3) -> str:
 36:     """Extract meaningful keywords from OCR text."""
 37:     if not ocr_text:
 38:         return ""
 39: 
 40:     # Skip if OCR text is too short or looks like garbage
 41:     if len(ocr_text) < 5:
 42:         return ""
 43: 
 44:     # Common noise patterns to skip
 45:     noise_patterns = [
 46:         r'^[\s\-\|\_\.\,\!\?\@\#\$\%\^\&\*\(\)]+$',  # Just punctuation
 47:         r'^[a-z]{1,2}$',  # Single/double letters
 48:     ]
 49: 
 50:     for pattern in noise_patterns:
 51:         if re.match(pattern, ocr_text.strip(), re.IGNORECASE):
 52:             return ""
 53: 
 54:     # Get first few meaningful words
 55:     words = ocr_text.split()
 56:     meaningful_words = []
 57: 
 58:     for word in words:
 59:         # Skip short words and numbers-only
 60:         clean_word = re.sub(r'[^\w]', '', word)
 61:         if len(clean_word) >= 3 and not clean_word.isdigit():
 62:             meaningful_words.append(clean_word)
 63:             if len(meaningful_words) >= max_words:
 64:                 break
 65: 
 66:     return '_'.join(meaningful_words) if meaningful_words else ""
 67: 
 68: 
 69: def generate_descriptive_filename(result: dict) -> str:
 70:     """Generate a new descriptive filename from analysis result."""
 71:     original_path = Path(result['path'])
 72:     original_name = original_path.stem
 73:     ext = original_path.suffix.lower()
 74: 
 75:     parts = []
 76: 
 77:     # Keep the date portion if it exists (YYYYMMDD)
 78:     date_match = re.match(r'^(\d{8})', original_name)
 79:     if date_match:
 80:         parts.append(date_match.group(1))
 81: 
 82:     # Add content type abbreviation
 83:     content_type = result.get('content_type')
 84:     if content_type and content_type in CONTENT_ABBREVIATIONS:
 85:         parts.append(CONTENT_ABBREVIATIONS[content_type])
 86:     elif content_type:
 87:         # Try to create abbreviation from content type
 88:         abbrev = sanitize_for_filename(content_type.split()[0], max_length=10)
 89:         if abbrev:
 90:             parts.append(abbrev.lower())
 91: 
 92:     # Add OCR keywords if available and meaningful
 93:     ocr_text = result.get('ocr_text')
 94:     if ocr_text:
 95:         keywords = extract_ocr_keywords(ocr_text)
 96:         if keywords and len(keywords) > 3:
 97:             parts.append(keywords)
 98: 
 99:     # Add confidence indicator for high-confidence classifications
100:     confidence = result.get('confidence')
101:     if confidence and confidence >= 0.7:
102:         pass  # Don't add anything, high confidence is the default
103:     elif confidence and confidence < 0.5:
104:         parts.append('uncertain')
105: 
106:     # Keep time portion if it exists (HHMMSS)
107:     time_match = re.search(r'_(\d{6})(?:_\d+)?$', original_name)
108:     if time_match:
109:         parts.append(time_match.group(1))
110: 
111:     # Handle duplicate suffix (_N)
112:     dup_match = re.search(r'_(\d+)$', original_name)
113:     if dup_match and not time_match:
114:         parts.append(dup_match.group(1))
115: 
116:     # Build new filename
117:     new_name = '_'.join(parts) + ext
118: 
119:     return new_name
120: 
121: 
122: def rename_with_descriptions(analysis_file: str, dry_run: bool = False) -> dict:
123:     """Rename files based on analysis results."""
124: 
125:     # Load analysis results
126:     with open(analysis_file, 'r') as f:
127:         data = json.load(f)
128: 
129:     results = data.get('results', [])
130: 
131:     print(f"\n{'='*60}")
132:     print(f"Adding Content Descriptions to Filenames {'(DRY RUN)' if dry_run else ''}")
133:     print(f"{'='*60}\n")
134:     print(f"Files to process: {len(results)}\n")
135: 
136:     stats = defaultdict(int)
137:     rename_log = []
138: 
139:     for i, result in enumerate(results, 1):
140:         original_path = Path(result['path'])
141: 
142:         # Skip if file doesn't exist
143:         if not original_path.exists():
144:             stats['missing'] += 1
145:             continue
146: 
147:         # Skip if no content type identified
148:         if not result.get('content_type'):
149:             stats['no_content_type'] += 1
150:             continue
151: 
152:         # Generate new filename
153:         new_name = generate_descriptive_filename(result)
154:         new_path = original_path.parent / new_name
155: 
156:         # Skip if name unchanged
157:         if new_path == original_path:
158:             stats['unchanged'] += 1
159:             continue
160: 
161:         # Handle collisions
162:         if new_path.exists() and new_path != original_path:
163:             new_path = resolve_collision(new_path)
164:             new_name = new_path.name
165: 
166:         # Perform rename
167:         try:
168:             if not dry_run:
169:                 original_path.rename(new_path)
170: 
171:             stats['renamed'] += 1
172:             rename_log.append({
173:                 'original': str(original_path),
174:                 'new': str(new_path),
175:                 'content_type': result.get('content_type'),
176:                 'confidence': result.get('confidence')
177:             })
178: 
