  33: class GraphStore:
  34:     """
  35:     High-level interface for graph-based file storage.
  36: 
  37:     Provides methods for:
  38:     - File CRUD operations
  39:     - Category management with hierarchy
  40:     - Relationship traversal (graph queries)
  41:     - Statistics and aggregations
  42:     """
  43: 
  44:     def __init__(self, db_path: str = 'results/file_organization.db'):
  45:         """
  46:         Initialize the graph store.
  47: 
  48:         Args:
  49:             db_path: Path to SQLite database
  50:         """
  51:         self.db_path = db_path
  52:         self.engine = create_engine(f'sqlite:///{db_path}', echo=False)
  53: 
  54:         # Enable SQLite optimizations
  55:         @event.listens_for(self.engine, "connect")
  56:         def set_sqlite_pragma(dbapi_connection, connection_record):
  57:             cursor = dbapi_connection.cursor()
  58:             cursor.execute("PRAGMA foreign_keys=ON")
  59:             cursor.execute("PRAGMA journal_mode=WAL")
  60:             cursor.execute("PRAGMA synchronous=NORMAL")
  61:             cursor.execute("PRAGMA cache_size=-64000")  # 64MB cache
  62:             cursor.close()
  63: 
  64:         # Create tables
  65:         Base.metadata.create_all(self.engine)
  66: 
  67:         # Session factory
  68:         self.SessionLocal = sessionmaker(bind=self.engine)
  69: 
  70:     def get_session(self) -> Session:
  71:         """Get a new database session."""
  72:         return self.SessionLocal()
  73: 
  74:     # =========================================================================
  75:     # File Operations
  76:     # =========================================================================
  77: 
  78:     def add_file(
  79:         self,
  80:         original_path: str,
  81:         filename: str,
  82:         session: Session = None,
  83:         **kwargs
  84:     ) -> File:
  85:         """
  86:         Add a new file to the store.
  87: 
  88:         Args:
  89:             original_path: Original file path
  90:             filename: File name
  91:             session: Optional existing session
  92:             **kwargs: Additional file properties
  93: 
  94:         Returns:
  95:             Created File object
  96:         """
  97:         close_session = session is None
  98:         session = session or self.get_session()
  99: 
 100:         try:
 101:             file_id = File.generate_id(original_path)
 102: 
 103:             # Check if file already exists
 104:             existing = session.query(File).filter(File.id == file_id).first()
 105:             if existing:
 106:                 # Update existing file
 107:                 for key, value in kwargs.items():
 108:                     if hasattr(existing, key):
 109:                         setattr(existing, key, value)
 110:                 session.commit()
 111:                 return existing
 112: 
 113:             # Create new file with canonical ID
 114:             file = File(
 115:                 id=file_id,
 116:                 canonical_id=File.generate_canonical_id(original_path),
 117:                 original_path=original_path,
 118:                 filename=filename,
 119:                 file_extension=Path(filename).suffix.lower() if filename else None,
 120:                 **kwargs
 121:             )
 122:             session.add(file)
 123:             session.commit()
 124:             return file
 125: 
 126:         except Exception as e:
 127:             session.rollback()
 128:             raise e
 129:         finally:
 130:             if close_session:
 131:                 session.close()
 132: 
 133:     def get_file(self, file_id: str = None, path: str = None, session: Session = None) -> Optional[File]:
 134:         """
 135:         Get a file by ID or path.
 136: 
 137:         Args:
 138:             file_id: File ID (hash)
 139:             path: Original file path
 140:             session: Optional existing session
 141: 
 142:         Returns:
