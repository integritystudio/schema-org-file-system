280:         """Create stratified train/test split.
281: 
282:         Args:
283:             test_ratio: Fraction of data for testing
284:             stratify_by: Field to stratify by ('category' or 'subcategory')
285:             random_seed: Random seed for reproducibility
286: 
287:         Returns:
288:             Tuple of (train_features, test_features)
289:         """
290:         import random
291:         random.seed(random_seed)
292: 
293:         if not self.features:
294:             raise ValueError("No features extracted. Call extract_all_features() first.")
295: 
296:         # Group by stratification field
297:         groups = defaultdict(list)
298:         for f in self.features:
299:             key = f.get(stratify_by, 'unknown')
300:             groups[key].append(f)
301: 
302:         train_data = []
303:         test_data = []
304: 
305:         for key, items in groups.items():
306:             random.shuffle(items)
