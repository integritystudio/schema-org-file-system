130: def evaluate_model(test_data_path: str, output_path: str = None) -> Dict[str, Any]:
131:     """
132:     Evaluate the categorization model on test data.
133: 
134:     Args:
135:         test_data_path: Path to test.json
136:         output_path: Path to save results (optional)
137: 
138:     Returns:
139:         Evaluation results dictionary
140:     """
141:     print("Loading test data...")
142:     with open(test_data_path, 'r') as f:
143:         test_data = json.load(f)
144: 
145:     print(f"Loaded {len(test_data)} test samples")
146: 
147:     model = FileCategorizationModel()
148: 
149:     # Run predictions
150:     results = []
151:     correct = 0
152:     correct_subcategory = 0
153: 
154:     category_metrics = defaultdict(lambda: {'tp': 0, 'fp': 0, 'fn': 0})
155:     confusion_matrix = defaultdict(lambda: defaultdict(int))
156:     confidence_scores = []
157: 
158:     print("Running predictions...")
159:     for i, feature in enumerate(test_data):
160:         actual_category = feature.get('category', 'uncategorized')
161:         actual_subcategory = feature.get('subcategory', 'other')
162: 
163:         predicted_category, predicted_subcategory, confidence = model.predict_category(feature)
164: 
165:         # Track results
166:         is_correct = predicted_category == actual_category
167:         is_subcategory_correct = predicted_subcategory == actual_subcategory
168: 
169:         if is_correct:
170:             correct += 1
171:             category_metrics[actual_category]['tp'] += 1
172:         else:
173:             category_metrics[actual_category]['fn'] += 1
174:             category_metrics[predicted_category]['fp'] += 1
175: 
176:         if is_subcategory_correct:
177:             correct_subcategory += 1
178: 
179:         confusion_matrix[actual_category][predicted_category] += 1
180:         confidence_scores.append(confidence)
181: 
182:         results.append({
183:             'filename': feature.get('filename'),
184:             'filepath': feature.get('filepath'),
185:             'actual_category': actual_category,
186:             'actual_subcategory': actual_subcategory,
187:             'predicted_category': predicted_category,
188:             'predicted_subcategory': predicted_subcategory,
189:             'confidence': confidence,
190:             'correct': is_correct,
191:             'subcategory_correct': is_subcategory_correct
192:         })
193: 
194:         if (i + 1) % 1000 == 0:
195:             print(f"  Processed {i + 1}/{len(test_data)}")
196: 
197:     # Calculate metrics
198:     accuracy = correct / len(test_data) if test_data else 0
199:     subcategory_accuracy = correct_subcategory / len(test_data) if test_data else 0
200:     avg_confidence = sum(confidence_scores) / len(confidence_scores) if confidence_scores else 0
201: 
202:     # Per-category metrics
203:     per_category_metrics = {}
204:     for category in category_metrics:
205:         tp = category_metrics[category]['tp']
206:         fp = category_metrics[category]['fp']
207:         fn = category_metrics[category]['fn']
208: 
209:         precision = tp / (tp + fp) if (tp + fp) > 0 else 0
210:         recall = tp / (tp + fn) if (tp + fn) > 0 else 0
211:         f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
212: 
213:         per_category_metrics[category] = {
214:             'precision': round(precision, 4),
215:             'recall': round(recall, 4),
216:             'f1_score': round(f1, 4),
217:             'support': tp + fn
218:         }
219: 
220:     # Find misclassifications
221:     misclassifications = [r for r in results if not r['correct']]
222:     misclassification_patterns = Counter(
223:         (r['actual_category'], r['predicted_category'])
224:         for r in misclassifications
225:     )
226: 
227:     # Build evaluation report
228:     evaluation = {
229:         'metadata': {
230:             'timestamp': datetime.now().isoformat(),
231:             'test_samples': len(test_data),
232:             'model': 'FileCategorizationModel v1.0'
233:         },
234:         'overall_metrics': {
235:             'accuracy': round(accuracy, 4),
236:             'subcategory_accuracy': round(subcategory_accuracy, 4),
237:             'avg_confidence': round(avg_confidence, 4),
238:             'total_correct': correct,
239:             'total_incorrect': len(test_data) - correct
240:         },
241:         'per_category_metrics': per_category_metrics,
242:         'confusion_matrix': {k: dict(v) for k, v in confusion_matrix.items()},
243:         'top_misclassifications': [
244:             {
245:                 'from': pattern[0],
246:                 'to': pattern[1],
247:                 'count': count
248:             }
249:             for pattern, count in misclassification_patterns.most_common(10)
250:         ],
251:         'sample_results': results[:100],  # Include sample of detailed results
252:         'all_predictions': results  # Full results
253:     }
254: 
255:     # Save results
256:     if output_path:
257:         print(f"Saving results to {output_path}")
258:         with open(output_path, 'w') as f:
259:             json.dump(evaluation, f, indent=2)
260: 
261:     return evaluation
262: 
263: 
264: def print_report(evaluation: Dict[str, Any]):
265:     """Print a formatted evaluation report."""
266:     print("\n" + "=" * 60)
267:     print("MODEL EVALUATION REPORT")
268:     print("=" * 60)
269: 
270:     print(f"\nTimestamp: {evaluation['metadata']['timestamp']}")
271:     print(f"Test Samples: {evaluation['metadata']['test_samples']:,}")
272: 
273:     print("\n" + "-" * 40)
274:     print("OVERALL METRICS")
