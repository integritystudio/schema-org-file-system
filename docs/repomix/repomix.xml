360:     def categorize_by_extension(self, file_path: Path) -> Optional[Tuple[str, str]]:
361:         """
362:         Categorize file by extension.
363:         Returns (category, subcategory) or None.
364:         """
365:         # Check for .map files specifically (source maps)
366:         if file_path.name.endswith('.js.map'):
367:             return ('Technical', 'JavaScript')
368:         elif file_path.name.endswith('.css.map'):
369:             return ('Technical', 'JavaScript')
370:         elif file_path.name.endswith('.ts.map'):
371:             return ('Technical', 'JavaScript')
372: 
373:         ext = file_path.suffix.lower().lstrip('.')
374: 
375:         for category, extensions in self.extension_map.items():
376:             if ext in extensions:
377:                 # Map to destination paths
378:                 if category == 'images':
379:                     return ('Media/Photos', 'Other')
380:                 elif category == 'videos':
381:                     return ('Media/Videos', 'Recordings')
382:                 elif category == 'audio':
383:                     return ('Media/Audio', 'Other')
384:                 elif category == 'documents':
385:                     return ('Documents', 'General')
386:                 elif category == 'spreadsheets':
387:                     return ('Data', 'Spreadsheets')
388:                 elif category == 'presentations':
389:                     return ('Documents', 'Presentations')
390:                 elif category == 'code':
391:                     return ('Technical', 'Code')
392:                 elif category == 'data':
393:                     return ('Data', 'Configs')
394:                 elif category == 'archives':
395:                     return ('Data', 'Archives')
396:                 elif category == 'certificates':
397:                     return ('Technical', 'Certificates')
398:                 elif category == 'game_files':
399:                     return ('GameAssets', 'SaveFiles')
400:                 elif category == 'design':
401:                     return ('Creative', 'Design')
402:                 elif category == '3d':
403:                     return ('Creative', '3D')
404: 
405:         return None
