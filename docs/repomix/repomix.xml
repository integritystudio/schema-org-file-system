  1: #!/usr/bin/env python3
  2: """
  3: Organize renamed files into Schema.org-based folder structure based on content type.
  4: Uses the CLIP classification results to determine proper organization.
  5: """
  6: 
  7: import os
  8: import sys
  9: import json
 10: import shutil
 11: from pathlib import Path
 12: from collections import defaultdict
 13: from typing import Dict, Tuple
 14: 
 15: from shared.constants import CONTENT_TO_SCHEMA
 16: from shared.file_ops import resolve_collision
 17: 
 18: 
 19: def get_schema_path(content_type: str, base_path: Path) -> Path:
 20:     """Get the Schema.org-based path for a content type."""
 21:     if content_type in CONTENT_TO_SCHEMA:
 22:         category, subcategory = CONTENT_TO_SCHEMA[content_type]
 23:         return base_path / category / subcategory
 24:     else:
 25:         # Default to ImageObject/Other for unknown types
 26:         return base_path / "ImageObject" / "Other"
 27: 
 28: 
 29: def organize_files(
 30:     rename_log_file: str,
 31:     base_path: str = "~/Documents",
 32:     dry_run: bool = False,
 33:     move_files: bool = True
 34: ) -> Dict:
 35:     """Organize files based on content classification."""
 36: 
 37:     base_path = Path(base_path).expanduser()
 38: 
 39:     # Load rename log with content types
 40:     with open(rename_log_file, 'r') as f:
 41:         data = json.load(f)
 42: 
 43:     print(f"\n{'='*60}")
 44:     print(f"Organizing Files by Content {'(DRY RUN)' if dry_run else ''}")
 45:     print(f"{'='*60}\n")
 46:     print(f"Base path: {base_path}")
 47:     print(f"Files to organize: {len(data['log'])}")
 48:     print(f"Mode: {'Move' if move_files else 'Copy'}\n")
 49: 
 50:     stats = defaultdict(int)
 51:     organization_log = []
 52: 
 53:     for i, item in enumerate(data['log'], 1):
 54:         source_path = Path(item['new'])
 55:         content_type = item.get('content_type')
 56: 
 57:         # Skip if file doesn't exist
 58:         if not source_path.exists():
 59:             stats['missing'] += 1
 60:             continue
 61: 
 62:         # Skip if no content type
 63:         if not content_type:
 64:             stats['no_content_type'] += 1
 65:             continue
 66: 
 67:         # Get destination path
 68:         dest_dir = get_schema_path(content_type, base_path)
 69:         dest_path = dest_dir / source_path.name
 70: 
 71:         # Skip if already in correct location
 72:         if source_path.parent == dest_dir:
 73:             stats['already_organized'] += 1
 74:             continue
 75: 
 76:         # Handle collisions
 77:         dest_path = resolve_collision(dest_path)
 78: 
 79:         # Create destination directory
 80:         if not dry_run:
 81:             dest_dir.mkdir(parents=True, exist_ok=True)
 82: 
 83:         # Move or copy file
 84:         try:
 85:             if not dry_run:
 86:                 if move_files:
 87:                     shutil.move(str(source_path), str(dest_path))
 88:                 else:
 89:                     shutil.copy2(str(source_path), str(dest_path))
 90: 
 91:             stats['organized'] += 1
 92:             organization_log.append({
 93:                 'source': str(source_path),
 94:                 'destination': str(dest_path),
 95:                 'content_type': content_type,
 96:                 'schema_category': CONTENT_TO_SCHEMA.get(content_type, ('ImageObject', 'Other'))
 97:             })
 98: 
 99:             if i <= 30 or i % 50 == 0:
100:                 action = "Would move" if dry_run else ("Moved" if move_files else "Copied")
101:                 rel_dest = dest_path.relative_to(base_path)
102:                 print(f"  {action}: {source_path.name}")
103:                 print(f"       → {rel_dest}")
104: 
105:         except Exception as e:
106:             stats['errors'] += 1
107:             print(f"  Error: {source_path.name}: {e}")
108: 
109:     # Print summary
110:     print(f"\n{'='*60}")
111:     print("Organization Summary")
112:     print(f"{'='*60}\n")
113:     print(f"Total files: {len(data['log'])}")
114:     print(f"Organized: {stats['organized']}")
115:     print(f"Already in place: {stats['already_organized']}")
116:     print(f"Missing files: {stats['missing']}")
117:     print(f"No content type: {stats['no_content_type']}")
118:     print(f"Errors: {stats['errors']}")
119: 
120:     if dry_run:
121:         print(f"\n⚠️  This was a DRY RUN - no files were moved")
122: 
123:     # Show organization breakdown
124:     if organization_log:
125:         print(f"\nOrganization by Schema.org Category:")
126:         print("-" * 40)
127:         category_counts = defaultdict(int)
128:         for item in organization_log:
129:             cat = "/".join(item['schema_category'])
130:             category_counts[cat] += 1
131: 
132:         for cat, count in sorted(category_counts.items(), key=lambda x: x[1], reverse=True):
133:             print(f"  {cat}: {count}")
134: 
135:     return {
136:         'stats': dict(stats),
137:         'log': organization_log
138:     }
139: 
140: 
141: def main():
142:     import argparse
143: 
144:     parser = argparse.ArgumentParser(
145:         description='Organize files into Schema.org-based folder structure'
146:     )
147:     parser.add_argument(
148:         '--rename-log',
149:         default=str(Path(__file__).parent.parent / 'results' / 'content_rename_log.json'),
150:         help='Path to rename log JSON file'
151:     )
152:     parser.add_argument(
153:         '--base-path',
154:         default='~/Documents',
155:         help='Base path for organization (default: ~/Documents)'
156:     )
157:     parser.add_argument(
158:         '--dry-run',
159:         action='store_true',
160:         help='Preview changes without moving files'
161:     )
162:     parser.add_argument(
163:         '--copy',
164:         action='store_true',
165:         help='Copy files instead of moving'
166:     )
167:     parser.add_argument(
168:         '--output-log',
169:         help='Save organization log to JSON file'
170:     )
171: 
172:     args = parser.parse_args()
173: 
174:     result = organize_files(
175:         rename_log_file=args.rename_log,
176:         base_path=args.base_path,
177:         dry_run=args.dry_run,
178:         move_files=not args.copy
179:     )
180: 
181:     if args.output_log:
182:         with open(args.output_log, 'w') as f:
183:             json.dump(result, f, indent=2)
184:         print(f"\nOrganization log saved to: {args.output_log}")
185: 
186: 
187: if __name__ == '__main__':
188:     main()
