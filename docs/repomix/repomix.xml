163:             except ImportError:
164:                 missing.append("transformers")
165: 
166:             self.features['clip_vision'] = FeatureStatus(
167:                 name="AI Vision (CLIP)",
168:                 available=False,
169:                 error=f"Missing: {', '.join(missing)}",
170:                 impact="No AI classification - pip install torch transformers"
171:             )
