 1: """Shared file operation utilities."""
 2: from pathlib import Path
 3: 
 4: 
 5: def resolve_collision(dest_path: Path) -> Path:
 6:   """Resolve filename collision by appending incrementing counter.
 7: 
 8:   Given /foo/bar.png where bar.png exists, returns /foo/bar_1.png, etc.
 9:   """
10:   if not dest_path.exists():
11:     return dest_path
12:   stem = dest_path.stem
13:   ext = dest_path.suffix
14:   parent = dest_path.parent
15:   counter = 1
16:   while dest_path.exists():
17:     dest_path = parent / f"{stem}_{counter}{ext}"
18:     counter += 1
19:   return dest_path
