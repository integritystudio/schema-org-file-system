253: class FileProcessingErrorTracker:
254:     """
255:     Specialized error tracker for file processing operations.
256: 
257:     Usage:
258:         tracker = FileProcessingErrorTracker()
259: 
260:         for file in files:
261:             with tracker.track_file(file.path):
262:                 process_file(file)
263: 
264:         tracker.print_summary()
265:     """
266: 
267:     def __init__(self):
268:         self.processed = 0
269:         self.succeeded = 0
270:         self.failed = 0
271:         self.errors: list[Dict[str, Any]] = []
272: 
273:     @contextmanager
274:     def track_file(self, file_path: str, category: Optional[str] = None):
275:         """Track processing of a single file."""
276:         self.processed += 1
277:         context = {
278:             'file_path': file_path,
279:             'file_number': self.processed,
280:             'category': category
281:         }
282: 
283:         try:
284:             with track_operation('process_file', op_type='file', **context):
285:                 yield
286:             self.succeeded += 1
287:         except Exception as e:
288:             self.failed += 1
289:             error_info = {
290:                 'file_path': file_path,
291:                 'error_type': type(e).__name__,
292:                 'error_message': str(e),
293:                 'category': category
294:             }
295:             self.errors.append(error_info)
296: 
297:             capture_error(
298:                 e,
299:                 level=ErrorLevel.WARNING,  # File errors are usually recoverable
300:                 context=context,
301:                 tags={'error_type': type(e).__name__}
302:             )
303:             # Don't re-raise - continue processing other files
304: 
305:     def print_summary(self):
306:         """Print processing summary."""
307:         print(f"\nFile Processing Summary:")
308:         print(f"  Processed: {self.processed}")
309:         print(f"  Succeeded: {self.succeeded} ({self.succeeded/max(self.processed,1)*100:.1f}%)")
310:         print(f"  Failed: {self.failed}")
311: 
312:         if self.errors:
313:             # Group errors by type
314:             error_types: Dict[str, int] = {}
315:             for error in self.errors:
316:                 error_type = error['error_type']
317:                 error_types[error_type] = error_types.get(error_type, 0) + 1
318: 
319:             print(f"\nError breakdown:")
320:             for error_type, count in sorted(error_types.items(), key=lambda x: -x[1]):
321:                 print(f"  {error_type}: {count}")
322: 
323:     def get_stats(self) -> Dict[str, Any]:
324:         """Get processing statistics as dict."""
325:         return {
326:             'processed': self.processed,
327:             'succeeded': self.succeeded,
328:             'failed': self.failed,
329:             'success_rate': self.succeeded / max(self.processed, 1),
330:             'errors': self.errors
331:         }
332: 
333: 
334: # Singleton tracker for the application
335: _file_tracker: Optional[FileProcessingErrorTracker] = None
336: 
337: 
338: def get_file_tracker() -> FileProcessingErrorTracker:
339:     """Get or create the singleton file tracker."""
340:     global _file_tracker
341:     if _file_tracker is None:
342:         _file_tracker = FileProcessingErrorTracker()
343:     return _file_tracker
344: 
345: 
346: def reset_file_tracker() -> FileProcessingErrorTracker:
347:     """Reset the file tracker for a new processing run."""
348:     global _file_tracker
349:     _file_tracker = FileProcessingErrorTracker()
350:     return _file_tracker
351: 
