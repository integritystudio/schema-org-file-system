275:             file.current_path = result.get('destination') or file.current_path
276:             file.status = status
277:             db_session.flush()  # Ensure updates are visible
278: 
279:         # Add category relationship
280:         category = result.get('category')
281:         subcategory = result.get('subcategory')
282: 
283:         if category and category != 'uncategorized':
284:             self.graph_store.add_file_to_category(
285:                 file_id, category, subcategory, session=db_session
286:             )
287:             self.stats['categories'] += 1
288: 
289:         # Add company relationship
