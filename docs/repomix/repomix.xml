707:     def organize_file(self, file_path: Path, dry_run: bool = False) -> Dict:
708:         """
709:         Organize a single file.
710: 
711:         Args:
712:             file_path: Path to the file
713:             dry_run: If True, don't actually move files
714: 
715:         Returns:
716:             Dictionary with organization details
717:         """
718:         result = {
719:             'source': str(file_path),
720:             'status': 'skipped',
721:             'reason': None,
722:             'destination': None,
723:             'schema': None
724:         }
725: 
726:         # Skip if should be skipped
727:         if self.should_skip_file(file_path):
728:             result['reason'] = 'system_file'
729:             self.stats['skipped'] += 1
730:             return result
731: 
732:         # Skip if not a file
733:         if not file_path.is_file():
734:             result['reason'] = 'not_file'
735:             self.stats['skipped'] += 1
736:             return result
737: 
738:         try:
739:             # Detect category
740:             category, subcategory, schema_type = self.detect_file_category(file_path)
741: 
742:             # Generate schema
743:             schema = self.generate_schema(file_path, schema_type)
744: 
745:             # Validate schema
746:             validation_report = self.validator.validate(schema)
747: 
748:             # Get destination path
749:             dest_path = self.get_destination_path(file_path, category, subcategory)
750: 
751:             # Skip if already in the right place
752:             if file_path == dest_path:
753:                 result['status'] = 'already_organized'
754:                 result['destination'] = str(dest_path)
755:                 result['schema'] = schema
756:                 self.stats['already_organized'] += 1
757:                 return result
758: 
759:             # Move file if not dry run
760:             if not dry_run:
761:                 shutil.move(str(file_path), str(dest_path))
762: 
763:                 # Register schema with new path
764:                 schema['url'] = f"file://{dest_path.absolute()}"
765:                 self.registry.register(
766:                     str(dest_path),
767:                     schema,
768:                     metadata={
769:                         'category': category,
770:                         'subcategory': subcategory,
771:                         'organized_date': datetime.now().isoformat(),
772:                         'is_valid': validation_report.is_valid()
773:                     }
774:                 )
775: 
776:             result['status'] = 'organized' if not dry_run else 'would_organize'
777:             result['destination'] = str(dest_path)
778:             result['schema'] = schema
779:             result['category'] = category
780:             result['subcategory'] = subcategory
781:             result['is_valid'] = validation_report.is_valid()
782: 
783:             self.stats['organized'] += 1
784:             self.stats[f'{category}_{subcategory}'] += 1
785: 
786:         except Exception as e:
787:             result['status'] = 'error'
788:             result['reason'] = str(e)
789:             self.stats['errors'] += 1
