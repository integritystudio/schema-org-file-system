<file path="src/integration.py">
  1: """
  2: Integration layer for Schema.org structured data.
  3: 
  4: Provides multiple output formats (JSON-LD, microdata, RDFa),
  5: API endpoints, and bulk export functionality.
  6: """
  7: 
  8: from typing import Any, Dict, List, Optional, Union
  9: from enum import Enum
 10: from xml.etree.ElementTree import Element, SubElement, tostring
 11: from html import escape
 12: import json
 13: 
 14: 
 15: class OutputFormat(Enum):
 16:     """Supported output formats."""
 17:     JSON_LD = "json-ld"
 18:     MICRODATA = "microdata"
 19:     RDFA = "rdfa"
 20:     JSON = "json"
 21: 
 22: 
 23: class SchemaIntegration:
 24:     """
 25:     Integration layer for Schema.org structured data.
 26: 
 27:     Handles conversion between formats, HTML embedding,
 28:     and provides API-ready output.
 29:     """
 30: 
 31:     def __init__(self):
 32:         """Initialize integration layer."""
 33:         self.schemas: List[Dict[str, Any]] = []
 34: 
 35:     def add_schema(self, schema: Union[Dict[str, Any], 'SchemaOrgBase']) -> 'SchemaIntegration':
 36:         """
 37:         Add schema to collection.
 38: 
 39:         Args:
 40:             schema: Schema dictionary or SchemaOrgBase instance
 41: 
 42:         Returns:
 43:             Self for method chaining
 44:         """
 45:         if hasattr(schema, 'to_dict'):
 46:             schema = schema.to_dict()
 47:         self.schemas.append(schema)
 48:         return self
 49: 
 50:     def to_json_ld(self, schema: Optional[Dict[str, Any]] = None,
 51:                    indent: int = 2) -> str:
 52:         """
 53:         Convert to JSON-LD format.
 54: 
 55:         Args:
 56:             schema: Specific schema to convert (or use all schemas)
 57:             indent: JSON indentation
 58: 
 59:         Returns:
 60:             JSON-LD string
 61:         """
 62:         if schema is None:
 63:             if len(self.schemas) == 1:
 64:                 data = self.schemas[0]
 65:             else:
 66:                 data = {"@graph": self.schemas}
 67:         else:
 68:             data = schema
 69: 
 70:         return json.dumps(data, indent=indent, ensure_ascii=False)
 71: 
 72:     def to_json_ld_script(self, schema: Optional[Dict[str, Any]] = None,
 73:                          indent: int = 2) -> str:
 74:         """
 75:         Convert to JSON-LD script tag for HTML.
 76: 
 77:         Args:
 78:             schema: Specific schema to convert
 79:             indent: JSON indentation
 80: 
 81:         Returns:
 82:             HTML script tag with JSON-LD
 83:         """
 84:         json_ld = self.to_json_ld(schema, indent)
 85:         return f'<script type="application/ld+json">\n{json_ld}\n</script>'
 86: 
 87:     def to_microdata(self, schema: Dict[str, Any],
 88:                      tag: str = "div") -> str:
 89:         """
 90:         Convert to HTML5 microdata format.
 91: 
 92:         Args:
 93:             schema: Schema dictionary
 94:             tag: HTML tag to use
 95: 
 96:         Returns:
 97:             HTML with microdata attributes
 98:         """
 99:         schema_type = schema.get("@type", "Thing")
100:         html_parts = [f'<{tag} itemscope itemtype="https://schema.org/{schema_type}">']
101: 
102:         for key, value in schema.items():
103:             if key.startswith("@"):
104:                 continue
105: 
106:             if isinstance(value, dict) and "@type" in value:
107:                 # Nested schema
108:                 html_parts.append(self.to_microdata(value, tag="div"))
109:             elif isinstance(value, list):
110:                 for item in value:
111:                     if isinstance(item, dict) and "@type" in item:
112:                         html_parts.append(self.to_microdata(item, tag="div"))
113:                     else:
114:                         html_parts.append(
115:                             f'  <meta itemprop="{key}" content="{escape(str(item))}">'
116:                         )
117:             else:
118:                 # Simple property
119:                 if key in ["url", "contentUrl", "thumbnailUrl"]:
120:                     html_parts.append(
121:                         f'  <link itemprop="{key}" href="{escape(str(value))}">'
122:                     )
123:                 elif key in ["image", "logo"]:
124:                     if isinstance(value, str):
125:                         html_parts.append(
126:                             f'  <link itemprop="{key}" href="{escape(value)}">'
127:                         )
128:                 else:
129:                     html_parts.append(
130:                         f'  <meta itemprop="{key}" content="{escape(str(value))}">'
131:                     )
132: 
133:         html_parts.append(f'</{tag}>')
134:         return '\n'.join(html_parts)
135: 
136:     def to_rdfa(self, schema: Dict[str, Any],
137:                 tag: str = "div") -> str:
138:         """
139:         Convert to RDFa format.
140: 
141:         Args:
142:             schema: Schema dictionary
143:             tag: HTML tag to use
144: 
145:         Returns:
146:             HTML with RDFa attributes
147:         """
148:         schema_type = schema.get("@type", "Thing")
149:         html_parts = [
150:             f'<{tag} vocab="https://schema.org/" typeof="{schema_type}">'
151:         ]
152: 
153:         for key, value in schema.items():
154:             if key.startswith("@"):
155:                 continue
156: 
157:             if isinstance(value, dict) and "@type" in value:
158:                 # Nested schema
159:                 nested_html = self.to_rdfa(value, tag="div")
160:                 html_parts.append(f'  <div property="{key}">')
161:                 html_parts.append(f'    {nested_html}')
162:                 html_parts.append('  </div>')
163:             elif isinstance(value, list):
164:                 for item in value:
165:                     if isinstance(item, dict) and "@type" in item:
166:                         nested_html = self.to_rdfa(item, tag="div")
167:                         html_parts.append(f'  <div property="{key}">')
168:                         html_parts.append(f'    {nested_html}')
169:                         html_parts.append('  </div>')
170:                     else:
171:                         html_parts.append(
172:                             f'  <meta property="{key}" content="{escape(str(item))}">'
173:                         )
174:             else:
175:                 # Simple property
176:                 if key in ["url", "contentUrl", "thumbnailUrl"]:
177:                     html_parts.append(
178:                         f'  <link property="{key}" href="{escape(str(value))}">'
179:                     )
180:                 else:
181:                     html_parts.append(
182:                         f'  <meta property="{key}" content="{escape(str(value))}">'
183:                     )
184: 
185:         html_parts.append(f'</{tag}>')
186:         return '\n'.join(html_parts)
187: 
188:     def export_format(self, format: OutputFormat,
189:                      schema: Optional[Dict[str, Any]] = None) -> str:
190:         """
191:         Export in specified format.
192: 
193:         Args:
194:             format: Output format
195:             schema: Specific schema (or use all)
196: 
197:         Returns:
198:             Formatted string
199:         """
200:         if schema is None and len(self.schemas) > 0:
201:             schema = self.schemas[0]
202: 
203:         if format == OutputFormat.JSON_LD:
204:             return self.to_json_ld(schema)
205:         elif format == OutputFormat.MICRODATA:
206:             return self.to_microdata(schema)
207:         elif format == OutputFormat.RDFA:
208:             return self.to_rdfa(schema)
209:         elif format == OutputFormat.JSON:
210:             return json.dumps(schema, indent=2)
211:         else:
212:             raise ValueError(f"Unsupported format: {format}")
213: 
214:     def export_all(self, format: OutputFormat) -> List[str]:
215:         """
216:         Export all schemas in specified format.
217: 
218:         Args:
219:             format: Output format
220: 
221:         Returns:
222:             List of formatted strings
223:         """
224:         return [self.export_format(format, schema) for schema in self.schemas]
225: 
226:     def create_html_page(self, title: str,
227:                         content: str,
228:                         format: OutputFormat = OutputFormat.JSON_LD) -> str:
229:         """
230:         Create complete HTML page with embedded structured data.
231: 
232:         Args:
233:             title: Page title
234:             content: Page content HTML
235:             format: Structured data format to use
236: 
237:         Returns:
238:             Complete HTML page
239:         """
240:         structured_data = ""
241:         if format == OutputFormat.JSON_LD:
242:             structured_data = self.to_json_ld_script()
243:         elif format == OutputFormat.MICRODATA:
244:             # Microdata is embedded in content
245:             structured_data = f"<!-- Microdata embedded in content -->"
246:         elif format == OutputFormat.RDFA:
247:             # RDFa is embedded in content
248:             structured_data = f"<!-- RDFa embedded in content -->"
249: 
250:         html = f"""<!DOCTYPE html>
251: <html lang="en">
252: <head>
253:     <meta charset="UTF-8">
254:     <meta name="viewport" content="width=device-width, initial-scale=1.0">
255:     <title>{escape(title)}</title>
256:     {structured_data}
257: </head>
258: <body>
259:     {content}
260: </body>
261: </html>"""
262:         return html
263: 
264:     def get_api_response(self, schema_id: Optional[str] = None) -> Dict[str, Any]:
265:         """
266:         Get API-ready response.
267: 
268:         Args:
269:             schema_id: Specific schema ID (or return all)
270: 
271:         Returns:
272:             API response dictionary
273:         """
274:         if schema_id is not None:
275:             # In real implementation, look up by ID
276:             schema = self.schemas[0] if self.schemas else {}
277:             return {
278:                 "success": True,
279:                 "data": schema,
280:                 "format": "application/ld+json"
281:             }
282:         else:
283:             return {
284:                 "success": True,
285:                 "data": self.schemas,
286:                 "count": len(self.schemas),
287:                 "format": "application/ld+json"
288:             }
289: 
290:     def export_bulk(self, format: OutputFormat,
291:                    file_path: str) -> None:
292:         """
293:         Export all schemas to file.
294: 
295:         Args:
296:             format: Output format
297:             file_path: Output file path
298:         """
299:         if format == OutputFormat.JSON_LD or format == OutputFormat.JSON:
300:             data = {"@graph": self.schemas} if len(self.schemas) > 1 else self.schemas[0]
301:             with open(file_path, 'w', encoding='utf-8') as f:
302:                 json.dump(data, f, indent=2, ensure_ascii=False)
303:         else:
304:             # For HTML formats, create one file per schema
305:             base_path = file_path.rsplit('.', 1)[0]
306:             for i, schema in enumerate(self.schemas):
307:                 output = self.export_format(format, schema)
308:                 with open(f"{base_path}_{i}.html", 'w', encoding='utf-8') as f:
309:                     f.write(output)
310: 
311:     def clear(self) -> None:
312:         """Clear all schemas."""
313:         self.schemas = []
314: 
315: 
316: class SchemaRegistry:
317:     """
318:     Registry for managing multiple schemas with metadata.
319: 
320:     Provides indexing, search, and retrieval capabilities.
321:     """
322: 
323:     def __init__(self):
324:         """Initialize registry."""
325:         self.registry: Dict[str, Dict[str, Any]] = {}
326: 
327:     def register(self, schema_id: str, schema: Dict[str, Any],
328:                 metadata: Optional[Dict[str, Any]] = None) -> None:
329:         """
330:         Register a schema.
331: 
332:         Args:
333:             schema_id: Unique schema identifier
334:             schema: Schema dictionary
335:             metadata: Additional metadata
336:         """
337:         self.registry[schema_id] = {
338:             "schema": schema,
339:             "metadata": metadata or {},
340:             "registered_at": str(json.dumps({"timestamp": "now"}))
341:         }
342: 
343:     def get(self, schema_id: str) -> Optional[Dict[str, Any]]:
344:         """Get schema by ID."""
345:         entry = self.registry.get(schema_id)
346:         return entry["schema"] if entry else None
347: 
348:     def get_by_type(self, schema_type: str) -> List[Dict[str, Any]]:
349:         """Get all schemas of specific type."""
350:         results = []
351:         for entry in self.registry.values():
352:             schema = entry["schema"]
353:             if schema.get("@type") == schema_type:
354:                 results.append(schema)
355:         return results
356: 
357:     def search(self, query: str) -> List[Dict[str, Any]]:
358:         """
359:         Search schemas by text.
360: 
361:         Args:
362:             query: Search query
363: 
364:         Returns:
365:             List of matching schemas
366:         """
367:         results = []
368:         query_lower = query.lower()
369:         for entry in self.registry.values():
370:             schema = entry["schema"]
371:             # Search in name and description
372:             if (query_lower in str(schema.get("name", "")).lower() or
373:                 query_lower in str(schema.get("description", "")).lower()):
374:                 results.append(schema)
375:         return results
376: 
377:     def list_all(self) -> List[str]:
378:         """List all schema IDs."""
379:         return list(self.registry.keys())
380: 
381:     def count(self) -> int:
382:         """Get total count of schemas."""
383:         return len(self.registry)
384: 
385:     def remove(self, schema_id: str) -> bool:
386:         """
387:         Remove schema by ID.
388: 
389:         Args:
390:             schema_id: Schema ID to remove
391: 
392:         Returns:
393:             True if removed, False if not found
394:         """
395:         if schema_id in self.registry:
396:             del self.registry[schema_id]
397:             return True
398:         return False
399: 
400:     def export_all(self) -> List[Dict[str, Any]]:
401:         """Export all schemas."""
402:         return [entry["schema"] for entry in self.registry.values()]
403: 
404:     def get_statistics(self) -> Dict[str, Any]:
405:         """Get registry statistics."""
406:         type_counts: Dict[str, int] = {}
407:         for entry in self.registry.values():
408:             schema_type = entry["schema"].get("@type", "Unknown")
409:             type_counts[schema_type] = type_counts.get(schema_type, 0) + 1
410: 
411:         return {
412:             "total_schemas": len(self.registry),
413:             "types": type_counts
414:         }
