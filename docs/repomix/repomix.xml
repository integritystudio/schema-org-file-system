  1: #!/usr/bin/env python3
  2: """
  3: Image Content Renamer - Rename images based on visual content analysis.
  4: 
  5: Uses CLIP vision model to analyze image content and generate descriptive filenames.
  6: """
  7: 
  8: import argparse
  9: import re
 10: from datetime import datetime
 11: from pathlib import Path
 12: from typing import Optional, List, Tuple
 13: 
 14: try:
 15:     from PIL import Image
 16: except ImportError:
 17:     pass
 18: 
 19: from shared.clip_utils import CLIPClassifier, CLIP_AVAILABLE
 20: from shared.constants import IMAGE_EXTENSIONS_WIDE
 21: from shared.file_ops import resolve_collision
 22: 
 23: 
 24: class ImageContentRenamer:
 25:     """Rename images based on visual content analysis."""
 26: 
 27:     IMAGE_EXTENSIONS = IMAGE_EXTENSIONS_WIDE
 28: 
 29:     # Content categories for CLIP classification
 30:     CONTENT_CATEGORIES = [
 31:         # Furniture & Home
 32:         "sofa", "couch", "sectional", "chair", "table", "desk", "bed", "lamp",
 33:         "bookshelf", "cabinet", "dresser", "nightstand", "ottoman", "bench",
 34:         # Rooms
 35:         "living room", "bedroom", "kitchen", "bathroom", "office", "patio", "porch",
 36:         "dining room", "garage", "backyard", "garden",
 37:         # People & Portraits
 38:         "portrait", "selfie", "group photo", "family photo", "headshot",
 39:         # Pets
 40:         "dog", "cat", "pet", "puppy", "kitten",
 41:         # Food & Drinks
 42:         "food", "meal", "restaurant", "coffee", "dessert", "cooking",
 43:         # Nature & Outdoors
 44:         "landscape", "mountain", "beach", "ocean", "forest", "sunset", "sunrise",
 45:         "flowers", "trees", "park", "lake", "river", "sky",
 46:         # Travel & Architecture
 47:         "building", "architecture", "city", "street", "landmark", "monument",
 48:         "hotel", "airport", "bridge",
 49:         # Events
 50:         "party", "wedding", "birthday", "concert", "celebration", "graduation",
 51:         # Documents & Screenshots
 52:         "document", "screenshot", "receipt", "menu", "sign", "text",
 53:         # Vehicles
 54:         "car", "motorcycle", "bicycle", "airplane", "boat",
 55:         # Art & Creative
 56:         "art", "painting", "drawing", "illustration", "craft",
 57:         # Technology
 58:         "computer", "phone", "electronics", "gadget",
 59:         # Sports & Activities
 60:         "sports", "fitness", "hiking", "swimming", "yoga",
 61:     ]
 62: 
 63:     # More specific descriptions for refinement
 64:     REFINEMENT_TERMS = {
 65:         "sofa": ["leather sofa", "fabric sofa", "sectional sofa", "outdoor sofa", "modern sofa"],
 66:         "living room": ["cozy living room", "modern living room", "minimalist living room"],
 67:         "landscape": ["mountain landscape", "coastal landscape", "rural landscape", "urban landscape"],
 68:         "food": ["breakfast", "lunch", "dinner", "snack", "appetizer"],
 69:         "dog": ["golden retriever", "labrador", "german shepherd", "poodle", "bulldog"],
 70:         "cat": ["tabby cat", "black cat", "white cat", "orange cat", "calico cat"],
 71:     }
 72: 
 73:     def __init__(self, dry_run: bool = False):
 74:         self.dry_run = dry_run
 75:         self.classifier = None
 76:         self.stats = {
 77:             'total': 0,
 78:             'renamed': 0,
 79:             'skipped': 0,
 80:             'errors': 0,
 81:             'no_content': 0,
 82:         }
 83: 
 84:         if CLIP_AVAILABLE:
 85:             self.classifier = CLIPClassifier()
 86: 
 87:     def analyze_image(self, image_path: Path) -> Optional[Tuple[str, float]]:
 88:         """
 89:         Analyze image content using CLIP.
 90: 
 91:         Returns:
 92:             Tuple of (best_category, confidence) or None if analysis fails
 93:         """
 94:         if not CLIP_AVAILABLE or self.classifier is None:
 95:             return None
 96: 
 97:         try:
 98:             # First pass: broad category classification
 99:             top_category, top_confidence = self.classifier.top_match(
100:                 image_path, self.CONTENT_CATEGORIES
101:             )
102: 
103:             # Second pass: refinement if category has specific terms
104:             if top_category in self.REFINEMENT_TERMS and top_confidence > 0.15:
105:                 refined = self._refine_category(image_path, top_category)
106:                 if refined:
107:                     return refined
108: 
109:             return (top_category, top_confidence)
110: 
111:         except Exception as e:
112:             print(f"  Error analyzing image: {e}")
113:             return None
114: 
115:     def _refine_category(self, image_path: Path, category: str) -> Optional[Tuple[str, float]]:
116:         """Refine the category with more specific terms."""
117:         refinements = self.REFINEMENT_TERMS.get(category, [])
118:         if not refinements:
119:             return None
120: 
121:         top_term, top_confidence = self.classifier.top_match(image_path, refinements)
122: 
123:         if top_confidence > 0.3:
124:             return (top_term, top_confidence)
125:         return None
126: 
127:     def generate_filename(self, image_path: Path, content: str, confidence: float) -> str:
128:         """Generate a new filename based on content analysis."""
129:         # Clean up content for filename
130:         clean_content = content.lower().replace(" ", "_")
131:         clean_content = re.sub(r'[^a-z0-9_]', '', clean_content)
132: 
133:         # Try to get date from file metadata
134:         date_str = self._get_date_string(image_path)
135: 
136:         # Build filename
137:         ext = image_path.suffix.lower()
138: 
139:         if date_str:
140:             new_name = f"{date_str}_{clean_content}{ext}"
141:         else:
142:             new_name = f"{clean_content}{ext}"
143: 
144:         return new_name
145: 
146:     def _get_date_string(self, image_path: Path) -> Optional[str]:
147:         """Extract date from image EXIF or file modification time."""
148:         try:
149:             image = Image.open(image_path)
150:             exif = image._getexif()
151:             if exif:
152:                 # DateTimeOriginal (36867) or DateTime (306)
153:                 for tag_id in [36867, 306]:
154:                     if tag_id in exif:
155:                         date_str = exif[tag_id]
156:                         dt = datetime.strptime(date_str, "%Y:%m:%d %H:%M:%S")
157:                         return dt.strftime("%Y%m%d")
158:         except Exception:
159:             pass
160: 
161:         # Fallback to file modification time
162:         try:
163:             mtime = image_path.stat().st_mtime
164:             dt = datetime.fromtimestamp(mtime)
165:             return dt.strftime("%Y%m%d")
166:         except Exception:
167:             return None
168: 
169:     def should_rename(self, filename: str) -> bool:
170:         """Check if file has a generic name that should be renamed."""
171:         stem = Path(filename).stem.lower()
172: 
173:         generic_patterns = [
174:             r'^img_\d+',
175:             r'^pxl_\d+',
176:             r'^dsc_?\d+',
177:             r'^dcim_\d+',
178:             r'^\d{8}_\d{6}',
179:             r'^\d+$',
180:             r'^[a-f0-9]{32}',
181:             r'^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}',
182:             r'^image\d*$',
183:             r'^photo\d*$',
184:             r'^unnamed',
185:         ]
186: 
187:         for pattern in generic_patterns:
188:             if re.match(pattern, stem):
189:                 return True
190:         return False
191: 
192:     def rename_file(self, file_path: Path) -> dict:
193:         """Analyze and rename a single image file."""
194:         result = {
195:             'original': file_path.name,
196:             'new_name': None,
197:             'content': None,
198:             'confidence': None,
199:             'status': 'pending',
200:             'error': None,
201:         }
202: 
203:         # Check if already has descriptive name
204:         if not self.should_rename(file_path.name):
205:             result['status'] = 'skipped'
206:             result['error'] = 'Already has descriptive name'
207:             self.stats['skipped'] += 1
208:             return result
209: 
210:         # Analyze content
211:         analysis = self.analyze_image(file_path)
212:         if not analysis:
213:             result['status'] = 'no_content'
214:             result['error'] = 'Could not analyze content'
215:             self.stats['no_content'] += 1
216:             return result
217: 
218:         content, confidence = analysis
219:         result['content'] = content
220:         result['confidence'] = confidence
221: 
222:         # Skip if confidence is too low
223:         if confidence < 0.10:
224:             result['status'] = 'low_confidence'
225:             result['error'] = f'Confidence too low: {confidence:.1%}'
226:             self.stats['skipped'] += 1
227:             return result
228: 
229:         # Generate new filename
230:         new_name = self.generate_filename(file_path, content, confidence)
231:         result['new_name'] = new_name
232: 
233:         # Handle duplicates
234:         new_path = file_path.parent / new_name
235:         if new_path.exists() and new_path != file_path:
236:             new_path = resolve_collision(new_path)
237:             new_name = new_path.name
238:             result['new_name'] = new_name
239: 
240:         # Perform rename
241:         if not self.dry_run:
242:             try:
243:                 file_path.rename(new_path)
244:                 result['status'] = 'renamed'
245:                 self.stats['renamed'] += 1
246:             except Exception as e:
247:                 result['status'] = 'error'
248:                 result['error'] = str(e)
249:                 self.stats['errors'] += 1
250:         else:
251:             result['status'] = 'would_rename'
252:             self.stats['renamed'] += 1
253: 
254:         return result
255: 
256:     def process_directory(self, source_dir: Path, recursive: bool = False):
257:         """Process all images in a directory."""
258:         print(f"\n{'=' * 60}")
259:         print(f"Image Content Renamer {'(DRY RUN)' if self.dry_run else ''}")
260:         print(f"{'=' * 60}\n")
261: 
262:         if not CLIP_AVAILABLE:
263:             print("Error: CLIP not available. Install torch and transformers.")
264:             return
265: 
266:         print(f"Scanning: {source_dir}")
267:         print(f"Recursive: {recursive}\n")
268: 
269:         # Find all image files
270:         if recursive:
271:             files = []
272:             for ext in self.IMAGE_EXTENSIONS:
273:                 files.extend(source_dir.rglob(f"*{ext}"))
274:                 files.extend(source_dir.rglob(f"*{ext.upper()}"))
275:         else:
276:             files = [f for f in source_dir.iterdir()
277:                     if f.is_file() and f.suffix.lower() in self.IMAGE_EXTENSIONS]
278: 
279:         self.stats['total'] = len(files)
280:         print(f"Total image files: {len(files)}")
281: 
282:         # Filter for generic filenames
283:         generic_files = [f for f in files if self.should_rename(f.name)]
284:         print(f"Generic filenames to process: {len(generic_files)}\n")
285: 
286:         # Process each file
287:         for i, file_path in enumerate(generic_files, 1):
288:             print(f"[{i}/{len(generic_files)}] {file_path.name}")
289:             result = self.rename_file(file_path)
290: 
291:             if result['status'] in ('renamed', 'would_rename'):
292:                 prefix = "  → Would rename:" if self.dry_run else "  ✓ Renamed:"
293:                 print(f"{prefix} {result['original']} → {result['new_name']}")
294:                 print(f"    Content: {result['content']} ({result['confidence']:.1%})")
295:             elif result['status'] == 'skipped':
296:                 print(f"  ⊘ Skipped: {result['error']}")
297:             elif result['status'] == 'no_content':
298:                 print(f"  ⚠ No content detected")
299:             elif result['status'] == 'error':
300:                 print(f"  ✗ Error: {result['error']}")
301: 
302:         # Print summary
303:         self._print_summary()
304: 
305:     def _print_summary(self):
306:         """Print processing summary."""
307:         print(f"\n{'=' * 60}")
308:         print("Renaming Summary")
309:         print(f"{'=' * 60}\n")
310:         print(f"Total image files: {self.stats['total']}")
311:         print(f"Successfully renamed: {self.stats['renamed']}")
312:         print(f"Skipped: {self.stats['skipped']}")
313:         print(f"No content detected: {self.stats['no_content']}")
314:         print(f"Errors: {self.stats['errors']}")
315: 
316:         if self.dry_run:
317:             print(f"\n⚠️  This was a DRY RUN - no files were renamed")
318: 
319: 
320: def main():
321:     parser = argparse.ArgumentParser(
322:         description="Rename images based on visual content analysis using CLIP"
323:     )
324:     parser.add_argument("--dry-run", action="store_true",
325:                        help="Simulate renaming without actually renaming files")
326:     parser.add_argument("--source", type=str, default="~/Documents",
327:                        help="Source directory to scan (default: ~/Documents)")
328:     parser.add_argument("--recursive", action="store_true",
329:                        help="Recursively scan subdirectories")
330:     parser.add_argument("--file", type=str,
331:                        help="Process a single file instead of directory")
332: 
333:     args = parser.parse_args()
334: 
335:     renamer = ImageContentRenamer(dry_run=args.dry_run)
336: 
337:     if args.file:
338:         file_path = Path(args.file).expanduser()
339:         if not file_path.exists():
340:             print(f"Error: File not found: {file_path}")
341:             return
342:         print(f"\nAnalyzing: {file_path.name}")
343:         result = renamer.rename_file(file_path)
344:         if result['content']:
345:             print(f"Content: {result['content']} ({result['confidence']:.1%})")
346:         if result['new_name']:
347:             print(f"New name: {result['new_name']}")
348:     else:
349:         source_dir = Path(args.source).expanduser()
350:         if not source_dir.exists():
351:             print(f"Error: Directory not found: {source_dir}")
352:             return
353:         renamer.process_directory(source_dir, recursive=args.recursive)
354: 
355: 
356: if __name__ == "__main__":
357:     main()
