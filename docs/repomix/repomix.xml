308:             train_data.extend(items[:split_idx])
309:             test_data.extend(items[split_idx:])
310: 
311:         # Shuffle final results
312:         random.shuffle(train_data)
313:         random.shuffle(test_data)
314: 
315:         self.statistics['train_test_split'] = {
316:             'train_size': len(train_data),
317:             'test_size': len(test_data),
318:             'test_ratio': round(len(test_data) / len(self.features), 3),
319:             'stratify_by': stratify_by,
320:         }
321: 
322:         return train_data, test_data
