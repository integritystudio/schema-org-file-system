  1: #!/usr/bin/env python3
  2: """
  3: Integration module for applying correction feedback to the file organizer.
  4: 
  5: This module provides functions to:
  6: 1. Apply learned corrections before categorization
  7: 2. Integrate feedback patterns into the categorization logic
  8: 3. Generate correction suggestions from organization results
  9: """
 10: 
 11: import os
 12: import json
 13: from typing import Dict, List, Optional, Tuple
 14: from correction_feedback import CorrectionFeedbackSystem
 15: 
 16: 
 17: class FeedbackIntegration:
 18:     """Integrates correction feedback with the file organizer."""
 19: 
 20:     def __init__(self, feedback_file: str = None):
 21:         """Initialize the integration.
 22: 
 23:         Args:
 24:             feedback_file: Path to corrections JSON file
 25:         """
 26:         self.feedback = CorrectionFeedbackSystem(feedback_file)
 27:         self._cached_rules = None
 28: 
 29:     def get_cached_rules(self) -> Dict:
 30:         """Get or compute cached rules."""
 31:         if self._cached_rules is None:
 32:             self._cached_rules = self.feedback.export_rules()
 33:         return self._cached_rules
 34: 
 35:     def invalidate_cache(self):
 36:         """Invalidate the cached rules (call after adding corrections)."""
 37:         self._cached_rules = None
 38: 
 39:     def pre_categorize_check(
 40:         self,
 41:         file_path: str,
 42:         filename: str,
 43:         proposed_category: str,
 44:         proposed_subcategory: str = None
 45:     ) -> Tuple[str, str, float]:
 46:         """Check if corrections suggest a different category.
 47: 
 48:         This should be called BEFORE final categorization to apply learned rules.
 49: 
 50:         Args:
 51:             file_path: Path to the file
 52:             filename: The filename
 53:             proposed_category: Category the organizer wants to assign
 54:             proposed_subcategory: Subcategory the organizer wants to assign
 55: 
 56:         Returns:
 57:             Tuple of (final_category, final_subcategory, confidence)
 58:             confidence is 1.0 for original proposal, <1.0 for suggestions
 59:         """
 60:         # First check if this exact file has a correction
 61:         correction = self.feedback.check_file(file_path)
 62:         if correction:
 63:             return (
 64:                 correction["correct_category"],
 65:                 correction.get("correct_subcategory"),
 66:                 1.0  # Exact match has full confidence
 67:             )
 68: 
 69:         # Check for pattern-based suggestions
 70:         suggestion = self.feedback.get_suggestion(filename, proposed_category)
 71:         if suggestion and suggestion["confidence"] >= 0.7:
 72:             return (
 73:                 suggestion["suggested_category"],
 74:                 suggestion.get("suggested_subcategory") or proposed_subcategory,
 75:                 suggestion["confidence"]
 76:             )
 77: 
 78:         # No correction needed
 79:         return (proposed_category, proposed_subcategory, 1.0)
 80: 
 81:     def get_pattern_keywords(self) -> Dict[str, Dict]:
 82:         """Get learned keyword patterns for each category.
 83: 
 84:         Returns keywords that should trigger specific categories based on
 85:         correction feedback.
 86: 
 87:         Returns:
 88:             Dictionary mapping categories to their learned keywords
 89:         """
 90:         rules = self.get_cached_rules()
 91:         keywords = {}
 92: 
 93:         for rule in rules.get("pattern_rules", []):
 94:             category = rule["category"]
 95:             if category not in keywords:
 96:                 keywords[category] = {
 97:                     "patterns": [],
 98:                     "content_hints": []
 99:                 }
100: 
101:             pattern = rule["pattern"]
102:             # Convert pattern labels back to keywords
103:             if pattern.startswith("ext:"):
104:                 keywords[category]["patterns"].append(f"extension:{pattern[4:]}")
105:             else:
106:                 keywords[category]["patterns"].append(pattern)
107: 
108:         for rule in rules.get("content_rules", []):
109:             category = rule["category"]
110:             if category not in keywords:
111:                 keywords[category] = {
112:                     "patterns": [],
113:                     "content_hints": []
114:                 }
115:             keywords[category]["content_hints"].append(rule["hint"])
116: 
117:         return keywords
118: 
119:     def apply_to_organization_result(
120:         self,
121:         result: Dict,
122:         auto_apply: bool = False
123:     ) -> Dict:
124:         """Apply feedback suggestions to an organization result.
125: 
126:         Args:
127:             result: A single result from the organization report
128:             auto_apply: Whether to automatically apply high-confidence suggestions
129: 
130:         Returns:
131:             Modified result with feedback suggestions
132:         """
133:         filename = result.get("schema", {}).get("name") or os.path.basename(result.get("source", ""))
134:         current_category = result.get("category", "uncategorized")
135: 
136:         suggestion = self.feedback.get_suggestion(filename, current_category)
137: 
138:         if suggestion:
139:             result["feedback_suggestion"] = suggestion
140: 
141:             if auto_apply and suggestion["confidence"] >= 0.85:
142:                 result["category"] = suggestion["suggested_category"]
143:                 if suggestion.get("suggested_subcategory"):
144:                     result["subcategory"] = suggestion["suggested_subcategory"]
145:                 result["feedback_applied"] = True
146: 
147:         return result
148: 
149:     def batch_apply_corrections(
150:         self,
151:         results: List[Dict],
152:         confidence_threshold: float = 0.85
153:     ) -> Tuple[List[Dict], Dict]:
154:         """Apply corrections to a batch of organization results.
155: 
156:         Args:
157:             results: List of organization results
158:             confidence_threshold: Minimum confidence to auto-apply
159: 
160:         Returns:
161:             Tuple of (modified_results, statistics)
162:         """
163:         modified = []
164:         stats = {
165:             "total": len(results),
166:             "suggestions_made": 0,
167:             "auto_applied": 0,
168:             "categories_changed": {}
169:         }
170: 
171:         for result in results:
172:             original_category = result.get("category")
173:             modified_result = self.apply_to_organization_result(
174:                 result.copy(),
175:                 auto_apply=confidence_threshold < 1.0
176:             )
177: 
178:             if "feedback_suggestion" in modified_result:
179:                 stats["suggestions_made"] += 1
180: 
181:             if modified_result.get("feedback_applied"):
182:                 stats["auto_applied"] += 1
183:                 new_category = modified_result["category"]
184:                 key = f"{original_category} -> {new_category}"
185:                 stats["categories_changed"][key] = stats["categories_changed"].get(key, 0) + 1
186: 
187:             modified.append(modified_result)
188: 
189:         return modified, stats
190: 
191:     def generate_correction_report(self, results: List[Dict]) -> str:
192:         """Generate a report of suggested corrections from organization results.
193: 
194:         Args:
195:             results: List of organization results
196: 
197:         Returns:
198:             Markdown report string
199:         """
200:         suggestions = []
201: 
202:         for result in results:
203:             filename = result.get("schema", {}).get("name") or os.path.basename(result.get("source", ""))
204:             current_category = result.get("category", "uncategorized")
205: 
206:             suggestion = self.feedback.get_suggestion(filename, current_category)
207:             if suggestion:
208:                 suggestions.append({
209:                     "filename": filename,
210:                     "current": current_category,
211:                     "suggested": suggestion["suggested_category"],
212:                     "confidence": suggestion["confidence"],
213:                     "patterns": suggestion["matching_patterns"]
214:                 })
215: 
216:         if not suggestions:
217:             return "No correction suggestions based on learned patterns."
218: 
219:         report = "# Correction Suggestions Report\n\n"
220:         report += f"Found {len(suggestions)} files that may be miscategorized:\n\n"
221: 
222:         for s in sorted(suggestions, key=lambda x: -x["confidence"]):
223:             report += f"## {s['filename']}\n"
224:             report += f"- Current: `{s['current']}`\n"
225:             report += f"- Suggested: `{s['suggested']}`\n"
226:             report += f"- Confidence: {s['confidence']:.1%}\n"
227:             report += f"- Matching patterns: {', '.join(s['patterns'])}\n\n"
228: 
229:         return report
230: 
231: 
