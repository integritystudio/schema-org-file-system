179: @contextmanager
180: def track_operation(
181:     operation_name: str,
182:     op_type: str = 'task',
183:     **attributes
184: ):
185:     """
186:     Context manager for tracking operation performance.
187: 
188:     Usage:
189:         with track_operation('classify_image', file_path='/path/to/file.jpg'):
190:             result = classifier.classify(image)
191: 
192:     Args:
193:         operation_name: Name of the operation
194:         op_type: Type of operation (task, db, http, etc.)
195:         **attributes: Additional attributes to attach
196:     """
197:     if not SENTRY_AVAILABLE:
198:         yield
199:         return
200: 
201:     with sentry_sdk.start_span(op=op_type, name=operation_name) as span:
202:         for key, value in attributes.items():
203:             span.set_data(key, str(value) if value is not None else None)
204:         try:
205:             yield span
206:         except Exception as e:
207:             span.set_status('error')
208:             capture_error(e, context={'operation': operation_name, **attributes})
209:             raise
210: 
211: 
212: def track_error(
213:     operation: str = None,
214:     level: str = ErrorLevel.ERROR,
215:     reraise: bool = True
216: ) -> Callable:
217:     """
218:     Decorator for automatic error tracking.
219: 
220:     Usage:
221:         @track_error('process_file')
222:         def process_file(path):
223:             # ... your code
224: 
225:         @track_error('classify', reraise=False)
226:         def classify(image):
227:             # Errors are captured but not re-raised
228:     """
229:     def decorator(func: Callable) -> Callable:
230:         @functools.wraps(func)
231:         def wrapper(*args, **kwargs):
232:             op_name = operation or func.__name__
233:             try:
234:                 with track_operation(op_name, op_type='function'):
235:                     return func(*args, **kwargs)
236:             except Exception as e:
237:                 capture_error(
238:                     e,
239:                     level=level,
240:                     context={
241:                         'function': func.__name__,
242:                         'args_count': len(args),
243:                         'kwargs_keys': list(kwargs.keys())
244:                     }
245:                 )
246:                 if reraise:
247:                     raise
248:                 return None
249:         return wrapper
250:     return decorator
251: 
