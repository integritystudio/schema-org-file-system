238:     def __init__(self, config_path: Optional[str] = None):
239:         """
240:         Initialize the cost calculator.
241: 
242:         Args:
243:             config_path: Optional path to custom cost configuration JSON
244:         """
245:         self.cost_configs: Dict[str, ModelCostConfig] = {}
246:         self.usage_records: List[UsageRecord] = []
247:         self.session_start = datetime.now()
248: 
249:         # Load default configs
250:         for name, config in self.DEFAULT_COST_CONFIGS.items():
251:             self.cost_configs[name] = config
252: 
253:         # Load custom config if provided
254:         if config_path and Path(config_path).exists():
255:             self._load_custom_config(config_path)
256: 
257:     def _load_custom_config(self, config_path: str):
258:         """Load custom cost configuration from JSON."""
259:         with open(config_path, 'r') as f:
260:             custom_config = json.load(f)
261: 
262:         for name, config_dict in custom_config.get('models', {}).items():
263:             self.cost_configs[name] = ModelCostConfig(
264:                 name=config_dict.get('name', name),
265:                 cost_type=CostType(config_dict.get('cost_type', 'compute')),
266:                 cost_per_unit=config_dict.get('cost_per_unit', 0.0),
267:                 unit_type=config_dict.get('unit_type', 'invocation'),
268:                 avg_processing_time_sec=config_dict.get('avg_processing_time_sec', 1.0),
269:                 success_rate=config_dict.get('success_rate', 1.0),
270:                 description=config_dict.get('description', ''),
271:                 files_correctly_classified=config_dict.get('files_correctly_classified', 0.0),
272:                 manual_time_saved_sec=config_dict.get('manual_time_saved_sec', 0.0)
273:             )
