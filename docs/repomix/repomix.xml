  1: #!/usr/bin/env python3
  2: """
  3: Data Preprocessing Pipeline for File Organization ML
  4: 
  5: This module provides comprehensive data preprocessing for training
  6: ML models on file categorization:
  7: 
  8: 1. Feature extraction from filenames, paths, and metadata
  9: 2. Text normalization and tokenization
 10: 3. Train/test splitting with stratification
 11: 4. Data validation and quality metrics
 12: 5. Feature engineering for pattern learning
 13: """
 14: 
 15: import os
 16: import re
 17: import json
 18: import hashlib
 19: from pathlib import Path
 20: from datetime import datetime
 21: from typing import Dict, List, Optional, Tuple, Any
 22: from collections import Counter, defaultdict
 23: import unicodedata
 24: 
 25: from shared.constants import SCREENSHOT_PATTERNS, DOCUMENT_PATTERNS
 26: 
 27: # Game asset patterns for filename matching (subset of game keywords as regex)
 28: GAME_ASSET_PATTERNS = [
 29:     r'sprite', r'frame', r'tile', r'texture',
 30:     r'audio', r'sfx', r'bgm', r'music',
 31:     r'icon', r'button', r'ui_',
 32: ]
 33: 
 34: 
 35: class FileFeatureExtractor:
 36:     """Extract ML features from file metadata."""
 37: 
 38:     def __init__(self):
 39:         self.extension_map = self._build_extension_map()
 40: 
 41:     def _build_extension_map(self) -> Dict[str, str]:
 42:         """Build mapping of extensions to general categories."""
 43:         return {
 44:             # Images
 45:             '.jpg': 'image', '.jpeg': 'image', '.png': 'image',
 46:             '.gif': 'image', '.bmp': 'image', '.webp': 'image',
 47:             '.heic': 'image', '.heif': 'image', '.svg': 'image',
 48:             '.tiff': 'image', '.ico': 'image',
 49:             # Videos
 50:             '.mp4': 'video', '.mov': 'video', '.avi': 'video',
 51:             '.mkv': 'video', '.webm': 'video', '.m4v': 'video',
 52:             # Audio
 53:             '.mp3': 'audio', '.wav': 'audio', '.ogg': 'audio',
 54:             '.flac': 'audio', '.aac': 'audio', '.m4a': 'audio',
 55:             # Documents
 56:             '.pdf': 'document', '.doc': 'document', '.docx': 'document',
 57:             '.txt': 'text', '.rtf': 'document', '.odt': 'document',
 58:             # Spreadsheets
 59:             '.xls': 'spreadsheet', '.xlsx': 'spreadsheet', '.csv': 'data',
 60:             # Code
 61:             '.py': 'code', '.js': 'code', '.ts': 'code', '.jsx': 'code',
 62:             '.tsx': 'code', '.html': 'code', '.css': 'code', '.json': 'data',
 63:             '.xml': 'data', '.yaml': 'data', '.yml': 'data',
 64:             # Archives
 65:             '.zip': 'archive', '.tar': 'archive', '.gz': 'archive',
 66:             '.rar': 'archive', '.7z': 'archive',
 67:         }
 68: 
 69:     def extract_features(self, file_record: Dict) -> Dict[str, Any]:
 70:         """Extract all features from a file record."""
 71:         filename = file_record.get('schema', {}).get('name', '')
 72:         filepath = file_record.get('source', '')
 73:         category = file_record.get('category', 'uncategorized')
 74:         subcategory = file_record.get('subcategory', '')
 75: 
 76:         features = {
 77:             # Basic features
 78:             'filename': filename,
 79:             'filename_lower': filename.lower(),
 80:             'filepath': filepath,
 81:             'category': category,
 82:             'subcategory': subcategory,
 83: 
 84:             # Extension features
 85:             'extension': self._get_extension(filename),
 86:             'extension_category': self._get_extension_category(filename),
 87: 
 88:             # Filename pattern features
 89:             'filename_tokens': self._tokenize_filename(filename),
 90:             'filename_length': len(filename),
 91:             'has_numbers': bool(re.search(r'\d', filename)),
 92:             'has_underscores': '_' in filename,
 93:             'has_dashes': '-' in filename,
 94:             'has_spaces': ' ' in filename,
 95:             'starts_with_date': self._starts_with_date(filename),
 96: 
 97:             # Pattern detection
 98:             'is_screenshot': self._matches_patterns(filename, SCREENSHOT_PATTERNS),
 99:             'is_game_asset': self._matches_patterns(filename, GAME_ASSET_PATTERNS),
100:             'is_document': self._matches_patterns(filename, DOCUMENT_PATTERNS),
101: 
102:             # Metadata features
103:             'has_extracted_text': file_record.get('extracted_text_length', 0) > 0,
104:             'extracted_text_length': file_record.get('extracted_text_length', 0),
105:             'has_company_name': file_record.get('company_name') is not None,
106:             'has_people_names': len(file_record.get('people_names', [])) > 0,
107:             'people_count': len(file_record.get('people_names', [])),
108: 
109:             # Image metadata features
110:             'has_datetime': file_record.get('image_metadata', {}).get('datetime') is not None,
111:             'has_gps': file_record.get('image_metadata', {}).get('gps_coordinates') is not None,
112:             'has_location': file_record.get('image_metadata', {}).get('location_name') is not None,
113: 
114:             # Path features
115:             'path_depth': filepath.count('/') if filepath else 0,
116:             'parent_folder': self._get_parent_folder(filepath),
117: 
118:             # Derived features
119:             'filename_hash': self._hash_filename(filename),
120:         }
121: 
122:         return features
123: 
124:     def _get_extension(self, filename: str) -> str:
125:         """Get lowercase file extension."""
126:         return Path(filename).suffix.lower()
127: 
128:     def _get_extension_category(self, filename: str) -> str:
129:         """Get category based on extension."""
130:         ext = self._get_extension(filename)
131:         return self.extension_map.get(ext, 'other')
132: 
133:     def _tokenize_filename(self, filename: str) -> List[str]:
134:         """Tokenize filename into meaningful parts."""
135:         # Remove extension
136:         name = Path(filename).stem
137: 
138:         # Normalize unicode
139:         name = unicodedata.normalize('NFKD', name)
140: 
141:         # Split on common delimiters
142:         tokens = re.split(r'[_\-\s\.]+', name)
143: 
144:         # Split camelCase
145:         expanded_tokens = []
146:         for token in tokens:
147:             # Split on camelCase boundaries
148:             parts = re.findall(r'[A-Z]?[a-z]+|[A-Z]+(?=[A-Z][a-z]|\d|\W|$)|\d+', token)
149:             expanded_tokens.extend(parts if parts else [token])
150: 
151:         # Lowercase and filter
152:         return [t.lower() for t in expanded_tokens if t and len(t) > 1]
153: 
154:     def _starts_with_date(self, filename: str) -> bool:
155:         """Check if filename starts with a date pattern."""
156:         date_patterns = [
157:             r'^\d{8}',  # YYYYMMDD
158:             r'^\d{4}-\d{2}-\d{2}',  # YYYY-MM-DD
159:             r'^\d{2}-\d{2}-\d{4}',  # MM-DD-YYYY
160:             r'^20\d{2}\d{4}',  # 20YYMMDD
161:         ]
162:         return any(re.match(p, filename) for p in date_patterns)
163: 
164:     def _matches_patterns(self, filename: str, patterns: List[str]) -> bool:
165:         """Check if filename matches any of the patterns."""
166:         filename_lower = filename.lower()
167:         return any(re.search(p, filename_lower) for p in patterns)
168: 
169:     def _get_parent_folder(self, filepath: str) -> str:
170:         """Get immediate parent folder name."""
171:         if not filepath:
172:             return ''
173:         parts = Path(filepath).parts
174:         return parts[-2] if len(parts) >= 2 else ''
175: 
176:     def _hash_filename(self, filename: str) -> str:
177:         """Create a hash of the filename for deduplication."""
178:         return hashlib.sha256(filename.encode()).hexdigest()[:8]
179: 
180: 
181: class DataPreprocessor:
182:     """Main preprocessing pipeline for file organization data."""
183: 
184:     def __init__(self, report_path: str = None):
185:         """Initialize preprocessor.
186: 
187:         Args:
188:             report_path: Path to organization report JSON
189:         """
190:         self.report_path = report_path
191:         self.feature_extractor = FileFeatureExtractor()
192:         self.data = None
193:         self.features = None
194:         self.statistics = {}
195: 
196:     def load_data(self, report_path: str = None) -> Dict:
197:         """Load organization report data."""
198:         path = report_path or self.report_path
199:         if not path:
200:             raise ValueError("No report path provided")
201: 
202:         with open(path, 'r') as f:
203:             self.data = json.load(f)
204: 
205:         self.statistics['total_records'] = len(self.data.get('results', []))
206:         self.statistics['load_time'] = datetime.now().isoformat()
207:         return self.data
208: 
209:     def extract_all_features(self) -> List[Dict]:
210:         """Extract features from all records."""
211:         if not self.data:
212:             raise ValueError("No data loaded. Call load_data() first.")
213: 
214:         results = self.data.get('results', [])
215:         self.features = []
216: 
217:         for record in results:
218:             features = self.feature_extractor.extract_features(record)
219:             self.features.append(features)
220: 
221:         self.statistics['features_extracted'] = len(self.features)
222:         return self.features
223: 
224:     def compute_statistics(self) -> Dict:
225:         """Compute dataset statistics."""
226:         if not self.features:
227:             raise ValueError("No features extracted. Call extract_all_features() first.")
228: 
229:         # Category distribution
230:         categories = Counter(f['category'] for f in self.features)
231:         subcategories = Counter(f['subcategory'] for f in self.features)
232: 
233:         # Extension distribution
234:         extensions = Counter(f['extension'] for f in self.features)
235: 
236:         # Pattern counts
237:         screenshots = sum(1 for f in self.features if f['is_screenshot'])
238:         game_assets = sum(1 for f in self.features if f['is_game_asset'])
239:         documents = sum(1 for f in self.features if f['is_document'])
240: 
241:         # Metadata availability
242:         has_text = sum(1 for f in self.features if f['has_extracted_text'])
243:         has_datetime = sum(1 for f in self.features if f['has_datetime'])
244:         has_gps = sum(1 for f in self.features if f['has_gps'])
245: 
246:         # Filename analysis
247:         avg_filename_length = sum(f['filename_length'] for f in self.features) / len(self.features)
248:         token_counts = Counter()
249:         for f in self.features:
250:             token_counts.update(f['filename_tokens'])
251: 
252:         self.statistics.update({
253:             'category_distribution': dict(categories),
