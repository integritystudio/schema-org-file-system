 782:     def extract_exif_data(self, image_path: Path) -> Dict[str, Any]:
 783:         """
 784:         Extract EXIF data from an image.
 785: 
 786:         Returns:
 787:             Dictionary with EXIF data
 788:         """
 789:         if not self.metadata_available:
 790:             return {}
 791: 
 792:         try:
 793:             image = Image.open(image_path)
 794:             exif_data = {}
 795: 
 796:             # Get EXIF data
 797:             exif = image._getexif()
 798:             if exif:
 799:                 for tag_id, value in exif.items():
 800:                     tag = TAGS.get(tag_id, tag_id)
 801:                     exif_data[tag] = value
 802: 
 803:             return exif_data
 804: 
 805:         except Exception as e:
 806:             print(f"  EXIF extraction error: {e}")
 807:             return {}
 808: 
 809:     def extract_datetime(self, image_path: Path) -> Optional[datetime]:
 810:         """
 811:         Extract the datetime when the photo was taken.
 812: 
 813:         Returns:
 814:             datetime object or None
 815:         """
 816:         exif_data = self.extract_exif_data(image_path)
 817: 
 818:         if not exif_data:
 819:             return None
 820: 
 821:         # Try different datetime tags
 822:         datetime_tags = ['DateTimeOriginal', 'DateTimeDigitized', 'DateTime']
 823: 
 824:         for tag in datetime_tags:
 825:             if tag in exif_data:
 826:                 try:
 827:                     # Parse datetime string (format: "2023:11:26 14:30:00")
 828:                     dt_str = str(exif_data[tag])
 829:                     dt = datetime.strptime(dt_str, "%Y:%m:%d %H:%M:%S")
 830:                     return dt
 831:                 except (ValueError, TypeError):
 832:                     continue
 833: 
 834:         return None
 835: 
 836:     def extract_gps_coordinates(self, image_path: Path) -> Optional[Tuple[float, float]]:
 837:         """
 838:         Extract GPS coordinates from image EXIF data.
 839: 
 840:         Returns:
 841:             Tuple of (latitude, longitude) or None
 842:         """
 843:         if not self.metadata_available:
 844:             return None
 845: 
 846:         try:
 847:             image = Image.open(image_path)
 848:             exif = image._getexif()
 849: 
 850:             if not exif:
 851:                 return None
 852: 
 853:             # Get GPS info
 854:             gps_info = {}
 855:             for tag_id, value in exif.items():
 856:                 tag = TAGS.get(tag_id, tag_id)
 857:                 if tag == 'GPSInfo':
 858:                     for gps_tag_id in value:
 859:                         gps_tag = GPSTAGS.get(gps_tag_id, gps_tag_id)
 860:                         gps_info[gps_tag] = value[gps_tag_id]
 861: 
 862:             if not gps_info:
 863:                 return None
 864: 
 865:             # Convert to decimal degrees
 866:             lat = self._convert_to_degrees(gps_info.get('GPSLatitude'))
 867:             lon = self._convert_to_degrees(gps_info.get('GPSLongitude'))
 868: 
 869:             if lat is None or lon is None:
 870:                 return None
 871: 
 872:             # Adjust for hemisphere
 873:             if gps_info.get('GPSLatitudeRef') == 'S':
 874:                 lat = -lat
 875:             if gps_info.get('GPSLongitudeRef') == 'W':
 876:                 lon = -lon
 877: 
 878:             return (lat, lon)
 879: 
 880:         except Exception as e:
 881:             print(f"  GPS extraction error: {e}")
 882:             return None
 883: 
 884:     def _convert_to_degrees(self, value) -> Optional[float]:
 885:         """
 886:         Convert GPS coordinates to degrees.
 887: 
 888:         Args:
 889:             value: GPS coordinate in format ((deg, 1), (min, 1), (sec, 1))
 890: 
 891:         Returns:
 892:             Decimal degrees or None
 893:         """
 894:         if not value:
 895:             return None
 896: 
 897:         try:
 898:             d = float(value[0][0]) / float(value[0][1])
 899:             m = float(value[1][0]) / float(value[1][1])
 900:             s = float(value[2][0]) / float(value[2][1])
 901: 
 902:             return d + (m / 60.0) + (s / 3600.0)
 903:         except (IndexError, TypeError, ZeroDivisionError):
 904:             return None
 905: 
 906:     def get_location_name(self, coordinates: Tuple[float, float]) -> Optional[str]:
 907:         """
 908:         Get location name from GPS coordinates using reverse geocoding.
 909: 
 910:         Args:
 911:             coordinates: Tuple of (latitude, longitude)
 912: 
 913:         Returns:
 914:             Location name (city, state, country) or None
 915:         """
 916:         if not self.geocoder:
 917:             return None
 918: 
 919:         with CostTracker(self.cost_calculator, 'nominatim_geocoding') if self.cost_calculator else nullcontext():
 920:             try:
 921:                 lat, lon = coordinates
 922:                 location = self.geocoder.reverse(f"{lat}, {lon}", exactly_one=True)
 923: 
 924:                 if location and location.raw.get('address'):
 925:                     address = location.raw['address']
 926: 
 927:                     # Try to get city, state, country
 928:                     parts = []
 929: 
 930:                     # City
 931:                     city = address.get('city') or address.get('town') or address.get('village')
 932:                     if city:
 933:                         parts.append(city)
 934: 
 935:                     # State/Region
 936:                     state = address.get('state') or address.get('region')
 937:                     if state:
 938:                         parts.append(state)
 939: 
 940:                     # Country
 941:                     country = address.get('country')
 942:                     if country:
 943:                         parts.append(country)
 944: 
 945:                     if parts:
 946:                         return ', '.join(parts)
 947: 
 948:             except (GeocoderTimedOut, GeocoderServiceError) as e:
 949:                 print(f"  Geocoding error: {e}")
 950:             except Exception as e:
 951:                 print(f"  Location lookup error: {e}")
 952: 
 953:             return None
 954: 
 955:     def get_metadata_summary(self, image_path: Path) -> Dict[str, Any]:
 956:         """
 957:         Get a summary of image metadata.
 958: 
 959:         Returns:
 960:             Dictionary with datetime, GPS coordinates, and location
 961:         """
 962:         summary = {
 963:             'datetime': None,
 964:             'gps_coordinates': None,
 965:             'location_name': None,
 966:             'year': None,
 967:             'month': None,
 968:             'date_str': None
 969:         }
 970: 
 971:         # Extract datetime
 972:         dt = self.extract_datetime(image_path)
 973:         if dt:
 974:             summary['datetime'] = dt
 975:             summary['year'] = dt.year
 976:             summary['month'] = dt.month
 977:             summary['date_str'] = dt.strftime("%Y-%m")
 978: 
 979:         # Extract GPS
 980:         coords = self.extract_gps_coordinates(image_path)
 981:         if coords:
 982:             summary['gps_coordinates'] = coords
 983:             # Get location name (with rate limiting consideration)
 984:             location = self.get_location_name(coords)
 985:             if location:
 986:                 summary['location_name'] = location
 987: 
 988:         return summary
