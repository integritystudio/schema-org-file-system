201:     related_to = relationship(
202:         'FileRelationship',
203:         foreign_keys='FileRelationship.source_file_id',
204:         back_populates='source_file'
205:     )
206:     related_from = relationship(
207:         'FileRelationship',
208:         foreign_keys='FileRelationship.target_file_id',
209:         back_populates='target_file'
