  1: #!/usr/bin/env python3
  2: """
  3: Cost Tracking Integration for File Organizer
  4: 
  5: Provides integration between the cost calculator and the existing
  6: file organization system with minimal code changes required.
  7: """
  8: 
  9: import time
 10: from functools import wraps
 11: from typing import Callable, Optional, Dict, Any
 12: from pathlib import Path
 13: from contextlib import contextmanager
 14: 
 15: from cost_roi_calculator import CostROICalculator, CostTracker
 16: from constants import SEPARATOR_WIDTH_LARGE, SEPARATOR_WIDTH_SMALL
 17: 
 18: 
 19: # Global calculator instance for easy integration
 20: _global_calculator: Optional[CostROICalculator] = None
 21: 
 22: 
 23: def get_calculator() -> CostROICalculator:
 24:     """Get or create the global cost calculator instance."""
 25:     global _global_calculator
 26:     if _global_calculator is None:
 27:         _global_calculator = CostROICalculator()
 28:     return _global_calculator
 29: 
 30: 
 31: def reset_calculator():
 32:     """Reset the global calculator (useful for testing)."""
 33:     global _global_calculator
 34:     _global_calculator = None
 35: 
 36: 
 37: def track_cost(feature_name: str, files_processed: int = 1):
 38:     """
 39:     Decorator to track costs for a function.
 40: 
 41:     Usage:
 42:         @track_cost('clip_vision')
 43:         def analyze_image(image_path):
 44:             # ... do analysis ...
 45:             return result
 46: 
 47:     Args:
 48:         feature_name: Name of the feature being tracked
 49:         files_processed: Number of files processed per call
 50:     """
 51:     def decorator(func: Callable):
 52:         @wraps(func)
 53:         def wrapper(*args, **kwargs):
 54:             calculator = get_calculator()
 55:             with CostTracker(calculator, feature_name, files_processed):
 56:                 return func(*args, **kwargs)
 57:         return wrapper
 58:     return decorator
 59: 
 60: 
 61: @contextmanager
 62: def track_feature(
 63:     feature_name: str,
 64:     files_processed: int = 1,
 65:     file_path: Optional[Path] = None
 66: ):
 67:     """
 68:     Context manager for tracking feature costs.
 69: 
 70:     Usage:
 71:         with track_feature('tesseract_ocr', file_path=image_path):
 72:             text = pytesseract.image_to_string(image)
 73: 
 74:     Args:
 75:         feature_name: Name of the feature
 76:         files_processed: Number of files
 77:         file_path: Optional path for file size tracking
 78:     """
 79:     calculator = get_calculator()
 80:     file_size = 0
 81:     if file_path and Path(file_path).exists():
 82:         file_size = Path(file_path).stat().st_size
 83: 
 84:     with CostTracker(
 85:         calculator,
 86:         feature_name,
 87:         files_processed=files_processed,
 88:         input_file_size_bytes=file_size
 89:     ):
 90:         yield
 91: 
 92: 
 93: def record_feature_usage(
 94:     feature_name: str,
 95:     processing_time_sec: float,
 96:     files_processed: int = 1,
 97:     success: bool = True,
 98:     error_message: Optional[str] = None
 99: ):
100:     """
101:     Manually record feature usage.
102: 
103:     Use this when the context manager or decorator approach isn't suitable.
104: 
105:     Args:
106:         feature_name: Name of the feature
107:         processing_time_sec: Time taken
108:         files_processed: Number of files processed
109:         success: Whether it succeeded
110:         error_message: Error message if failed
111:     """
112:     calculator = get_calculator()
113:     calculator.record_usage(
114:         feature_name=feature_name,
115:         processing_time_sec=processing_time_sec,
116:         files_processed=files_processed,
117:         success=success,
118:         error_message=error_message
119:     )
120: 
121: 
122: def get_cost_report() -> Dict[str, Any]:
123:     """Get the current cost report."""
124:     return get_calculator().generate_report()
125: 
126: 
127: def print_cost_summary():
128:     """Print the cost summary."""
129:     get_calculator().print_summary()
130: 
131: 
132: def save_cost_report(output_path: str):
133:     """Save the cost report to a file."""
134:     get_calculator().generate_report(output_path)
135: 
136: 
137: def estimate_processing_cost(
138:     file_count: int,
139:     features: Optional[list] = None
140: ) -> Dict[str, Any]:
141:     """
142:     Estimate cost for processing a number of files.
143: 
144:     Args:
145:         file_count: Number of files to estimate
146:         features: List of features to use (None for all)
147: 
148:     Returns:
149:         Cost estimate dictionary
150:     """
151:     return get_calculator().estimate_cost_for_files(file_count, features)
152: 
153: 
154: class FeatureTracker:
155:     """
156:     Helper class for tracking multiple features in a processing pipeline.
157: 
158:     Usage:
159:         tracker = FeatureTracker()
160: 
161:         # Track CLIP analysis
162:         with tracker.track('clip_vision'):
163:             scores = model.classify(image)
164: 
165:         # Track OCR
166:         with tracker.track('tesseract_ocr'):
167:             text = pytesseract.image_to_string(image)
168: 
169:         # Get summary
170:         print(tracker.summary())
171:     """
172: 
173:     def __init__(self):
174:         self.timings = {}
175:         self.successes = {}
176:         self.errors = {}
177: 
178:     @contextmanager
179:     def track(self, feature_name: str, files: int = 1):
180:         """Track a specific feature."""
181:         start = time.time()
182:         success = True
183:         error_msg = None
184: 
185:         try:
186:             yield
187:         except Exception as e:
188:             success = False
189:             error_msg = str(e)
190:             raise
191:         finally:
192:             elapsed = time.time() - start
193:             self.timings[feature_name] = self.timings.get(feature_name, 0) + elapsed
194:             self.successes[feature_name] = self.successes.get(feature_name, 0) + (1 if success else 0)
195:             if error_msg:
196:                 self.errors[feature_name] = error_msg
197: 
198:             # Record to global calculator
199:             record_feature_usage(
200:                 feature_name=feature_name,
201:                 processing_time_sec=elapsed,
202:                 files_processed=files,
203:                 success=success,
204:                 error_message=error_msg
205:             )
206: 
207:     def summary(self) -> Dict[str, Any]:
208:         """Get tracking summary."""
209:         return {
210:             'timings': self.timings,
211:             'successes': self.successes,
212:             'errors': self.errors,
213:             'total_time': sum(self.timings.values())
214:         }
215: 
216: 
217: # Example integration showing how to modify scripts/file_organizer_content_based.py
218: INTEGRATION_EXAMPLE = '''
219: # Add to scripts/file_organizer_content_based.py:
220: 
221: # At top of file, add import:
222: from src.cost_integration import track_feature, print_cost_summary, save_cost_report
223: 
224: # In ImageContentAnalyzer.classify_image_content():
225: def classify_image_content(self, image_path: Path) -> Dict[str, float]:
226:     """Classify image content using CLIP zero-shot classification."""
227:     if not self.vision_available or self.model is None:
228:         return {}
229: 
230:     with track_feature('clip_vision', file_path=image_path):  # ADD THIS
231:         try:
232:             image = Image.open(image_path)
233:             # ... rest of classification code ...
234:             return scores
235:         except Exception as e:
236:             print(f"  Image classification error: {e}")
237:             return {}
238: 
239: # In ContentBasedFileOrganizer.extract_text_from_image():
240: def extract_text_from_image(self, image_path: Path) -> str:
241:     """Extract text from image using OCR."""
242:     if not self.ocr_available:
243:         return ""
244: 
245:     with track_feature('tesseract_ocr', file_path=image_path):  # ADD THIS
246:         try:
247:             image = Image.open(image_path)
248:             text = pytesseract.image_to_string(image)
249:             return text.strip()
250:         except Exception as e:
251:             print(f"  OCR error: {e}")
252:             return ""
253: 
254: # At end of organize_directories():
255: def organize_directories(self, source_dirs: List[str], dry_run: bool = False, limit: int = None) -> Dict:
256:     """Organize files from multiple source directories."""
257:     # ... existing code ...
258: 
259:     # At end, add cost summary
260:     if not dry_run:
261:         print_cost_summary()  # ADD THIS
262:         save_cost_report(f"results/cost_report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
263: 
264:     return summary
265: '''
266: 
267: 
268: def print_integration_guide():
269:     """Print guide for integrating cost tracking."""
270:     print("=" * SEPARATOR_WIDTH_LARGE)
271:     print("COST TRACKING INTEGRATION GUIDE")
272:     print("=" * SEPARATOR_WIDTH_LARGE)
273:     print("""
274: To add cost tracking to your file organizer, you have several options:
275: 
276: 1. DECORATOR APPROACH (for standalone functions):
277:    -----------------------------------------------
278:    from src.cost_integration import track_cost
279: 
280:    @track_cost('clip_vision')
281:    def classify_image(image_path):
282:        # ... your code ...
283:        return result
284: 
285: 2. CONTEXT MANAGER APPROACH (for code blocks):
286:    -------------------------------------------
287:    from src.cost_integration import track_feature
288: 
289:    with track_feature('tesseract_ocr', file_path=image_path):
290:        text = pytesseract.image_to_string(image)
291: 
292: 3. MANUAL RECORDING (for complex cases):
293:    -------------------------------------
294:    from src.cost_integration import record_feature_usage
295: 
296:    start = time.time()
297:    try:
298:        result = do_processing()
299:        record_feature_usage('my_feature', time.time() - start, success=True)
300:    except Exception as e:
301:        record_feature_usage('my_feature', time.time() - start, success=False, error_message=str(e))
302: 
303: 4. FEATURE TRACKER CLASS (for pipelines):
304:    --------------------------------------
305:    from src.cost_integration import FeatureTracker
306: 
307:    tracker = FeatureTracker()
308:    with tracker.track('clip_vision'):
309:        scores = analyze_image(path)
310:    with tracker.track('tesseract_ocr'):
311:        text = extract_text(path)
