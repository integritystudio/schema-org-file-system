  1: #!/usr/bin/env python3
  2: """
  3: Analyze renamed image files to generate descriptions using OCR and CLIP.
  4: Identifies files that match the renaming pattern and provides content descriptions.
  5: """
  6: 
  7: import os
  8: import sys
  9: import re
 10: import json
 11: import csv
 12: from pathlib import Path
 13: from datetime import datetime
 14: from typing import Dict, List, Optional, Tuple
 15: from collections import defaultdict
 16: 
 17: from shared.clip_utils import CLIPClassifier, CLIP_AVAILABLE
 18: from shared.ocr_utils import extract_ocr_text, is_ocr_available
 19: from shared.constants import CLIP_CATEGORY_PROMPTS, IMAGE_EXTENSIONS
 20: 
 21: 
 22: class RenamedFileAnalyzer:
 23:     """Analyzes renamed files to generate descriptions."""
 24: 
 25:     # Pattern for files renamed by image_renamer_metadata.py
 26:     # Format: YYYYMMDD_HHMMSS[_N].ext or YYYYMMDD_Location_HHMMSS[_N].ext
 27:     RENAMED_PATTERNS = [
 28:         r'^\d{8}_\d{6}(_\d+)?\.(jpg|jpeg|png|webp|gif|bmp|heic)$',  # 20190129_100453.png
 29:         r'^\d{8}_[A-Za-z_]+_\d{6}(_\d+)?\.(jpg|jpeg|png|webp|gif|bmp|heic)$',  # 20190129_NewYork_100453.png
 30:         r'^Screenshot_.*\.(jpg|jpeg|png|webp|gif|bmp|heic)$',  # Screenshot_*.png
 31:     ]
 32: 
 33:     def __init__(self):
 34:         """Initialize analyzer with OCR and CLIP models."""
 35:         self.ocr_available = is_ocr_available()
 36:         self.vision_available = CLIP_AVAILABLE
 37:         self.classifier = None
 38:         self.stats = defaultdict(int)
 39: 
 40:         if self.vision_available:
 41:             try:
 42:                 self.classifier = CLIPClassifier()
 43:             except Exception as e:
 44:                 print(f"Warning: Could not load CLIP model: {e}")
 45:                 self.vision_available = False
 46: 
 47:     def is_renamed_file(self, filename: str) -> bool:
 48:         """Check if filename matches renamed pattern."""
 49:         for pattern in self.RENAMED_PATTERNS:
 50:             if re.match(pattern, filename, re.IGNORECASE):
 51:                 return True
 52:         return False
 53: 
 54:     def classify_with_clip(self, image_path: Path) -> Optional[Dict[str, float]]:
 55:         """Classify image content using CLIP."""
 56:         if not self.vision_available or self.classifier is None:
 57:             return None
 58: 
 59:         try:
 60:             raw_results = self.classifier.classify_raw(image_path, CLIP_CATEGORY_PROMPTS)
 61: 
 62:             # Clean up category names for display
 63:             results = {}
 64:             for prompt, confidence in raw_results:
 65:                 clean_name = prompt.replace("a photo of ", "").replace("a screenshot of ", "screenshot: ")
 66:                 results[clean_name] = confidence
 67: 
 68:             return results
 69: 
 70:         except Exception:
 71:             return None
 72: 
 73:     def get_top_classifications(self, classifications: Dict[str, float], top_n: int = 3, threshold: float = 0.1) -> List[Tuple[str, float]]:
 74:         """Get top classifications above threshold."""
 75:         if not classifications:
 76:             return []
 77: 
 78:         sorted_items = sorted(classifications.items(), key=lambda x: x[1], reverse=True)
 79:         return [(k, v) for k, v in sorted_items[:top_n] if v >= threshold]
 80: 
 81:     def analyze_file(self, file_path: Path) -> Dict:
 82:         """Analyze a single file and return description."""
 83:         result = {
 84:             'path': str(file_path),
 85:             'filename': file_path.name,
 86:             'size_kb': round(file_path.stat().st_size / 1024, 1),
 87:             'ocr_text': None,
 88:             'content_type': None,
 89:             'confidence': None,
 90:             'all_classifications': None,
 91:             'description': None
 92:         }
 93: 
 94:         # Run CLIP classification
 95:         classifications = self.classify_with_clip(file_path)
 96:         if classifications:
 97:             top_classes = self.get_top_classifications(classifications)
 98:             if top_classes:
 99:                 result['content_type'] = top_classes[0][0]
100:                 result['confidence'] = round(top_classes[0][1], 3)
101:                 result['all_classifications'] = [(k, round(v, 3)) for k, v in top_classes]
102:                 self.stats['clip_analyzed'] += 1
103: 
104:         # Run OCR for text detection
105:         ocr_text = extract_ocr_text(file_path)
106:         if ocr_text:
107:             result['ocr_text'] = ocr_text
108:             self.stats['ocr_text_found'] += 1
109: 
110:         # Generate description
111:         description_parts = []
112: 
113:         if result['content_type']:
114:             description_parts.append(f"Content: {result['content_type']} ({result['confidence']:.0%} confident)")
115: 
116:         if result['ocr_text']:
117:             preview = result['ocr_text'][:100] + "..." if len(result['ocr_text']) > 100 else result['ocr_text']
118:             description_parts.append(f"Text detected: \"{preview}\"")
119: 
120:         result['description'] = " | ".join(description_parts) if description_parts else "No description available"
121: 
122:         return result
123: 
124:     def find_renamed_files(self, source_dir: str, recursive: bool = True) -> List[Path]:
125:         """Find all files matching renamed patterns."""
126:         source_path = Path(source_dir).expanduser()
127:         renamed_files = []
128: 
129:         image_extensions = IMAGE_EXTENSIONS
130: 
131:         if recursive:
132:             all_files = []
133:             for ext in image_extensions:
134:                 all_files.extend(source_path.rglob(f'*{ext}'))
135:                 all_files.extend(source_path.rglob(f'*{ext.upper()}'))
136:         else:
137:             all_files = []
138:             for ext in image_extensions:
139:                 all_files.extend(source_path.glob(f'*{ext}'))
140:                 all_files.extend(source_path.glob(f'*{ext.upper()}'))
141: 
142:         for f in all_files:
143:             if self.is_renamed_file(f.name):
144:                 renamed_files.append(f)
145: 
146:         return renamed_files
147: 
148:     def analyze_directory(self, source_dir: str, limit: int = None, output_file: str = None) -> Dict:
149:         """Analyze all renamed files in directory."""
150:         print(f"\n{'='*60}")
151:         print("Renamed File Content Analyzer")
152:         print(f"{'='*60}\n")
153: 
154:         # Find renamed files
155:         print(f"Scanning: {source_dir}")
156:         renamed_files = self.find_renamed_files(source_dir)
157: 
158:         print(f"Found {len(renamed_files)} renamed files to analyze\n")
159: 
160:         if limit:
161:             renamed_files = renamed_files[:limit]
162:             print(f"Limiting to first {limit} files\n")
163: 
164:         results = []
165: 
166:         for i, file_path in enumerate(renamed_files, 1):
167:             if i % 25 == 0 or i == 1:
168:                 print(f"[{i}/{len(renamed_files)}] Analyzing...")
169: 
170:             try:
171:                 result = self.analyze_file(file_path)
172:                 results.append(result)
173:                 self.stats['analyzed'] += 1
174: 
175:                 # Print progress for each file
176:                 if result['content_type']:
177:                     print(f"  {file_path.name}: {result['content_type']} ({result['confidence']:.0%})")
178: 
179:             except Exception as e:
180:                 print(f"  Error analyzing {file_path.name}: {e}")
181:                 self.stats['errors'] += 1
182: 
183:         # Generate summary
184:         summary = {
185:             'total_found': len(renamed_files),
186:             'analyzed': self.stats['analyzed'],
187:             'clip_analyzed': self.stats['clip_analyzed'],
188:             'ocr_text_found': self.stats['ocr_text_found'],
189:             'errors': self.stats['errors'],
190:             'results': results
191:         }
192: 
193:         # Save results
194:         if output_file:
195:             output_path = Path(output_file)
196: 
197:             if output_path.suffix == '.json':
198:                 with open(output_path, 'w') as f:
199:                     json.dump(summary, f, indent=2)
200:             elif output_path.suffix == '.csv':
201:                 with open(output_path, 'w', newline='') as f:
202:                     writer = csv.DictWriter(f, fieldnames=['filename', 'path', 'size_kb', 'content_type', 'confidence', 'ocr_text', 'description'])
203:                     writer.writeheader()
204:                     for r in results:
205:                         writer.writerow({
206:                             'filename': r['filename'],
207:                             'path': r['path'],
208:                             'size_kb': r['size_kb'],
209:                             'content_type': r['content_type'],
210:                             'confidence': r['confidence'],
211:                             'ocr_text': r['ocr_text'],
212:                             'description': r['description']
213:                         })
214: 
215:             print(f"\nResults saved to: {output_path}")
216: 
217:         return summary
218: 
219:     def print_summary(self, summary: Dict):
220:         """Print analysis summary."""
221:         print(f"\n{'='*60}")
222:         print("Analysis Summary")
223:         print(f"{'='*60}\n")
224: 
225:         print(f"Total renamed files found: {summary['total_found']}")
226:         print(f"Successfully analyzed: {summary['analyzed']}")
227:         print(f"CLIP classifications: {summary['clip_analyzed']}")
228:         print(f"OCR text detected: {summary['ocr_text_found']}")
229:         print(f"Errors: {summary['errors']}")
230: 
231:         # Content type breakdown
232:         if summary['results']:
233:             content_types = defaultdict(int)
234:             for r in summary['results']:
235:                 if r['content_type']:
236:                     content_types[r['content_type']] += 1
237: 
238:             if content_types:
239:                 print(f"\nContent Type Breakdown:")
240:                 for ctype, count in sorted(content_types.items(), key=lambda x: x[1], reverse=True)[:10]:
241:                     print(f"  {ctype}: {count}")
242: 
243: 
244: def main():
245:     """Main entry point."""
246:     import argparse
247: 
248:     parser = argparse.ArgumentParser(
249:         description='Analyze renamed image files using OCR and CLIP'
250:     )
251:     parser.add_argument(
252:         '--source',
253:         default='~/Documents',
254:         help='Source directory to scan (default: ~/Documents)'
255:     )
256:     parser.add_argument(
257:         '--limit',
258:         type=int,
259:         help='Limit number of files to analyze'
260:     )
261:     parser.add_argument(
262:         '--output',
263:         default=str(Path(__file__).parent.parent / 'results' / 'renamed_files_analysis.json'),
264:         help='Output file (JSON or CSV)'
265:     )
266: 
267:     args = parser.parse_args()
268: 
269:     # Create analyzer
270:     analyzer = RenamedFileAnalyzer()
271: 
272:     # Analyze files
273:     summary = analyzer.analyze_directory(
274:         source_dir=args.source,
275:         limit=args.limit,
276:         output_file=args.output
277:     )
278: 
279:     # Print summary
280:     analyzer.print_summary(summary)
281: 
282: 
283: if __name__ == '__main__':
284:     main()
