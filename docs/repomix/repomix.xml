460: ### API Response Pattern
461: 
462: Provide Schema.org data through APIs:
463: 
464: ```python
465: from flask import Flask, jsonify, request
466: 
467: app = Flask(__name__)
468: 
469: @app.route('/api/files/<file_id>/schema', methods=['GET'])
470: def get_file_schema(file_id: str):
471:     """Return file schema in requested format."""
472: 
473:     # Get schema
474:     schema = repository.get(file_id)
475:     if not schema:
476:         return jsonify({'error': 'File not found'}), 404
477: 
478:     # Get format parameter
479:     format = request.args.get('format', 'json-ld')
480: 
481:     # Convert to requested format
482:     integration = SchemaIntegration()
483:     integration.add_schema(schema)
484: 
485:     if format == 'json-ld':
486:         return jsonify(schema)
487:     elif format == 'microdata':
488:         return integration.to_microdata(schema), 200, {'Content-Type': 'text/html'}
489:     elif format == 'rdfa':
490:         return integration.to_rdfa(schema), 200, {'Content-Type': 'text/html'}
491:     else:
492:         return jsonify({'error': 'Unsupported format'}), 400
493: 
494: @app.route('/api/files/<file_id>/schema', methods=['PUT'])
495: def update_file_schema(file_id: str):
496:     """Update file schema."""
497: 
498:     schema = request.json
499: 
500:     # Validate
501:     validator = SchemaValidator()
502:     report = validator.validate(schema)
503: 
504:     if not report.is_valid():
505:         return jsonify({
506:             'error': 'Invalid schema',
507:             'validation': report.to_dict()
508:         }), 400
509: 
510:     # Update
511:     success = repository.update(file_id, schema)
512: 
513:     if success:
