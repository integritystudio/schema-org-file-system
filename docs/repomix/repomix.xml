564:         # Split on first colon
565:         key_part, value = line.split(':', 1)
566:         key = key_part.split(';')[0].upper()  # Remove parameters
567: 
568:         if key == 'FN':
569:             generator.set_name(name=value)
570:         elif key == 'N':
571:             # N:Last;First;Middle;Prefix;Suffix
572:             parts = value.split(';')
573:             if len(parts) >= 2:
574:                 generator.set_name(
575:                     family_name=parts[0] if parts[0] else None,
576:                     given_name=parts[1] if len(parts) > 1 and parts[1] else None,
577:                     additional_name=parts[2] if len(parts) > 2 and parts[2] else None,
578:                     honorific_prefix=parts[3] if len(parts) > 3 and parts[3] else None,
579:                     honorific_suffix=parts[4] if len(parts) > 4 and parts[4] else None,
580:                 )
581:         elif key == 'EMAIL':
582:             generator.set_contact_info(email=value)
583:         elif key == 'TEL':
584:             generator.set_contact_info(telephone=value)
585:         elif key == 'ORG':
586:             generator.set_job_info(works_for=value.split(';')[0])
587:         elif key == 'TITLE':
588:             generator.set_job_info(job_title=value)
589:         elif key == 'URL':
590:             generator.set_url(value)
591:         elif key == 'BDAY':
592:             generator.set_birth_info(birth_date=value)
593:         elif key == 'ADR':
594:             # ADR:;;Street;City;Region;PostalCode;Country
595:             parts = value.split(';')
596:             if len(parts) >= 7:
597:                 generator.set_address(
598:                     street=parts[2] if parts[2] else None,
599:                     city=parts[3] if len(parts) > 3 and parts[3] else None,
600:                     region=parts[4] if len(parts) > 4 and parts[4] else None,
601:                     postal_code=parts[5] if len(parts) > 5 and parts[5] else None,
602:                     country=parts[6] if len(parts) > 6 and parts[6] else None,
