277:     def _update_learned_patterns(
278:         self,
279:         patterns: List[str],
280:         correct_category: str,
281:         correct_subcategory: str
282:     ) -> None:
283:         """Update learned patterns from corrections."""
284:         for pattern in patterns:
285:             if pattern not in self.data["learned_patterns"]:
286:                 self.data["learned_patterns"][pattern] = {
287:                     "categories": {},
288:                     "subcategories": {}
289:                 }
290: 
291:             learned = self.data["learned_patterns"][pattern]
292: 
293:             # Update category counts
294:             if correct_category not in learned["categories"]:
295:                 learned["categories"][correct_category] = 0
296:             learned["categories"][correct_category] += 1
297: 
298:             # Update subcategory counts
299:             if correct_subcategory:
300:                 if correct_subcategory not in learned["subcategories"]:
301:                     learned["subcategories"][correct_subcategory] = 0
302:                 learned["subcategories"][correct_subcategory] += 1
303: 
304:     def get_suggestion(self, filename: str, current_category: str = None) -> Optional[Dict]:
305:         """Get a category suggestion based on learned patterns.
306: 
307:         Args:
308:             filename: The filename to check
309:             current_category: The currently assigned category
310: 
311:         Returns:
312:             Dictionary with suggested category and confidence, or None
313:         """
314:         patterns = self.extract_filename_patterns(filename)
315: 
316:         category_votes = defaultdict(float)
317:         subcategory_votes = defaultdict(float)
318: 
319:         for pattern in patterns:
320:             if pattern in self.data["learned_patterns"]:
321:                 learned = self.data["learned_patterns"][pattern]
322: 
323:                 # Weight by occurrence count
324:                 for cat, count in learned["categories"].items():
325:                     category_votes[cat] += count
326: 
327:                 for subcat, count in learned["subcategories"].items():
328:                     subcategory_votes[subcat] += count
329: 
330:         if not category_votes:
331:             return None
332: 
333:         # Find best category
334:         total_votes = sum(category_votes.values())
335:         best_category = max(category_votes.items(), key=lambda x: x[1])
336:         confidence = best_category[1] / total_votes if total_votes > 0 else 0
337: 
338:         # Find best subcategory
339:         best_subcategory = None
340:         if subcategory_votes:
341:             best_subcategory = max(subcategory_votes.items(), key=lambda x: x[1])[0]
342: 
343:         # Only suggest if confidence is above threshold and different from current
344:         if confidence >= 0.6 and best_category[0] != current_category:
345:             return {
346:                 "suggested_category": best_category[0],
347:                 "suggested_subcategory": best_subcategory,
348:                 "confidence": round(confidence, 3),
349:                 "matching_patterns": patterns,
350:                 "sample_count": int(best_category[1])
351:             }
352: 
353:         return None
354: 
