425:     def _compute_quality_score(self, issues: Dict) -> float:
426:         """Compute overall data quality score (0-100)."""
427:         total = len(self.features)
428:         if total == 0:
429:             return 0.0
430: 
431:         # Penalize based on issues
432:         penalties = 0
433:         penalties += len(issues['missing_category']) * 0.5
434:         penalties += len(issues['empty_filename']) * 1.0
435:         penalties += len(issues['duplicate_filenames']) * 0.1
436:         penalties += len(issues['suspicious_extensions']) * 0.05
437: 
438:         score = max(0, 100 - (penalties / total * 100))
439:         return round(score, 2)
