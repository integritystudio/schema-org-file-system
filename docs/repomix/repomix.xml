169: /**
170:  * Check if metrics meet thresholds and return violations
171:  */
172: export function checkThresholds(
173:   metrics: PerformanceMetrics,
174:   thresholds: PerformanceThresholds = DEFAULT_THRESHOLDS
175: ): string[] {
176:   const violations: string[] = [];
177: 
178:   if (thresholds.lcp && metrics.lcp !== null && metrics.lcp > thresholds.lcp) {
179:     violations.push(`LCP (${metrics.lcp}ms) exceeds threshold (${thresholds.lcp}ms)`);
180:   }
181: 
182:   if (thresholds.fcp && metrics.fcp !== null && metrics.fcp > thresholds.fcp) {
183:     violations.push(`FCP (${metrics.fcp}ms) exceeds threshold (${thresholds.fcp}ms)`);
184:   }
185: 
186:   if (thresholds.cls && metrics.cls !== null && metrics.cls > thresholds.cls) {
187:     violations.push(`CLS (${metrics.cls}) exceeds threshold (${thresholds.cls})`);
188:   }
189: 
190:   if (thresholds.ttfb && metrics.ttfb !== null && metrics.ttfb > thresholds.ttfb) {
191:     violations.push(`TTFB (${metrics.ttfb}ms) exceeds threshold (${thresholds.ttfb}ms)`);
192:   }
193: 
194:   if (thresholds.domContentLoaded && metrics.domContentLoaded !== null &&
195:       metrics.domContentLoaded > thresholds.domContentLoaded) {
196:     violations.push(`DOMContentLoaded (${metrics.domContentLoaded}ms) exceeds threshold (${thresholds.domContentLoaded}ms)`);
197:   }
198: 
199:   if (thresholds.loadComplete && metrics.loadComplete !== null &&
200:       metrics.loadComplete > thresholds.loadComplete) {
201:     violations.push(`Load Complete (${metrics.loadComplete}ms) exceeds threshold (${thresholds.loadComplete}ms)`);
202:   }
203: 
204:   return violations;
205: }
