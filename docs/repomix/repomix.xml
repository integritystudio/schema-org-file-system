<file path="scripts/shared/clip_utils.py">
  1: """CLIP model loading and classification utilities."""
  2: from __future__ import annotations
  3: import logging
  4: from pathlib import Path
  5: 
  6: logger = logging.getLogger(__name__)
  7: 
  8: CLIP_AVAILABLE = False
  9: try:
 10:   import torch
 11:   from transformers import CLIPProcessor, CLIPModel
 12:   from PIL import Image
 13:   CLIP_AVAILABLE = True
 14: except ImportError:
 15:   pass
 16: 
 17: # HEIC support
 18: try:
 19:   from pillow_heif import register_heif_opener
 20:   register_heif_opener()
 21: except ImportError:
 22:   pass
 23: 
 24: 
 25: class CLIPClassifier:
 26:   """Shared CLIP model loader and classifier.
 27: 
 28:   Consolidates model loading + inference that was duplicated across
 29:   analyze_renamed_files.py, image_content_analyzer.py,
 30:   image_content_renamer.py, and screenshot_renamer.py.
 31:   """
 32: 
 33:   MODEL_NAME = "openai/clip-vit-base-patch32"
 34: 
 35:   def __init__(self, device: str | None = None):
 36:     if not CLIP_AVAILABLE:
 37:       raise RuntimeError("CLIP not available. Install torch and transformers.")
 38:     self.device = device or self._detect_device()
 39:     logger.info("Loading CLIP model %s", self.MODEL_NAME)
 40:     self.model = CLIPModel.from_pretrained(self.MODEL_NAME)
 41:     self.processor = CLIPProcessor.from_pretrained(self.MODEL_NAME)
 42:     self.model.to(self.device)
 43:     self.model.eval()
 44:     logger.info("CLIP model loaded (device: %s)", self.device)
 45: 
 46:   @staticmethod
 47:   def _detect_device() -> str:
 48:     if torch.backends.mps.is_available():
 49:       return "mps"
 50:     if torch.cuda.is_available():
 51:       return "cuda"
 52:     return "cpu"
 53: 
 54:   @staticmethod
 55:   def is_available() -> bool:
 56:     return CLIP_AVAILABLE
 57: 
 58:   def classify(
 59:     self,
 60:     image_path: Path,
 61:     labels: list[str],
 62:     prompt_prefix: str = "a photo of ",
 63:   ) -> list[tuple[str, float]]:
 64:     """Classify image against labels.
 65: 
 66:     Returns list of (label, confidence) sorted by confidence descending.
 67:     """
 68:     with Image.open(image_path) as img:
 69:       image = img.convert("RGB")
 70:     text_inputs = [f"{prompt_prefix}{lbl}" for lbl in labels]
 71: 
 72:     inputs = self.processor(
 73:       text=text_inputs,
 74:       images=image,
 75:       return_tensors="pt",
 76:       padding=True,
 77:     )
 78:     inputs = {k: v.to(self.device) for k, v in inputs.items()}
 79: 
 80:     with torch.no_grad():
 81:       outputs = self.model(**inputs)
 82:       probs = outputs.logits_per_image.softmax(dim=1)
 83: 
 84:     results = [(labels[i], probs[0][i].item()) for i in range(len(labels))]
 85:     results.sort(key=lambda x: x[1], reverse=True)
 86:     return results
 87: 
 88:   def classify_raw(
 89:     self,
 90:     image_path: Path,
 91:     text_prompts: list[str],
 92:   ) -> list[tuple[str, float]]:
 93:     """Classify image using raw text prompts (no prefix added).
 94: 
 95:     Useful when labels already include "a photo of" etc.
 96:     Returns list of (prompt, confidence) sorted by confidence descending.
 97:     """
 98:     with Image.open(image_path) as img:
 99:       image = img.convert("RGB")
100: 
101:     inputs = self.processor(
102:       text=text_prompts,
103:       images=image,
104:       return_tensors="pt",
105:       padding=True,
106:     )
107:     inputs = {k: v.to(self.device) for k, v in inputs.items()}
108: 
109:     with torch.no_grad():
110:       outputs = self.model(**inputs)
111:       probs = outputs.logits_per_image.softmax(dim=1)
112: 
113:     results = [(text_prompts[i], probs[0][i].item()) for i in range(len(text_prompts))]
114:     results.sort(key=lambda x: x[1], reverse=True)
115:     return results
116: 
117:   def top_match(
118:     self,
119:     image_path: Path,
120:     labels: list[str],
121:     prompt_prefix: str = "a photo of ",
122:   ) -> tuple[str, float]:
123:     """Return single best match (label, confidence)."""
124:     results = self.classify(image_path, labels, prompt_prefix)
125:     return results[0] if results else ("unknown", 0.0)
