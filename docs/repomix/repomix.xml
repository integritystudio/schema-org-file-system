1111:     def is_home_interior_no_people(self, image_path: Path) -> Tuple[bool, Dict[str, float]]:
1112:         """
1113:         Check if image is a home interior without people.
1114: 
1115:         Returns:
1116:             Tuple of (is_interior_no_people, classification_scores)
1117:         """
1118:         if not self.vision_available:
1119:             return (False, {})
1120: 
1121:         # Classify image content
1122:         scores = self.classify_image_content(image_path)
1123: 
1124:         if not scores:
1125:             return (False, {})
1126: 
1127:         # Check for home interior indicators
1128:         interior_score = max(
1129:             scores.get("a photo of a home interior room", 0),
1130:             scores.get("a photo of a living room", 0),
1131:             scores.get("a photo of a bedroom", 0),
1132:             scores.get("a photo of a kitchen", 0),
1133:             scores.get("a photo of a bathroom", 0),
1134:             scores.get("a photo of furniture", 0)
1135:         )
1136: 
1137:         # Check for people
1138:         people_score = scores.get("a photo of people", 0)
1139:         has_faces = self.detect_people(image_path)
1140: 
1141:         # Determine if it's an interior without people
1142:         is_interior = interior_score > 0.3  # 30% confidence threshold
1143:         has_people = people_score > 0.2 or has_faces  # 20% confidence or face detection
1144: 
1145:         return (is_interior and not has_people, scores)
1146: 
1147:     def has_people_in_photo(self, image_path: Path) -> Tuple[bool, Dict[str, float]]:
1148:         """
1149:         Check if image contains people (for social photos).
1150: 
1151:         Returns:
1152:             Tuple of (has_people, classification_scores)
1153:         """
1154:         if not self.vision_available:
1155:             return (False, {})
1156: 
1157:         # Classify image content
1158:         scores = self.classify_image_content(image_path)
1159: 
1160:         if not scores:
1161:             return (False, {})
1162: 
1163:         # Check for people indicators
1164:         people_score = scores.get("a photo of people", 0)
1165:         has_faces = self.detect_people(image_path)
1166: 
1167:         # Check that it's NOT a screenshot
1168:         screenshot_score = scores.get("a screenshot", 0)
1169:         is_screenshot = screenshot_score > 0.4  # High threshold for screenshots
1170: 
1171:         # Determine if photo has people (and is not a screenshot)
1172:         has_people = (people_score > 0.15 or has_faces) and not is_screenshot
1173: 
1174:         return (has_people, scores)
