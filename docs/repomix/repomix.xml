622:     def merge_metadata(self, *metadata_dicts: Dict[str, Any]) -> Dict[str, Any]:
623:         """
624:         Merge multiple metadata dictionaries.
625: 
626:         Later dictionaries override earlier ones.
627: 
628:         Args:
629:             *metadata_dicts: Variable number of metadata dictionaries
630: 
631:         Returns:
632:             Merged metadata dictionary
633:         """
634:         merged: Dict[str, Any] = {}
635:         for metadata in metadata_dicts:
636:             for key, value in metadata.items():
637:                 if key not in merged or value is not None:
638:                     merged[key] = value
639:         return merged
640: 
641:     def create_enriched_schema(self, generator_class, base_metadata: Dict[str, Any],
642:                               *enrichment_sources: Dict[str, Any]) -> Any:
643:         """
644:         Create enriched schema from multiple metadata sources.
645: 
646:         Args:
647:             generator_class: Schema generator class to use
648:             base_metadata: Base metadata dictionary
649:             *enrichment_sources: Additional enrichment source dictionaries
650: 
651:         Returns:
652:             Configured schema generator instance
653:         """
654:         # Merge all metadata
655:         merged = self.merge_metadata(base_metadata, *enrichment_sources)
656: 
657:         # Create generator instance
658:         generator = generator_class()
659: 
660:         # Apply metadata to generator
661:         for key, value in merged.items():
662:             if hasattr(generator, 'set_property'):
663:                 try:
664:                     generator.set_property(key, value)
665:                 except Exception:
666:                     pass  # Skip properties that can't be set
667: 
668:         return generator
