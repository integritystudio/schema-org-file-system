<file path="scripts/image_renamer_metadata.py">
  1: #!/usr/bin/env python3
  2: """
  3: Rename image files based on metadata for better organization.
  4: Renames generic camera filenames (IMG_*, PXL_*, DSC_*) to human-readable names
  5: using EXIF metadata (date, location) and OCR for screenshots.
  6: """
  7: 
  8: import os
  9: import re
 10: import argparse
 11: from pathlib import Path
 12: from datetime import datetime
 13: from typing import Optional, Dict, Tuple
 14: from collections import defaultdict
 15: 
 16: # Import metadata and OCR classes from content-based organizer
 17: import sys
 18: sys.path.append(str(Path(__file__).parent))
 19: 
 20: try:
 21:     from PIL import Image
 22:     import piexif
 23:     from geopy.geocoders import Nominatim
 24:     import pytesseract
 25: except ImportError as e:
 26:     print(f"Missing required library: {e}")
 27:     print("Install with: pip install Pillow piexif geopy pytesseract pillow-heif")
 28:     sys.exit(1)
 29: 
 30: 
 31: class ImageRenamer:
 32:     """Rename images based on metadata."""
 33: 
 34:     # Patterns that indicate non-human-readable filenames
 35:     # Note: These are matched against lowercased filenames
 36:     GENERIC_PATTERNS = [
 37:         r'^img_\d+',           # IMG_1234.jpg
 38:         r'^dsc_?\d+',          # DSC_1234.jpg, DSC1234.jpg
 39:         r'^pxl_\d+',           # PXL_20250425_023840031.jpg
 40:         r'^dcim_\d+',          # DCIM_1234.jpg
 41:         r'^\d{8}_\d{6}',       # 20250425_123456.jpg
 42:         r'^\d{4}-\d{2}-\d{2}', # 2025-04-25.jpg
 43:         r'^screenshot\s+\d{4}', # Screenshot 2025-11-23...
 44:         r'^\d+$',              # 12345.jpg (pure numbers)
 45:         r'^[a-f0-9]{32}',      # MD5-style hashes
 46:         r'^unnamed\(\d+\)',    # unnamed(1).jpg
 47:         r'^image\(\d+\)',      # image(1).jpg
 48:         r'^photo\(\d+\)',      # photo(1).jpg
 49:         r'^file\(\d+\)',       # file(1).jpg
 50:         r'^\d{13}',            # 1715549219720 (Unix timestamps in ms)
 51:         r'^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}', # UUIDs
 52:     ]
 53: 
 54:     def __init__(self, base_path: str = None):
 55:         """Initialize the renamer."""
 56:         self.base_path = Path(base_path or "~/Documents").expanduser()
 57:         self.stats = defaultdict(int)
 58:         self.geolocator = Nominatim(user_agent="image_renamer")
 59: 
 60:         # HEIC support
 61:         try:
 62:             from pillow_heif import register_heif_opener
 63:             register_heif_opener()
 64:             self.heic_support = True
 65:         except ImportError:
 66:             self.heic_support = False
 67:             print("⚠️  HEIC support not available. Install pillow-heif for HEIC images.")
 68: 
 69:     def is_generic_filename(self, filename: str) -> bool:
 70:         """Check if filename is generic/non-human-readable."""
 71:         stem = Path(filename).stem.lower()  # Convert to lowercase for case-insensitive matching
 72: 
 73:         for pattern in self.GENERIC_PATTERNS:
 74:             if re.match(pattern, stem):
 75:                 return True
 76: 
 77:         return False
 78: 
 79:     def extract_exif_data(self, image_path: Path) -> Optional[Dict]:
 80:         """Extract EXIF data from image."""
 81:         try:
 82:             img = Image.open(image_path)
 83:             if not hasattr(img, '_getexif') or img._getexif() is None:
 84:                 # Try piexif for JPEG/HEIC
 85:                 exif_dict = piexif.load(str(image_path))
 86:                 if exif_dict:
 87:                     return exif_dict
 88:             else:
 89:                 return img._getexif()
 90:             return None
 91:         except Exception as e:
 92:             return None
 93: 
 94:     def extract_datetime(self, image_path: Path) -> Optional[datetime]:
 95:         """Extract datetime from EXIF."""
 96:         try:
 97:             img = Image.open(image_path)
 98:             exif_data = img._getexif()
 99: 
100:             if exif_data:
101:                 # Try different datetime tags
102:                 for tag_id in [36867, 36868, 306]:  # DateTimeOriginal, DateTimeDigitized, DateTime
103:                     if tag_id in exif_data:
104:                         dt_str = exif_data[tag_id]
105:                         try:
106:                             dt = datetime.strptime(dt_str, "%Y:%m:%d %H:%M:%S")
107:                             return dt
108:                         except (ValueError, TypeError):
109:                             continue
110: 
111:             # Try piexif
112:             exif_dict = piexif.load(str(image_path))
113:             if exif_dict and piexif.ExifIFD.DateTimeOriginal in exif_dict.get("Exif", {}):
114:                 dt_bytes = exif_dict["Exif"][piexif.ExifIFD.DateTimeOriginal]
115:                 dt_str = dt_bytes.decode('utf-8') if isinstance(dt_bytes, bytes) else dt_bytes
116:                 try:
117:                     dt = datetime.strptime(dt_str, "%Y:%m:%d %H:%M:%S")
118:                     return dt
119:                 except (ValueError, TypeError):
120:                     pass
121: 
122:         except Exception:
123:             pass
124: 
125:         return None
126: 
127:     def extract_gps_coordinates(self, image_path: Path) -> Optional[Tuple[float, float]]:
128:         """Extract GPS coordinates from EXIF."""
129:         try:
130:             exif_dict = piexif.load(str(image_path))
131:             if not exif_dict or "GPS" not in exif_dict:
132:                 return None
133: 
134:             gps_info = exif_dict["GPS"]
135: 
136:             # Get latitude
137:             if piexif.GPSIFD.GPSLatitude not in gps_info or piexif.GPSIFD.GPSLatitudeRef not in gps_info:
138:                 return None
139: 
140:             lat = gps_info[piexif.GPSIFD.GPSLatitude]
141:             lat_ref = gps_info[piexif.GPSIFD.GPSLatitudeRef].decode('utf-8')
142: 
143:             # Get longitude
144:             if piexif.GPSIFD.GPSLongitude not in gps_info or piexif.GPSIFD.GPSLongitudeRef not in gps_info:
145:                 return None
146: 
147:             lon = gps_info[piexif.GPSIFD.GPSLongitude]
148:             lon_ref = gps_info[piexif.GPSIFD.GPSLongitudeRef].decode('utf-8')
149: 
150:             # Convert to decimal degrees
151:             def to_decimal(coord):
152:                 d, m, s = coord
153:                 return d[0]/d[1] + (m[0]/m[1])/60 + (s[0]/s[1])/3600
154: 
155:             latitude = to_decimal(lat)
156:             if lat_ref == 'S':
157:                 latitude = -latitude
158: 
159:             longitude = to_decimal(lon)
160:             if lon_ref == 'W':
161:                 longitude = -longitude
162: 
163:             return (latitude, longitude)
164: 
165:         except Exception:
166:             return None
167: 
168:     def get_location_name(self, coordinates: Tuple[float, float]) -> Optional[str]:
169:         """Get location name from GPS coordinates."""
170:         try:
171:             location = self.geolocator.reverse(coordinates, language='en', timeout=10)
172:             if location:
173:                 address = location.raw.get('address', {})
174:                 # Try to get city, town, or village
175:                 place = (address.get('city') or
176:                         address.get('town') or
177:                         address.get('village') or
178:                         address.get('county'))
179:                 return place
180:         except Exception:
181:             pass
182:         return None
183: 
184:     def extract_screenshot_text(self, image_path: Path) -> Optional[str]:
185:         """Extract text from screenshots using OCR."""
186:         try:
187:             img = Image.open(image_path)
188:             text = pytesseract.image_to_string(img)
189: 
190:             # Clean up text - extract first meaningful phrase
191:             lines = [line.strip() for line in text.split('\n') if line.strip()]
192:             if lines:
193:                 # Get first line that's not too short
194:                 for line in lines[:3]:
195:                     if len(line) > 10 and len(line) < 50:
196:                         # Clean for filename
197:                         clean_text = re.sub(r'[^\w\s-]', '', line)
198:                         clean_text = re.sub(r'\s+', '_', clean_text.strip())
199:                         return clean_text[:40]  # Max 40 chars
200:         except Exception:
201:             pass
202:         return None
203: 
204:     def generate_new_filename(self, image_path: Path) -> Optional[str]:
205:         """Generate a new human-readable filename based on metadata."""
206:         ext = image_path.suffix.lower()
207: 
208:         # Check if it's a screenshot
209:         is_screenshot = 'screenshot' in image_path.stem.lower()
210: 
211:         if is_screenshot:
212:             # For screenshots, try OCR first
213:             text = self.extract_screenshot_text(image_path)
214:             if text:
215:                 return f"Screenshot_{text}{ext}"
216: 
217:             # Fall back to datetime
218:             dt = self.extract_datetime(image_path)
219:             if dt:
220:                 return f"Screenshot_{dt.strftime('%Y%m%d_%H%M%S')}{ext}"
221: 
222:             return None
223: 
224:         # For regular photos, use date + location
225:         dt = self.extract_datetime(image_path)
226:         coords = self.extract_gps_coordinates(image_path)
227: 
228:         parts = []
229: 
230:         # Add date
231:         if dt:
232:             parts.append(dt.strftime('%Y%m%d'))
233:         else:
234:             # Fall back to file modification time if no EXIF date
235:             mod_time = datetime.fromtimestamp(image_path.stat().st_mtime)
236:             parts.append(mod_time.strftime('%Y%m%d'))
237:             dt = mod_time  # Use for time part below
238: 
239:         # Add location
240:         if coords:
241:             location = self.get_location_name(coords)
242:             if location:
243:                 # Clean location name for filename
244:                 clean_loc = re.sub(r'[^\w\s-]', '', location)
245:                 clean_loc = re.sub(r'\s+', '_', clean_loc)
246:                 parts.append(clean_loc)
247: 
248:         # Add time if we have date
249:         if dt:
250:             parts.append(dt.strftime('%H%M%S'))
251: 
252:         if parts:
253:             return '_'.join(parts) + ext
254: 
255:         return None
256: 
257:     def rename_file(self, file_path: Path, dry_run: bool = False) -> Dict:
258:         """Rename a single file based on metadata."""
259:         result = {
260:             'source': str(file_path),
261:             'status': 'skipped',
262:             'destination': None,
263:             'reason': None
264:         }
265: 
266:         # Check if file exists
267:         if not file_path.exists() or not file_path.is_file():
268:             result['reason'] = 'Not a file'
269:             self.stats['skipped'] += 1
270:             return result
271: 
272:         # Check if filename is already human-readable
273:         if not self.is_generic_filename(file_path.name):
274:             result['reason'] = 'Already human-readable'
275:             result['status'] = 'already_readable'
276:             self.stats['already_readable'] += 1
277:             return result
278: 
279:         # Check if it's an image
280:         if file_path.suffix.lower() not in ['.jpg', '.jpeg', '.png', '.heic', '.gif', '.bmp', '.webp']:
281:             result['reason'] = 'Not an image file'
282:             self.stats['skipped'] += 1
283:             return result
284: 
285:         # Generate new filename
286:         try:
287:             new_name = self.generate_new_filename(file_path)
288: 
289:             if not new_name:
290:                 result['reason'] = 'No metadata available'
291:                 result['status'] = 'no_metadata'
292:                 self.stats['no_metadata'] += 1
293:                 return result
294: 
295:             # Create new path in same directory
296:             new_path = file_path.parent / new_name
297: 
298:             # Handle duplicates
299:             if new_path.exists() and new_path != file_path:
300:                 counter = 1
301:                 stem = Path(new_name).stem
302:                 ext = Path(new_name).suffix
303:                 while new_path.exists():
304:                     new_name = f"{stem}_{counter}{ext}"
305:                     new_path = file_path.parent / new_name
306:                     counter += 1
307: 
308:             # Perform rename
309:             if not dry_run:
310:                 file_path.rename(new_path)
311:                 result['status'] = 'renamed'
312:                 print(f"  ✓ Renamed: {file_path.name} → {new_name}")
313:             else:
314:                 result['status'] = 'would_rename'
315:                 print(f"  → Would rename: {file_path.name} → {new_name}")
316: 
317:             result['destination'] = str(new_path)
318:             self.stats['renamed'] += 1
319: 
320:         except Exception as e:
321:             result['status'] = 'error'
322:             result['reason'] = str(e)
323:             self.stats['errors'] += 1
324:             print(f"  ✗ Error renaming {file_path.name}: {e}")
325: 
326:         return result
327: 
328:     def rename_directory(self, source_dir: str, dry_run: bool = False, recursive: bool = False) -> Dict:
329:         """Rename all generic image files in a directory."""
330:         results = []
331:         source_path = Path(source_dir).expanduser()
332: 
333:         print(f"\n{'='*60}")
334:         print(f"Image Metadata Renamer {'(DRY RUN)' if dry_run else ''}")
335:         print(f"{'='*60}\n")
336:         print(f"Scanning: {source_path}")
337:         print(f"Recursive: {recursive}\n")
338: 
339:         # Collect all image files
340:         image_extensions = {'.jpg', '.jpeg', '.png', '.heic', '.gif', '.bmp', '.webp'}
341:         all_files = []
342: 
343:         if recursive:
344:             for ext in image_extensions:
345:                 all_files.extend(source_path.rglob(f'*{ext}'))
346:                 all_files.extend(source_path.rglob(f'*{ext.upper()}'))
347:         else:
348:             for ext in image_extensions:
349:                 all_files.extend(source_path.glob(f'*{ext}'))
350:                 all_files.extend(source_path.glob(f'*{ext.upper()}'))
351: 
352:         # Filter for generic filenames
353:         generic_files = [f for f in all_files if self.is_generic_filename(f.name)]
354: 
355:         print(f"Total image files: {len(all_files)}")
356:         print(f"Generic filenames to process: {len(generic_files)}\n")
357: 
358:         # Process each file
359:         for i, file_path in enumerate(generic_files, 1):
360:             if i % 50 == 0:
361:                 print(f"[{i}/{len(generic_files)}] Processing...")
362: 
363:             result = self.rename_file(file_path, dry_run=dry_run)
364:             results.append(result)
365: 
366:         # Generate summary
367:         summary = {
368:             'total_images': len(all_files),
369:             'generic_filenames': len(generic_files),
370:             'renamed': self.stats['renamed'],
371:             'already_readable': self.stats['already_readable'],
372:             'no_metadata': self.stats['no_metadata'],
373:             'skipped': self.stats['skipped'],
374:             'errors': self.stats['errors'],
375:             'dry_run': dry_run,
376:             'results': results
377:         }
378: 
379:         return summary
380: 
381:     def print_summary(self, summary: Dict):
382:         """Print renaming summary."""
383:         print(f"\n{'='*60}")
384:         print("Renaming Summary")
385:         print(f"{'='*60}\n")
386: 
387:         print(f"Total image files: {summary['total_images']}")
388:         print(f"Generic filenames found: {summary['generic_filenames']}")
389:         print(f"Successfully renamed: {summary['renamed']}")
390:         print(f"Already human-readable: {summary['already_readable']}")
391:         print(f"No metadata available: {summary['no_metadata']}")
392:         print(f"Skipped: {summary['skipped']}")
393:         print(f"Errors: {summary['errors']}")
394: 
395:         if summary['dry_run']:
396:             print("\n⚠️  This was a DRY RUN - no files were renamed")
397: 
398:         # Show breakdown by reason
399:         if summary['no_metadata'] > 0:
400:             print(f"\nℹ️  {summary['no_metadata']} files have no EXIF metadata to generate names from")
401: 
402: 
403: def main():
404:     """Main entry point."""
405:     parser = argparse.ArgumentParser(
406:         description='Rename images with generic filenames using metadata'
407:     )
408:     parser.add_argument(
409:         '--dry-run',
410:         action='store_true',
411:         help='Simulate renaming without actually renaming files'
412:     )
413:     parser.add_argument(
414:         '--source',
415:         default='~/Documents',
416:         help='Source directory to scan (default: ~/Documents)'
417:     )
418:     parser.add_argument(
419:         '--recursive',
420:         action='store_true',
421:         help='Recursively scan subdirectories'
422:     )
423: 
424:     args = parser.parse_args()
425: 
426:     # Create renamer
427:     renamer = ImageRenamer()
428: 
429:     # Rename files
430:     summary = renamer.rename_directory(
431:         source_dir=args.source,
432:         dry_run=args.dry_run,
433:         recursive=args.recursive
434:     )
435: 
436:     # Print summary
437:     renamer.print_summary(summary)
438: 
439: 
440: if __name__ == '__main__':
441:     main()
