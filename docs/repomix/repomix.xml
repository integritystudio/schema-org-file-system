 744:     def find_related_files(
 745:         self,
 746:         file_id: str,
 747:         relationship_type: RelationshipType = None,
 748:         depth: int = 1,
 749:         session: Session = None
 750:     ) -> List[Tuple[File, RelationshipType, float]]:
 751:         """
 752:         Find files related to a given file (graph traversal).
 753: 
 754:         Args:
 755:             file_id: Starting file ID
 756:             relationship_type: Filter by relationship type
 757:             depth: How many hops to traverse (1 = direct relationships only)
 758:             session: Optional existing session
 759: 
 760:         Returns:
 761:             List of (file, relationship_type, confidence) tuples
 762:         """
 763:         close_session = session is None
 764:         session = session or self.get_session()
 765: 
 766:         try:
 767:             results = []
 768:             visited = {file_id}
 769: 
 770:             # BFS traversal
 771:             current_level = [file_id]
 772: 
 773:             for _ in range(depth):
 774:                 next_level = []
 775: 
 776:                 for current_id in current_level:
 777:                     # Get outgoing relationships
 778:                     query = session.query(FileRelationship).filter(
 779:                         FileRelationship.source_file_id == current_id
 780:                     )
 781:                     if relationship_type:
 782:                         query = query.filter(FileRelationship.relationship_type == relationship_type)
 783: 
 784:                     for rel in query.all():
 785:                         if rel.target_file_id not in visited:
 786:                             visited.add(rel.target_file_id)
 787:                             next_level.append(rel.target_file_id)
 788:                             file = session.query(File).filter(File.id == rel.target_file_id).first()
 789:                             if file:
 790:                                 results.append((file, rel.relationship_type, rel.confidence))
 791: 
 792:                     # Get incoming relationships
 793:                     query = session.query(FileRelationship).filter(
 794:                         FileRelationship.target_file_id == current_id
 795:                     )
 796:                     if relationship_type:
 797:                         query = query.filter(FileRelationship.relationship_type == relationship_type)
 798: 
 799:                     for rel in query.all():
 800:                         if rel.source_file_id not in visited:
 801:                             visited.add(rel.source_file_id)
 802:                             next_level.append(rel.source_file_id)
 803:                             file = session.query(File).filter(File.id == rel.source_file_id).first()
 804:                             if file:
 805:                                 results.append((file, rel.relationship_type, rel.confidence))
 806: 
 807:                 current_level = next_level
 808: 
 809:             return results
 810: 
 811:         finally:
 812:             if close_session:
 813:                 session.close()
 814: 
 815:     def find_duplicates(self, content_hash: str = None, session: Session = None) -> List[List[File]]:
 816:         """
 817:         Find groups of duplicate files by content hash.
 818: 
 819:         Args:
 820:             content_hash: Specific hash to look for (or all if None)
 821:             session: Optional existing session
 822: 
 823:         Returns:
 824:             List of file groups (files with same content)
 825:         """
 826:         close_session = session is None
 827:         session = session or self.get_session()
 828: 
 829:         try:
 830:             if content_hash:
 831:                 files = session.query(File).filter(File.content_hash == content_hash).all()
 832:                 return [files] if len(files) > 1 else []
 833: 
 834:             # Find all hashes with more than one file
 835:             duplicates = session.query(File.content_hash, func.count(File.id).label('count'))\
 836:                 .filter(File.content_hash.isnot(None))\
 837:                 .group_by(File.content_hash)\
 838:                 .having(func.count(File.id) > 1)\
 839:                 .all()
 840: 
 841:             result = []
 842:             for hash_val, _ in duplicates:
 843:                 files = session.query(File).filter(File.content_hash == hash_val).all()
 844:                 result.append(files)
 845: 
 846:             return result
 847: 
 848:         finally:
 849:             if close_session:
 850:                 session.close()
