445:         '--dry-run', '-n',
446:         action='store_true',
447:         default=True,
448:         help='Dry run - show what would be done without making changes (default)'
449:     )
450:     parser.add_argument(
451:         '--execute', '-x',
452:         action='store_true',
453:         help='Actually execute the rename/move operations'
454:     )
455:     parser.add_argument(
456:         '--min-confidence', '-c',
457:         type=float,
458:         default=0.1,
459:         help='Minimum confidence threshold (default: 0.1)'
460:     )
461:     parser.add_argument(
462:         '--sentry-dsn',
463:         help='Sentry DSN for error tracking'
464:     )
465: 
466:     args = parser.parse_args()
467: 
468:     # Initialize Sentry if available
469:     sentry_dsn = args.sentry_dsn or os.environ.get('FILE_SYSTEM_SENTRY_DSN')
470:     if sentry_dsn and ERROR_TRACKING_AVAILABLE:
