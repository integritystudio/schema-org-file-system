132:             'new_categories': [],
133:             'category_changes': []
134:         }
135: 
136:     return {
137:         'is_first': False,
138:         'files_delta': current['total_files'] - previous['total_files'],
139:         'organized_delta': current['organized_count'] - previous['organized_count'],
140:         'success_rate_delta': round(current['success_rate'] - previous['success_rate'], 1),
141:         'cost_delta': round(current['total_cost'] - previous['total_cost'], 4),
142:         'time_delta': round(
143:             (current['total_processing_time_sec'] or 0) -
144:             (previous['total_processing_time_sec'] or 0), 2
145:         )
146:     }
147: 
148: 
149: def get_cumulative_stats() -> dict[str, Any]:
150:     """Get cumulative statistics across all sessions."""
151:     with db_connection() as conn:
152:         cursor = conn.cursor()
153: 
154:         cursor.execute("""
155:             SELECT
156:                 COUNT(DISTINCT session_id) as total_sessions,
157:                 COUNT(*) as total_files,
158:                 SUM(CASE WHEN status = 'organized' THEN 1 ELSE 0 END) as total_organized,
159:                 AVG(processing_time_sec) as avg_processing_time
160:             FROM files
161:             WHERE session_id IS NOT NULL
162:         """)
163: 
164:         row = cursor.fetchone()
165:         stats = dict(row) if row else {
166:             'total_sessions': 0, 'total_files': 0,
167:             'total_organized': 0, 'avg_processing_time': None,
168:         }
169: 
170:         # Get category totals
171:         cursor.execute("""
172:             SELECT
173:                 c.name,
174:                 COUNT(fc.file_id) as count
175:             FROM categories c
176:             LEFT JOIN file_categories fc ON c.id = fc.category_id
177:             GROUP BY c.id
178:             ORDER BY count DESC
179:             LIMIT 5
180:         """)
181: 
182:         stats['top_categories'] = [dict(row) for row in cursor.fetchall()]
183: 
184:     return stats
185: 
186: 
187: def generate_timeline_data() -> dict[str, Any]:
188:     """Generate complete timeline data structure."""
189:     sessions = get_sessions()
190: 
191:     # Enrich each session with detailed data
192:     enriched_sessions = []
193:     previous_session = None
194: 
195:     for session in sessions:
196:         session['categories'] = get_session_categories(session['id'])
197:         session['schema_types'] = get_session_schema_types(session['id'])
198:         session['extensions'] = get_session_extensions(session['id'])
199:         session['changes'] = calculate_session_changes(session, previous_session)
200: 
201:         enriched_sessions.append(session)
202:         previous_session = session
203: 
204:     return {
205:         'generated_at': datetime.now().isoformat(),
206:         'cumulative': get_cumulative_stats(),
207:         'sessions': enriched_sessions,
208:         'session_count': len(enriched_sessions)
209:     }
210: 
211: 
212: def main():
213:     """Generate and save timeline data."""
214:     print(f"Generating timeline data from {DB_PATH}...")
215: 
216:     data = generate_timeline_data()
217: 
218:     OUTPUT_PATH.parent.mkdir(parents=True, exist_ok=True)
219:     with open(OUTPUT_PATH, 'w') as f:
220:         json.dump(data, f, indent=2, default=str)
221: 
222:     print(f"Timeline data saved to {OUTPUT_PATH}")
223:     print(f"  - {data['session_count']} sessions")
224:     print(f"  - {data['cumulative']['total_files']} total files")
225: 
226: 
227: if __name__ == "__main__":
228:     main()
</file>

