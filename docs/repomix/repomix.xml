 70: def get_session_categories(session_id: str) -> list[dict[str, Any]]:
 71:     """Get category breakdown for a specific session."""
 72:     with db_connection() as conn:
 73:         cursor = conn.cursor()
 74:         cursor.execute("""
 75:             SELECT
 76:                 c.name,
 77:                 c.color,
