542: def run_migration(db_path: str = 'results/file_organization.db', dry_run: bool = False) -> Dict[str, Any]:
543:     """
544:     Run ID generation migration to add canonical_id to all entities.
545: 
546:     This function:
547:     1. Adds canonical_id columns if they don't exist
548:     2. Backfills canonical_id for existing records using deterministic UUID v5
549:     3. Creates the merge_events table if needed
550: 
551:     Args:
552:         db_path: Path to SQLite database
553:         dry_run: If True, show what would be done without making changes
554: 
555:     Returns:
556:         Migration statistics
557:     """
558:     import sqlite3
559:     import uuid
560:     from pathlib import Path
561: 
562:     # Namespace UUIDs for deterministic ID generation (must match models.py)
563:     NAMESPACES = {
564:         'file': uuid.UUID('f4e8a9c0-1234-5678-9abc-def012345678'),
565:         'category': uuid.UUID('c4e8a9c0-2345-6789-abcd-ef0123456789'),
566:         'company': uuid.UUID('c0e1a2b3-4567-89ab-cdef-012345678901'),
567:         'person': uuid.UUID('d1e2a3b4-5678-9abc-def0-123456789012'),
568:         'location': uuid.UUID('e2e3a4b5-6789-abcd-ef01-234567890123'),
569:     }
570: 
571:     def generate_canonical_id(namespace: str, name: str) -> str:
572:         """Generate deterministic UUID v5 from name."""
573:         ns_uuid = NAMESPACES.get(namespace)
574:         if not ns_uuid:
575:             raise ValueError(f"Unknown namespace: {namespace}")
576:         return str(uuid.uuid5(ns_uuid, name.lower().strip()))
