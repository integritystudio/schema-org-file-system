3566:                         file_id=file_id,
3567:                         person_name=person_name,
3568:                         role='mentioned',
3569:                         session=session
3570:                     )
3571: 
3572:             # Add location if available from image metadata
3573:             if image_metadata and image_metadata.get('location'):
3574:                 location_info = image_metadata['location']
3575:                 self.graph_store.add_file_to_location(
3576:                     file_id=file_id,
