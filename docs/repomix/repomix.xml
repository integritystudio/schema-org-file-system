275:     def record_usage(
276:         self,
277:         feature_name: str,
278:         processing_time_sec: float,
279:         files_processed: int = 1,
280:         success: bool = True,
281:         error_message: Optional[str] = None,
282:         input_file_size_bytes: int = 0,
283:         metadata: Optional[Dict[str, Any]] = None
284:     ) -> UsageRecord:
285:         """
286:         Record a usage event for a feature/model.
287: 
288:         Args:
289:             feature_name: Name of the feature (must match cost_configs key)
290:             processing_time_sec: Time taken for processing
291:             files_processed: Number of files processed
292:             success: Whether the processing succeeded
293:             error_message: Error message if failed
294:             input_file_size_bytes: Size of input file
295:             metadata: Additional metadata
296: 
297:         Returns:
298:             The created UsageRecord
299:         """
300:         record = UsageRecord(
301:             feature_name=feature_name,
302:             timestamp=datetime.now(),
303:             processing_time_sec=processing_time_sec,
304:             files_processed=files_processed,
305:             success=success,
306:             error_message=error_message,
307:             input_file_size_bytes=input_file_size_bytes,
308:             metadata=metadata or {}
309:         )
310:         self.usage_records.append(record)
311:         return record
312: 
313:     def calculate_feature_cost(self, feature_name: str) -> CostSummary:
314:         """
315:         Calculate total cost for a specific feature.
316: 
317:         Args:
318:             feature_name: Name of the feature
319: 
320:         Returns:
321:             CostSummary for the feature
322:         """
323:         config = self.cost_configs.get(feature_name)
324:         if not config:
325:             raise ValueError(f"Unknown feature: {feature_name}")
326: 
327:         # Filter records for this feature
328:         records = [r for r in self.usage_records if r.feature_name == feature_name]
329: 
330:         if not records:
331:             return CostSummary(
332:                 feature_name=feature_name,
333:                 total_invocations=0,
334:                 total_processing_time_sec=0.0,
335:                 total_cost=0.0,
336:                 avg_cost_per_file=0.0,
337:                 success_rate=0.0,
338:                 total_files_processed=0
339:             )
340: 
341:         total_invocations = len(records)
342:         total_processing_time = sum(r.processing_time_sec for r in records)
343:         total_files = sum(r.files_processed for r in records)
344:         successful = sum(1 for r in records if r.success)
345: 
346:         # Calculate cost based on cost type
347:         if config.cost_type == CostType.COMPUTE:
348:             # Cost based on invocations
349:             total_cost = total_invocations * config.cost_per_unit
350:         elif config.cost_type == CostType.API_CALL:
351:             total_cost = total_invocations * config.cost_per_unit
352:         else:
353:             total_cost = total_invocations * config.cost_per_unit
354: 
355:         avg_cost_per_file = total_cost / total_files if total_files > 0 else 0.0
356:         success_rate = successful / total_invocations if total_invocations > 0 else 0.0
357: 
358:         return CostSummary(
359:             feature_name=feature_name,
360:             total_invocations=total_invocations,
361:             total_processing_time_sec=total_processing_time,
362:             total_cost=total_cost,
363:             avg_cost_per_file=avg_cost_per_file,
364:             success_rate=success_rate,
365:             total_files_processed=total_files
366:         )
367: 
368:     def calculate_roi(self, feature_name: str) -> ROIMetrics:
369:         """
370:         Calculate ROI for a specific feature.
371: 
372:         ROI = (Value Generated - Cost) / Cost * 100
373: 
374:         Value is calculated as:
375:         - Manual time saved * hourly rate * success rate
376: 
377:         Args:
378:             feature_name: Name of the feature
379: 
380:         Returns:
381:             ROIMetrics for the feature
382:         """
383:         config = self.cost_configs.get(feature_name)
384:         if not config:
385:             raise ValueError(f"Unknown feature: {feature_name}")
386: 
387:         cost_summary = self.calculate_feature_cost(feature_name)
388: 
389:         if cost_summary.total_files_processed == 0:
390:             return ROIMetrics(
391:                 feature_name=feature_name,
392:                 total_cost=0.0,
393:                 total_value=0.0,
394:                 roi_percentage=0.0,
395:                 manual_hours_saved=0.0,
396:                 cost_per_file=0.0,
397:                 value_per_file=0.0,
398:                 break_even_files=0
399:             )
400: 
401:         # Calculate value generated
402:         # Value = (manual time saved * files classified correctly) * hourly rate
403:         files_classified = cost_summary.total_files_processed * config.files_correctly_classified
404:         total_time_saved_sec = files_classified * config.manual_time_saved_sec
405:         total_time_saved_hours = total_time_saved_sec / 3600
406:         total_value = total_time_saved_hours * self.MANUAL_HOURLY_RATE
407: 
408:         # Calculate ROI
409:         if cost_summary.total_cost > 0:
410:             roi_percentage = ((total_value - cost_summary.total_cost) / cost_summary.total_cost) * 100
411:         else:
412:             roi_percentage = float('inf') if total_value > 0 else 0.0
413: 
414:         # Calculate break-even point
415:         cost_per_file = cost_summary.avg_cost_per_file
416:         value_per_file = (config.manual_time_saved_sec / 3600) * self.MANUAL_HOURLY_RATE * config.files_correctly_classified
417: 
418:         if cost_per_file > 0 and value_per_file > cost_per_file:
419:             break_even_files = 1  # Already profitable per file
420:         elif cost_per_file > 0:
421:             # Need multiple files to break even
422:             break_even_files = int(cost_summary.total_cost / value_per_file) + 1 if value_per_file > 0 else float('inf')
423:         else:
424:             break_even_files = 0  # No cost
425: 
426:         return ROIMetrics(
427:             feature_name=feature_name,
428:             total_cost=cost_summary.total_cost,
429:             total_value=total_value,
430:             roi_percentage=roi_percentage,
431:             manual_hours_saved=total_time_saved_hours,
432:             cost_per_file=cost_per_file,
433:             value_per_file=value_per_file,
434:             break_even_files=break_even_files
435:         )
