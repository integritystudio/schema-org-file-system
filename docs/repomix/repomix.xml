391:             if not f['category'] or f['category'] == 'uncategorized':
392:                 issues['missing_category'].append(f['filename'])
393: 
394:             # Check for empty filenames
395:             if not f['filename']:
396:                 issues['empty_filename'].append(f['filepath'])
397: 
398:             # Check for suspicious extensions
399:             if f['extension'] and f['extension'] not in self.feature_extractor.extension_map:
400:                 issues['suspicious_extensions'].append((f['filename'], f['extension']))
401: 
402:         # Find duplicates
403:         issues['duplicate_filenames'] = [
404:             name for name, count in filename_counts.items() if count > 1
405:         ]
406: 
407:         # Summarize
408:         quality_report = {
409:             'total_records': len(self.features),
410:             'uncategorized_count': len(issues['missing_category']),
411:             'empty_filename_count': len(issues['empty_filename']),
412:             'duplicate_count': len(issues['duplicate_filenames']),
413:             'unknown_extension_count': len(issues['suspicious_extensions']),
414:             'quality_score': self._compute_quality_score(issues),
415:             'issues_sample': {
416:                 'uncategorized': issues['missing_category'][:10],
417:                 'duplicates': issues['duplicate_filenames'][:10],
418:                 'unknown_extensions': list(set(ext for _, ext in issues['suspicious_extensions']))[:10],
419:             }
420:         }
421: 
422:         self.statistics['data_quality'] = quality_report
423:         return quality_report
