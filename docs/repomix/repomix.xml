 50: def table_exists(conn: sqlite3.Connection, table: str) -> bool:
 51:     """Check if a table exists."""
 52:     cursor = conn.execute(
 53:         "SELECT name FROM sqlite_master WHERE type='table' AND name=?",
 54:         (table,)
 55:     )
 56:     return cursor.fetchone() is not None
