3498:     def _persist_to_graph_store(
3499:         self,
3500:         file_path: Path,
3501:         dest_path: Path,
3502:         category: str,
3503:         subcategory: str,
3504:         schema: Dict,
3505:         extracted_text: str,
3506:         company_name: Optional[str],
3507:         people_names: List[str],
3508:         image_metadata: Optional[Dict]
3509:     ) -> None:
3510:         """
3511:         Persist file and its relationships to the graph store with canonical IDs.
3512: 
3513:         This method creates:
3514:         - File record with canonical_id (urn:sha256:{hash})
3515:         - Category record with canonical_id (UUID v5 from name)
3516:         - Company record with canonical_id (UUID v5 from name)
3517:         - Person records with canonical_id (UUID v5 from name)
3518:         - Location record with canonical_id (UUID v5 from name)
3519:         - Relationships between file and entities
3520:         """
3521:         try:
3522:             session = self.graph_store.get_session()
3523: 
3524:             # Get file stats
3525:             stat = file_path.stat() if file_path.exists() else dest_path.stat()
3526: 
3527:             # Add file to store (generates canonical_id automatically)
3528:             file_record = self.graph_store.add_file(
3529:                 original_path=str(file_path),
3530:                 filename=file_path.name,
3531:                 session=session,
3532:                 current_path=str(dest_path),
3533:                 file_size=stat.st_size,
3534:                 mime_type=schema.get('encodingFormat'),
3535:                 schema_type=schema.get('@type'),
3536:                 schema_data=schema,
3537:                 extracted_text=extracted_text[:10000] if extracted_text else None,
3538:                 extracted_text_length=len(extracted_text) if extracted_text else 0,
3539:                 status=FileStatus.ORGANIZED,
3540:                 organized_at=datetime.now()
3541:             )
3542: 
3543:             file_id = file_record.id
3544: 
3545:             # Add category relationship
3546:             self.graph_store.add_file_to_category(
3547:                 file_id=file_id,
3548:                 category_name=category,
3549:                 subcategory_name=subcategory,
3550:                 session=session
3551:             )
3552: 
3553:             # Add company relationship if detected
3554:             if company_name:
3555:                 self.graph_store.add_file_to_company(
3556:                     file_id=file_id,
3557:                     company_name=company_name,
3558:                     context='content_analysis',
3559:                     session=session
3560:                 )
3561: 
3562:             # Add people relationships if detected
3563:             if people_names:
