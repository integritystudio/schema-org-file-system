186:     def extract_text_ocr(self, image_path: Path) -> str:
187:         """Extract text from image using OCR."""
188:         return extract_ocr_text(image_path, config='--psm 10 --oem 3') or ""
189: 
190:     def classify_image(self, image_path: Path) -> Tuple[str, float, Dict[str, float]]:
191:         """
192:         Classify image content using CLIP.
193: 
194:         Returns:
195:             Tuple of (best_category, confidence, all_scores)
196:         """
197:         if not self.vision_available or self.classifier is None:
198:             return ("unknown", 0.0, {})
199: 
200:         try:
201:             raw_results = self.classifier.classify_raw(image_path, self.game_categories)
202: 
203:             scores = {prompt: conf for prompt, conf in raw_results}
204:             best_category = raw_results[0][0]
205:             confidence = raw_results[0][1]
206: 
207:             return (best_category, confidence, scores)
208: 
209:         except Exception as e:
210:             print(f"  Classification error for {image_path.name}: {e}")
211:             return ("unknown", 0.0, {})
212: 
213:     def detect_number(self, image_path: Path) -> Optional[str]:
214:         """Try to detect if image contains a number."""
215:         # First try OCR
216:         text = self.extract_text_ocr(image_path)
217: 
218:         # Check if it's a number
219:         if text and text.isdigit():
220:             return text
221: 
222:         # Check filename for number hints
223:         filename = image_path.stem
224:         # Extract leading number from filename like "30_20251120..."
225:         match = re.match(r'^(\d+)_', filename)
226:         if match:
227:             num = match.group(1)
228:             # This might be the actual content if it's a number icon
229:             return num
230: 
231:         return None
232: 
233:     def get_image_hash(self, image_path: Path) -> str:
234:         """Get a short hash of image content for uniqueness."""
235:         try:
236:             with open(image_path, 'rb') as f:
237:                 return hashlib.sha256(f.read()).hexdigest()[:8]
238:         except Exception:
239:             return datetime.now().strftime("%H%M%S")
240: 
241:     def analyze_image(self, image_path: Path) -> Dict:
242:         """
243:         Fully analyze an image and return rename/category info.
244: 
245:         Returns:
246:             Dict with: category, folder, new_name, confidence, detected_text
247:         """
248:         result = {
249:             'original_path': str(image_path),
250:             'original_name': image_path.name,
251:             'category': 'unknown',
252:             'folder': 'Uncategorized',
253:             'new_name': None,
254:             'confidence': 0.0,
255:             'detected_text': None,
256:             'top_scores': {}
257:         }
258: 
259:         # Classify with CLIP
260:         best_category, confidence, scores = self.classify_image(image_path)
261: 
262:         result['category'] = best_category
263:         result['confidence'] = confidence
264:         result['top_scores'] = dict(sorted(scores.items(), key=lambda x: x[1], reverse=True)[:5])
265: 
266:         # Get folder mapping
267:         result['folder'] = self.category_mapping.get(best_category, 'Uncategorized')
268: 
269:         # Try to detect numbers
270:         detected_num = self.detect_number(image_path)
271:         if detected_num:
272:             result['detected_text'] = detected_num
273: 
274:         # Generate new name
275:         prefix = self.name_prefixes.get(best_category, 'asset')
276:         img_hash = self.get_image_hash(image_path)
277:         ext = image_path.suffix.lower()
278: 
279:         if detected_num and best_category == "a number or digit icon":
280:             # For number icons, use the number in name
281:             result['new_name'] = f"num_{detected_num}_{img_hash}{ext}"
282:         else:
283:             result['new_name'] = f"{prefix}_{img_hash}{ext}"
284: 
285:         return result
286: 
