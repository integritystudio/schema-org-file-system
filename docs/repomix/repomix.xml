  1: #!/usr/bin/env python3
  2: """
  3: Model Evaluation Script
  4: 
  5: Runs the existing file categorization model on the test dataset
  6: and generates evaluation metrics and results.
  7: """
  8: 
  9: import os
 10: import json
 11: import re
 12: from datetime import datetime
 13: from pathlib import Path
 14: from typing import Dict, List, Tuple, Any
 15: from collections import Counter, defaultdict
 16: 
 17: from shared.constants import (
 18:     GAME_AUDIO_KEYWORDS, GAME_MUSIC_KEYWORDS, GAME_SPRITE_KEYWORDS,
 19:     SCREENSHOT_PATTERNS, DOCUMENT_PATTERNS,
 20: )
 21: 
 22: 
 23: class FileCategorizationModel:
 24:     """Simulates the categorization logic from file_organizer_content_based.py"""
 25: 
 26:     def __init__(self):
 27:         self.all_game_keywords = set(
 28:             GAME_AUDIO_KEYWORDS +
 29:             GAME_MUSIC_KEYWORDS +
 30:             GAME_SPRITE_KEYWORDS
 31:         )
 32: 
 33:     def predict_category(self, feature: Dict) -> Tuple[str, str, float]:
 34:         """
 35:         Predict category based on features.
 36: 
 37:         Returns:
 38:             Tuple of (predicted_category, predicted_subcategory, confidence)
 39:         """
 40:         filename = feature.get('filename', '').lower()
 41:         filename_tokens = feature.get('filename_tokens', [])
 42:         extension = feature.get('extension', '').lower()
 43:         extension_category = feature.get('extension_category', '')
 44: 
 45:         # Check for screenshots first
 46:         if self._matches_patterns(filename, SCREENSHOT_PATTERNS):
 47:             if extension in ['.png', '.jpg', '.jpeg']:
 48:                 return ('media', 'photos_screenshots', 0.95)
 49: 
 50:         # Check for game assets
 51:         game_score = self._calculate_game_asset_score(filename_tokens, extension)
 52:         if game_score > 0.5:
 53:             subcategory = self._determine_game_subcategory(filename_tokens, extension)
 54:             return ('game_assets', subcategory, game_score)
 55: 
 56:         # Check for documents
 57:         if self._matches_patterns(filename, DOCUMENT_PATTERNS):
 58:             return ('legal', 'other', 0.7)
 59: 
 60:         # Media files
 61:         if extension_category == 'image':
 62:             return ('media', 'photos_other', 0.6)
 63:         elif extension_category == 'video':
 64:             return ('media', 'videos_recordings', 0.6)
 65:         elif extension_category == 'audio':
 66:             # Could be game audio or regular audio
 67:             if game_score > 0.3:
 68:                 return ('game_assets', 'audio', 0.7)
 69:             return ('media', 'audio', 0.5)
 70: 
 71:         # Technical files
 72:         if extension in ['.js', '.ts', '.py', '.json', '.xml', '.yaml', '.yml']:
 73:             return ('technical', 'code', 0.7)
 74: 
 75:         # Default to uncategorized
 76:         return ('uncategorized', 'other', 0.3)
 77: 
 78:     def _matches_patterns(self, text: str, patterns: List[str]) -> bool:
 79:         """Check if text matches any patterns."""
 80:         return any(re.search(p, text, re.IGNORECASE) for p in patterns)
 81: 
 82:     def _calculate_game_asset_score(self, tokens: List[str], extension: str) -> float:
 83:         """Calculate likelihood of being a game asset."""
 84:         if not tokens:
 85:             return 0.0
 86: 
 87:         # Count matching keywords
 88:         matches = sum(1 for t in tokens if t.lower() in self.all_game_keywords)
 89: 
 90:         # Base score from keyword matches
 91:         score = min(matches / max(len(tokens), 1) * 1.5, 1.0)
 92: 
 93:         # Boost for game-typical extensions
 94:         if extension in ['.png', '.wav', '.ogg', '.mp3']:
 95:             score = min(score + 0.1, 1.0)
 96: 
 97:         # Boost for numeric suffixes (common in game assets)
 98:         if tokens and tokens[-1].isdigit():
 99:             score = min(score + 0.1, 1.0)
100: 
101:         return score
102: 
103:     def _determine_game_subcategory(self, tokens: List[str], extension: str) -> str:
104:         """Determine the game asset subcategory."""
105:         tokens_lower = [t.lower() for t in tokens]
106: 
107:         # Audio files
108:         if extension in ['.wav', '.ogg', '.mp3']:
109:             # Check for music keywords
110:             music_matches = sum(1 for t in tokens_lower if t in GAME_MUSIC_KEYWORDS)
111:             audio_matches = sum(1 for t in tokens_lower if t in GAME_AUDIO_KEYWORDS)
112: 
113:             if music_matches > audio_matches:
114:                 return 'music'
115:             return 'audio'
116: 
117:         # Image files - sprites or textures
118:         if extension in ['.png', '.jpg', '.jpeg', '.gif', '.svg']:
119:             # Check for texture-related keywords
120:             texture_keywords = ['texture', 'wall', 'floor', 'tile', 'seamless', 'pattern']
121:             texture_matches = sum(1 for t in tokens_lower if t in texture_keywords)
122: 
123:             if texture_matches > 0:
124:                 return 'textures'
125:             return 'sprites'
126: 
127:         return 'other'
128: 
