  1: #!/usr/bin/env python3
  2: """
  3: Update Organization Report with Labeled Category Data
  4: 
  5: This script updates the content_organization_report with category assignments
  6: from the labeling sessions stored in the database.
  7: """
  8: 
  9: import json
 10: import hashlib
 11: from datetime import datetime
 12: from pathlib import Path
 13: from typing import Dict, List, Tuple
 14: 
 15: from shared.db_utils import db_connection
 16: 
 17: 
 18: def compute_file_id(filepath: str) -> str:
 19:     """Compute the file ID (SHA-256 hash of the path)."""
 20:     return hashlib.sha256(filepath.encode()).hexdigest()
 21: 
 22: 
 23: def get_labeled_categories(db_path: str, ml_session: str) -> Tuple[Dict, Dict]:
 24:     """
 25:     Get file-to-category mappings from labeling sessions.
 26:     These are manual corrections that should override ML predictions.
 27: 
 28:     The labeling sessions processed files BEFORE organization, so paths differ.
 29:     We match by FILENAME since files were moved during organization.
 30: 
 31:     Args:
 32:         db_path: Path to SQLite database
 33:         ml_session: The main ML session ID to exclude
 34: 
 35:     Returns:
 36:         Tuple of (path_dict, filename_dict) mapping to category info
 37:     """
 38:     labeled_by_path = {}
 39:     labeled_by_filename = {}
 40:     with db_connection(db_path, row_factory=False) as conn:
 41:         cursor = conn.cursor()
 42: 
 43:         # Get ONLY labeling session data (manual corrections)
 44:         # These are the ground truth labels from human review
 45:         query_labeling = """
 46:         SELECT f.original_path, f.filename, c.name, c.full_path
 47:         FROM files f
 48:         JOIN file_categories fc ON f.id = fc.file_id
 49:         JOIN categories c ON fc.category_id = c.id
 50:         WHERE f.session_id <> ?
 51:         """
 52: 
 53:         cursor.execute(query_labeling, (ml_session,))
 54: 
 55:         for row in cursor.fetchall():
 56:             original_path, filename, category_name, full_path = row
 57:             parts = full_path.split('/') if full_path else []
 58:             parent_category = parts[0] if parts else category_name
 59: 
 60:             labeled_by_path[original_path] = (category_name, full_path, parent_category)
 61:             # Index by filename for matching moved files
 62:             labeled_by_filename[filename] = (category_name, full_path, parent_category)
 63: 
 64:     print(f"  - Labeling session records: {len(labeled_by_path)}")
 65:     print(f"  - Unique filenames: {len(labeled_by_filename)}")
 66: 
 67:     return labeled_by_path, labeled_by_filename
 68: 
 69: 
 70: def update_report(report_path: str, labeled_data: Tuple[Dict, Dict], output_path: str) -> Dict:
 71:     """
 72:     Update the organization report with labeled category data.
 73: 
 74:     Args:
 75:         report_path: Path to original report JSON
 76:         labeled_data: Tuple of (path_dict, filename_dict) mapping to category info
 77:         output_path: Path to save updated report
 78: 
 79:     Returns:
 80:         Statistics about the update
 81:     """
 82:     labeled_by_path, labeled_by_filename = labeled_data
 83: 
 84:     print(f"Loading report from: {report_path}")
 85:     with open(report_path, 'r') as f:
 86:         report = json.load(f)
 87: 
 88:     results = report.get('results', [])
 89: 
 90:     stats = {
 91:         'total_files': len(results),
 92:         'updated': 0,
 93:         'unchanged': 0,
 94:         'matched_by_path': 0,
 95:         'matched_by_filename': 0,
 96:         'not_found': 0,
 97:         'category_changes': {},
 98:         'updated_files': []
 99:     }
100: 
101:     for result in results:
