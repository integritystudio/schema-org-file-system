103:     def enrich_from_file_stats(self, file_path: str) -> Dict[str, Any]:
104:         """
105:         Extract metadata from file system stats.
106: 
107:         Args:
108:             file_path: Path to file
109: 
110:         Returns:
111:             Metadata dictionary with proper @id for JSON-LD
112: 
113:         Note:
114:             The @id is generated as a content-addressed URN using SHA-256 hash
115:             of the absolute file path. This ensures:
116:             - Same file always gets the same @id (deterministic)
117:             - Valid IRI for JSON-LD compliance
118:             - Deduplication across systems
119:         """
120:         path = Path(file_path)
121:         if not path.exists():
122:             return {}
123: 
124:         stats = path.stat()
125: 
126:         # Generate deterministic @id from absolute path hash
127:         abs_path = str(path.absolute())
128:         file_hash = hashlib.sha256(abs_path.encode()).hexdigest()
129: 
130:         return {
131:             '@id': f'urn:sha256:{file_hash}',
132:             'name': path.name,
133:             'url': f'file://{path.absolute()}',
134:             'encodingFormat': self.get_encoding_format(file_path),
135:             'contentSize': stats.st_size,
136:             'dateCreated': datetime.fromtimestamp(stats.st_ctime),
137:             'dateModified': datetime.fromtimestamp(stats.st_mtime),
138:         }
