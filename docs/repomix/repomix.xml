373: ## Integration Patterns
374: 
375: ### Repository Pattern
376: 
377: Manage schemas with a repository:
378: 
379: ```python
380: class SchemaRepository:
381:     """Repository pattern for schema management."""
382: 
383:     def __init__(self, storage_backend):
384:         self.storage = storage_backend
385:         self.validator = SchemaValidator()
386: 
387:     def save(self, schema_id: str, schema: Dict) -> bool:
388:         """Save schema after validation."""
389:         report = self.validator.validate(schema)
390:         if not report.is_valid():
391:             raise ValueError("Invalid schema")
392: 
393:         return self.storage.save(schema_id, schema)
394: 
395:     def get(self, schema_id: str) -> Optional[Dict]:
396:         """Retrieve schema."""
397:         return self.storage.get(schema_id)
398: 
399:     def find_by_type(self, schema_type: str) -> List[Dict]:
400:         """Find all schemas of given type."""
401:         return self.storage.find_by_type(schema_type)
402: 
403:     def update(self, schema_id: str, updates: Dict) -> bool:
404:         """Update existing schema."""
405:         schema = self.get(schema_id)
406:         if not schema:
407:             return False
408: 
409:         schema.update(updates)
410: 
411:         # Re-validate
412:         report = self.validator.validate(schema)
413:         if not report.is_valid():
414:             raise ValueError("Updated schema is invalid")
415: 
416:         return self.storage.save(schema_id, schema)
417: ```
418: 
419: ### Event-Driven Updates
420: 
421: Update schemas when files change:
422: 
423: ```python
424: from watchdog.observers import Observer
425: from watchdog.events import FileSystemEventHandler
426: 
427: class SchemaUpdateHandler(FileSystemEventHandler):
428:     """Update schemas when files change."""
429: 
430:     def __init__(self, schema_repository):
431:         self.repository = schema_repository
432:         self.enricher = MetadataEnricher()
433: 
434:     def on_modified(self, event):
435:         """Handle file modification."""
436:         if not event.is_directory:
437:             self._update_schema(event.src_path)
438: 
439:     def _update_schema(self, file_path: str):
440:         """Regenerate schema for modified file."""
441:         # Extract new metadata
442:         metadata = self.enricher.enrich_from_file_stats(file_path)
443: 
444:         # Get existing schema
445:         schema_id = self._get_schema_id(file_path)
446:         schema = self.repository.get(schema_id)
447: 
448:         if schema:
449:             # Update modification date
450:             schema['dateModified'] = datetime.now().isoformat()
451: 
452:             # Update other metadata
453:             if 'contentSize' in metadata:
454:                 schema['contentSize'] = metadata['contentSize']
455: 
456:             # Save updated schema
457:             self.repository.update(schema_id, schema)
458: ```
