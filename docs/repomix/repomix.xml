222:     @staticmethod
223:     def generate_canonical_id(path: str) -> str:
224:         """
225:         Generate canonical IRI for JSON-LD @id from file path.
226: 
227:         Uses SHA-256 hash of the path in URN format.
228: 
229:         Args:
230:             path: File path (absolute recommended)
231: 
232:         Returns:
233:             URN string (urn:sha256:{hash})
234:         """
235:         file_hash = hashlib.sha256(path.encode()).hexdigest()
236:         return f"urn:sha256:{file_hash}"
