3199: 
3200:             if image_metadata.get('location_name'):
3201:                 print(f"  ✓ Location: {image_metadata['location_name']}")
3202: 
3203:         # PRIORITY 3.5: Check for identification documents in images (passport, ID, license)
3204:         # These should go to Person/ folder, not Media/
3205:         if schema_type == 'ImageObject' and self.ocr_available:
3206:             # Extract text from image via OCR
3207:             ocr_text = self.extract_text_from_image(file_path)
3208:             if ocr_text and len(ocr_text) >= 30:
3209:                 ocr_lower = ocr_text.lower()
3210:                 # Check for identification document keywords
3211:                 id_keywords = ['passport', 'driver license', "driver's license", 'identification',
3212:                               'united states of america', 'department of state', 'nationality',
3213:                               'date of birth', 'place of birth', 'surname', 'given names',
3214:                               'social security', 'state id', 'national id']
3215:                 if any(kw in ocr_lower for kw in id_keywords):
3216:                     print(f"  ✓ Identification document detected via OCR")
3217:                     people_names = []
3218: 
3219:                     # Method 1: Parse passport MRZ (Machine Readable Zone)
3220:                     # Format: P<COUNTRY{SURNAME}<<{GIVEN_NAME}<...
3221:                     mrz_match = re.search(r'P<[A-Z]{3}([A-Z]+)<<([A-Z]+)<', ocr_text)
3222:                     if mrz_match:
3223:                         surname = mrz_match.group(1).title()
3224:                         given = mrz_match.group(2).title()
3225:                         people_names = [f"{given} {surname}"]
3226: 
3227:                     # Method 2: Look for name fields with values on next line or after colon
3228:                     # Passport format: "Surname\nLEDLIE" or "Surname/Nom\nLEDLIE"
3229:                     if not people_names:
3230:                         # Find surname (all caps, standalone on line)
3231:                         surname_match = re.search(r'(?:surname|nom|apellidos)[/\w\s]*\n\s*([A-Z]{2,})\b', ocr_text, re.IGNORECASE)
3232:                         given_match = re.search(r'(?:given\s*names?|pr[ée]noms?|nombres)[/\w\s]*\n\s*([A-Z]{2,})\b', ocr_text, re.IGNORECASE)
3233:                         if surname_match and given_match:
3234:                             people_names = [f"{given_match.group(1).title()} {surname_match.group(1).title()}"]
3235: 
3236:                     # Method 3: General name extraction patterns
3237:                     if not people_names:
3238:                         people_names = self.classifier.extract_people_names(ocr_text)
3239: 
3240:                     if people_names:
3241:                         print(f"  ✓ Person identified: {people_names[0]}")
3242:                     return ('person', 'contacts', schema_type, ocr_text, None, people_names, image_metadata)
3243: 
3244:         # PRIORITY 4: Check for media files (photos, videos, audio)
3245:         # This runs after metadata extraction so we can use GPS/datetime for classification
3246:         media_classification = self.classify_media_file(file_path, image_metadata)
3247:         if media_classification:
3248:             category, media_type, subcategory = media_classification
3249:             # Point B: enhance weak photos/other for images
3250:             if media_type == 'photos' and subcategory == 'other':
3251:                 enhanced = self.enhance_weak_image_classification(file_path, image_metadata)
3252:                 if enhanced:
3253:                     print(f"  ✓ Enhanced media: {enhanced[0]}/{enhanced[1]}")
3254:                     return (enhanced[0], enhanced[1], schema_type, '', None, [], image_metadata)
3255:             print(f"  ✓ Media file detected: {media_type}/{subcategory}")
3256:             return (category, f"{media_type}_{subcategory}", schema_type, '', None, [], image_metadata)
3257: 
3258:         # PRIORITY 5: Check for photos with people (social)
3259:         if schema_type == 'ImageObject' and self.image_analyzer.vision_available:
3260:             print(f"  Analyzing image content...")
3261: 
3262:             # First check if photo has people
3263:             has_people, people_scores = self.image_analyzer.has_people_in_photo(file_path)
3264: 
3265:             if has_people:
3266:                 print(f"  ✓ Detected: Photo with people")
3267:                 if people_scores:
3268:                     top_categories = sorted(people_scores.items(), key=lambda x: x[1], reverse=True)[:3]
3269:                     print(f"  Top matches: {', '.join([f'{cat}: {score:.2%}' for cat, score in top_categories])}")
3270:                 return ('media', 'photos_social', schema_type, '', None, [], image_metadata)
3271: 
3272:             # Then check for home interior without people
3273:             is_property_mgmt, vision_scores = self.image_analyzer.is_home_interior_no_people(file_path)
3274: 
3275:             if is_property_mgmt:
3276:                 print(f"  ✓ Detected: Home interior without people")
3277:                 if vision_scores:
3278:                     top_categories = sorted(vision_scores.items(), key=lambda x: x[1], reverse=True)[:3]
3279:                     print(f"  Top matches: {', '.join([f'{cat}: {score:.2%}' for cat, score in top_categories])}")
3280:                 return ('property_management', 'other', schema_type, '', None, [], image_metadata)
3281: 
3282:         # PRIORITY 6: Regular text extraction and classification
3283:         print(f"  Extracting content...")
3284:         extracted_text = self.extract_text(file_path)
3285: 
3286:         if extracted_text:
3287:             print(f"  Extracted {len(extracted_text)} characters")
3288:             category, subcategory, company_name, people_names = self.classifier.classify_content(extracted_text, file_path.name)
3289:             if company_name:
3290:                 print(f"  Detected company: {company_name}")
3291:             if people_names:
3292:                 print(f"  Detected people: {', '.join(people_names[:3])}{' ...' if len(people_names) > 3 else ''}")
3293:             print(f"  Classified as: {category}/{subcategory}")
3294:         else:
3295:             print(f"  No text extracted, using filename")
3296:             category, subcategory, company_name, people_names = self.classifier.classify_content("", file_path.name)
3297: 
3298:         # Point C: last-resort enhancement for uncategorized images
3299:         if category == 'uncategorized' and schema_type == 'ImageObject':
3300:             enhanced = self.enhance_weak_image_classification(file_path, image_metadata)
3301:             if enhanced:
3302:                 print(f"  ✓ Enhanced uncategorized: {enhanced[0]}/{enhanced[1]}")
