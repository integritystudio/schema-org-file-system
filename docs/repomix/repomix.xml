159: def capture_warning(
160:     message: str,
161:     context: Optional[Dict[str, Any]] = None,
162:     tags: Optional[Dict[str, str]] = None
163: ) -> Optional[str]:
164:     """Capture a warning message to Sentry."""
165:     if not SENTRY_AVAILABLE:
166:         print(f"[WARNING] {message}")
167:         return None
168: 
169:     with sentry_sdk.push_scope() as scope:
170:         scope.level = ErrorLevel.WARNING
171:         if tags:
172:             for key, value in tags.items():
173:                 scope.set_tag(key, value)
174:         if context:
175:             scope.set_context('warning_context', context)
176:         return sentry_sdk.capture_message(message)
177: 
