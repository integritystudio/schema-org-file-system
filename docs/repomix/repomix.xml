543:                     current_value += line.strip()
544:                     continue
545: 
546:                 # Process previous line
547:                 if current_value:
548:                     self._parse_vcard_line(generator, current_value)
549: 
550:                 current_value = line.strip()
551: 
552:             # Process last line
553:             if current_value:
