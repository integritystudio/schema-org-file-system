437:     def calculate_total_cost(self) -> Dict[str, Any]:
438:         """
439:         Calculate total cost across all features.
440: 
441:         Returns:
442:             Dictionary with total cost breakdown
443:         """
444:         total_cost = 0.0
445:         total_files = 0
446:         total_time = 0.0
447:         feature_costs = {}
448: 
449:         for feature_name in self.cost_configs.keys():
450:             summary = self.calculate_feature_cost(feature_name)
451:             if summary.total_invocations > 0:
452:                 feature_costs[feature_name] = asdict(summary)
453:                 total_cost += summary.total_cost
454:                 total_files += summary.total_files_processed
455:                 total_time += summary.total_processing_time_sec
456: 
457:         return {
458:             'total_cost': total_cost,
459:             'total_files_processed': total_files,
460:             'total_processing_time_sec': total_time,
461:             'avg_cost_per_file': total_cost / total_files if total_files > 0 else 0.0,
462:             'feature_breakdown': feature_costs
463:         }
464: 
465:     def calculate_total_roi(self) -> Dict[str, Any]:
466:         """
467:         Calculate total ROI across all features.
468: 
469:         Returns:
470:             Dictionary with total ROI breakdown
471:         """
472:         total_cost = 0.0
473:         total_value = 0.0
474:         total_hours_saved = 0.0
475:         feature_rois = {}
476: 
477:         for feature_name in self.cost_configs.keys():
478:             roi = self.calculate_roi(feature_name)
479:             if roi.total_cost > 0 or roi.total_value > 0:
480:                 feature_rois[feature_name] = asdict(roi)
481:                 total_cost += roi.total_cost
482:                 total_value += roi.total_value
483:                 total_hours_saved += roi.manual_hours_saved
484: 
485:         overall_roi = ((total_value - total_cost) / total_cost * 100) if total_cost > 0 else float('inf')
486: 
487:         return {
488:             'total_cost': total_cost,
489:             'total_value': total_value,
490:             'overall_roi_percentage': overall_roi,
491:             'total_manual_hours_saved': total_hours_saved,
492:             'hourly_rate_used': self.MANUAL_HOURLY_RATE,
493:             'feature_breakdown': feature_rois
494:         }
