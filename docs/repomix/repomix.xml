195:             self.features['geocoding'] = FeatureStatus(
196:                 name="Geocoding (geopy)",
197:                 available=True,
198:                 version=geopy.__version__,
199:                 impact="GPS coordinates to location names"
200:             )
201:         except ImportError:
202:             self.features['geocoding'] = FeatureStatus(
203:                 name="Geocoding (geopy)",
204:                 available=False,
