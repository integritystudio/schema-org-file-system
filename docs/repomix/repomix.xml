 774:         if self.metadata_available:
 775:             try:
 776:                 # Initialize geocoder with a user agent
 777:                 self.geocoder = Nominatim(user_agent="file_organizer_v1.0", timeout=5)
 778:             except Exception as e:
 779:                 print(f"Warning: Could not initialize geocoder: {e}")
 780:                 self.geocoder = None
