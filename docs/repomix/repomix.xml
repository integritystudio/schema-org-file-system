1022:     def detect_people(self, image_path: Path) -> bool:
1023:         """
1024:         Detect if there are people in the image using face detection.
1025: 
1026:         Returns:
1027:             True if people detected, False otherwise
1028:         """
1029:         if not self.vision_available or self.face_cascade is None:
1030:             return False
1031: 
1032:         with CostTracker(self.cost_calculator, 'face_detection') if self.cost_calculator else nullcontext():
1033:             try:
