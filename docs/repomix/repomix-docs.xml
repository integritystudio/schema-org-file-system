140: from src.<module_name> import <ClassName>
141: 
142: 
143: class Test<ClassName>:
144:     """Test <ClassName> class."""
145: 
146:     @pytest.fixture
147:     def instance(self):
148:         """Create test instance with mocked dependencies."""
149:         return <ClassName>()
150: 
151:     def test_basic_functionality(self, instance):
152:         """Test basic functionality works as expected."""
153:         result = instance.method()
154:         assert result is not None
155: 
156:     def test_error_handling(self, instance):
157:         """Test error handling for invalid inputs."""
158:         with pytest.raises(ValueError):
159:             instance.method(invalid_input)
160: 
161:     @patch('src.<module_name>.external_dependency')
162:     def test_with_mocked_dependency(self, mock_dep, instance):
163:         """Test with mocked external dependency."""
164:         mock_dep.return_value = "mocked"
