158: ## Validation Strategy
159: 
160: ### Validate Early and Often
161: 
162: ```python
163: def create_and_validate_schema(generator, data):
164:     """Pattern: Create, validate, handle errors."""
165: 
166:     # Create schema
167:     schema = generator.create_from_data(data)
168: 
169:     # Validate immediately
170:     validator = SchemaValidator()
171:     report = validator.validate(schema.to_dict())
172: 
173:     # Handle validation results
174:     if not report.is_valid():
175:         # Log errors
176:         for error in report.get_messages_by_level(ValidationLevel.ERROR):
177:             logger.error(f"Schema validation error: {error.message}")
178: 
179:         # Decide: fail fast or continue with warnings
180:         raise ValueError("Invalid schema")
181: 
182:     # Check completion
183:     if schema.get_completion_score() < 0.7:
184:         logger.warning("Schema completion score below 70%")
185: 
186:     return schema
187: ```
188: 
189: ### Batch Validation
190: 
191: For processing multiple files:
192: 
193: ```python
194: def validate_file_collection(schemas: List[Dict]) -> Dict:
195:     """Validate multiple schemas efficiently."""
196: 
197:     validator = SchemaValidator()
198:     reports = validator.validate_batch(schemas)
199: 
200:     # Generate summary
201:     summary = validator.generate_summary_report(reports)
202: 
203:     # Log results
204:     logger.info(f"Validated {summary['total_schemas']} schemas")
205:     logger.info(f"Success rate: {summary['success_rate']:.1f}%")
206: 
207:     # Handle failures
208:     if summary['invalid_schemas'] > 0:
209:         logger.warning(f"{summary['invalid_schemas']} schemas failed validation")
210: 
211:         # Collect failed schemas for review
212:         failed = [
213:             (i, report) for i, report in enumerate(reports)
214:             if not report.is_valid()
215:         ]
216: 
217:         return {
218:             'summary': summary,
219:             'failed': failed
220:         }
221: 
222:     return {'summary': summary}
223: ```
224: 
225: ### Pre-Production Validation
226: 
227: Before deploying schemas:
228: 
229: ```python
230: def pre_production_validation(schema: Dict) -> bool:
231:     """Comprehensive pre-production checks."""
232: 
233:     validator = SchemaValidator()
234:     report = validator.validate(schema)
235: 
236:     # Check 1: No errors
237:     if report.has_errors():
238:         return False
239: 
240:     # Check 2: Required properties present
241:     required_props = ["name", "@type", "@context"]
242:     if not all(prop in schema for prop in required_props):
243:         return False
244: 
245:     # Check 3: URLs are absolute
246:     url_props = ["url", "contentUrl", "thumbnailUrl"]
247:     for prop in url_props:
248:         if prop in schema:
249:             if not schema[prop].startswith(('http://', 'https://', 'file://')):
250:                 return False
251: 
252:     # Check 4: Completion score threshold
253:     # (implementation depends on your SchemaOrgBase instance)
254: 
255:     return True
256: ```
